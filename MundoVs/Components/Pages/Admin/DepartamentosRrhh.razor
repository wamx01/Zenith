@page "/configuracion/departamentos"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Departamentos</PageTitle>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver departamentos.</div>
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <h1 class="display-6 fw-bold"><i class="bi bi-buildings me-2"></i>Departamentos</h1>
                <p class="text-muted mb-0">Catálogo base de departamentos para clasificar empleados y asistencia.</p>
            </div>
            @if (_puedeEditar)
            {
                <button class="btn btn-primary" @onclick="Nuevo"><i class="bi bi-plus-circle me-1"></i>Nuevo departamento</button>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        @if (mostrarForm)
        {
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando.Id == Guid.Empty ? "Nuevo departamento" : "Editar departamento")</h5></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Nombre</label>
                            <InputText class="form-control" @bind-Value="editando.Nombre" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Descripción</label>
                            <InputText class="form-control" @bind-Value="editando.Descripcion" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Orden</label>
                            <InputNumber class="form-control" @bind-Value="editando.Orden" />
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.IsActive" />
                                <label class="form-check-label">Activo</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-success" @onclick="Guardar" disabled="@guardando"><i class="bi bi-save me-1"></i>Guardar</button>
                        <button class="btn btn-outline-secondary" @onclick="Cancelar" disabled="@guardando">Cancelar</button>
                    </div>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th class="text-center">Orden</th>
                            <th class="text-center">Activo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lista.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No hay departamentos configurados.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in lista)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Nombre</td>
                                    <td class="text-muted">@(string.IsNullOrWhiteSpace(item.Descripcion) ? "—" : item.Descripcion)</td>
                                    <td class="text-center">@item.Orden</td>
                                    <td class="text-center"><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Sí" : "No")</span></td>
                                    <td class="text-end">
                                        @if (_puedeEditar)
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(item.Id)"><i class="bi bi-pencil"></i></button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<DepartamentoRrhh> lista = [];
    private DepartamentoRrhh editando = new();
    private bool mostrarForm;
    private bool guardando;
    private bool _puedeVer;
    private bool _puedeEditar;
    private Guid _empresaId;
    private string? error;
    private string? ok;

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
            await CargarAsync();
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "empleados.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "empleados.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        lista = await db.DepartamentosRrhh
            .AsNoTracking()
            .OrderBy(d => d.Orden)
            .ThenBy(d => d.Nombre)
            .ToListAsync();
    }

    private void Nuevo()
    {
        error = ok = null;
        editando = new DepartamentoRrhh { Id = Guid.Empty, IsActive = true, Orden = lista.Count == 0 ? 1 : lista.Max(d => d.Orden) + 1 };
        mostrarForm = true;
    }

    private void Cancelar()
    {
        mostrarForm = false;
        editando = new();
        error = ok = null;
    }

    private async Task Editar(Guid id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var departamento = await db.DepartamentosRrhh.AsNoTracking().FirstOrDefaultAsync(d => d.Id == id);
        if (departamento == null)
        {
            error = "No se encontró el departamento.";
            return;
        }

        error = ok = null;
        editando = new DepartamentoRrhh
        {
            Id = departamento.Id,
            EmpresaId = departamento.EmpresaId,
            Nombre = departamento.Nombre,
            Descripcion = departamento.Descripcion,
            Orden = departamento.Orden,
            IsActive = departamento.IsActive,
            CreatedAt = departamento.CreatedAt,
            CreatedBy = departamento.CreatedBy,
            UpdatedAt = departamento.UpdatedAt,
            UpdatedBy = departamento.UpdatedBy
        };
        mostrarForm = true;
    }

    private async Task Guardar()
    {
        error = ok = null;
        if (string.IsNullOrWhiteSpace(editando.Nombre))
        {
            error = "El nombre es requerido.";
            return;
        }

        if (_empresaId == Guid.Empty)
        {
            error = "No hay empresa activa.";
            return;
        }

        guardando = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var nombre = editando.Nombre.Trim();
            var duplicado = await db.DepartamentosRrhh.AnyAsync(d => d.Nombre == nombre && d.Id != editando.Id);
            if (duplicado)
            {
                error = "Ya existe un departamento con ese nombre.";
                return;
            }

            if (editando.Id == Guid.Empty)
            {
                db.DepartamentosRrhh.Add(new DepartamentoRrhh
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    Nombre = nombre,
                    Descripcion = string.IsNullOrWhiteSpace(editando.Descripcion) ? null : editando.Descripcion.Trim(),
                    Orden = editando.Orden,
                    IsActive = editando.IsActive,
                    CreatedAt = DateTime.UtcNow
                });
            }
            else
            {
                var actual = await db.DepartamentosRrhh.FirstOrDefaultAsync(d => d.Id == editando.Id);
                if (actual == null)
                {
                    error = "No se encontró el departamento a guardar.";
                    return;
                }

                actual.Nombre = nombre;
                actual.Descripcion = string.IsNullOrWhiteSpace(editando.Descripcion) ? null : editando.Descripcion.Trim();
                actual.Orden = editando.Orden;
                actual.IsActive = editando.IsActive;
                actual.UpdatedAt = DateTime.UtcNow;
            }

            await db.SaveChangesAsync();
            ok = "Departamento guardado.";
            mostrarForm = false;
            await CargarAsync();
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }
}
