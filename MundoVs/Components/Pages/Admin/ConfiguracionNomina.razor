    private void EliminarConceptoNomina(NominaConceptoConfigRrhh concepto)
    {
        conceptosNominaConfigurables.RemoveAll(c => c == concepto || (concepto.Id != Guid.Empty && c.Id == concepto.Id));
        if (concepto.Id != Guid.Empty)
            conceptosNominaEliminados.Add(concepto.Id);

        if (conceptoNominaEnCaptura.Id == concepto.Id)
            PrepararNuevoConceptoNomina();
    }

