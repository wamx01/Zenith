                actual.EsLegal = baseConcepto.EsLegal;
                actual.Observaciones = baseConcepto.Observaciones;
                actual.IsActive = true;
                actual.UpdatedAt = DateTime.UtcNow;
            }

            await db.SaveChangesAsync();
            await CargarConfiguracionAsync();
            ok = "Conceptos base de nómina cargados.";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
