@page "/configuracion/nomina"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IAppConfigRepository AppConfig
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Configuración de Nómina</PageTitle>

<style>
    .nom-toolbar {
        border: 0;
        border-radius: 1rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #fff;
    }

    .nom-toolbar .text-muted {
        color: rgba(255,255,255,.74) !important;
    }

    .nom-kpi-card,
    .nom-config-card {
        border: 0;
        border-radius: 1rem;
        box-shadow: 0 .4rem 1.2rem rgba(15, 23, 42, .08);
    }

    .nom-kpi-card .card-body {
        padding: .85rem 1rem;
    }

    .nom-kpi-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #64748b;
        font-weight: 700;
        margin-bottom: .2rem;
    }

    .nom-kpi-value {
        font-size: 1.55rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.1;
    }

    .nom-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: .25rem;
        margin-bottom: .25rem;
    }

    .nom-section-title {
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .nom-section-subtitle {
        font-size: .8rem;
        color: #64748b;
        margin: 0;
    }

    .nom-config-card .card-header {
        padding: .85rem 1rem;
        font-weight: 700;
    }

    .nom-config-card .card-body {
        padding: .95rem 1rem;
    }

    .nom-form-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: .9rem;
    }

    .nom-form-row {
        display: grid;
        grid-template-columns: minmax(0, 160px) minmax(0, 1fr) minmax(0, 1fr);
        gap: .85rem;
        align-items: start;
        padding: .75rem 0;
        border-bottom: 1px solid #e2e8f0;
    }

    .nom-form-row:last-child {
        border-bottom: 0;
        padding-bottom: 0;
    }

    .nom-form-row:first-child {
        padding-top: 0;
    }

    .nom-form-group {
        min-width: 0;
    }

    .nom-form-group .form-label {
        margin-bottom: .3rem;
        font-size: .8rem;
        font-weight: 700;
    }

    .nom-form-group .form-text,
    .nom-help-text {
        font-size: .74rem;
        line-height: 1.35;
    }

    .nom-row-title {
        font-size: .88rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
    }

    .nom-row-subtitle {
        font-size: .75rem;
        color: #64748b;
        line-height: 1.4;
        margin-top: .2rem;
    }

    .nom-inline-note {
        padding: .7rem .8rem;
        border-radius: .85rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        font-size: .78rem;
        color: #475569;
    }

    .nom-json-preview {
        background: #0f172a;
        color: #e2e8f0;
        border: 0;
    }

    @@media (max-width: 991.98px) {
        .nom-form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver la configuración de nómina.</div>
    }
    else
    {
        <div class="card nom-toolbar mb-4">
            <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3 py-3">
                <div>
                    <h1 class="display-6 fw-bold mb-1"><i class="bi bi-sliders me-2"></i>Configuración de Nómina</h1>
                    <p class="text-muted mb-0">Ordena reglas base, incidencias, cumplimiento fiscal y catálogos operativos en una sola vista compacta.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-light" type="submit" form="form-config-nomina" disabled="@guardando"><i class="bi bi-save me-1"></i>@(guardando ? "Guardando..." : "Guardar cambios")</button>
                    <a class="btn btn-outline-light" href="/configuracion">Volver</a>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <EditForm id="form-config-nomina" Model="configuracion" OnValidSubmit="GuardarAsync">
            <div class="row g-3 mb-4">
                <div class="col-xl-3 col-md-6">
                    <div class="card nom-kpi-card h-100">
                        <div class="card-body">
                            <div class="nom-kpi-label">Periodicidades</div>
                            <div class="nom-kpi-value">3</div>
                            <div class="small text-muted">Semanal, quincenal y mensual.</div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card nom-kpi-card h-100">
                        <div class="card-body">
                            <div class="nom-kpi-label">Festivos</div>
                            <div class="nom-kpi-value">@festivos.Count</div>
                            <div class="small text-muted">Fechas especiales capturadas en calendario.</div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card nom-kpi-card h-100">
                        <div class="card-body">
                            <div class="nom-kpi-label">Percepciones</div>
                            <div class="nom-kpi-value">@tiposPercepcion.Count</div>
                            <div class="small text-muted">Tipos disponibles para captura manual.</div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="card nom-kpi-card h-100">
                        <div class="card-body">
                            <div class="nom-kpi-label">Deducciones</div>
                            <div class="nom-kpi-value">@tiposDeduccion.Count</div>
                            <div class="small text-muted">Tipos activos para descuentos y recibo.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12">
                    <div class="nom-section-header">
                        <div>
                            <h2 class="nom-section-title">Base de cálculo y periodos</h2>
                            <p class="nom-section-subtitle">Primero define cómo se prorratea el sueldo y cómo se cortan los periodos de pago.</p>
                        </div>
                    </div>
                </div>

                <div class="col-xxl-7 col-xl-12">
                    <div class="card nom-config-card h-100">
                        <div class="card-header bg-white">Bases por periodicidad</div>
                        <div class="card-body">
                            <div class="nom-form-grid">
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Semanal</div>
                                        <div class="nom-row-subtitle">Base principal para empleados semanales y cálculo por hora.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Días base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.DiasBaseSemanal" />
                                        <div class="form-text">Usados para prorratear sueldo base.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Horas base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.HorasBaseSemanal" />
                                        <div class="form-text">Referencia para sueldo por hora y horas extra.</div>
                                    </div>
                                </div>
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Quincenal</div>
                                        <div class="nom-row-subtitle">Parámetros para personal pagado por quincena.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Días base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.DiasBaseQuincenal" />
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Horas base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.HorasBaseQuincenal" />
                                    </div>
                                </div>
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Mensual</div>
                                        <div class="nom-row-subtitle">Referencia para esquemas de pago mensual.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Días base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.DiasBaseMensual" />
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Horas base</label>
                                        <InputNumber class="form-control" @bind-Value="configuracion.HorasBaseMensual" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xxl-5 col-xl-12">
                    <div class="card nom-config-card h-100 border-primary">
                        <div class="card-header bg-primary text-white">Cortes del periodo</div>
                        <div class="card-body">
                            <div class="nom-form-grid">
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Semanal</div>
                                        <div class="nom-row-subtitle">El día de corte se toma como fin del periodo.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Día de corte</label>
                                        <InputSelect class="form-select" @bind-Value="corteSemanal.DiaCorteSemana">
                                            @foreach (var dia in DiasSemanaDisponibles)
                                            {
                                                <option value="@dia">@ObtenerNombreDia(dia)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Pago sugerido</label>
                                        <InputSelect class="form-select" @bind-Value="corteSemanal.DiaPagoSugerido">
                                            @foreach (var dia in DiasSemanaDisponibles)
                                            {
                                                <option value="@dia">@ObtenerNombreDia(dia)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Quincenal</div>
                                        <div class="nom-row-subtitle">Ejemplo: 15 genera periodos del 1 al 15 y del 16 al cierre.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Día de corte</label>
                                        <InputNumber class="form-control" @bind-Value="corteQuincenal.DiaCorteMes" />
                                    </div>
                                    <div class="nom-inline-note">La primera quincena cierra en este día y la segunda al último día del mes.</div>
                                </div>
                                <div class="nom-form-row">
                                    <div>
                                        <div class="nom-row-title">Mensual</div>
                                        <div class="nom-row-subtitle">Usa 31 para mes calendario o un día fijo para cortes desplazados.</div>
                                    </div>
                                    <div class="nom-form-group">
                                        <label class="form-label">Día de corte</label>
                                        <InputNumber class="form-control" @bind-Value="corteMensual.DiaCorteMes" />
                                    </div>
                                    <div class="nom-inline-note">Ejemplo: 25 genera periodos del 26 al 25 del siguiente mes.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card nom-config-card h-100">
                        <div class="card-header bg-white">Reglas base de prenómina</div>
                        <div class="card-body">
                            <div class="row g-3 align-items-start">
                                <div class="col-xl-4 col-md-6">
                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" @bind-Value="reglasPrenomina.PermitirHorasExtraManual" />
                                        <label class="form-check-label">Permitir captura manual de horas extra</label>
                                    </div>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" @bind-Value="reglasPrenomina.ValidarDiasPagadosContraPeriodo" />
                                        <label class="form-check-label">Validar días pagados contra el período</label>
                                    </div>
                                </div>
                                <div class="col-xl-4 col-md-6">
                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" @bind-Value="reglasPrenomina.RequierePrenominaCerradaParaNomina" />
                                        <label class="form-check-label">Requerir prenómina cerrada para generar nómina</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Vista JSON</label>
                                    <textarea class="form-control font-monospace nom-json-preview" rows="5" readonly>@ObtenerReglasPrenominaJsonPreview()</textarea>
                                    <div class="form-text">La vista JSON se genera automáticamente con las banderas operativas activas.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="nom-section-header">
                        <div>
                            <h2 class="nom-section-title">Incidencias y tiempo</h2>
                            <p class="nom-section-subtitle">Agrupa los factores que afectan descansos trabajados, festivos, tiempo extra y banco de horas.</p>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100 border-warning">
                        <div class="card-header bg-warning-subtle">Festivo trabajado</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Factor general de pago</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.FactorFestivoTrabajado" />
                                <div class="form-text">Fallback cuando la fecha no define factor específico o está en `0`.</div>
                            </div>
                            <div class="nom-help-text text-muted">Ejemplo: <strong>2</strong> paga doble el festivo trabajado.</div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100 border-warning">
                        <div class="card-header bg-warning-subtle">Descanso trabajado</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Factor de pago</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.FactorDescansoTrabajado" />
                                <div class="form-text">Se aplica al sueldo diario por cada día registrado como descanso trabajado.</div>
                            </div>
                            <div class="nom-help-text text-muted">La prima dominical se calcula aparte cuando corresponda.</div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100 border-primary">
                        <div class="card-header bg-primary text-white">Horas extra</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Factor de pago</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.FactorHoraExtra" />
                                <div class="form-text">Ejemplo: 2 = doble, 1.5 = tiempo y medio.</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Factor extra triple</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.FactorHoraExtraTriple" />
                            </div>
                            <div class="nom-help-text text-muted">Primeras 9 horas extra semanales = doble; excedente = triple.</div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100 border-info">
                        <div class="card-header bg-info-subtle">Banco de horas</div>
                        <div class="card-body">
                            <div class="form-check form-switch mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="configuracion.BancoHorasHabilitado" />
                                <label class="form-check-label">Habilitar banco de horas</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Factor acumulación</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.BancoHorasFactorAcumulacion" />
                            </div>
                            <div>
                                <label class="form-label">Tope de saldo en horas</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.BancoHorasTopeHoras" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="nom-section-header">
                        <div>
                            <h2 class="nom-section-title">Cumplimiento y cálculo legal</h2>
                            <p class="nom-section-subtitle">Mantén visibles los parámetros fiscales, seguridad social y prestaciones mínimas.</p>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100">
                        <div class="card-header bg-white">Parámetros normativos</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">UMA diaria</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.UmaDiaria" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Salario mínimo general</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.SalarioMinimoGeneral" />
                            </div>
                            <div>
                                <label class="form-label">Salario mínimo frontera</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.SalarioMinimoFrontera" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100">
                        <div class="card-header bg-white">IMSS</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Tasa obrera</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.TasaImssObrera" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tasa patronal</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.TasaImssPatronal" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Prima riesgo trabajo</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.PrimaRiesgoTrabajo" />
                            </div>
                            <div>
                                <label class="form-label">Tope SBC en UMA</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.TopeSbcEnUma" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100 border-success">
                        <div class="card-header bg-success-subtle">ISR y subsidio</div>
                        <div class="card-body d-flex flex-column gap-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="configuracion.RetencionIsrHabilitada" />
                                <label class="form-check-label">Habilitar retención ISR</label>
                            </div>
                            <div class="nom-help-text text-muted">Las tablas de ISR y subsidio son configuración maestra global. Aquí solo decides si la empresa las aplica.</div>
                            @if (_esSuperAdmin)
                            {
                                <div>
                                    <a class="btn btn-sm btn-outline-primary" href="/superadmin/configuracion-nomina">Editar tablas globales</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <div class="card nom-config-card h-100">
                        <div class="card-header bg-white">Vacaciones y aguinaldo</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Ciclo vacacional</label>
                                <InputSelect class="form-select" @bind-Value="configuracion.TipoCicloVacacional">
                                    @foreach (var tipo in Enum.GetValues<TipoCicloVacacionalRrhh>())
                                    {
                                        <option value="@tipo">@tipo</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Pago prima vacacional</label>
                                <InputSelect class="form-select" @bind-Value="configuracion.FormaPagoPrimaVacacional">
                                    @foreach (var forma in Enum.GetValues<FormaPagoPrimaVacacionalRrhh>())
                                    {
                                        <option value="@forma">@forma</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Primer ciclo vacacional</label>
                                <InputSelect class="form-select" @bind-Value="configuracion.PoliticaPrimerCicloVacacional">
                                    @foreach (var politica in Enum.GetValues<PoliticaPrimerCicloVacacionalRrhh>())
                                    {
                                        <option value="@politica">@politica</option>
                                    }
                                </InputSelect>
                                <div class="form-text">Define si el año 1 entra completo o proporcional cuando el empleado alcanza elegibilidad en el corte anual.</div>
                            </div>
                            @if (configuracion.TipoCicloVacacional == TipoCicloVacacionalRrhh.CorteFijoAnual)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Mes inicio ciclo</label>
                                    <InputNumber class="form-control" @bind-Value="configuracion.MesInicioCicloVacacional" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Día inicio ciclo</label>
                                    <InputNumber class="form-control" @bind-Value="configuracion.DiaInicioCicloVacacional" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Meses mínimos para año 1</label>
                                    <InputNumber class="form-control" @bind-Value="configuracion.MesesMinimosPrimerAnioVacacional" />
                                    <div class="form-text">Si el empleado no cumple este mínimo al corte, permanece en año 0.</div>
                                </div>
                            }
                            <div class="mb-3">
                                <label class="form-label">Prima vacacional mínima</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.PrimaVacacionalMinima" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Días aguinaldo mínimo</label>
                                <InputNumber class="form-control" @bind-Value="configuracion.DiasAguinaldoMinimo" />
                            </div>
                            <div>
                                <label class="form-label">Tabla vacaciones JSON</label>
                                <InputTextArea class="form-control font-monospace" @bind-Value="configuracion.TablaVacacionesJson" rows="5" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
