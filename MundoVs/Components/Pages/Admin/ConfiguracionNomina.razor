                        EsLegal = baseConcepto.EsLegal,
                        Observaciones = baseConcepto.Observaciones,
                        IsActive = true,
                        CreatedAt = DateTime.UtcNow
                    });
                    continue;
                }

                actual.Nombre = baseConcepto.Nombre;
                actual.Naturaleza = baseConcepto.Naturaleza;
                actual.Destino = baseConcepto.Destino;
                actual.TipoCalculo = baseConcepto.TipoCalculo;
                actual.Orden = baseConcepto.Orden;
                actual.EsRecurrente = baseConcepto.EsRecurrente;
                actual.AplicaPorEmpleado = baseConcepto.AplicaPorEmpleado;
                actual.AfectaNetoEmpleado = baseConcepto.AfectaNetoEmpleado;
