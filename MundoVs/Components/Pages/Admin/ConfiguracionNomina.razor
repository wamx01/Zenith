                }
            };

            foreach (var baseConcepto in conceptosBase)
            {
                var actual = existentes.FirstOrDefault(c => string.Equals(c.Clave, baseConcepto.Clave, StringComparison.OrdinalIgnoreCase));
                if (actual == null)
                {
                    db.NominasConceptosConfigRrhh.Add(new NominaConceptoConfigRrhh
                    {
                        Id = Guid.NewGuid(),
                        EmpresaId = _empresaId,
