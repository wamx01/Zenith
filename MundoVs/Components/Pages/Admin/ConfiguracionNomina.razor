    private async Task GuardarConfiguracionPeriodoAsync()
    {
        if (_empresaId == Guid.Empty)
            throw new InvalidOperationException("No hay empresa activa para guardar corte y festivos.");

        await using var db = await DbFactory.CreateDbContextAsync();
        await GuardarCortePeriodoAsync(db, corteSemanal, 31);
        await GuardarCortePeriodoAsync(db, corteQuincenal, 15);
        await GuardarCortePeriodoAsync(db, corteMensual, 31);

        if (festivosEliminados.Count > 0)
        {
            var eliminados = await db.FestivosRrhh.Where(f => festivosEliminados.Contains(f.Id)).ToListAsync();
            if (eliminados.Count > 0)
                db.FestivosRrhh.RemoveRange(eliminados);
        }

        foreach (var festivo in festivos)
        {
            if (festivo.Id == Guid.Empty)
            {
                db.FestivosRrhh.Add(new FestivoRrhh
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    Fecha = festivo.Fecha.Date,
                    Nombre = festivo.Nombre.Trim(),
                    Tipo = festivo.Tipo,
                    AplicaPrimaEspecial = festivo.AplicaPrimaEspecial,
                    FactorPago = Math.Max(0m, festivo.FactorPago),
                    EsOficial = festivo.EsOficial,
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                });
            }
            else
            {
                var actual = await db.FestivosRrhh.FirstOrDefaultAsync(f => f.Id == festivo.Id);
                if (actual == null)
                    continue;

                actual.Fecha = festivo.Fecha.Date;
                actual.Nombre = festivo.Nombre.Trim();
                actual.Tipo = festivo.Tipo;
                actual.AplicaPrimaEspecial = festivo.AplicaPrimaEspecial;
                actual.FactorPago = Math.Max(0m, festivo.FactorPago);
                actual.EsOficial = festivo.EsOficial;
                actual.IsActive = true;
                actual.UpdatedAt = DateTime.UtcNow;
            }
        }

        await GuardarRubrosBonoAsync(db);
        await GuardarEsquemasBonoAsync(db);
        await GuardarAsignacionesEsquemaPorPosicionAsync(db);
        await GuardarTiposPercepcionAsync(db);
        await GuardarTiposDeduccionAsync(db);
        await GuardarConceptosNominaAsync(db);

        await db.SaveChangesAsync();
    }

    private async Task<NominaCorteRrhh> CargarCortePeriodoAsync(CrmDbContext db, PeriodicidadPago periodicidad, int diaCorteMesDefault)
        => await db.NominaCortesRrhh
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.EmpresaId == _empresaId && c.PeriodicidadPago == periodicidad && c.IsActive)
            ?? new NominaCorteRrhh
            {
                EmpresaId = _empresaId,
                PeriodicidadPago = periodicidad,
                DiaCorteSemana = DayOfWeek.Sunday,
                DiaCorteMes = diaCorteMesDefault,
                DiaPagoSugerido = DayOfWeek.Friday,
                IsActive = true
            };

    private async Task GuardarCortePeriodoAsync(CrmDbContext db, NominaCorteRrhh corte, int diaCorteMesDefault)
    {
        var corteActual = await db.NominaCortesRrhh
            .FirstOrDefaultAsync(c => c.EmpresaId == _empresaId && c.PeriodicidadPago == corte.PeriodicidadPago);

        if (corteActual == null)
        {
            db.NominaCortesRrhh.Add(new NominaCorteRrhh
            {
                EmpresaId = _empresaId,
                PeriodicidadPago = corte.PeriodicidadPago,
                DiaCorteSemana = corte.DiaCorteSemana,
                DiaCorteMes = NormalizarDiaCorteMes(corte.PeriodicidadPago, corte.DiaCorteMes, diaCorteMesDefault),
                DiaPagoSugerido = corte.DiaPagoSugerido,
                IsActive = true,
                CreatedAt = DateTime.UtcNow
            });

            return;
        }

        corteActual.DiaCorteSemana = corte.DiaCorteSemana;
        corteActual.DiaCorteMes = NormalizarDiaCorteMes(corte.PeriodicidadPago, corte.DiaCorteMes, diaCorteMesDefault);
        corteActual.DiaPagoSugerido = corte.DiaPagoSugerido;
        corteActual.IsActive = true;
        corteActual.UpdatedAt = DateTime.UtcNow;
    }

    private static int NormalizarDiaCorteMes(PeriodicidadPago periodicidad, int valor, int valorDefault)
        => periodicidad == PeriodicidadPago.Quincenal
            ? Math.Clamp(valor <= 0 ? valorDefault : valor, 1, 27)
            : Math.Clamp(valor <= 0 ? valorDefault : valor, 1, 31);

    private async Task GuardarEsquemasBonoAsync(CrmDbContext db)
    {
        if (esquemasBonoEliminados.Count > 0)
        {
            var eliminados = await db.BonosEstructurasRrhh.Where(e => esquemasBonoEliminados.Contains(e.Id)).ToListAsync();
            if (eliminados.Count > 0)
                db.BonosEstructurasRrhh.RemoveRange(eliminados);
        }

        foreach (var esquema in esquemasBono)
        {
            if (esquema.Id == Guid.Empty)
            {
                var nueva = new BonoEstructuraRrhh
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    Nombre = esquema.Nombre.Trim(),
                    Descripcion = string.IsNullOrWhiteSpace(esquema.Descripcion) ? null : esquema.Descripcion.Trim(),
                    TipoCaptura = esquema.TipoCaptura,
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                };
                db.BonosEstructurasRrhh.Add(nueva);

                var detalleOrden = 1;
                foreach (var detalle in esquema.Detalles.OrderBy(d => d.Orden))
                {
                    db.BonosEstructurasDetalleRrhh.Add(new BonoEstructuraDetalleRrhh
                    {
                        Id = Guid.NewGuid(),
                        BonoEstructuraRrhh = nueva,
                        BonoRubroRrhhId = detalle.BonoRubroRrhhId,
                        Orden = detalleOrden++,
                        Porcentaje = esquema.TipoCaptura == TipoCapturaBonoNomina.TotalDistribuido ? detalle.Porcentaje : 0m,
                        IsActive = true,
                        CreatedAt = DateTime.UtcNow
                    });
                }

                continue;
            }

            var actual = await db.BonosEstructurasRrhh
                .Include(e => e.Detalles)
                .FirstOrDefaultAsync(e => e.Id == esquema.Id);
            if (actual == null)
                continue;

            actual.Nombre = esquema.Nombre.Trim();
            actual.Descripcion = string.IsNullOrWhiteSpace(esquema.Descripcion) ? null : esquema.Descripcion.Trim();
            actual.TipoCaptura = esquema.TipoCaptura;
            actual.IsActive = true;
            actual.UpdatedAt = DateTime.UtcNow;

            var rubrosDeseados = esquema.Detalles.Select(d => d.BonoRubroRrhhId).ToHashSet();
            var eliminarDetalle = actual.Detalles.Where(d => !rubrosDeseados.Contains(d.BonoRubroRrhhId)).ToList();
            if (eliminarDetalle.Count > 0)
                db.BonosEstructurasDetalleRrhh.RemoveRange(eliminarDetalle);

            var existentes = actual.Detalles.ToDictionary(d => d.BonoRubroRrhhId, d => d);
            var orden = 1;
            foreach (var detalle in esquema.Detalles.OrderBy(d => d.Orden))
            {
                if (!existentes.TryGetValue(detalle.BonoRubroRrhhId, out var actualDetalle))
                {
                    db.BonosEstructurasDetalleRrhh.Add(new BonoEstructuraDetalleRrhh
                    {
                        Id = Guid.NewGuid(),
                        BonoEstructuraRrhhId = actual.Id,
                        BonoRubroRrhhId = detalle.BonoRubroRrhhId,
                        Orden = orden++,
                        Porcentaje = esquema.TipoCaptura == TipoCapturaBonoNomina.TotalDistribuido ? detalle.Porcentaje : 0m,
                        IsActive = true,
                        CreatedAt = DateTime.UtcNow
                    });
                    continue;
                }

                actualDetalle.Orden = orden++;
                actualDetalle.Porcentaje = esquema.TipoCaptura == TipoCapturaBonoNomina.TotalDistribuido ? detalle.Porcentaje : 0m;
                actualDetalle.IsActive = true;
                actualDetalle.UpdatedAt = DateTime.UtcNow;
            }
        }
    }

