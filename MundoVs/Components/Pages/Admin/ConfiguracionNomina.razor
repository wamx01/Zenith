    private DeduccionTipoRrhh tipoDeduccionEnCaptura = CrearTipoDeduccionVacio();
    private HashSet<Guid> tiposDeduccionEliminados = [];
    private List<NominaConceptoConfigRrhh> conceptosNominaConfigurables = [];
    private NominaConceptoConfigRrhh conceptoNominaEnCaptura = CrearConceptoNominaVacio();
    private HashSet<Guid> conceptosNominaEliminados = [];
