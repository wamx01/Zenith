    private void AgregarOActualizarConceptoNomina()
    {
        if (string.IsNullOrWhiteSpace(conceptoNominaEnCaptura.Clave) || string.IsNullOrWhiteSpace(conceptoNominaEnCaptura.Nombre))
        {
            error = "La clave y el nombre del concepto configurable son requeridos.";
            return;
        }

        var clave = conceptoNominaEnCaptura.Clave.Trim().ToUpperInvariant();
        if (conceptosNominaConfigurables.Any(c => c.Id != conceptoNominaEnCaptura.Id && c.Clave == clave))
        {
            error = "Ya existe un concepto configurable con esa clave.";
            return;
        }

        if (conceptoNominaEnCaptura.Id == Guid.Empty)
        {
            conceptosNominaConfigurables.Add(new NominaConceptoConfigRrhh
            {
                Id = Guid.Empty,
                Clave = clave,
                Nombre = conceptoNominaEnCaptura.Nombre.Trim(),
                Naturaleza = conceptoNominaEnCaptura.Naturaleza,
                Destino = conceptoNominaEnCaptura.Destino,
                TipoCalculo = conceptoNominaEnCaptura.TipoCalculo,
                MontoFijoDefault = conceptoNominaEnCaptura.MontoFijoDefault,
                PorcentajeDefault = conceptoNominaEnCaptura.PorcentajeDefault,
                CantidadDefault = conceptoNominaEnCaptura.CantidadDefault,
                TarifaDefault = conceptoNominaEnCaptura.TarifaDefault,
                Orden = conceptoNominaEnCaptura.Orden,
                EsRecurrente = conceptoNominaEnCaptura.EsRecurrente,
                AplicaPorEmpleado = conceptoNominaEnCaptura.AplicaPorEmpleado,
                AfectaNetoEmpleado = conceptoNominaEnCaptura.AfectaNetoEmpleado,
                AfectaCostoEmpresa = conceptoNominaEnCaptura.AfectaCostoEmpresa,
                AfectaPasivoSat = conceptoNominaEnCaptura.AfectaPasivoSat,
                AfectaPasivoImss = conceptoNominaEnCaptura.AfectaPasivoImss,
                AfectaProvision = conceptoNominaEnCaptura.AfectaProvision,
                AfectaBaseIsr = conceptoNominaEnCaptura.AfectaBaseIsr,
                AfectaBaseImss = conceptoNominaEnCaptura.AfectaBaseImss,
                EsLegal = conceptoNominaEnCaptura.EsLegal,
                Observaciones = conceptoNominaEnCaptura.Observaciones?.Trim(),
                IsActive = true
            });
        }
        else
        {
            var actual = conceptosNominaConfigurables.FirstOrDefault(c => c.Id == conceptoNominaEnCaptura.Id);
            if (actual == null)
                return;

            actual.Clave = clave;
            actual.Nombre = conceptoNominaEnCaptura.Nombre.Trim();
            actual.Naturaleza = conceptoNominaEnCaptura.Naturaleza;
            actual.Destino = conceptoNominaEnCaptura.Destino;
            actual.TipoCalculo = conceptoNominaEnCaptura.TipoCalculo;
            actual.MontoFijoDefault = conceptoNominaEnCaptura.MontoFijoDefault;
            actual.PorcentajeDefault = conceptoNominaEnCaptura.PorcentajeDefault;
            actual.CantidadDefault = conceptoNominaEnCaptura.CantidadDefault;
            actual.TarifaDefault = conceptoNominaEnCaptura.TarifaDefault;
            actual.Orden = conceptoNominaEnCaptura.Orden;
            actual.EsRecurrente = conceptoNominaEnCaptura.EsRecurrente;
            actual.AplicaPorEmpleado = conceptoNominaEnCaptura.AplicaPorEmpleado;
            actual.AfectaNetoEmpleado = conceptoNominaEnCaptura.AfectaNetoEmpleado;
            actual.AfectaCostoEmpresa = conceptoNominaEnCaptura.AfectaCostoEmpresa;
            actual.AfectaPasivoSat = conceptoNominaEnCaptura.AfectaPasivoSat;
            actual.AfectaPasivoImss = conceptoNominaEnCaptura.AfectaPasivoImss;
            actual.AfectaProvision = conceptoNominaEnCaptura.AfectaProvision;
            actual.AfectaBaseIsr = conceptoNominaEnCaptura.AfectaBaseIsr;
            actual.AfectaBaseImss = conceptoNominaEnCaptura.AfectaBaseImss;
            actual.EsLegal = conceptoNominaEnCaptura.EsLegal;
            actual.Observaciones = conceptoNominaEnCaptura.Observaciones?.Trim();
            actual.UpdatedAt = DateTime.UtcNow;
        }

        conceptosNominaConfigurables = conceptosNominaConfigurables.OrderBy(c => c.Orden).ThenBy(c => c.Nombre).ToList();
        PrepararNuevoConceptoNomina();
    }

