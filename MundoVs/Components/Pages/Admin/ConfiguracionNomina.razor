    private void AlternarRubroEsquema(Guid rubroId, bool selected)
    {
        if (selected)
        {
            rubrosEsquemaSeleccionados.Add(rubroId);
            porcentajesRubrosEsquema.TryAdd(rubroId, 0m);
            return;
        }

        rubrosEsquemaSeleccionados.Remove(rubroId);
        porcentajesRubrosEsquema.Remove(rubroId);
    }

    private Task OnTipoCapturaEsquemaBonoChangedAsync()
    {
        if (esquemaBonoEnCaptura.TipoCaptura != TipoCapturaBonoNomina.TotalDistribuido)
        {
            foreach (var rubroId in rubrosEsquemaSeleccionados)
                porcentajesRubrosEsquema[rubroId] = 0m;
        }

        return Task.CompletedTask;
    }

    private decimal ObtenerPorcentajeRubroEsquema(Guid rubroId)
        => porcentajesRubrosEsquema.TryGetValue(rubroId, out var porcentaje) ? porcentaje : 0m;

    private void ActualizarPorcentajeRubroEsquema(Guid rubroId, string? valor)
        => porcentajesRubrosEsquema[rubroId] = decimal.TryParse(valor, out var porcentaje) ? Math.Max(0m, porcentaje) : 0m;

    private void AgregarOActualizarEsquemaBono()
    {
        if (string.IsNullOrWhiteSpace(esquemaBonoEnCaptura.Nombre))
        {
            error = "El nombre de la estructura es requerido.";
            return;
        }

        if (rubrosEsquemaSeleccionados.Count == 0)
        {
            error = "Selecciona al menos un rubro para la estructura.";
            return;
        }

        if (esquemaBonoEnCaptura.TipoCaptura == TipoCapturaBonoNomina.TotalDistribuido && Math.Round(TotalPorcentajeEsquema, 2) != 100m)
        {
            error = "La estructura de bono distribuida debe sumar 100%.";
            return;
        }

        var nombre = esquemaBonoEnCaptura.Nombre.Trim();
        if (esquemasBono.Any(e => e.Id != esquemaBonoEnCaptura.Id && string.Equals(e.Nombre, nombre, StringComparison.OrdinalIgnoreCase)))
        {
            error = "Ya existe una estructura con ese nombre.";
            return;
        }

        var detalles = rubrosBono
            .Where(r => rubrosEsquemaSeleccionados.Contains(r.Id))
            .OrderBy(r => r.Orden)
            .ThenBy(r => r.Nombre)
            .Select((r, index) => new BonoEstructuraDetalleRrhh
            {
                Id = Guid.Empty,
                BonoRubroRrhhId = r.Id,
                BonoRubroRrhh = r,
                Orden = index + 1,
                Porcentaje = esquemaBonoEnCaptura.TipoCaptura == TipoCapturaBonoNomina.TotalDistribuido ? ObtenerPorcentajeRubroEsquema(r.Id) : 0m,
                IsActive = true
            })
            .ToList();

        if (esquemaBonoEnCaptura.Id == Guid.Empty)
        {
            esquemasBono.Add(new BonoEstructuraRrhh
            {
                Id = Guid.Empty,
                Nombre = nombre,
                Descripcion = string.IsNullOrWhiteSpace(esquemaBonoEnCaptura.Descripcion) ? null : esquemaBonoEnCaptura.Descripcion.Trim(),
                TipoCaptura = esquemaBonoEnCaptura.TipoCaptura,
                Detalles = detalles,
                IsActive = true
            });
        }
        else
        {
            var actual = esquemasBono.FirstOrDefault(e => e.Id == esquemaBonoEnCaptura.Id);
            if (actual == null)
                return;

            actual.Nombre = nombre;
            actual.Descripcion = string.IsNullOrWhiteSpace(esquemaBonoEnCaptura.Descripcion) ? null : esquemaBonoEnCaptura.Descripcion.Trim();
            actual.TipoCaptura = esquemaBonoEnCaptura.TipoCaptura;
            actual.Detalles = detalles;
        }

        esquemasBono = esquemasBono.OrderBy(e => e.Nombre).ToList();
        PrepararNuevoEsquemaBono();
    }

    private void EditarEsquemaBono(BonoEstructuraRrhh esquema)
    {
        esquemaBonoEnCaptura = new BonoEstructuraRrhh
        {
            Id = esquema.Id,
            Nombre = esquema.Nombre,
            Descripcion = esquema.Descripcion,
            TipoCaptura = esquema.TipoCaptura,
            IsActive = esquema.IsActive
        };
        rubrosEsquemaSeleccionados = esquema.Detalles.Select(d => d.BonoRubroRrhhId).ToHashSet();
        porcentajesRubrosEsquema = esquema.Detalles.ToDictionary(d => d.BonoRubroRrhhId, d => d.Porcentaje);
        error = ok = null;
    }

    private void EliminarEsquemaBono(BonoEstructuraRrhh esquema)
    {
        esquemasBono.RemoveAll(e => e == esquema || (esquema.Id != Guid.Empty && e.Id == esquema.Id));
        if (esquema.Id != Guid.Empty)
            esquemasBonoEliminados.Add(esquema.Id);

        foreach (var posicion in posiciones.Where(p => p.BonoEstructuraRrhhId == esquema.Id))
            posicion.BonoEstructuraRrhhId = null;

        if (esquemaBonoEnCaptura.Id == esquema.Id)
            PrepararNuevoEsquemaBono();
    }

