        if (_puedeVer)
        {
            await CargarConfiguracionAsync();
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _esSuperAdmin = state.User.IsInRole("SuperAdmin");
        _puedeVer = state.User.HasClaim("Capacidad", "configuracion.ver") || state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "configuracion.ver") || state.User.HasClaim("Capacidad", "nominas.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarConfiguracionAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        configuracionGlobal = await NominaConfiguracionLoader.LoadGlobalAsync(db);
        configuracion = await NominaConfiguracionLoader.LoadAsync(db, _empresaId);
        reglasPrenomina = configuracion.ObtenerReglasPrenomina();

        corteSemanal = await CargarCortePeriodoAsync(db, PeriodicidadPago.Semanal, 31);
        corteQuincenal = await CargarCortePeriodoAsync(db, PeriodicidadPago.Quincenal, 15);
        corteMensual = await CargarCortePeriodoAsync(db, PeriodicidadPago.Mensual, 31);

        festivos = await db.FestivosRrhh
            .AsNoTracking()
            .Where(f => f.IsActive)
            .OrderBy(f => f.Fecha)
            .ToListAsync();

        rubrosBono = await db.BonosRubrosRrhh
            .AsNoTracking()
            .Where(r => r.IsActive)
            .OrderBy(r => r.Orden)
            .ThenBy(r => r.Nombre)
            .ToListAsync();

        esquemasBono = await db.BonosEstructurasRrhh
            .AsNoTracking()
            .Include(e => e.Detalles.OrderBy(d => d.Orden))
                .ThenInclude(d => d.BonoRubroRrhh)
            .Where(e => e.IsActive)
            .OrderBy(e => e.Nombre)
            .ToListAsync();

        posiciones = await db.Posiciones
            .AsNoTracking()
            .Where(p => p.IsActive)
            .OrderBy(p => p.Orden)
            .ThenBy(p => p.Nombre)
            .ToListAsync();

        tiposPercepcion = await db.NominasPercepcionesTipos
            .AsNoTracking()
            .Where(t => t.IsActive)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Nombre)
            .ToListAsync();

        tiposDeduccion = await db.DeduccionesTiposRrhh
            .AsNoTracking()
            .Where(t => t.IsActive)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Nombre)
            .ToListAsync();

        conceptosNominaConfigurables = await db.NominasConceptosConfigRrhh
            .AsNoTracking()
            .Where(c => c.IsActive)
            .OrderBy(c => c.Orden)
            .ThenBy(c => c.Nombre)
            .ToListAsync();

        festivoEnCaptura = CrearFestivoVacio();
        festivosEliminados = [];
        rubroBonoEnCaptura = CrearRubroBonoVacio();
        rubrosBonoEliminados = [];
        esquemaBonoEnCaptura = CrearEsquemaBonoVacio();
        esquemasBonoEliminados = [];
        rubrosEsquemaSeleccionados = [];
        porcentajesRubrosEsquema = [];
        tipoPercepcionEnCaptura = CrearTipoPercepcionVacio();
        tiposPercepcionEliminados = [];
        tipoDeduccionEnCaptura = CrearTipoDeduccionVacio();
        tiposDeduccionEliminados = [];
        conceptoNominaEnCaptura = CrearConceptoNominaVacio();
        conceptosNominaEliminados = [];
    }

