    private void AgregarOActualizarFestivo()
    {
        error = ok = null;

        if (festivoEnCaptura.Fecha == default)
        {
            error = "La fecha del festivo es requerida.";
            return;
        }

        if (string.IsNullOrWhiteSpace(festivoEnCaptura.Nombre))
        {
            error = "El nombre del festivo es requerido.";
            return;
        }

        if (festivoEnCaptura.FactorPago < 0)
        {
            error = "El factor del festivo no puede ser negativo.";
            return;
        }

        var fecha = festivoEnCaptura.Fecha.Date;
        var duplicado = festivos.Any(f => f.Id != festivoEnCaptura.Id && f.Fecha.Date == fecha);
        if (duplicado)
        {
            error = "Ya existe un festivo configurado para esa fecha.";
            return;
        }

        if (festivoEnCaptura.Id == Guid.Empty)
        {
            festivos.Add(new FestivoRrhh
            {
                Id = Guid.Empty,
                Fecha = fecha,
                Nombre = festivoEnCaptura.Nombre.Trim(),
                Tipo = festivoEnCaptura.Tipo,
                AplicaPrimaEspecial = festivoEnCaptura.AplicaPrimaEspecial,
                FactorPago = Math.Max(0m, festivoEnCaptura.FactorPago),
                EsOficial = festivoEnCaptura.EsOficial,
                IsActive = true
            });
        }
        else
        {
            var actual = festivos.FirstOrDefault(f => f.Id == festivoEnCaptura.Id);
            if (actual == null)
                return;

            actual.Fecha = fecha;
            actual.Nombre = festivoEnCaptura.Nombre.Trim();
            actual.Tipo = festivoEnCaptura.Tipo;
            actual.AplicaPrimaEspecial = festivoEnCaptura.AplicaPrimaEspecial;
            actual.FactorPago = Math.Max(0m, festivoEnCaptura.FactorPago);
            actual.EsOficial = festivoEnCaptura.EsOficial;
        }

        festivos = festivos.OrderBy(f => f.Fecha).ToList();
        festivoEnCaptura = CrearFestivoVacio();
    }

    private void EditarFestivo(FestivoRrhh festivo)
    {
        festivoEnCaptura = new FestivoRrhh
        {
            Id = festivo.Id,
