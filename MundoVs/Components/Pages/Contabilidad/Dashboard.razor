    .db-ver-todos { font-size: .72rem; color: #4a6fa5; text-decoration: none; font-weight: 600; }
    .db-ver-todos:hover { color: #1e3a5f; }
</style>

@code {
    private bool cargando = true;
    private string periodo = "mes";

    // KPIs
    private int totalPedidosPeriodo;
    private decimal ingresoPeriodo;
    private int totalPiezasPeriodo;
    private int pedidosPendientes;
    private int pedidosTrendPct;
    private int ingresoTrendPct;

    // Datos
    private List<EstadoCount> pedidosPorEstado = [];
    private List<MesIngreso> ingresosPorMes = [];
    private List<ClienteRank> topClientes = [];
    private List<ProductoRank> topProductos = [];
    private List<GananciaProducto> gananciaProductos = [];
    private List<TallaDistribucion> distribucionTallas = [];
    private List<PedidoReciente> pedidosRecientes = [];

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        cargando = false;
    }

    private async Task OnPeriodoChanged(ChangeEventArgs e)
    {
        periodo = e.Value?.ToString() ?? "mes";
        cargando = true;
        await CargarDatos();
        cargando = false;
    }

    private DateTime GetFechaInicio()
    {
        var now = DateTime.UtcNow;
        return periodo switch
        {
            "mes" => new DateTime(now.Year, now.Month, 1),
            "trimestre" => now.AddMonths(-3),
            "semestre" => now.AddMonths(-6),
            "anio" => new DateTime(now.Year, 1, 1),
            _ => DateTime.MinValue
        };
    }

    private async Task CargarDatos()
    {
        var desde = GetFechaInicio();

        var pedidos = await DbContext.Pedidos
            .Include(p => p.Cliente)
            .Include(p => p.Detalles)
                .ThenInclude(d => d.Producto)
            .Where(p => p.FechaPedido >= desde)
            .ToListAsync();

        totalPedidosPeriodo = pedidos.Count;
        ingresoPeriodo = pedidos.Sum(p => p.Total);
        pedidosPendientes = pedidos.Count(p => p.Estado != EstadoPedidoEnum.Entregado && p.Estado != EstadoPedidoEnum.Facturado && p.Estado != EstadoPedidoEnum.Pagado && p.Estado != EstadoPedidoEnum.Cancelado);

        var pedidoIds = pedidos.Select(p => p.Id).ToList();
        var serigrafias = await DbContext.PedidosSerigrafia
            .Include(ps => ps.Tallas)
            .Include(ps => ps.PedidoDetalle)
            .Where(ps => pedidoIds.Contains(ps.PedidoDetalle.PedidoId))
            .ToListAsync();

        totalPiezasPeriodo = serigrafias.Sum(ps => ps.Tallas.Sum(t => t.Cantidad));

        await CalcularTrends(desde, pedidos);

        pedidosPorEstado = pedidos
            .GroupBy(p => p.Estado)
            .Select(g => new EstadoCount { Estado = g.Key, Count = g.Count() })
            .OrderByDescending(e => e.Count)
            .ToList();

        ingresosPorMes = pedidos
            .GroupBy(p => new { p.FechaPedido.Year, p.FechaPedido.Month })
            .Select(g => new MesIngreso
            {
                Year = g.Key.Year,
                Month = g.Key.Month,
                Ingreso = g.Sum(p => p.Total),
                Label = new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM yy")
            })
            .OrderBy(m => m.Year).ThenBy(m => m.Month)
            .ToList();

        topClientes = pedidos
            .GroupBy(p => new { p.ClienteId, Nombre = p.Cliente?.RazonSocial ?? "?" })
            .Select(g => new ClienteRank
            {
                Nombre = g.Key.Nombre,
                Total = g.Sum(p => p.Total),
                Pedidos = g.Count(),
                Piezas = serigrafias.Where(s => g.Select(p => p.Id).Contains(s.PedidoDetalle.PedidoId)).Sum(s => s.Tallas.Sum(t => t.Cantidad))
            })
            .OrderByDescending(c => c.Total)
            .Take(10)
            .ToList();

        topProductos = pedidos
            .SelectMany(p => p.Detalles)
            .GroupBy(d => new { d.ProductoId, Nombre = d.Producto?.Nombre ?? "?" })
            .Select(g => new ProductoRank
            {
                Nombre = g.Key.Nombre,
                Piezas = g.Sum(d => d.Cantidad),
                Pedidos = g.Select(d => d.PedidoId).Distinct().Count(),
                Ingreso = g.Sum(d => d.Total)
            })
            .OrderByDescending(p => p.Piezas)
            .Take(10)
            .ToList();

        var cotizaciones = await DbContext.CotizacionesSerigrafia
            .Include(c => c.Producto)
            .Include(c => c.Detalles)
            .ToListAsync();

        var cotizDict = cotizaciones
            .GroupBy(c => c.ProductoId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(c => c.CreatedAt).First());

        // Recalcular pedidos sin precio (creados antes del fix)
        var pedidosSinPrecio = pedidos.Where(p => p.Total == 0 && p.Detalles.Any()).ToList();
        if (pedidosSinPrecio.Any())
        {
            foreach (var p in pedidosSinPrecio)
            {
                foreach (var d in p.Detalles)
                {
                    if (cotizDict.TryGetValue(d.ProductoId, out var cot))
                    {
                        var piezas = serigrafias.FirstOrDefault(s => s.PedidoDetalle.PedidoId == p.Id)?.Tallas.Sum(t => t.Cantidad) ?? d.Cantidad;
                        d.PrecioUnitario = cot.PrecioFinalContado;
                        d.Cantidad = piezas;
                        d.Total = cot.PrecioFinalContado * piezas;
                        d.UpdatedAt = DateTime.UtcNow;
                    }
                }
                var sub = p.Detalles.Sum(d => d.Total);
                p.Subtotal = sub;
                p.Impuestos = Math.Round(sub * 0.16m, 2);
                p.Total = sub + p.Impuestos;
                p.UpdatedAt = DateTime.UtcNow;
            }
            await DbContext.SaveChangesAsync();
            ingresoPeriodo = pedidos.Sum(p => p.Total);
        }

        gananciaProductos = pedidos
            .SelectMany(p => p.Detalles)
            .GroupBy(d => new { d.ProductoId, Nombre = d.Producto?.Nombre ?? "?" })
            .Where(g => cotizDict.ContainsKey(g.Key.ProductoId))
            .Select(g =>
            {
                var cot = cotizDict[g.Key.ProductoId];
                var ingreso = g.Sum(d => d.Total);
                var piezas = g.Sum(d => d.Cantidad);
                var costo = cot.CostoTotalPorPar * piezas;
                return new GananciaProducto
                {
                    Nombre = g.Key.Nombre,
                    Piezas = piezas,
                    Ingreso = ingreso,
                    Costo = costo,
                    Ganancia = ingreso - costo
                };
            })
            .OrderByDescending(g => g.Ganancia)
            .Take(10)
            .ToList();

        var todasTallas = serigrafias.SelectMany(s => s.Tallas).ToList();
        distribucionTallas = todasTallas
            .GroupBy(t => t.Talla)
            .Select(g => new TallaDistribucion { Talla = g.Key, Cantidad = g.Sum(t => t.Cantidad) })
            .OrderByDescending(t => t.Cantidad)
            .Take(15)
            .ToList();

        pedidosRecientes = pedidos
            .OrderByDescending(p => p.FechaPedido)
            .Take(10)
            .Select(p =>
            {
                var ps = serigrafias.FirstOrDefault(s => s.PedidoDetalle.PedidoId == p.Id);
                var piezas = ps?.Tallas.Sum(t => t.Cantidad) ?? 0;
                var productoId = p.Detalles.FirstOrDefault()?.ProductoId;
                var costo = productoId.HasValue && cotizDict.TryGetValue(productoId.Value, out var cot)
                    ? cot.CostoTotalPorPar * piezas
                    : 0m;
                var ganancia = p.Total - costo;
                var margen = p.Total > 0 ? (int)Math.Round((double)ganancia / (double)p.Total * 100) : 0;
                return new PedidoReciente
                {
                    NumeroPedido = p.NumeroPedido,
                    Cliente = p.Cliente?.RazonSocial ?? "—",
                    Estilo = ps?.Estilo ?? "—",
                    Piezas = piezas,
                    Total = p.Total,
                    Costo = costo,
                    Ganancia = ganancia,
                    Margen = margen,
                    Estado = p.Estado,
                    Fecha = p.FechaPedido
                };
            })
            .ToList();
    }

    private async Task CalcularTrends(DateTime desde, List<Pedido> pedidosActuales)
    {
        if (periodo == "todo")
        {
            pedidosTrendPct = 0;
            ingresoTrendPct = 0;
            return;
        }

        var duracion = DateTime.UtcNow - desde;
        var desdeAnterior = desde - duracion;

        var pedidosAnteriores = await DbContext.Pedidos
            .Where(p => p.FechaPedido >= desdeAnterior && p.FechaPedido < desde)
            .ToListAsync();

        var pedidosAnt = pedidosAnteriores.Count;
        var ingresoAnt = pedidosAnteriores.Sum(p => p.Total);

        pedidosTrendPct = pedidosAnt > 0 ? (int)Math.Round(((double)pedidosActuales.Count - pedidosAnt) / pedidosAnt * 100) : 0;
        ingresoTrendPct = ingresoAnt > 0 ? (int)Math.Round(((double)ingresoPeriodo - (double)ingresoAnt) / (double)ingresoAnt * 100) : 0;
    }

    private static string GetEstadoColor(EstadoPedidoEnum estado) => estado switch
    {
        EstadoPedidoEnum.Nuevo => "#3b82f6",
        EstadoPedidoEnum.EnProceso => "#f59e0b",
        EstadoPedidoEnum.Producido => "#8b5cf6",
        EstadoPedidoEnum.Entregado => "#10b981",
        EstadoPedidoEnum.Facturado => "#059669",
        EstadoPedidoEnum.Pagado => "#047857",
        EstadoPedidoEnum.Cancelado => "#ef4444",
        _ => "#6b7280"
    };

    private class EstadoCount { public EstadoPedidoEnum Estado; public int Count; }
    private class MesIngreso { public int Year; public int Month; public decimal Ingreso; public string Label = ""; }
    private class ClienteRank { public string Nombre = ""; public decimal Total; public int Pedidos; public int Piezas; }
    private class ProductoRank { public string Nombre = ""; public int Piezas; public int Pedidos; public decimal Ingreso; }
    private class GananciaProducto { public string Nombre = ""; public int Piezas; public decimal Ingreso; public decimal Costo; public decimal Ganancia; }
    private class TallaDistribucion { public string Talla = ""; public int Cantidad; }
    private class PedidoReciente { public string NumeroPedido = ""; public string Cliente = ""; public string Estilo = ""; public int Piezas; public decimal Total; public decimal Costo; public decimal Ganancia; public int Margen; public EstadoPedidoEnum Estado; public DateTime Fecha; }
}
