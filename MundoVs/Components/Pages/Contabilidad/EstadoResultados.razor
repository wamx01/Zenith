@code {
    private bool cargando = true;
    private string periodo = "mes";
    private string nombreEmpresa = "MundoVs";
    private string rfcEmpresa = "";
    private string logoEmpresa = "";
    private string etiquetaPeriodo = "";

    // Estado de Resultados
    private decimal ingresosBrutos;
    private decimal descuentos;
    private decimal ingresosNetos;

    // Costo de Ventas (desglosado)
    private decimal costoMateriaPrima;
    private decimal costoInsumosBasicos;
    private decimal costoInsumosDiversos;
    private decimal costoManoObra;
    private decimal costoGIF; // Gastos indirectos de fabricación
    private decimal costoVentasTotal;

    private decimal utilidadBruta;

    // Gastos de operación
    private decimal gastosOperacion;
    private List<GastoFijoItem> detalleGastosFijos = [];

    private decimal utilidadOperacion;

    // Impuestos
    private decimal ivaTrasladado;
    private decimal ivaAcreditable;
    private decimal ivaPorPagar;
    private decimal isrEstimado;
    private decimal ptuEstimada;

    private decimal utilidadNeta;
    private decimal margenNeto;

    // Cobranza
    private decimal totalCobrado;
    private decimal totalPendienteCobro;

    // Desglose
    private List<ProductoDesglose> desgloseProductos = [];

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        cargando = false;
    }

    private async Task OnPeriodoChanged(ChangeEventArgs e)
    {
        periodo = e.Value?.ToString() ?? "mes";
        cargando = true;
        StateHasChanged();
        await CargarDatos();
        cargando = false;
    }

    private DateTime GetFechaInicio()
    {
        var now = DateTime.UtcNow;
        return periodo switch
        {
            "mes" => new DateTime(now.Year, now.Month, 1),
            "trimestre" => now.AddMonths(-3),
            "semestre" => now.AddMonths(-6),
            "anio" => new DateTime(now.Year, 1, 1),
            _ => DateTime.MinValue
        };
    }

    private string GetEtiquetaPeriodo()
    {
        var now = DateTime.Now;
        return periodo switch
        {
            "mes" => $"Del 1 al {DateTime.DaysInMonth(now.Year, now.Month)} de {now:MMMM yyyy}",
            "trimestre" => $"Últimos 3 meses (al {now:dd/MM/yyyy})",
            "semestre" => $"Últimos 6 meses (al {now:dd/MM/yyyy})",
            "anio" => $"Ejercicio fiscal {now.Year} (al {now:dd/MM/yyyy})",
            _ => "Todo el historial"
        };
    }

    private async Task CargarDatos()
    {
        var desde = GetFechaInicio();
        etiquetaPeriodo = GetEtiquetaPeriodo();

        // Config empresa
        var configNombre = await DbContext.AppConfigs.FirstOrDefaultAsync(c => c.Clave == "CompanyName");
        if (configNombre != null) nombreEmpresa = configNombre.Valor;

        var configLogo = await DbContext.AppConfigs.FirstOrDefaultAsync(c => c.Clave == "CompanyLogo");
        if (configLogo != null) logoEmpresa = configLogo.Valor;

        // Pedidos del periodo (excluir cancelados)
        var pedidos = await DbContext.Pedidos
            .AsNoTracking()
            .Include(p => p.Cliente)
            .Include(p => p.Detalles).ThenInclude(d => d.Producto)
            .Include(p => p.Detalles).ThenInclude(d => d.CotizacionSerigrafia).ThenInclude(c => c.Detalles)
            .Include(p => p.Conceptos)
            .Where(p => p.FechaPedido >= desde && p.Estado != EstadoPedidoEnum.Cancelado)
            .ToListAsync();

        var pedidoIds = pedidos.Select(p => p.Id).ToList();

        // Serigrafías para piezas
        var serigrafias = await DbContext.PedidosSerigrafia
            .AsNoTracking()
            .Include(ps => ps.Tallas)
            .Include(ps => ps.PedidoDetalle)
            .Where(ps => pedidoIds.Contains(ps.PedidoDetalle.PedidoId))
            .ToListAsync();

        // Cotizaciones de respaldo para detalles sin cotización ligada
        var cotizaciones = await DbContext.CotizacionesSerigrafia
            .AsNoTracking()
            .Include(c => c.Detalles)
            .Include(c => c.Producto)
            .Where(c => c.IsActive)
            .ToListAsync();

        var cotizDict = cotizaciones
            .GroupBy(c => c.ProductoId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(c => c.CreatedAt).First());

        var lineasProducto = pedidos
            .SelectMany(p => p.Detalles.Select(d => ConstruirLineaProducto(p, d, serigrafias, cotizDict)))
            .ToList();

        var lineasServicio = pedidos
            .SelectMany(p => p.Conceptos.Where(c => c.IsActive).Select(c => new LineaResultado
            {
                PedidoId = p.Id,
                ProductoId = null,
                Nombre = c.Descripcion,
                Piezas = Math.Max(0, c.Cantidad),
                IngresoBruto = Math.Max(0, c.Total),
                Descuento = 0,
                IngresoNeto = Math.Max(0, c.Total),
                CostoMateriaPrima = 0,
                CostoInsumosBasicos = 0,
                CostoInsumosDiversos = 0,
                CostoManoObra = 0,
                CostoGIF = 0,
                EsServicio = true
            }))
            .ToList();

        var lineasResultado = lineasProducto.Concat(lineasServicio).ToList();

        var pedidoTotales = lineasResultado
            .GroupBy(l => l.PedidoId)
            .ToDictionary(
                g => g.Key,
                g => new PedidoTotalCalculado
                {
                    PedidoId = g.Key,
                    Subtotal = Math.Round(g.Sum(x => x.IngresoNeto), 2),
                    Impuestos = Math.Round(g.Sum(x => x.IngresoNeto) * 0.16m, 2)
                });

        // ═══ INGRESOS ═══
        ingresosBrutos = Math.Round(lineasResultado.Sum(l => l.IngresoBruto), 2);
        descuentos = Math.Round(lineasResultado.Sum(l => l.Descuento), 2);
        ingresosNetos = Math.Round(lineasResultado.Sum(l => l.IngresoNeto), 2);

        // ═══ COSTO DE VENTAS ═══
        costoMateriaPrima = Math.Round(lineasProducto.Sum(l => l.CostoMateriaPrima), 2);
        costoInsumosBasicos = Math.Round(lineasProducto.Sum(l => l.CostoInsumosBasicos), 2);
        costoInsumosDiversos = Math.Round(lineasProducto.Sum(l => l.CostoInsumosDiversos), 2);
        var costoManoObraEstimado = Math.Round(lineasProducto.Sum(l => l.CostoManoObra), 2);
        costoGIF = Math.Round(lineasProducto.Sum(l => l.CostoGIF), 2);

        var valesPeriodo = await DbContext.ValesDestajo
            .AsNoTracking()
            .Include(v => v.Detalles)
            .Where(v => v.IsActive
                && v.Fecha >= desde
                && (v.Estatus == EstatusValeDestajo.Aprobado
                    || v.Estatus == EstatusValeDestajo.EnNomina
                    || v.Estatus == EstatusValeDestajo.Pagado))
            .ToListAsync();

        var costoManoObraReal = Math.Round(valesPeriodo.Sum(v => v.Detalles.Where(d => d.IsActive).Sum(d => d.Importe)), 2);
        costoManoObra = costoManoObraReal > 0 ? costoManoObraReal : costoManoObraEstimado;

        costoVentasTotal = costoMateriaPrima + costoInsumosBasicos + costoInsumosDiversos + costoManoObra + costoGIF;

        // ═══ UTILIDAD BRUTA ═══
        utilidadBruta = ingresosNetos - costoVentasTotal;

        // ═══ GASTOS DE OPERACIÓN (Gastos Fijos mensuales prorrateados al periodo) ═══
        var gastosFijos = await DbContext.GastosFijos.AsNoTracking().Where(g => g.IsActive).OrderBy(g => g.Orden).ToListAsync();
        var mesesPeriodo = periodo switch
        {
            "mes" => 1m,
            "trimestre" => 3m,
            "semestre" => 6m,
            "anio" => (decimal)DateTime.Now.Month,
            _ => Math.Max(1m, (decimal)(DateTime.UtcNow - desde).TotalDays / 30m)
        };

        detalleGastosFijos = gastosFijos.Select(g => new GastoFijoItem
        {
            Concepto = g.Concepto,
            Monto = Math.Round(g.CostoMensual * mesesPeriodo, 2)
        }).ToList();

        gastosOperacion = detalleGastosFijos.Sum(g => g.Monto);

        // ═══ UTILIDAD DE OPERACIÓN ═══
        utilidadOperacion = utilidadBruta - gastosOperacion;

        // ═══ IVA (Art. 1 LIVA — 16%) ═══
        ivaTrasladado = Math.Round(pedidoTotales.Sum(p => p.Value.Impuestos), 2);
        // IVA acreditable estimado: 16% sobre costos + gastos que generan IVA
        ivaAcreditable = Math.Round((costoVentasTotal + gastosOperacion) * 0.16m, 2);
        ivaPorPagar = Math.Max(0, ivaTrasladado - ivaAcreditable);

        // ═══ ISR (Art. 9 LISR — 30% sobre utilidad fiscal) ═══
        var baseGravable = Math.Max(0, utilidadOperacion);
        isrEstimado = Math.Round(baseGravable * 0.30m, 2);

        // ═══ PTU (Art. 123 Constitucional / Art. 120-127 LFT — 10%) ═══
        ptuEstimada = Math.Round(baseGravable * 0.10m, 2);

        // ═══ UTILIDAD NETA ═══
        utilidadNeta = utilidadOperacion - isrEstimado - ptuEstimada;
        margenNeto = ingresosNetos > 0 ? Math.Round(utilidadNeta / ingresosNetos * 100m, 1) : 0;

        // ═══ COBRANZA ═══
        var pagos = await DbContext.PagosPedido
            .AsNoTracking()
            .Where(p => p.IsActive && pedidoIds.Contains(p.PedidoId))
            .ToListAsync();
        totalCobrado = pagos.Sum(p => p.Monto);
        totalPendienteCobro = pedidoTotales.Sum(p => p.Value.Total) - totalCobrado;
        if (totalPendienteCobro < 0) totalPendienteCobro = 0;

        // ═══ DESGLOSE POR PRODUCTO ═══
        desgloseProductos = lineasProducto
            .GroupBy(l => new { l.ProductoId, l.Nombre })
            .Select(g =>
            {
                var ingreso = Math.Round(g.Sum(l => l.IngresoNeto), 2);
                var piezas = g.Sum(l => l.Piezas);
                var costo = Math.Round(g.Sum(l => l.CostoTotal), 2);
                var utilidad = ingreso - costo;
                var margen = ingreso > 0 ? Math.Round(utilidad / ingreso * 100m, 1) : 0;
                return new ProductoDesglose
                {
                    Nombre = g.Key.Nombre,
                    Piezas = piezas,
                    Ingreso = ingreso,
                    Costo = costo,
                    Utilidad = utilidad,
                    Margen = margen
                };
            })
            .OrderByDescending(p => p.Utilidad)
            .ToList();
    }

    private LineaResultado ConstruirLineaProducto(
        Pedido pedido,
        PedidoDetalle detalle,
        List<PedidoSerigrafia> serigrafias,
        Dictionary<Guid, CotizacionSerigrafia> cotizDict)
    {
        var piezas = ObtenerCantidadDetalle(pedido.Id, detalle, serigrafias);
        var cotizacion = detalle.CotizacionSerigrafia ?? cotizDict.GetValueOrDefault(detalle.ProductoId);
        var subtotal = ObtenerSubtotalDetalle(detalle, piezas, cotizacion);
        var descuento = Math.Max(0, detalle.Descuento);

        var costoMateriaPrimaLinea = 0m;
        var costoInsumosBasicosLinea = 0m;
        var costoInsumosDiversosLinea = 0m;
        var costoManoObraLinea = 0m;
        var costoGifLinea = 0m;

        if (cotizacion != null)
        {
            var factor = ObtenerFactorCotizacion(cotizacion, piezas);
            costoMateriaPrimaLinea = cotizacion.TotalTintas * factor;
            costoInsumosBasicosLinea = cotizacion.TotalInsumosBasicos * factor;
            costoInsumosDiversosLinea = cotizacion.TotalInsumosDiversos * factor;
            costoManoObraLinea = cotizacion.TotalManoObra * factor;
            costoGifLinea = cotizacion.TotalGastosFijos * factor;
        }

        return new LineaResultado
        {
            PedidoId = pedido.Id,
            ProductoId = detalle.ProductoId,
            Nombre = detalle.Producto?.Nombre ?? "—",
            Piezas = piezas,
            IngresoBruto = Math.Round(subtotal + descuento, 2),
            Descuento = Math.Round(descuento, 2),
            IngresoNeto = Math.Round(subtotal, 2),
            CostoMateriaPrima = Math.Round(costoMateriaPrimaLinea, 2),
            CostoInsumosBasicos = Math.Round(costoInsumosBasicosLinea, 2),
            CostoInsumosDiversos = Math.Round(costoInsumosDiversosLinea, 2),
            CostoManoObra = Math.Round(costoManoObraLinea, 2),
            CostoGIF = Math.Round(costoGifLinea, 2)
        };
    }

    private static decimal ObtenerFactorCotizacion(CotizacionSerigrafia cotizacion, int piezas)
    {
        var paresLam = cotizacion.ParesPorLamina > 0 ? cotizacion.ParesPorLamina : 1;
        return Math.Max(0, piezas) / paresLam;
    }

    private static decimal ObtenerSubtotalDetalle(PedidoDetalle detalle, int piezas, CotizacionSerigrafia? cotizacion)
    {
        if (detalle.Total > 0)
        {
            return detalle.Total;
        }

        var precioUnitario = detalle.PrecioUnitario > 0
            ? detalle.PrecioUnitario
            : cotizacion?.PrecioFinalContado ?? 0m;

        return Math.Round(precioUnitario * Math.Max(0, piezas), 2);
    }

    private static int ObtenerCantidadDetalle(Guid pedidoId, PedidoDetalle detalle, List<PedidoSerigrafia> serigrafias)
    {
        var piezasPedido = serigrafias
            .Where(s => s.PedidoDetalle.PedidoId == pedidoId && s.PedidoDetalleId == detalle.Id)
            .SelectMany(s => s.Tallas)
            .Sum(t => t.Cantidad);

        if (piezasPedido > 0)
        {
            return piezasPedido;
        }

        return Math.Max(0, detalle.Cantidad);
    }

    private class GastoFijoItem { public string Concepto = ""; public decimal Monto; }
    private class ProductoDesglose { public string Nombre = ""; public int Piezas; public decimal Ingreso; public decimal Costo; public decimal Utilidad; public decimal Margen; }
    private class PedidoTotalCalculado { public Guid PedidoId { get; set; } public decimal Subtotal { get; set; } public decimal Impuestos { get; set; } public decimal Total => Subtotal + Impuestos; }
    private class LineaResultado
    {
        public Guid PedidoId { get; set; }
        public Guid? ProductoId { get; set; }
        public string Nombre { get; set; } = "";
        public int Piezas { get; set; }
        public decimal IngresoBruto { get; set; }
        public decimal Descuento { get; set; }
        public decimal IngresoNeto { get; set; }
        public decimal CostoMateriaPrima { get; set; }
        public decimal CostoInsumosBasicos { get; set; }
        public decimal CostoInsumosDiversos { get; set; }
        public decimal CostoManoObra { get; set; }
        public decimal CostoGIF { get; set; }
        public bool EsServicio { get; set; }
        public decimal CostoTotal => CostoMateriaPrima + CostoInsumosBasicos + CostoInsumosDiversos + CostoManoObra + CostoGIF;
    }
}
