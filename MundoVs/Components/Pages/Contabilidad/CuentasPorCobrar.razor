    private void SeleccionarNotaCargo()
    {
        nuevoCargoManual.NotaEntregaId = Guid.TryParse(notaCargoIdTexto, out var notaId) && notaId != Guid.Empty
            ? notaId
            : null;

        if (nuevoCargoManual.NotaEntregaId.HasValue)
        {
            var nota = notasCargoDisponibles.FirstOrDefault(x => x.Id == nuevoCargoManual.NotaEntregaId.Value);
            if (nota != null && string.IsNullOrWhiteSpace(nuevoCargoManual.Referencia))
                nuevoCargoManual.Referencia = nota.NumeroNota;
        }
    }

    private async Task GuardarCargoManualAsync()
    {
        errorCargoManual = null;
        okCargoManual = null;

        if (!Guid.TryParse(cargoManualClienteIdTexto, out var clienteId) || clienteId == Guid.Empty)
        {
            errorCargoManual = "Selecciona un cliente para registrar el cargo.";
            return;
        }

        if (nuevoCargoManual.Monto <= 0 || string.IsNullOrWhiteSpace(nuevoCargoManual.Referencia) || string.IsNullOrWhiteSpace(nuevoCargoManual.Concepto))
        {
            errorCargoManual = "Captura monto, referencia y concepto para guardar el cargo.";
            return;
        }

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out var empresaId);
        if (empresaId == Guid.Empty)
        {
            errorCargoManual = "No hay empresa activa para guardar el cargo.";
            return;
        }

        nuevoCargoManual.Id = Guid.NewGuid();
        nuevoCargoManual.EmpresaId = empresaId;
        nuevoCargoManual.ClienteId = clienteId;
        nuevoCargoManual.IsActive = true;
        nuevoCargoManual.CreatedAt = DateTime.UtcNow;

        try
        {
            DbContext.CargosManualesCxC.Add(nuevoCargoManual);
            await DbContext.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            errorCargoManual = ex.InnerException?.Message ?? ex.Message;
            return;
        }

        okCargoManual = "Cargo guardado correctamente.";
        nuevoCargoManual = new CargoManualCxC { FechaCargo = DateTime.Today, Tipo = CargoManualCxCTipo.Ajuste };
        notaCargoIdTexto = string.Empty;
        textoBusquedaNotaCargo = string.Empty;
        notasCargoDisponibles = [];
        notasCargoDisponiblesFiltradas = [];
        cargoManualClienteIdTexto = string.Empty;
        mostrarCargoManualForm = false;
        await CargarDatos();
    }

    private async Task ExportarReportePdfAsync()
    {
        if (reporteAntiguedad.Count == 0)
            return;

        exportandoPdf = true;
        try
        {
            var pdf = await CuentasPorCobrarPdfService.GenerateReportePdfAsync(new CuentasPorCobrarPdfReport
            {
                Empresa = "Zenith",
                Desde = reporteDesde,
                Hasta = reporteHasta,
                ClienteFiltro = string.IsNullOrWhiteSpace(reporteClienteIdTexto) ? "Todos" : estadoCuentaClienteNombre,
                TotalPendiente = totalPendiente,
                TotalCobrado = totalCobrado,
                MontoVencido = montoVencido,
                ClientesConAdeudo = clientesConAdeudo,
                Bucket0a30 = graficaAntiguedad.FirstOrDefault(x => x.Titulo == "0-30")?.Monto ?? 0,
                Bucket31a60 = graficaAntiguedad.FirstOrDefault(x => x.Titulo == "31-60")?.Monto ?? 0,
                Bucket61a90 = graficaAntiguedad.FirstOrDefault(x => x.Titulo == "61-90")?.Monto ?? 0,
                BucketMas90 = graficaAntiguedad.FirstOrDefault(x => x.Titulo == "+90")?.Monto ?? 0,
                AntiguedadClientes = reporteAntiguedad.Select(x => new CuentasPorCobrarAntiguedadPdfItem
                {
                    Cliente = x.ClienteNombre,
                    Rango0a30 = x.Rango0a30,
                    Rango31a60 = x.Rango31a60,
                    Rango61a90 = x.Rango61a90,
                    RangoMas90 = x.RangoMas90
                }).ToList(),
                DocumentosVencidos = todosClientes.SelectMany(x => x.Facturas)
                    .Where(x => ObtenerSaldoDocumento(x) > 0 && x.DiasAtraso > 0)
                    .OrderByDescending(x => x.DiasAtraso)
                    .Take(40)
                    .Select(x => new CuentasPorCobrarVencidaPdfItem
                    {
                        Cliente = x.ClienteNombre,
                        Documento = x.NumeroFactura,
                        FechaEmision = x.FechaFactura,
                        FechaVencimiento = x.FechaVencimiento,
                        DiasAtraso = x.DiasAtraso,
                        Saldo = ObtenerSaldoDocumento(x)
                    }).ToList(),
                EstadoCuenta = new CuentasPorCobrarEstadoCuentaPdf
                {
                    Cliente = estadoCuentaClienteNombre,
                    SaldoInicial = estadoCuentaSaldoInicial,
                    SaldoFinal = estadoCuentaSaldoFinal,
                    Movimientos = estadoCuentaMovimientos.Select(x => new CuentasPorCobrarEstadoCuentaMovimientoPdfItem
                    {
                        Fecha = x.Fecha,
                        Tipo = x.Tipo,
                        Referencia = x.Referencia,
                        Concepto = x.Concepto,
                        Cargo = x.Cargo,
                        Abono = x.Abono,
                        Saldo = x.Saldo
                    }).ToList()
                },
                Movimientos = reporteMovimientos.Select(x => new CuentasPorCobrarMovimientoPdfItem
                {
                    Fecha = x.Fecha,
                    Cliente = x.ClienteNombre,
                    Tipo = x.Tipo,
                    Referencia = x.Referencia,
                    Concepto = x.Concepto,
                    Cargo = x.Cargo,
                    Abono = x.Abono,
                    Saldo = x.Saldo
                }).ToList()
            });

            await JS.InvokeVoidAsync("mundoVsAuth.downloadFileFromBase64", $"cxc-reporte-{reporteDesde:yyyyMMdd}-{reporteHasta:yyyyMMdd}.pdf", Convert.ToBase64String(pdf), "application/pdf");
        }
        finally
        {
            exportandoPdf = false;
        }
    }

