    private async Task CargarNotasCargoManualAsync()
    {
        notaCargoIdTexto = string.Empty;
        textoBusquedaNotaCargo = string.Empty;
        nuevoCargoManual.NotaEntregaId = null;
        errorCargoManual = null;
        okCargoManual = null;

        if (!Guid.TryParse(cargoManualClienteIdTexto, out var clienteId) || clienteId == Guid.Empty)
        {
            notasCargoDisponibles = [];
            notasCargoDisponiblesFiltradas = [];
            return;
        }

        notasCargoDisponibles = await DbContext.NotasEntrega
            .AsNoTracking()
            .Where(n => n.IsActive && n.ClienteId == clienteId && n.Estatus != NotaEntregaEstatus.Cancelada)
            .OrderByDescending(n => n.FechaNota)
            .Select(n => new NotaCargoOption
            {
                Id = n.Id,
                NumeroNota = n.NumeroNota,
                Fecha = n.FechaNota,
                Total = n.Total,
                Etiqueta = $"{n.NumeroNota} · {n.FechaNota:dd/MM/yyyy} · {n.Total:C2}"
            })
            .ToListAsync();

        notasCargoDisponiblesFiltradas = notasCargoDisponibles.ToList();
    }

    private void FiltrarNotasCargo()
    {
        if (string.IsNullOrWhiteSpace(textoBusquedaNotaCargo))
        {
            notasCargoDisponiblesFiltradas = notasCargoDisponibles.ToList();
            return;
        }

        var texto = textoBusquedaNotaCargo.Trim();
        notasCargoDisponiblesFiltradas = notasCargoDisponibles
            .Where(n => n.NumeroNota.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || n.Etiqueta.Contains(texto, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

