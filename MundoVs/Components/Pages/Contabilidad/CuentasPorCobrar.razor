@code {
    private List<ClienteAgrupado>? clientesAgrupados;
    private List<ClienteAgrupado> todosClientes = [];
    private Dictionary<Guid, List<PagoDocumentoViewModel>> pagosPorDocumento = new();
    private Guid? expandedCliente;
    private Guid? expandedFactura;
    private string filtro = "pendientes";
    private string ordenarPor = "mayor_adeudo";
    private string textoBusqueda = "";
    private string? errorPago;

    private decimal totalCobrado;
    private decimal totalPendiente;
    private int clientesConAdeudo;
    private decimal montoVencido;

    private DateTime nuevoPagoFecha = DateTime.Now;
    private decimal nuevoPagoMonto;
    private FormaPagoEnum nuevoPagoFormaPago = FormaPagoEnum.Transferencia;
    private string? nuevoPagoReferencia;
    private string? nuevoPagoNotas;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        var todasFacturas = await DbContext.Facturas
            .AsNoTracking()
            .Include(f => f.Cliente)
            .Include(f => f.Pedido)
            .Include(f => f.NotaEntrega)
            .Include(f => f.NotasEntregaRelacionadas)
                .ThenInclude(r => r.NotaEntrega)
            .Where(f => f.IsActive
                && f.TipoComprobante == FacturaTipoComprobante.Ingreso
                && f.Estatus != FacturaEstatus.Cancelado)
            .OrderByDescending(f => f.FechaEmision)
            .ToListAsync();

        var facturaIds = todasFacturas.Select(f => f.Id).ToList();
        var aplicaciones = await DbContext.PagosAplicacionDocumento
            .AsNoTracking()
            .Include(a => a.PagoRecibido)
            .Where(a => a.IsActive
                && facturaIds.Contains(a.FacturaId)
                && a.PagoRecibido.IsActive)
            .ToListAsync();

        var pagosDirectosNotas = await DbContext.PagosRecibidos
            .AsNoTracking()
            .Where(p => p.IsActive && p.NotaEntregaId.HasValue)
            .Where(p => !DbContext.PagosAplicacionDocumento.Any(a => a.PagoRecibidoId == p.Id && a.IsActive))
            .ToListAsync();

        pagosPorDocumento = aplicaciones
            .GroupBy(a => a.FacturaId)
            .ToDictionary(
                g => g.Key,
                g => g.Select(a => new PagoDocumentoViewModel
                {
                    RegistroId = a.Id,
                    PagoRecibidoId = a.PagoRecibidoId,
                    FechaPago = a.PagoRecibido.FechaPago,
                    FormaPagoSat = a.PagoRecibido.FormaPagoSat,
                    Referencia = a.PagoRecibido.Referencia,
                    Notas = a.PagoRecibido.Notas,
                    ImporteAplicado = a.ImporteAplicado,
                    EsAplicacionFactura = true
                }).ToList());

        foreach (var grupo in pagosDirectosNotas.Where(p => p.NotaEntregaId.HasValue).GroupBy(p => p.NotaEntregaId!.Value))
        {
            if (!pagosPorDocumento.TryGetValue(grupo.Key, out var lista))
            {
                lista = [];
                pagosPorDocumento[grupo.Key] = lista;
            }

            lista.AddRange(grupo.Select(p => new PagoDocumentoViewModel
            {
                RegistroId = p.Id,
                PagoRecibidoId = p.Id,
                FechaPago = p.FechaPago,
                FormaPagoSat = p.FormaPagoSat,
                Referencia = p.Referencia,
                Notas = p.Notas,
                ImporteAplicado = p.Monto,
                EsAplicacionFactura = false
            }));
        }

        var facturasView = todasFacturas.Select(f =>
        {
            var diasCredito = f.Cliente.DiasCredito ?? 0;
            DateTime? fechaVencimiento = diasCredito > 0 ? f.FechaEmision.AddDays(diasCredito) : null;
            var pagadoF = pagosPorDocumento.GetValueOrDefault(f.Id, []).Sum(x => x.ImporteAplicado);
            var saldoF = Math.Max(0, f.Total - pagadoF);
            var diasAtraso = 0;
            if (saldoF > 0 && fechaVencimiento.HasValue && fechaVencimiento.Value.Date < DateTime.Today)
            {
                diasAtraso = (DateTime.Today - fechaVencimiento.Value.Date).Days;
            }

            return new FacturaViewModel
            {
                FacturaId = f.Id,
                PedidoId = f.PedidoId,
                NotaEntregaId = f.NotaEntregaId,
                ClienteId = f.ClienteId,
                ClienteNombre = f.Cliente.RazonSocial,
                NumeroFactura = string.IsNullOrWhiteSpace(f.FolioFiscal) ? f.FolioInterno : f.FolioFiscal!,
                NumeroPedido = f.Pedido?.NumeroPedido,
                NumeroNota = ObtenerResumenNotas(f),
                FechaFactura = f.FechaEmision,
                FechaVencimiento = fechaVencimiento,
                DiasAtraso = diasAtraso,
                MetodoPagoSat = f.MetodoPagoSat,
                    Total = f.Total,
                    PermiteAplicarPago = true,
                    EtiquetaTipoDocumento = "Factura"
            };
        }).ToList();

        var notasPendientes = await DbContext.NotasEntrega
            .AsNoTracking()
            .Include(n => n.Cliente)
            .Include(n => n.Pedido)
            .Include(n => n.FacturasRelacionadas)
                .ThenInclude(r => r.Factura)
            .Where(n => n.IsActive && n.Estatus != NotaEntregaEstatus.Cancelada && n.Estatus != NotaEntregaEstatus.Borrador)
            .ToListAsync();

        var notasView = notasPendientes
            .Select(nota =>
            {
                var diasCredito = nota.Cliente.DiasCredito ?? 0;
                DateTime? fechaVencimiento = diasCredito > 0 ? nota.FechaNota.AddDays(diasCredito) : null;
                var totalFacturadoNota = nota.FacturasRelacionadas
                    .Where(r => r.IsActive && r.Factura.IsActive && r.Factura.Estatus != FacturaEstatus.Cancelado)
                    .Sum(r => r.Total);
                var pagadoNota = pagosPorDocumento.GetValueOrDefault(nota.Id, []).Sum(x => x.ImporteAplicado);
                var saldoNota = Math.Max(0, (nota.Total - totalFacturadoNota) - pagadoNota);
                var diasAtraso = 0;
                if (saldoNota > 0 && fechaVencimiento.HasValue && fechaVencimiento.Value.Date < DateTime.Today)
                {
                    diasAtraso = (DateTime.Today - fechaVencimiento.Value.Date).Days;
                }

                return new FacturaViewModel
                {
                    FacturaId = nota.Id,
                    PedidoId = nota.PedidoId,
                    NotaEntregaId = nota.Id,
                    ClienteId = nota.ClienteId,
                    ClienteNombre = nota.Cliente.RazonSocial,
                    NumeroFactura = nota.NumeroNota,
                    NumeroPedido = nota.Pedido?.NumeroPedido,
                    NumeroNota = nota.NumeroNota,
                    FechaFactura = nota.FechaNota,
                    FechaVencimiento = fechaVencimiento,
                    DiasAtraso = diasAtraso,
                    MetodoPagoSat = "PPD",
                    Total = Math.Max(0, nota.Total - totalFacturadoNota),
                    EsNotaEntrega = true,
                    PermiteAplicarPago = true,
                    EtiquetaTipoDocumento = totalFacturadoNota > 0 ? "Nota parcialmente facturada" : "Nota por cobrar"
                };
            })
            .Where(n => (n.Total - pagosPorDocumento.GetValueOrDefault(n.FacturaId, []).Sum(x => x.ImporteAplicado)) > 0 || pagosPorDocumento.GetValueOrDefault(n.FacturaId, []).Any())
            .ToList();

        var documentosView = facturasView.Concat(notasView).ToList();

        var totalFacturado = documentosView.Sum(f => f.Total);
        totalCobrado = pagosPorDocumento.SelectMany(kvp => kvp.Value).Sum(a => a.ImporteAplicado);
        totalPendiente = Math.Max(0, totalFacturado - totalCobrado);
        montoVencido = documentosView.Where(f => f.DiasAtraso > 0).Sum(f => f.Total - pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado));
        montoVencido = Math.Max(0, montoVencido);

        todosClientes = documentosView
            .GroupBy(f => new { f.ClienteId, f.ClienteNombre })
            .Select(g =>
            {
                var total = g.Sum(f => f.Total);
                var pagado = g.Sum(f => pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado));
                var mayorAtraso = g.Where(f =>
                {
                    var s = f.Total - pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado);
                    return s > 0;
                }).Select(f => f.DiasAtraso).DefaultIfEmpty(0).Max();

                return new ClienteAgrupado
                {
                    ClienteId = g.Key.ClienteId,
                    ClienteNombre = g.Key.ClienteNombre,
                    Total = total,
                    Pagado = pagado,
                    Saldo = Math.Max(0, total - pagado),
                    MayorDiasAtraso = mayorAtraso,
                    Facturas = g.OrderByDescending(f => f.FechaFactura).ToList()
                };
            })
            .ToList();

        clientesConAdeudo = todosClientes.Count(c => c.Saldo > 0);

        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        var lista = todosClientes.AsEnumerable();

        lista = filtro switch
        {
            "pendientes" => lista.Where(c => c.Saldo > 0),
            "pagadas" => lista.Where(c => c.Saldo <= 0),
            _ => lista
        };

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var busq = textoBusqueda.Trim();
            lista = lista.Where(c => c.ClienteNombre.Contains(busq, StringComparison.OrdinalIgnoreCase));
        }

        lista = ordenarPor switch
        {
            "mayor_adeudo" => lista.OrderByDescending(c => c.Saldo),
            "mayor_atraso" => lista.OrderByDescending(c => c.MayorDiasAtraso).ThenByDescending(c => c.Saldo),
            "nombre" => lista.OrderBy(c => c.ClienteNombre),
            _ => lista.OrderByDescending(c => c.Saldo)
        };

        clientesAgrupados = lista.ToList();
    }

    private void ToggleCliente(Guid clienteId)
    {
        if (expandedCliente == clienteId)
        {
            expandedCliente = null;
            expandedFactura = null;
        }
        else
        {
            expandedCliente = clienteId;
            expandedFactura = null;
        }
        ResetNuevoPago();
    }

    private void ToggleFactura(Guid facturaId)
    {
        expandedFactura = expandedFactura == facturaId ? null : facturaId;
        ResetNuevoPago();
    }

    private async Task AgregarPago(Guid facturaId, decimal totalFactura, Guid clienteId, Guid? pedidoId, Guid? notaEntregaId, string metodoPagoSat, bool esNotaEntrega)
    {
        errorPago = null;

        if (nuevoPagoMonto <= 0)
        {
            errorPago = "El importe debe ser mayor a $0.";
            return;
        }

        if (nuevoPagoFecha.Date > DateTime.Today)
        {
            errorPago = "La fecha del cobro no puede ser futura.";
            return;
        }

        var pagadoActual = ObtenerTotalPagadoActivo(facturaId);
        var saldoRestante = totalFactura - pagadoActual;
        if (nuevoPagoMonto > saldoRestante)
        {
            errorPago = $"El importe (${nuevoPagoMonto:F2}) excede el saldo pendiente (${saldoRestante:F2}).";
            return;
        }

        var saldoRestanteDocumento = totalFactura - ObtenerTotalPagadoActivo(facturaId);
        if (nuevoPagoMonto > saldoRestanteDocumento)
        {
            errorPago = $"El importe (${nuevoPagoMonto:F2}) excede el saldo pendiente (${saldoRestanteDocumento:F2}).";
            return;
        }

        Guid empresaIdPago;
        if (esNotaEntrega)
        {
            var nota = await DbContext.NotasEntrega.AsNoTracking().FirstOrDefaultAsync(n => n.Id == notaEntregaId);
            if (nota == null)
            {
                errorPago = "No se encontró la nota de entrega asociada al cobro.";
                return;
            }

            empresaIdPago = nota.EmpresaId;
        }
        else
        {
            var factura = await DbContext.Facturas.AsNoTracking().FirstOrDefaultAsync(f => f.Id == facturaId);
            if (factura == null)
            {
                errorPago = "No se encontró la factura asociada al cobro.";
                return;
            }

            empresaIdPago = factura.EmpresaId;
        }

        var pago = new PagoRecibido
        {
            Id = Guid.NewGuid(),
            EmpresaId = empresaIdPago,
            ClienteId = clienteId,
            PedidoId = pedidoId,
            NotaEntregaId = notaEntregaId,
            FechaPago = nuevoPagoFecha,
            Monto = nuevoPagoMonto,
            FormaPagoSat = MapFormaPagoSat(nuevoPagoFormaPago),
            MedioCobroInterno = GetFormaPagoLabel(MapFormaPagoSat(nuevoPagoFormaPago)),
            Referencia = nuevoPagoReferencia,
            Notas = nuevoPagoNotas,
            CreatedAt = DateTime.UtcNow,
            IsActive = true
        };

        DbContext.PagosRecibidos.Add(pago);

        if (!esNotaEntrega)
        {
            var factura = await DbContext.Facturas.AsNoTracking().FirstOrDefaultAsync(f => f.Id == facturaId);
            if (factura == null)
            {
                errorPago = "No se encontró la factura asociada al cobro.";
                return;
            }

            DbContext.PagosAplicacionDocumento.Add(new PagoAplicacionDocumento
            {
                Id = Guid.NewGuid(),
                EmpresaId = factura.EmpresaId,
                PagoRecibidoId = pago.Id,
                PagoRecibido = pago,
                FacturaId = facturaId,
                ImporteAplicado = nuevoPagoMonto,
                SaldoAnterior = saldoRestanteDocumento,
                SaldoInsoluto = Math.Max(0, saldoRestanteDocumento - nuevoPagoMonto),
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });
        }

        await DbContext.SaveChangesAsync();
        if (!esNotaEntrega)
        {
            await ActualizarEstadoFacturaAsync(facturaId);
        }

        var keepCliente = clienteId;
        var keepFactura = expandedFactura;
        ResetNuevoPago();
        await CargarDatos();
        expandedCliente = keepCliente;
        expandedFactura = keepFactura;
    }

    private async Task EliminarPago(Guid aplicacionId, Guid facturaId, Guid clienteId, bool esNotaEntrega)
    {
        if (esNotaEntrega)
        {
            var pagoDirecto = await DbContext.PagosRecibidos.FirstOrDefaultAsync(p => p.Id == aplicacionId && p.IsActive);
            if (pagoDirecto == null)
            {
                return;
            }

            pagoDirecto.IsActive = false;
            pagoDirecto.UpdatedAt = DateTime.UtcNow;
            await DbContext.SaveChangesAsync();

            await CargarDatos();
            expandedCliente = clienteId;
            expandedFactura = facturaId;
            return;
        }

        var aplicacion = await DbContext.PagosAplicacionDocumento
            .Include(a => a.PagoRecibido)
            .FirstOrDefaultAsync(a => a.Id == aplicacionId && a.IsActive);
        if (aplicacion == null)
        {
            return;
        }

        aplicacion.IsActive = false;
        aplicacion.UpdatedAt = DateTime.UtcNow;

        var aplicacionesActivas = await DbContext.PagosAplicacionDocumento
            .CountAsync(a => a.PagoRecibidoId == aplicacion.PagoRecibidoId && a.IsActive && a.Id != aplicacionId);

        if (aplicacionesActivas == 0)
        {
            aplicacion.PagoRecibido.IsActive = false;
            aplicacion.PagoRecibido.UpdatedAt = DateTime.UtcNow;
        }

        await DbContext.SaveChangesAsync();
        await ActualizarEstadoFacturaAsync(facturaId);

        await CargarDatos();
        expandedCliente = clienteId;
        expandedFactura = facturaId;
    }

    private async Task ActualizarEstadoFacturaAsync(Guid facturaId)
    {
        var factura = await DbContext.Facturas.FindAsync(facturaId);
        if (factura == null) return;

        var totalPagado = await DbContext.PagosAplicacionDocumento
            .Where(a => a.FacturaId == facturaId && a.IsActive)
            .SumAsync(a => a.ImporteAplicado);

        if (factura.Total > 0 && totalPagado >= factura.Total)
        {
            if (factura.Estatus != FacturaEstatus.PagadoTotal)
            {
                factura.Estatus = FacturaEstatus.PagadoTotal;
                factura.UpdatedAt = DateTime.UtcNow;
                await DbContext.SaveChangesAsync();
            }
        }
        else if (totalPagado > 0)
        {
            if (factura.Estatus != FacturaEstatus.PagadoParcial)
            {
                factura.Estatus = FacturaEstatus.PagadoParcial;
                factura.UpdatedAt = DateTime.UtcNow;
                await DbContext.SaveChangesAsync();
            }
        }
        else if (factura.Estatus is FacturaEstatus.PagadoTotal or FacturaEstatus.PagadoParcial)
        {
            factura.Estatus = string.IsNullOrWhiteSpace(factura.UuidFiscal)
                ? FacturaEstatus.PendienteTimbrado
                : FacturaEstatus.Timbrado;
            factura.UpdatedAt = DateTime.UtcNow;
            await DbContext.SaveChangesAsync();
        }
    }

    private void ResetNuevoPago()
    {
        nuevoPagoFecha = DateTime.Now;
        nuevoPagoMonto = 0;
        nuevoPagoFormaPago = FormaPagoEnum.Transferencia;
        nuevoPagoReferencia = null;
        nuevoPagoNotas = null;
        errorPago = null;
    }

    private decimal ObtenerTotalPagadoActivo(Guid facturaId)
        => pagosPorDocumento.GetValueOrDefault(facturaId, []).Sum(p => p.ImporteAplicado);

    private static string GetFormaPagoLabel(string formaPagoSat) => formaPagoSat switch
    {
        "01" => "Efectivo",
        "02" => "Cheque",
        "03" => "Transferencia",
        "04" => "Tarjeta Crédito",
        "28" => "Tarjeta Débito",
        _ => "Otro"
    };

    private static string MapFormaPagoSat(FormaPagoEnum forma) => forma switch
    {
        FormaPagoEnum.Efectivo => "01",
        FormaPagoEnum.Cheque => "02",
        FormaPagoEnum.Transferencia => "03",
        FormaPagoEnum.TarjetaCredito => "04",
        FormaPagoEnum.TarjetaDebito => "28",
        _ => "99"
    };

    private static string GetAtrasoColor(int diasAtraso) => diasAtraso switch
    {
        <= 0 => "#10b981",
        <= 30 => "#f59e0b",
        _ => "#ef4444"
    };

    private static string? ObtenerResumenNotas(Factura factura)
    {
        var notas = factura.NotasEntregaRelacionadas
            .Where(r => r.IsActive)
            .Select(r => r.NotaEntrega.NumeroNota)
            .Distinct()
            .ToList();

        if (notas.Count == 0 && factura.NotaEntrega != null)
        {
            return factura.NotaEntrega.NumeroNota;
        }

        return notas.Count == 0 ? null : string.Join(", ", notas);
    }

    private class FacturaViewModel
    {
        public Guid FacturaId { get; set; }
        public Guid? PedidoId { get; set; }
        public Guid? NotaEntregaId { get; set; }
        public Guid ClienteId { get; set; }
        public string ClienteNombre { get; set; } = "";
        public string NumeroFactura { get; set; } = "";
        public string? NumeroPedido { get; set; }
        public string? NumeroNota { get; set; }
        public DateTime FechaFactura { get; set; }
        public DateTime? FechaVencimiento { get; set; }
        public int DiasAtraso { get; set; }
        public string MetodoPagoSat { get; set; } = "";
        public decimal Total { get; set; }
        public bool EsNotaEntrega { get; set; }
        public bool PermiteAplicarPago { get; set; } = true;
        public string EtiquetaTipoDocumento { get; set; } = "Factura";
    }

    private class PagoDocumentoViewModel
    {
        public Guid RegistroId { get; set; }
        public Guid PagoRecibidoId { get; set; }
        public DateTime FechaPago { get; set; }
        public string FormaPagoSat { get; set; } = "03";
        public string? Referencia { get; set; }
        public string? Notas { get; set; }
        public decimal ImporteAplicado { get; set; }
        public bool EsAplicacionFactura { get; set; }
    }

    private class ClienteAgrupado
    {
        public Guid ClienteId { get; set; }
        public string ClienteNombre { get; set; } = "";
        public decimal Total { get; set; }
        public decimal Pagado { get; set; }
        public decimal Saldo { get; set; }
        public int MayorDiasAtraso { get; set; }
        public List<FacturaViewModel> Facturas { get; set; } = [];
    }
}
