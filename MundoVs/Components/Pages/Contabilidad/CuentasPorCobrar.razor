@code {
    private List<ClienteAgrupado>? clientesAgrupados;
    private List<ClienteAgrupado> todosClientes = [];
    private Dictionary<Guid, List<PagoDocumentoViewModel>> pagosPorDocumento = new();
    private Guid? expandedCliente;
    private Guid? expandedFactura;
    private string filtro = "pendientes";
    private string ordenarPor = "mayor_adeudo";
    private string textoBusqueda = "";
    private string? errorPago;
    private bool mostrarCargoManualForm;
    private string cargoManualClienteIdTexto = string.Empty;
    private string notaCargoIdTexto = string.Empty;
    private string textoBusquedaNotaCargo = string.Empty;
    private string? errorCargoManual;
    private string? okCargoManual;
    private DateTime reporteDesde = DateTime.Today.AddMonths(-1);
    private DateTime reporteHasta = DateTime.Today;
    private string reporteClienteIdTexto = string.Empty;
    private bool exportandoPdf;

    private decimal totalCobrado;
    private decimal totalPendiente;
    private int clientesConAdeudo;
    private decimal montoVencido;
    private List<ClienteReporteItem> clientesDisponiblesReporte = [];
    private List<AntiguedadReporteItem> reporteAntiguedad = [];
    private List<GraficaAntiguedadItem> graficaAntiguedad = [];
    private List<EstadoCuentaMovimientoItem> estadoCuentaMovimientos = [];
    private List<MovimientoReporteItem> reporteMovimientos = [];
    private string estadoCuentaClienteNombre = "Sin selección";
    private decimal estadoCuentaSaldoInicial;
    private decimal estadoCuentaSaldoFinal;
    private CargoManualCxC nuevoCargoManual = new() { FechaCargo = DateTime.Today, Tipo = CargoManualCxCTipo.Ajuste };
    private List<CargoManualCxC> cargosManuales = [];
    private List<NotaCargoOption> notasCargoDisponibles = [];
    private List<NotaCargoOption> notasCargoDisponiblesFiltradas = [];

    private DateTime nuevoPagoFecha = DateTime.Now;
    private decimal nuevoPagoMonto;
    private FormaPagoEnum nuevoPagoFormaPago = FormaPagoEnum.Transferencia;
    private string? nuevoPagoReferencia;
    private string? nuevoPagoNotas;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        var todasFacturas = await DbContext.Facturas
            .AsNoTracking()
            .Include(f => f.Cliente)
            .Include(f => f.Pedido)
            .Include(f => f.NotaEntrega)
            .Include(f => f.NotasEntregaRelacionadas)
                .ThenInclude(r => r.NotaEntrega)
            .Where(f => f.IsActive
                && f.TipoComprobante == FacturaTipoComprobante.Ingreso
                && f.Estatus != FacturaEstatus.Cancelado)
            .OrderByDescending(f => f.FechaEmision)
            .ToListAsync();

        var facturaIds = todasFacturas.Select(f => f.Id).ToList();
        var aplicaciones = await DbContext.PagosAplicacionDocumento
            .AsNoTracking()
            .Include(a => a.PagoRecibido)
            .Where(a => a.IsActive
                && facturaIds.Contains(a.FacturaId)
                && a.PagoRecibido.IsActive)
            .ToListAsync();

        var pagosDirectosNotas = await DbContext.PagosRecibidos
            .AsNoTracking()
            .Where(p => p.IsActive && p.NotaEntregaId.HasValue)
            .Where(p => !DbContext.PagosAplicacionDocumento.Any(a => a.PagoRecibidoId == p.Id && a.IsActive))
            .ToListAsync();

        cargosManuales = await DbContext.CargosManualesCxC
            .AsNoTracking()
            .Include(c => c.Cliente)
            .Where(c => c.IsActive)
            .OrderByDescending(c => c.FechaCargo)
            .ToListAsync();

        pagosPorDocumento = aplicaciones
            .GroupBy(a => a.FacturaId)
            .ToDictionary(
                g => g.Key,
                g => g.Select(a => new PagoDocumentoViewModel
                {
                    RegistroId = a.Id,
                    PagoRecibidoId = a.PagoRecibidoId,
                    FechaPago = a.PagoRecibido.FechaPago,
                    FormaPagoSat = a.PagoRecibido.FormaPagoSat,
                    Referencia = a.PagoRecibido.Referencia,
                    Notas = a.PagoRecibido.Notas,
                    ImporteAplicado = a.ImporteAplicado,
                    EsAplicacionFactura = true
                }).ToList());

        foreach (var grupo in pagosDirectosNotas.Where(p => p.NotaEntregaId.HasValue).GroupBy(p => p.NotaEntregaId!.Value))
        {
            if (!pagosPorDocumento.TryGetValue(grupo.Key, out var lista))
            {
                lista = [];
                pagosPorDocumento[grupo.Key] = lista;
            }

            lista.AddRange(grupo.Select(p => new PagoDocumentoViewModel
            {
                RegistroId = p.Id,
                PagoRecibidoId = p.Id,
                FechaPago = p.FechaPago,
                FormaPagoSat = p.FormaPagoSat,
                Referencia = p.Referencia,
                Notas = p.Notas,
                ImporteAplicado = p.Monto,
                EsAplicacionFactura = false
            }));
        }

        var facturasView = todasFacturas.Select(f =>
        {
            var diasCredito = f.Cliente.DiasCredito ?? 0;
            DateTime? fechaVencimiento = diasCredito > 0 ? f.FechaEmision.AddDays(diasCredito) : null;
            var pagadoF = pagosPorDocumento.GetValueOrDefault(f.Id, []).Sum(x => x.ImporteAplicado);
            var saldoF = Math.Max(0, f.Total - pagadoF);
            var diasAtraso = 0;
            if (saldoF > 0 && fechaVencimiento.HasValue && fechaVencimiento.Value.Date < DateTime.Today)
            {
                diasAtraso = (DateTime.Today - fechaVencimiento.Value.Date).Days;
            }

            return new FacturaViewModel
            {
                FacturaId = f.Id,
                PedidoId = f.PedidoId,
                NotaEntregaId = f.NotaEntregaId,
                ClienteId = f.ClienteId,
                ClienteNombre = f.Cliente.RazonSocial,
                NumeroFactura = string.IsNullOrWhiteSpace(f.FolioFiscal) ? f.FolioInterno : f.FolioFiscal!,
                NumeroPedido = f.Pedido?.NumeroPedido,
                NumeroNota = ObtenerResumenNotas(f),
                FechaFactura = f.FechaEmision,
                FechaVencimiento = fechaVencimiento,
                DiasAtraso = diasAtraso,
                MetodoPagoSat = f.MetodoPagoSat,
                    Total = f.Total,
                    PermiteAplicarPago = true,
                    EtiquetaTipoDocumento = "Factura"
            };
        }).ToList();

        var notasPendientes = await DbContext.NotasEntrega
            .AsNoTracking()
            .Include(n => n.Cliente)
            .Include(n => n.Pedido)
            .Include(n => n.FacturasRelacionadas)
                .ThenInclude(r => r.Factura)
            .Where(n => n.IsActive && n.Estatus != NotaEntregaEstatus.Cancelada && n.Estatus != NotaEntregaEstatus.Borrador)
            .ToListAsync();

        var notasView = notasPendientes
            .Select(nota =>
            {
                var diasCredito = nota.Cliente.DiasCredito ?? 0;
                DateTime? fechaVencimiento = diasCredito > 0 ? nota.FechaNota.AddDays(diasCredito) : null;
                var totalFacturadoNota = nota.FacturasRelacionadas
                    .Where(r => r.IsActive && r.Factura.IsActive && r.Factura.Estatus != FacturaEstatus.Cancelado)
                    .Sum(r => r.Total);
                var pagadoNota = pagosPorDocumento.GetValueOrDefault(nota.Id, []).Sum(x => x.ImporteAplicado);
                var saldoNota = Math.Max(0, (nota.Total - totalFacturadoNota) - pagadoNota);
                var diasAtraso = 0;
                if (saldoNota > 0 && fechaVencimiento.HasValue && fechaVencimiento.Value.Date < DateTime.Today)
                {
                    diasAtraso = (DateTime.Today - fechaVencimiento.Value.Date).Days;
                }

                return new FacturaViewModel
                {
                    FacturaId = nota.Id,
                    PedidoId = nota.PedidoId,
                    NotaEntregaId = nota.Id,
                    ClienteId = nota.ClienteId,
                    ClienteNombre = nota.Cliente.RazonSocial,
                    NumeroFactura = nota.NumeroNota,
                    NumeroPedido = nota.Pedido?.NumeroPedido,
                    NumeroNota = nota.NumeroNota,
                    FechaFactura = nota.FechaNota,
                    FechaVencimiento = fechaVencimiento,
                    DiasAtraso = diasAtraso,
                    MetodoPagoSat = "PPD",
                    Total = Math.Max(0, nota.Total - totalFacturadoNota),
                    EsNotaEntrega = true,
                    PermiteAplicarPago = true,
                    EtiquetaTipoDocumento = totalFacturadoNota > 0 ? "Nota parcialmente facturada" : "Nota por cobrar"
                };
            })
            .Where(n => (n.Total - pagosPorDocumento.GetValueOrDefault(n.FacturaId, []).Sum(x => x.ImporteAplicado)) > 0 || pagosPorDocumento.GetValueOrDefault(n.FacturaId, []).Any())
            .ToList();

        var documentosView = facturasView.Concat(notasView).ToList();

        var totalFacturado = documentosView.Sum(f => f.Total);
        totalCobrado = pagosPorDocumento.SelectMany(kvp => kvp.Value).Sum(a => a.ImporteAplicado);
        totalPendiente = Math.Max(0, totalFacturado - totalCobrado);
        montoVencido = documentosView.Where(f => f.DiasAtraso > 0).Sum(f => f.Total - pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado));
        montoVencido = Math.Max(0, montoVencido);

        todosClientes = documentosView
            .GroupBy(f => new { f.ClienteId, f.ClienteNombre })
            .Select(g =>
            {
                var total = g.Sum(f => f.Total);
                var pagado = g.Sum(f => pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado));
                var mayorAtraso = g.Where(f =>
                {
                    var s = f.Total - pagosPorDocumento.GetValueOrDefault(f.FacturaId, []).Sum(x => x.ImporteAplicado);
                    return s > 0;
                }).Select(f => f.DiasAtraso).DefaultIfEmpty(0).Max();

                return new ClienteAgrupado
                {
                    ClienteId = g.Key.ClienteId,
                    ClienteNombre = g.Key.ClienteNombre,
                    Total = total,
                    Pagado = pagado,
                    Saldo = Math.Max(0, total - pagado),
                    MayorDiasAtraso = mayorAtraso,
                    Facturas = g.OrderByDescending(f => f.FechaFactura).ToList()
                };
            })
            .ToList();

        clientesConAdeudo = todosClientes.Count(c => c.Saldo > 0);
        clientesDisponiblesReporte = todosClientes
            .OrderBy(c => c.ClienteNombre)
            .Select(c => new ClienteReporteItem { Id = c.ClienteId, Nombre = c.ClienteNombre })
            .ToList();

        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        ConstruirReportes();

        var lista = todosClientes.AsEnumerable();

        lista = filtro switch
        {
            "pendientes" => lista.Where(c => c.Saldo > 0),
            "pagadas" => lista.Where(c => c.Saldo <= 0),
            _ => lista
        };

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var busq = textoBusqueda.Trim();
            lista = lista.Where(c => c.ClienteNombre.Contains(busq, StringComparison.OrdinalIgnoreCase));
        }

        lista = ordenarPor switch
        {
            "mayor_adeudo" => lista.OrderByDescending(c => c.Saldo),
            "mayor_atraso" => lista.OrderByDescending(c => c.MayorDiasAtraso).ThenByDescending(c => c.Saldo),
            "nombre" => lista.OrderBy(c => c.ClienteNombre),
            _ => lista.OrderByDescending(c => c.Saldo)
        };

        clientesAgrupados = lista.ToList();
    }

    private void ConstruirReportes()
    {
        var clienteIdFiltro = Guid.TryParse(reporteClienteIdTexto, out var clienteId) ? clienteId : Guid.Empty;

        var documentos = todosClientes
            .SelectMany(c => c.Facturas)
            .Where(f => !reporteDesde.Date.Equals(default(DateTime)) ? f.FechaFactura.Date >= reporteDesde.Date : true)
            .Where(f => !reporteHasta.Date.Equals(default(DateTime)) ? f.FechaFactura.Date <= reporteHasta.Date : true)
            .Where(f => clienteIdFiltro == Guid.Empty || f.ClienteId == clienteIdFiltro)
            .ToList();

        reporteAntiguedad = documentos
            .GroupBy(f => new { f.ClienteId, f.ClienteNombre })
            .Select(g => new AntiguedadReporteItem
            {
                ClienteId = g.Key.ClienteId,
                ClienteNombre = g.Key.ClienteNombre,
                Rango0a30 = g.Where(x => ObtenerSaldoDocumento(x) > 0 && x.DiasAtraso <= 30).Sum(ObtenerSaldoDocumento),
                Rango31a60 = g.Where(x => ObtenerSaldoDocumento(x) > 0 && x.DiasAtraso is >= 31 and <= 60).Sum(ObtenerSaldoDocumento),
                Rango61a90 = g.Where(x => ObtenerSaldoDocumento(x) > 0 && x.DiasAtraso is >= 61 and <= 90).Sum(ObtenerSaldoDocumento),
                RangoMas90 = g.Where(x => ObtenerSaldoDocumento(x) > 0 && x.DiasAtraso > 90).Sum(ObtenerSaldoDocumento)
            })
            .Where(x => x.Total > 0)
            .OrderByDescending(x => x.Total)
            .ToList();

        var bucket0a30 = reporteAntiguedad.Sum(x => x.Rango0a30);
        var bucket31a60 = reporteAntiguedad.Sum(x => x.Rango31a60);
        var bucket61a90 = reporteAntiguedad.Sum(x => x.Rango61a90);
        var bucketMas90 = reporteAntiguedad.Sum(x => x.RangoMas90);
        var maximo = new[] { bucket0a30, bucket31a60, bucket61a90, bucketMas90 }.Max();
        if (maximo <= 0) maximo = 1;

        graficaAntiguedad =
        [
            new() { Titulo = "0-30", Monto = bucket0a30, Color = "#10b981", Porcentaje = (double)(bucket0a30 / maximo * 100m) },
            new() { Titulo = "31-60", Monto = bucket31a60, Color = "#f59e0b", Porcentaje = (double)(bucket31a60 / maximo * 100m) },
            new() { Titulo = "61-90", Monto = bucket61a90, Color = "#f97316", Porcentaje = (double)(bucket61a90 / maximo * 100m) },
            new() { Titulo = "+90", Monto = bucketMas90, Color = "#ef4444", Porcentaje = (double)(bucketMas90 / maximo * 100m) }
        ];

        ConstruirEstadoCuenta(documentos, clienteIdFiltro);
        ConstruirReporteMovimientos(documentos, clienteIdFiltro);
    }

    private void ConstruirEstadoCuenta(List<FacturaViewModel> documentos, Guid clienteIdFiltro)
    {
        estadoCuentaMovimientos = [];
        estadoCuentaSaldoInicial = 0;
        estadoCuentaSaldoFinal = 0;

        if (clienteIdFiltro == Guid.Empty)
        {
            estadoCuentaClienteNombre = "Selecciona un cliente";
            return;
        }

        estadoCuentaClienteNombre = clientesDisponiblesReporte.FirstOrDefault(x => x.Id == clienteIdFiltro)?.Nombre ?? "Cliente";

        var movimientos = new List<EstadoCuentaMovimientoItem>();
        decimal saldo = 0;

        foreach (var documento in documentos.Where(x => x.ClienteId == clienteIdFiltro).OrderBy(x => x.FechaFactura).ThenBy(x => x.NumeroFactura))
        {
            var saldoDocumento = ObtenerSaldoDocumento(documento);
            saldo += documento.Total;
            movimientos.Add(new EstadoCuentaMovimientoItem
            {
                Fecha = documento.FechaFactura,
                Tipo = documento.EsNotaEntrega ? "Nota" : "Factura",
                Referencia = documento.NumeroFactura,
                Concepto = documento.NumeroPedido ?? documento.NumeroNota ?? documento.EtiquetaTipoDocumento,
                Cargo = documento.Total,
                Abono = 0,
                Saldo = saldo
            });

            foreach (var pago in pagosPorDocumento.GetValueOrDefault(documento.FacturaId, []).OrderBy(x => x.FechaPago))
            {
                saldo -= pago.ImporteAplicado;
                movimientos.Add(new EstadoCuentaMovimientoItem
                {
                    Fecha = pago.FechaPago,
                    Tipo = "Pago",
                    Referencia = pago.Referencia ?? GetFormaPagoLabel(pago.FormaPagoSat),
                    Concepto = documento.NumeroFactura,
                    Cargo = 0,
                    Abono = pago.ImporteAplicado,
                    Saldo = saldo
                });
            }
        }

        foreach (var cargo in cargosManuales.Where(x => x.ClienteId == clienteIdFiltro).OrderBy(x => x.FechaCargo))
        {
            saldo += cargo.Monto;
            movimientos.Add(new EstadoCuentaMovimientoItem
            {
                Fecha = cargo.FechaCargo,
                Tipo = cargo.Tipo.ToString(),
                Referencia = cargo.Referencia,
                Concepto = cargo.Concepto,
                Cargo = cargo.Monto,
                Abono = 0,
                Saldo = saldo
            });
        }

        estadoCuentaMovimientos = movimientos.OrderBy(x => x.Fecha).ThenBy(x => x.Tipo).ToList();
        estadoCuentaSaldoFinal = estadoCuentaMovimientos.LastOrDefault()?.Saldo ?? 0;
    }

    private void ConstruirReporteMovimientos(List<FacturaViewModel> documentos, Guid clienteIdFiltro)
    {
        var movimientos = new List<MovimientoReporteItem>();
        var movimientosPorCliente = new Dictionary<Guid, decimal>();

        foreach (var documento in documentos
            .Where(x => clienteIdFiltro == Guid.Empty || x.ClienteId == clienteIdFiltro)
            .OrderBy(x => x.FechaFactura)
            .ThenBy(x => x.ClienteNombre)
            .ThenBy(x => x.NumeroFactura))
        {
            movimientosPorCliente.TryAdd(documento.ClienteId, 0m);
            movimientosPorCliente[documento.ClienteId] += documento.Total;

            movimientos.Add(new MovimientoReporteItem
            {
                Fecha = documento.FechaFactura,
                ClienteNombre = documento.ClienteNombre,
                Tipo = documento.EsNotaEntrega ? "Cargo nota" : "Cargo factura",
                Referencia = documento.NumeroFactura,
                Concepto = ConstruirConceptoMovimiento(documento),
                Cargo = documento.Total,
                Abono = 0,
                Saldo = movimientosPorCliente[documento.ClienteId]
            });

            foreach (var pago in pagosPorDocumento.GetValueOrDefault(documento.FacturaId, []).OrderBy(x => x.FechaPago))
            {
                movimientosPorCliente[documento.ClienteId] -= pago.ImporteAplicado;

                movimientos.Add(new MovimientoReporteItem
                {
                    Fecha = pago.FechaPago,
                    ClienteNombre = documento.ClienteNombre,
                    Tipo = "Cobro",
                    Referencia = pago.Referencia ?? GetFormaPagoLabel(pago.FormaPagoSat),
                    Concepto = string.IsNullOrWhiteSpace(pago.Notas)
                        ? $"Cobro aplicado a {documento.NumeroFactura}"
                        : pago.Notas!,
                    Cargo = 0,
                    Abono = pago.ImporteAplicado,
                    Saldo = movimientosPorCliente[documento.ClienteId]
                });
            }
        }

        foreach (var cargo in cargosManuales
            .Where(x => clienteIdFiltro == Guid.Empty || x.ClienteId == clienteIdFiltro)
            .OrderBy(x => x.FechaCargo)
            .ThenBy(x => x.Cliente.RazonSocial))
        {
            movimientosPorCliente.TryAdd(cargo.ClienteId, 0m);
            movimientosPorCliente[cargo.ClienteId] += cargo.Monto;

            movimientos.Add(new MovimientoReporteItem
            {
                Fecha = cargo.FechaCargo,
                ClienteNombre = cargo.Cliente.RazonSocial,
                Tipo = cargo.Tipo.ToString(),
                Referencia = cargo.Referencia,
                Concepto = cargo.Concepto,
                Cargo = cargo.Monto,
                Abono = 0,
                Saldo = movimientosPorCliente[cargo.ClienteId]
            });
        }

        reporteMovimientos = movimientos
            .OrderBy(x => x.Fecha)
            .ThenBy(x => x.ClienteNombre)
            .ThenBy(x => x.Tipo)
            .ToList();
    }

    private static string ConstruirConceptoMovimiento(FacturaViewModel documento)
    {
        var conceptoBase = documento.NumeroPedido ?? documento.NumeroNota ?? documento.EtiquetaTipoDocumento;
        if (!string.IsNullOrWhiteSpace(conceptoBase) && conceptoBase.Contains("garant", StringComparison.OrdinalIgnoreCase))
            return conceptoBase;

        return conceptoBase;
    }

    private decimal ObtenerSaldoDocumento(FacturaViewModel documento)
        => Math.Max(0, documento.Total - pagosPorDocumento.GetValueOrDefault(documento.FacturaId, []).Sum(x => x.ImporteAplicado));

