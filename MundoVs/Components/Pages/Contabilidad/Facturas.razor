    private static string? LimpiarTexto(string? valor)
        => string.IsNullOrWhiteSpace(valor) ? null : valor.Trim();

    private static string ObtenerClaseEstatus(FacturaEstatus estatus) => estatus switch
    {
        FacturaEstatus.Timbrado => "bg-success",
        FacturaEstatus.PagadoTotal => "bg-primary",
        FacturaEstatus.PagadoParcial => "bg-warning text-dark",
        FacturaEstatus.ErrorTimbrado => "bg-danger",
        FacturaEstatus.Cancelado => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string ObtenerResumenNotasFactura(Factura factura)
    {
        var notas = factura.NotasEntregaRelacionadas
            .Where(r => r.IsActive)
            .Select(r => r.NotaEntrega.NumeroNota)
            .Distinct()
            .ToList();

        if (notas.Count == 0 && factura.NotaEntrega != null)
        {
            return factura.NotaEntrega.NumeroNota;
        }

        return notas.Count == 0 ? "—" : string.Join(", ", notas);
    }

    private static bool PuedeEmitirse(Factura factura)
        => factura.Estatus is FacturaEstatus.Borrador or FacturaEstatus.PendienteTimbrado or FacturaEstatus.ErrorTimbrado;

