@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool cargando = true;
    private string companyName = "Zenith";
    private string companySlogan = "Plataforma operativa empresarial";
    private string companyGiro = "General";
    private string? companyLogo = "/branding/zenith-logo.svg";
    private Guid empresaId;
    private bool esSuperAdmin;
    private ClaimsPrincipal user = new(new ClaimsIdentity());

    // Módulos
    private bool moduloCalzado;
    private bool moduloSerigrafia = true;
    private int modulosActivos;

    // Totales usuario normal
    private int totalClientes;
    private int totalProductos;

    // Totales SuperAdmin
    private int totalEmpresas;
    private int totalUsuarios;
    private int totalCapacidades;
    private int totalPlanes;
    private int empresasActivas;
    private int empresasDemo;
    private int empresasSuspendidas;
    private int empresasCanceladas;
    private int empresasOperativas;
    private int empresasSinAdmin;
    private int empresasConSuscripcionVigente;
    private int empresasPendientesAtencion;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            user = state.User;
            esSuperAdmin = string.Equals(user.FindFirst(ClaimTypes.Role)?.Value, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
            _ = Guid.TryParse(user.FindFirst("EmpresaId")?.Value, out empresaId);
        }

        await CargarBrandingAsync();

        var giro = await AppConfigRepository.GetValueAsync("GiroEmpresa");
        if (!string.IsNullOrEmpty(giro)) companyGiro = giro;

        if (esSuperAdmin)
        {
            await CargarEstadisticasSuperAdmin();
        }
        else
        {
            await CargarModulos();
            await CargarEstadisticas();
            ModuloState.OnChange += OnModuloStateChanged;
        }

        cargando = false;
    }

    private async Task CargarBrandingAsync()
    {
        var configuredName = await AppConfigRepository.GetValueAsync("CompanyName");
        var configuredSlogan = await AppConfigRepository.GetValueAsync("CompanySlogan");

        await using var context = await ContextFactory.CreateDbContextAsync();
        Empresa? empresaActual = null;

        if (empresaId != Guid.Empty)
        {
            empresaActual = await context.Empresas
                .AsNoTracking()
                .FirstOrDefaultAsync(e => e.Id == empresaId && e.IsActive);
        }

        if (empresaActual is null && esSuperAdmin)
        {
            return;
        }

        var nombreEmpresa = string.IsNullOrWhiteSpace(empresaActual?.NombreComercial)
            ? empresaActual?.RazonSocial
            : empresaActual.NombreComercial;

        if (!string.IsNullOrWhiteSpace(nombreEmpresa))
        {
            companyName = nombreEmpresa.Trim();
        }
        else if (EsBrandingValido(configuredName))
        {
            companyName = configuredName.Trim();
        }

        if (!string.IsNullOrWhiteSpace(empresaActual?.Slogan))
        {
            companySlogan = empresaActual.Slogan.Trim();
        }
        else if (EsBrandingValido(configuredSlogan))
        {
            companySlogan = configuredSlogan.Trim();
        }
    }

    private bool EsBrandingValido(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return false;

        var normalized = value.Trim();
        return !string.Equals(normalized, "MundoVs", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, "Empresa", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, user.Identity?.Name, StringComparison.OrdinalIgnoreCase)
            && !string.Equals(normalized, user.FindFirst(ClaimTypes.Role)?.Value, StringComparison.OrdinalIgnoreCase);
    }

    private async Task CargarModulos()
    {
        moduloCalzado = string.Equals(await AppConfigRepository.GetValueAsync("Modulo:Calzado"), "true", StringComparison.OrdinalIgnoreCase);
        moduloSerigrafia = !string.Equals(await AppConfigRepository.GetValueAsync("Modulo:Serigrafia"), "false", StringComparison.OrdinalIgnoreCase);
        modulosActivos = (moduloCalzado ? 1 : 0) + (moduloSerigrafia ? 1 : 0);
    }

    private void OnModuloStateChanged()
    {
        moduloCalzado = ModuloState.Calzado;
        moduloSerigrafia = ModuloState.Serigrafia;
        modulosActivos = (moduloCalzado ? 1 : 0) + (moduloSerigrafia ? 1 : 0);
        InvokeAsync(StateHasChanged);
    }

    private async Task CargarEstadisticas()
    {
        if (Tiene("clientes.ver"))
        {
            var clientes = await ClienteRepository.GetAllAsync();
            totalClientes = clientes.Count();
        }

        if (Tiene("productos.ver"))
        {
            var productos = await ProductoRepository.GetAllAsync();
            totalProductos = productos.Count();
        }
    }

    private async Task CargarEstadisticasSuperAdmin()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();

        var empresas = await context.Empresas
            .IgnoreQueryFilters()
            .AsNoTracking()
            .ToListAsync();

        var adminsEmpresa = await context.Usuarios
            .IgnoreQueryFilters()
            .Include(u => u.TipoUsuario)
            .AsNoTracking()
            .Where(u => u.TipoUsuario.Nombre == "Administrador")
            .Select(u => u.EmpresaId)
            .Distinct()
            .ToListAsync();

        var hoy = DateTime.Today;
        var suscripcionesVigentes = await context.SuscripcionesEmpresa
            .IgnoreQueryFilters()
            .AsNoTracking()
            .Where(s => s.Estado == EstadoSuscripcion.Activa
                || (s.Estado == EstadoSuscripcion.Trial && (!s.FechaFin.HasValue || s.FechaFin.Value.Date >= hoy)))
            .Select(s => s.EmpresaId)
            .Distinct()
            .ToListAsync();

        totalEmpresas = empresas.Count;
        empresasActivas = empresas.Count(e => e.Estado == EmpresaEstado.Activa && e.IsActive && !e.IsSuspended);
        empresasDemo = empresas.Count(e => e.Estado == EmpresaEstado.Demo);
        empresasSuspendidas = empresas.Count(e => e.Estado == EmpresaEstado.Suspendida || e.IsSuspended);
        empresasCanceladas = empresas.Count(e => e.Estado == EmpresaEstado.Cancelada);
        empresasOperativas = empresas.Count(e => e.IsActive && e.Estado != EmpresaEstado.Cancelada);
        empresasSinAdmin = empresas.Count(e => !adminsEmpresa.Contains(e.Id));
        empresasConSuscripcionVigente = suscripcionesVigentes.Count;
        empresasPendientesAtencion = empresasSinAdmin + empresasSuspendidas + empresasCanceladas;

        totalUsuarios = await context.Usuarios.IgnoreQueryFilters().AsNoTracking().CountAsync();
        totalCapacidades = await context.Capacidades.IgnoreQueryFilters().AsNoTracking().CountAsync();
        totalPlanes = await context.Planes.IgnoreQueryFilters().AsNoTracking().CountAsync();
    }

    private bool Tiene(string capacidad)
        => user.HasClaim("Capacidad", capacidad);

    public void Dispose()
    {
        if (!esSuperAdmin)
            ModuloState.OnChange -= OnModuloStateChanged;
    }
}
