    private async Task OnFechaTallaProceso(PedidoSerigrafiaTallaProceso seg, DateTime? value)
    {
        if (!PuedeEditarProcesosProduccion())
        {
            return;
        }

        await _opLock.WaitAsync();
        try
        {
            seg.FechaPaso = value;
            seg.UpdatedAt = DateTime.UtcNow;
