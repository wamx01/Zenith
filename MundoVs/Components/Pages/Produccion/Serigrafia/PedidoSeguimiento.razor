@page "/pedidos/{PedidoId:guid}/seguimiento"
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Inventario
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject IPedidoRepository PedidoRepository
@inject CrmDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppConfigRepository AppConfigRepository
@inject INotaEntregaPdfService NotaEntregaPdfService
@rendermode InteractiveServer

<PageTitle>Seguimiento de Pedido</PageTitle>

<div class="sg-page">
    @if (pedido == null)
    {
        <div class="d-flex align-items-center justify-content-center" style="height:60vh">
            <div class="spinner-border text-primary me-2" role="status" style="width:1.6rem;height:1.6rem;"></div>
            <span class="text-muted">Cargando...</span>
        </div>
    }
    else
    {
        <!-- ?? Header ?? -->
        <div class="sg-header mb-3">
            <div class="sg-header-left">
                <a class="sg-back" href="@(pedidoSerigrafia != null ? "/serigrafia/pedidos" : "/pedidos")">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <div class="sg-title">
                        <i class="bi bi-clipboard-data me-2"></i>@pedido.NumeroPedido
                        <span class="sg-cliente">@pedido.Cliente?.RazonSocial</span>
                    </div>
                    <div class="sg-meta">
                        <span><i class="bi bi-calendar3 me-1"></i>Pedido: @pedido.FechaPedido.ToString("dd/MM/yyyy")</span>
                        @if (pedidoSerigrafia?.PedidoDetalle?.CotizacionSerigrafia != null)
                        {
                            <span><i class="bi bi-calculator me-1"></i>@ObtenerEtiquetaCotizacion(pedidoSerigrafia.PedidoDetalle.CotizacionSerigrafia)</span>
                        }
                        @if (pedidoSerigrafia?.FechaEntregaReal.HasValue == true)
                        {
                            <span>
                                <i class="bi bi-calendar-check me-1"></i>Entrega: @pedidoSerigrafia.FechaEntregaReal.Value.ToString("dd/MM/yyyy")
                            </span>
                        }
                        <span class="sg-estado-badge sg-estado-@pedido.Estado.ToString().ToLower()">@pedido.Estado</span>
                    </div>
                </div>
            </div>
            @if (pedidoSerigrafia != null)
            {
                var tallasTotal = pedidoSerigrafia.Tallas.Sum(t => t.Cantidad);
                var procesos2 = pedidoSerigrafia.TiposProceso.Select(tp => tp.TipoProceso).OrderBy(p => p.Orden).ToList();
                var tallasListas = pedidoSerigrafia.Tallas.Count(t => EsTallaCompletada(t.Id, procesos2));
                var pct = pedidoSerigrafia.Tallas.Any() ? (int)Math.Round((double)tallasListas / pedidoSerigrafia.Tallas.Count * 100) : 0;
                <div class="sg-progress-block">
                    <div class="sg-progress-label">
                        <span>@tallasListas / @pedidoSerigrafia.Tallas.Count tallas completas</span>
                        <span class="fw-bold">@pct%</span>
                    </div>
                    <div class="sg-progress-bar-wrap">
                        <div class="sg-progress-bar" style="width:@pct%"></div>
                    </div>
                    <div class="sg-progress-sub">@tallasTotal piezas totales · @pedidoSerigrafia.TiposProceso.Count procesos</div>
                </div>
            }
        </div>

        @if (ObtenerObservacionOperativaPedido() is { Length: > 0 } observacionOperativa)
        {
            <div class="alert alert-info py-2 mb-3">
                <i class="bi bi-info-circle me-1"></i>@observacionOperativa
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorFg))
        {
            <div class="alert alert-danger py-2 mb-3">@errorFg</div>
        }
        @if (!string.IsNullOrWhiteSpace(okFg))
        {
            <div class="alert alert-success py-2 mb-3">@okFg</div>
        }

        @if (conceptosPedido.Any())
        {
            var conceptosCompletados = conceptosPedido.Count(c => c.Completado);
            var conceptosPct = conceptosPedido.Count > 0 ? (int)Math.Round((double)conceptosCompletados / conceptosPedido.Count * 100) : 0;
            <div class="sg-card mb-3">
                <div class="sg-card-header">
                    <span><i class="bi bi-list-check me-2"></i>Servicios del pedido</span>
                    <span class="sg-card-sub">@conceptosCompletados / @conceptosPedido.Count completados</span>
                </div>
                <div class="sg-servicios-body">
                    <div class="sg-progress-label mb-2">
                        <span>Avance servicios</span>
                        <span class="fw-bold">@conceptosPct%</span>
                    </div>
                    <div class="sg-progress-bar-wrap mb-3">
                        <div class="sg-progress-bar" style="width:@conceptosPct%"></div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-center">Completado</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var concepto in conceptosPedido.OrderBy(c => c.CreatedAt))
                                {
                                    <tr>
                                        <td>@concepto.Tipo</td>
                                        <td>@concepto.Descripcion</td>
                                        <td class="text-center">@concepto.Cantidad</td>
                                        <td class="text-end">@concepto.PrecioUnitario.ToString("C2")</td>
                                        <td class="text-end fw-semibold">@concepto.Total.ToString("C2")</td>
                                        <td class="text-center">
                                            <InputCheckbox Value="concepto.Completado"
                                                           ValueChanged="async (bool value) => await OnConceptoCompletadoChanged(concepto, value)"
                                                           ValueExpression="() => concepto.Completado" />
                                        </td>
                                        <td>
                                            <InputDate TValue="DateTime?" class="form-control form-control-sm sg-servicio-date"
                                                       Value="concepto.FechaCompletado"
                                                       ValueChanged="async (DateTime? value) => await OnConceptoFechaChanged(concepto, value)"
                                                       ValueExpression="() => concepto.FechaCompletado" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (ObtenerSkusPendientesFinishedGoods().ToList() is { Count: > 0 } skusPendientesFg)
        {
            <div class="sg-card mb-3">
                <div class="sg-card-header">
                    <span><i class="bi bi-box-seam me-2"></i>SKU listos para finished goods</span>
                    <span class="sg-card-sub">Producción completa pendiente de ingreso</span>
                </div>
                <div class="sg-servicios-body">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                        <div class="text-muted small">Cuando un `SKU` completó todos sus procesos, puedes ingresarlo a `finished goods` sin registrar todavía una entrega.</div>
                        @if (PuedeIngresarFinishedGoods())
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="IngresarTodosLosSkusPendientesAFinishedGoodsAsync" disabled="@guardandoFg">
                                <i class="bi bi-box-arrow-in-down me-1"></i>Ingresar todos
                            </button>
                        }
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>SKU</th>
                                    <th>Talla</th>
                                    <th>Color</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-end">Precio unitario</th>
                                    <th>Estado</th>
                                    <th class="text-end">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var skuFg in skusPendientesFg)
                                {
                                    <tr>
                                        <td class="fw-semibold">@skuFg.Sku</td>
                                        <td>@skuFg.Talla</td>
                                        <td>@(string.IsNullOrWhiteSpace(skuFg.Color) ? "—" : skuFg.Color)</td>
                                        <td class="text-center">@skuFg.Cantidad.ToString("0.##")</td>
                                        <td class="text-end">@skuFg.PrecioUnitario.ToString("C2")</td>
                                        <td><span class="badge bg-success-subtle text-success-emphasis border">Completo</span></td>
                                        <td class="text-end">
                                            @if (PuedeIngresarFinishedGoods())
                                            {
                                                <button type="button" class="btn btn-sm btn-primary" @onclick="() => IngresarDetalleTallaAFinishedGoodsAsync(skuFg.PedidoDetalleTallaId)" disabled="@guardandoFg">
                                                    <i class="bi bi-plus-square me-1"></i>Ingresar a FG
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Sin permiso</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (detalleTallasPedido.Any())
        {
            <div class="sg-card mb-3">
                <div class="sg-card-header">
                    <span><i class="bi bi-tags me-2"></i>Snapshot comercial por talla</span>
                    <span class="sg-card-sub">Precio congelado al momento de vender</span>
                </div>
                <div class="sg-servicios-body">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Talla</th>
                                    <th>SKU</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-end">% variación</th>
                                    <th class="text-end">Precio unitario</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var talla in detalleTallasPedido.OrderBy(t => t.Orden).ThenBy(t => t.Talla))
                                {
                                    <tr>
                                        <td class="fw-semibold">@talla.Talla</td>
                                        <td>@(talla.ProductoVariante?.Sku ?? "—")</td>
                                        <td class="text-center">@talla.Cantidad.ToString("0.##")</td>
                                        <td class="text-end">@talla.PorcentajeVariacion.ToString("N2")%</td>
                                        <td class="text-end">@talla.PrecioUnitario.ToString("C2")</td>
                                        <td class="text-end fw-semibold">@talla.Total.ToString("C2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" class="text-end fw-semibold">Subtotal producto</td>
                                    <td class="text-end fw-bold">@detalleTallasPedido.Sum(t => t.Total).ToString("C2")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Proceso compacto por talla y operación -->
        @if (pedidoSerigrafia != null && pedidoSerigrafia.Tallas.Any() && pedidoSerigrafia.TiposProceso.Any())
        {
            var procesos = pedidoSerigrafia.TiposProceso.Select(tp => tp.TipoProceso).OrderBy(p => p.Orden).ToList();
            <div class="sg-card mb-3">
                <div class="sg-card-header">
                    <span><i class="bi bi-table me-2"></i>Proceso por talla y operación</span>
                    <span class="sg-card-sub">@pedidoSerigrafia.Estilo @(string.IsNullOrEmpty(pedidoSerigrafia.CombinacionColor) ? "" : "· " + pedidoSerigrafia.CombinacionColor)</span>
                </div>
                @if (!PuedeEditarProcesosProduccion())
                {
                    <div class="alert alert-warning py-2 m-3 mb-0">
                        <i class="bi bi-lock me-1"></i>La producción está cerrada para edición. Solo un usuario con la capacidad especial puede reabrir checks y fechas de proceso.
                    </div>
                }
                <div class="sg-matrix-wrap">
                    <table class="sg-matrix">
                        <thead>
                            <tr>
                                <th class="sg-th-talla">Talla</th>
                                @foreach (var proc in procesos)
                                {
                                    <th class="sg-th-proc">@proc?.Nombre</th>
                                }
                                <th class="sg-th-pct">Avance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var talla in pedidoSerigrafia.Tallas.OrderBy(t => t.Talla))
                            {
                                var tallaCompleta = EsTallaCompletada(talla.Id, procesos);
                                var compCount = procesos.Count(p => seguimientoTallaProcesos.Any(s => s.PedidoSerigrafiaTallaId == talla.Id && s.TipoProcesoId == p!.Id && s.Completado));
                                var tallaPct = procesos.Count > 0 ? (int)Math.Round((double)compCount / procesos.Count * 100) : 0;
                                <tr class="@(tallaCompleta ? "sg-row-done" : compCount > 0 ? "sg-row-partial" : "")">
                                    <td class="sg-td-talla">
                                        <span class="sg-talla-num">#@talla.Talla</span>
                                        <span class="sg-talla-qty">@talla.Cantidad pz</span>
                                    </td>
                                    @foreach (var proc in procesos)
                                    {
                                        var seg = seguimientoTallaProcesos.FirstOrDefault(s => s.PedidoSerigrafiaTallaId == talla.Id && s.TipoProcesoId == proc!.Id);
                                        var cantidadAsignada = seg != null ? ObtenerCantidadAsignada(seg.Id) : 0;
                                        var importeAsignado = seg != null ? ObtenerImporteAsignado(seg.Id) : 0m;
                                        var personasAsignadas = seg != null ? ObtenerDestajos(seg.Id).Count(d => d.IsActive) : 0;
                                        <td class="sg-td-proc @(seg?.Completado == true ? "sg-cell-done" : cantidadAsignada > 0 ? "sg-cell-wip" : "")">
                                            @if (seg != null)
                                            {
                                                var pctPz = talla.Cantidad > 0 ? Math.Min(100, (int)Math.Round((double)cantidadAsignada / talla.Cantidad * 100)) : 0;
                                                <div class="sg-op @(seg.Completado ? "sg-op--done" : cantidadAsignada > 0 ? "sg-op--wip" : "sg-op--idle")"
                                                     @onclick="() => AbrirModalDestajo(seg, talla.Talla, proc?.Nombre)"
                                                     role="button" tabindex="0">
                                                    <div class="sg-op__head">
                                                        <button class="sg-chk @(seg.Completado ? "sg-chk--on" : "")"
                                                                @onclick="async () => await OnCheckTallaProcesoClickAsync(seg, talla.Talla, proc?.Nombre)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@(!PuedeEditarProcesosProduccion())"
                                                                title="@(seg.Completado ? "Marcar pendiente" : "Marcar listo")">
                                                            <i class="bi @(seg.Completado ? "bi-check-circle-fill" : "bi-circle")"></i>
                                                        </button>
                                                        <div class="sg-op__bar">
                                                            <div class="sg-op__bar-fill @(pctPz >= 100 ? "is-full" : "")" style="width:@pctPz%"></div>
                                                        </div>
                                                        <span class="sg-op__count @(cantidadAsignada >= talla.Cantidad ? "is-ok" : "")">@cantidadAsignada/@talla.Cantidad</span>
                                                    </div>
                                                    <div class="sg-op__meta">
                                                        <span class="sg-op__money">@importeAsignado.ToString("C2")</span>
                                                        <div class="sg-op__date-wrap" @onclick:stopPropagation="true">
                                                            <InputDate TValue="DateTime?" class="sg-op__date"
                                                                       Value="seg.FechaPaso"
                                                                       ValueChanged="async (DateTime? dt) => await OnFechaTallaProceso(seg, dt)"
                                                                       ValueExpression="() => seg.FechaPaso"
                                                                       disabled="@(!PuedeEditarProcesosProduccion())" />
                                                        </div>
                                                    </div>
                                                    <div class="sg-op__foot">
                                                        <span class="sg-op__people @(personasAsignadas > 0 ? "has-data" : "")">
                                                            <i class="bi @(personasAsignadas > 0 ? "bi-people-fill" : "bi-person-plus")"></i>
                                                            @if (personasAsignadas > 0)
                                                            {
                                                                <span class="sg-op__badge">@personasAsignadas</span>
                                                            }
                                                        </span>
                                                        <span class="sg-op__cta">Detalle <i class="bi bi-chevron-right"></i></span>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="sg-na">—</span>
                                            }
                                        </td>
                                    }
                                    <td class="sg-td-pct">
                                        <div class="sg-mini-bar-wrap">
                                            <div class="sg-mini-bar" style="width:@tallaPct%"></div>
                                        </div>
                                        <span class="sg-mini-pct">@compCount/@procesos.Count</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (modalConfirmarCheckAbierto && confirmacionSeguimiento is not null)
        {
            <div class="sg-modal-backdrop" @onclick="CerrarModalConfirmacionCheck"></div>
            <div class="sg-modal-shell">
                <div class="sg-modal-card" style="width:min(460px,100%);max-height:none;">
                    <div class="sg-modal-header">
                        <div>
                            <div class="sg-modal-title">Confirmar completado</div>
                            <div class="sg-modal-subtitle">Talla @confirmacionTallaNombre · @confirmacionProcesoNombre</div>
                        </div>
                        <button type="button" class="sg-modal-close" @onclick="CerrarModalConfirmacionCheck">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    <div class="sg-modal-body">
                        <div class="alert alert-info py-2 mb-3">
                            <i class="bi bi-question-circle me-1"></i>¿Deseas agregar empleados a este proceso?
                        </div>
                        <div class="small text-muted mb-3">
                            Si eliges <strong>No</strong>, el sistema completará automáticamente la cantidad pendiente. Si eliges <strong>Sí</strong>, podrás capturar participantes y el check se marcará solo cuando la cantidad asignada cubra el total.
                        </div>
                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CerrarModalConfirmacionCheck">Cancelar</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="ConfirmarCheckConEmpleadosAsync">Sí, agregar empleados</button>
                            <button type="button" class="btn btn-primary btn-sm" @onclick="ConfirmarCheckSinEmpleadosAsync">No, completar cantidad</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (modalConfirmarIngresoFgAbierto && confirmacionIngresoFgItem is not null)
        {
            <div class="sg-modal-backdrop" @onclick="PosponerIngresoFinishedGoods"></div>
            <div class="sg-modal-shell">
                <div class="sg-modal-card" style="width:min(460px,100%);max-height:none;">
                    <div class="sg-modal-header">
                        <div>
                            <div class="sg-modal-title">SKU listo para finished goods</div>
                            <div class="sg-modal-subtitle">@confirmacionIngresoFgItem.Sku · Talla @confirmacionIngresoFgItem.Talla</div>
                        </div>
                        <button type="button" class="sg-modal-close" @onclick="PosponerIngresoFinishedGoods">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    <div class="sg-modal-body">
                        <div class="alert alert-success py-2 mb-3">
                            <i class="bi bi-box-seam me-1"></i>El `SKU` completó todos sus procesos. ¿Deseas ingresarlo ahora a `finished goods`?
                        </div>
                        <div class="sg-modal-summary mb-3">
                            <div class="sg-modal-kpi">
                                <span class="sg-modal-kpi-label">Cliente</span>
                                <strong>@(pedido?.Cliente?.RazonSocial ?? "—")</strong>
                            </div>
                            <div class="sg-modal-kpi">
                                <span class="sg-modal-kpi-label">Color</span>
                                <strong>@(string.IsNullOrWhiteSpace(confirmacionIngresoFgItem.Color) ? "—" : confirmacionIngresoFgItem.Color)</strong>
                            </div>
                            <div class="sg-modal-kpi">
                                <span class="sg-modal-kpi-label">Cantidad</span>
                                <strong>@confirmacionIngresoFgItem.Cantidad.ToString("0.##") pz</strong>
                            </div>
                        </div>
                        @if (confirmacionIngresoFgEsUltimoSku)
                        {
                            <div class="alert alert-info py-2 mb-3">
                                <i class="bi bi-stars me-1"></i>Este es el último `SKU` pendiente del pedido. Al ingresarlo a `FG`, la producción del pedido quedará completamente reflejada en inventario.
                            </div>
                        }
                        <div class="small text-muted mb-3">
                            Si eliges <strong>Ahora</strong>, se registrará el ingreso inmediato a `FG`. Si eliges <strong>Después</strong>, quedará en la lista de pendientes.
                        </div>
                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="PosponerIngresoFinishedGoods">Después</button>
                            <button type="button" class="btn btn-primary btn-sm" @onclick="ConfirmarIngresoFinishedGoodsDetectadoAsync" disabled="@guardandoFg">
                                <i class="bi bi-box-arrow-in-down me-1"></i>Ingresar ahora
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (modalDestajoAbierto && modalSeguimiento is not null)
        {
            var segModal = modalSeguimiento;
            var destajosModal = ObtenerDestajos(segModal.Id);
            var destajosModalOrdenados = OrdenarDestajos(destajosModal).ToList();

            <div class="sg-modal-backdrop" @onclick="CerrarModalDestajo"></div>
            <div class="sg-modal-shell">
                <div class="sg-modal-card">
                    <div class="sg-modal-header">
                        <div>
                            <div class="sg-modal-title">Participantes del proceso</div>
                            <div class="sg-modal-subtitle">Talla @modalTallaNombre · @modalProcesoNombre</div>
                        </div>
                        <button type="button" class="sg-modal-close" @onclick="CerrarModalDestajo">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <div class="sg-modal-body">
                        @if (!string.IsNullOrWhiteSpace(modalDestajoError))
                        {
                            <div class="alert alert-warning py-2 mb-3">@modalDestajoError</div>
                        }

                        <div class="sg-modal-summary">
                            <div class="sg-modal-kpi">
                                <span class="sg-modal-kpi-label">Planeado</span>
                                <strong>@ObtenerCantidadTallaSeguimiento(segModal) pz</strong>
                            </div>
                            <div class="sg-modal-kpi @(ObtenerCantidadAsignada(segModal.Id) >= ObtenerCantidadTallaSeguimiento(segModal) ? "is-ok" : "is-warn")">
                                <span class="sg-modal-kpi-label">Asignado</span>
                                <strong>@ObtenerCantidadAsignada(segModal.Id) pz</strong>
                            </div>
                            <div class="sg-modal-kpi @(ObtenerCantidadDisponible(segModal) == 0 ? "is-ok" : string.Empty)">
                                <span class="sg-modal-kpi-label">Disponible</span>
                                <strong>@ObtenerCantidadDisponible(segModal) pz</strong>
                            </div>
                            <div class="sg-modal-kpi">
                                <span class="sg-modal-kpi-label">Personas</span>
                                <strong>@destajosModalOrdenados.Count(d => d.IsActive)</strong>
                            </div>
                            <div class="sg-modal-kpi sg-modal-kpi-money">
                                <span class="sg-modal-kpi-label">Importe</span>
                                <strong>@ObtenerImporteAsignado(segModal.Id).ToString("C2")</strong>
                            </div>
                        </div>

                        <div class="sg-destajo-list sg-destajo-list-modal">
                            @if (destajosModalOrdenados.Any())
                            {
                                @foreach (var destajo in destajosModalOrdenados)
                                {
                                    var onEmpleadoChanged = CrearCambioEmpleadoCallback(destajo);
                                    var onGuardarDestajo = CrearGuardarDestajoCallback(segModal, destajo);
                                    var onEliminarDestajo = CrearEliminarDestajoCallback(segModal, destajo);
                                    <div class="sg-destajo-item sg-destajo-item-modal">
                                        <select class="sg-empleado-input" value="@ObtenerEmpleadoValue(destajo)" @onchange="onEmpleadoChanged">
                                            <option value="">Selecciona empleado...</option>
                                            @foreach (var empleado in empleadosActivos)
                                            {
                                                <option value="@empleado.Id">@empleado.NombreCompleto</option>
                                            }
                                        </select>
                                        <div class="sg-destajo-row">
                                            <div class="sg-campo-num">
                                                <span class="sg-mini-label">Pzs</span>
                                                <InputNumber class="sg-destajo-input" @bind-Value="destajo.CantidadProcesada" @bind-Value:after="() => OnCantidadDestajoCapturada(segModal, destajo)" />
                                            </div>
                                            <div class="sg-campo-num">
                                                <span class="sg-mini-label">Tar</span>
                                                <InputNumber class="sg-destajo-input sg-destajo-input-compact-money" @bind-Value="destajo.TarifaUnitario" />
                                            </div>
                                            <div class="sg-campo-num">
                                                <span class="sg-mini-label">Min</span>
                                                <InputNumber class="sg-destajo-input" @bind-Value="destajo.TiempoMinutos" />
                                            </div>
                                            <span class="sg-destajo-total">@CalcularImporteDestajo(destajo).ToString("C2")</span>
                                            <div class="sg-destajo-buttons">
                                                <button type="button" class="sg-destajo-save" title="Guardar" @onclick="onGuardarDestajo"><i class="bi bi-save"></i></button>
                                                <button type="button" class="sg-destajo-remove" title="Quitar" @onclick="onEliminarDestajo"><i class="bi bi-trash"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="sg-empty-split">Aún no hay participantes registrados para esta operación.</div>
                            }
                        </div>
                    </div>

                    <div class="sg-modal-footer">
                        <button type="button" class="sg-destajo-add sg-destajo-add-modal" @onclick="() => AgregarDestajoDesdeModal(segModal)">
                            <i class="bi bi-person-plus me-1"></i>Agregar empleado
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CerrarModalDestajo">Cerrar</button>
                    </div>
                </div>
            </div>
        }

        <div class="sg-card">
            <div class="sg-card-header">
                <span><i class="bi bi-truck me-2"></i>Entregas parciales y notas</span>
                <span class="sg-card-sub">Registrar parcialidades desde el pedido</span>
            </div>
            <div class="sg-entrega-body">
                <div class="sg-entrega-resumen mb-3">
                    <div class="sg-resumen-kpi">
                        <span class="sg-resumen-label">Piezas pedido</span>
                        <strong>@piezasPedidoTotal</strong>
                    </div>
                    <div class="sg-resumen-kpi sg-resumen-kpi-ok">
                        <span class="sg-resumen-label">Entregadas</span>
                        <strong>@piezasEntregadas</strong>
                    </div>
                    <div class="sg-resumen-kpi sg-resumen-kpi-warn">
                        <span class="sg-resumen-label">Pendientes</span>
                        <strong>@piezasPendientes</strong>
                    </div>
                    <div class="sg-resumen-kpi">
                        <span class="sg-resumen-label">Notas</span>
                        <strong>@notasEntrega.Count</strong>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorNota))
                {
                    <div class="alert alert-danger py-2">@errorNota</div>
                }
                @if (!string.IsNullOrWhiteSpace(okNota))
                {
                    <div class="alert alert-success py-2">@okNota</div>
                }

                <div class="row g-3 align-items-end mb-3">
                    <div class="col-md-3">
                        <label class="sg-label">Fecha de nota</label>
                        <InputDate TValue="DateTime" class="form-control sg-input" @bind-Value="fechaNotaEntrega" />
                    </div>
                    <div class="col-md-4">
                        <label class="sg-label">Observaciones</label>
                        <input type="text" class="form-control sg-input" @bind="observacionesNotaEntrega" placeholder="Chofer, ruta, parcialidad, etc." />
                    </div>
                    <div class="col-md-2">
                        <div class="form-check form-switch mt-4">
                            <InputCheckbox class="form-check-input" @bind-Value="noRequiereFacturaNota" />
                            <label class="form-check-label">No requiere factura</label>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-check form-switch mt-4">
                            <InputCheckbox class="form-check-input" @bind-Value="aplicaIvaNota" />
                            <label class="form-check-label">Aplica IVA</label>
                        </div>
                    </div>
                    <div class="col-md-2 d-grid">
                            <button class="sg-btn-save" @onclick="CrearNotaEntregaAsync" disabled="@(guardandoNota || piezasPendientes <= 0)">
                                <i class="bi bi-file-earmark-plus me-1"></i>Generar nota de entrega
                        </button>
                    </div>
                </div>

                @if (corridaPedido.Any())
                {
                    <div class="border rounded bg-white p-3 mb-3">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                            <div>
                                <div class="sg-label mb-0">Entrega por talla</div>
                                <div class="text-muted" style="font-size:.72rem">Captura la parcialidad real por talla. Total a entregar: <strong>@cantidadNotaEntrega</strong></div>
                                @if (!PuedeTomarTodoPendiente())
                                {
                                    <div class="text-muted" style="font-size:.68rem">No puedes tomar todo lo pendiente hasta terminar los procesos de producción.</div>
                                }
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AutollenarEntregaPendiente" disabled="@(!PuedeTomarTodoPendiente())">
                                <i class="bi bi-magic me-1"></i>Tomar todo pendiente
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Talla</th>
                                        <th class="text-center">Pedido</th>
                                        <th class="text-end">Precio unit.</th>
                                        <th class="text-center">Entregadas</th>
                                        <th class="text-center">Pendientes</th>
                                        <th class="text-center">Esta nota</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var talla in corridaPedido)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@talla.Talla</td>
                                            <td class="text-center">@talla.CantidadPedido</td>
                                            <td class="text-end">@talla.PrecioUnitario.ToString("C2")</td>
                                            <td class="text-center">@talla.CantidadEntregada</td>
                                            <td class="text-center">@talla.CantidadPendiente</td>
                                            <td style="max-width:120px">
                                                <InputNumber class="form-control form-control-sm" @bind-Value="talla.CantidadEntregar" @bind-Value:after="RecalcularEntregaActual" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="5" class="text-end fw-semibold">Total nota</td>
                                        <td class="text-center fw-bold">@cantidadNotaEntrega</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                }

                @if (notasEntrega.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nota</th>
                                    <th>Fecha</th>
                                    <th class="text-center">Piezas</th>
                                    <th class="text-end">Total</th>
                                    <th>Estatus</th>
                                    <th>CFDI</th>
                                    <th>Factura</th>
                                    <th>PDF</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var nota in notasEntrega.OrderByDescending(n => n.FechaNota))
                                {
                                    <tr>
                                        <td class="fw-semibold">@nota.NumeroNota</td>
                                        <td>@nota.FechaNota.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@ObtenerCantidadNota(nota)</td>
                                        <td class="text-end">@nota.Total.ToString("C2")</td>
                                        <td><span class="sg-estado-badge">@nota.Estatus</span></td>
                                        <td>
                                            @if (nota.NoRequiereFactura)
                                            {
                                                <span class="badge bg-secondary">No requerida</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">Requerida</span>
                                            }
                                        </td>
                                        <td>
                                            <div>@ObtenerResumenFacturaNota(nota)</div>
                                            @if (ObtenerResumenTallasNota(nota) is { Length: > 0 } resumenTallas)
                                            {
                                                <div class="text-muted" style="font-size:.68rem">@resumenTallas</div>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(nota.PdfUrl))
                                            {
                                                <a class="btn btn-sm btn-outline-danger" href="@nota.PdfUrl" target="_blank" download>
                                                    <i class="bi bi-file-earmark-pdf"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Pendiente</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="sg-empty-split">Aún no hay notas de entrega para este pedido.</div>
                }
            </div>
        </div>
    }
</div>

<style>
    /* ?? Page ????????????????????????????????????????? */
    .sg-page { padding: 1rem 1.25rem; }
    @@media (min-width:768px) { .sg-page { padding: 1.25rem 2rem; } }

    /* ?? Header ??????????????????????????????????????? */
    .sg-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: .75rem; }
    .sg-header-left { display: flex; align-items: flex-start; gap: .75rem; }
    .sg-back { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 8px; border: 1.5px solid #d1d9e0; color: #4a6fa5; background: #fff; font-size: 1rem; flex-shrink: 0; margin-top: .15rem; }
    .sg-back:hover { background: #1e3a5f; color: #fff; border-color: #1e3a5f; }
    .sg-title { font-size: 1.1rem; font-weight: 700; color: #1e3a5f; display: flex; align-items: center; flex-wrap: wrap; gap: .4rem; }
    .sg-cliente { font-size: .85rem; font-weight: 500; color: #4a6fa5; }
    .sg-meta { display: flex; align-items: center; flex-wrap: wrap; gap: .75rem; font-size: .75rem; color: #6c757d; margin-top: .25rem; }
    .sg-estado-badge { font-size: .68rem; font-weight: 700; padding: .2rem .55rem; border-radius: 20px; background: #eef2fb; color: #1e3a5f; border: 1px solid #c8d4e8; }

    /* ?? Progress block ???????????????????????????????? */
    .sg-progress-block { min-width: 200px; }
    .sg-progress-label { display: flex; justify-content: space-between; font-size: .72rem; color: #374151; margin-bottom: .25rem; }
    .sg-progress-bar-wrap { height: 6px; background: #e5e7eb; border-radius: 99px; overflow: hidden; }
    .sg-progress-bar { height: 100%; background: linear-gradient(90deg,#10b981,#34d399); border-radius: 99px; transition: width .4s; }
    .sg-progress-sub { font-size: .65rem; color: #9ca3af; margin-top: .2rem; }

    /* ?? Card ?????????????????????????????????????????? */
    .sg-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.04); overflow: hidden; }
    .sg-card-header { display: flex; align-items: center; justify-content: space-between; padding: .6rem 1rem; background: #f8f9fb; border-bottom: 1px solid #e8edf5; font-size: .8rem; font-weight: 700; color: #1e3a5f; }
    .sg-card-sub { font-size: .7rem; font-weight: 400; color: #6b7280; }

    /* Matriz compacta por talla y operación */
    .sg-matrix-wrap { overflow-x: auto; max-height: 58vh; overflow-y: auto; background: #fcfdff; }
    .sg-matrix { width: max-content; min-width: 100%; border-collapse: separate; border-spacing: 0; font-size: .74rem; }
    .sg-matrix thead th { position: sticky; top: 0; z-index: 3; background: #1e3a5f; color: #d9e4f0; padding: .42rem .55rem; font-size: .65rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; white-space: nowrap; border-right: 1px solid rgba(255,255,255,.08); }
    .sg-matrix tbody td { padding: .22rem .35rem; border-bottom: 1px solid #eef2f7; border-right: 1px solid #f3f4f6; vertical-align: top; }
    .sg-matrix tbody tr:last-child td { border-bottom: none; }
    .sg-th-talla { min-width: 95px; position: sticky; left: 0; z-index: 4; }
    .sg-th-proc { min-width: 152px; text-align: center; }
    .sg-th-pct { min-width: 80px; text-align: center; }
    .sg-td-talla { position: sticky; left: 0; background: #fff; z-index: 2; }
    .sg-td-proc { text-align: center; }
    .sg-td-pct { text-align: center; min-width: 80px; }
    .sg-talla-num { font-weight: 700; color: #1e3a5f; margin-right: .28rem; }
    .sg-talla-qty { font-size: .66rem; color: #6b7280; }
    .sg-row-done td { background: rgba(16,185,129,.07) !important; }
    .sg-row-partial td { background: rgba(245,158,11,.05) !important; }
    .sg-row-done .sg-td-talla { background: rgba(16,185,129,.07) !important; }
    .sg-row-partial .sg-td-talla { background: rgba(245,158,11,.05) !important; }
    .sg-cell-done { background: rgba(16,185,129,.08) !important; }
    .sg-cell-wip { background: rgba(245,158,11,.05) !important; }

    /* Operation cell card */
    .sg-op { display: flex; flex-direction: column; gap: .22rem; padding: .32rem .38rem; border-radius: 7px; border-left: 3px solid #e2e8f0; background: #fff; min-width: 0; cursor: pointer; transition: box-shadow .15s, border-color .15s; }
    .sg-op:hover { box-shadow: 0 2px 10px rgba(30,58,95,.1); }
    .sg-op:focus-visible { outline: 2px solid #4a6fa5; outline-offset: 1px; }
    .sg-op--done { border-left-color: #10b981; background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%); }
    .sg-op--wip { border-left-color: #f59e0b; background: linear-gradient(135deg, #fffbeb 0%, #fef9c3 100%); }
    .sg-op--idle { border-left-color: #e2e8f0; }
    .sg-op__head { display: flex; align-items: center; gap: .3rem; }
    .sg-chk { background: none; border: none; padding: 0; cursor: pointer; font-size: .92rem; line-height: 1; display: inline-flex; align-items: center; color: #cbd5e1; transition: color .15s; flex-shrink: 0; }
    .sg-chk--on { color: #10b981; }
    .sg-chk:hover:not(.sg-chk--on) { color: #64748b; }
    .sg-op__bar { flex: 1; height: 4px; background: #e5e7eb; border-radius: 99px; overflow: hidden; min-width: 20px; }
    .sg-op__bar-fill { height: 100%; background: linear-gradient(90deg, #f59e0b, #fbbf24); border-radius: 99px; transition: width .3s; }
    .sg-op__bar-fill.is-full { background: linear-gradient(90deg, #10b981, #34d399); }
    .sg-op__count { font-size: .58rem; font-weight: 800; color: #64748b; white-space: nowrap; flex-shrink: 0; letter-spacing: -.01em; }
    .sg-op__count.is-ok { color: #166534; }
    .sg-op__meta { display: flex; align-items: center; justify-content: space-between; gap: .2rem; }
    .sg-op__money { font-size: .56rem; font-weight: 700; color: #075985; white-space: nowrap; }
    .sg-op__date-wrap { flex-shrink: 0; }
    .sg-op__date { font-size: .56rem !important; padding: .1rem .16rem !important; border-radius: 4px; border: 1px solid #e2e8f0; background: transparent; color: #64748b; width: 78px; min-width: 0; text-align: center; cursor: text; }
    .sg-op__date:focus { border-color: #4a6fa5; background: #fff; outline: none; }
    .sg-op__foot { display: flex; align-items: center; justify-content: space-between; gap: .2rem; padding-top: .18rem; border-top: 1px solid rgba(0,0,0,.04); }
    .sg-op__people { display: inline-flex; align-items: center; gap: .2rem; font-size: .7rem; color: #94a3b8; }
    .sg-op__people.has-data { color: #1e3a5f; }
    .sg-op__badge { display: inline-flex; align-items: center; justify-content: center; min-width: 16px; height: 16px; padding: 0 .18rem; border-radius: 999px; background: #1e3a5f; color: #fff; font-size: .5rem; font-weight: 800; }
    .sg-op__cta { display: inline-flex; align-items: center; gap: .12rem; font-size: .52rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #94a3b8; transition: color .15s; }
    .sg-op:hover .sg-op__cta { color: #1e3a5f; }
    .sg-mini-label { display: block; font-size: .54rem; font-weight: 700; letter-spacing: .03em; text-transform: uppercase; color: #64748b; margin-bottom: .08rem; }
    .sg-destajo-list { display: flex; flex-direction: column; gap: .25rem; }
    .sg-destajo-item { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 7px; padding: .3rem; text-align: left; }
    .sg-empleado-input { font-size: .66rem !important; padding: .22rem .3rem !important; border-radius: 6px; border: 1px solid #d1d9e0; background: #fff; color: #374151; width: 100%; min-width: 0; margin-bottom: .22rem; }
    .sg-destajo-row { display: flex; align-items: flex-end; gap: .3rem; flex-wrap: nowrap; }
    .sg-campo-num { display: flex; flex-direction: column; flex-shrink: 0; }
    .sg-destajo-input { font-size: .62rem !important; padding: .16rem .18rem !important; border-radius: 5px; border: 1px solid #d1d9e0; background: #fff; color: #374151; width: 52px; min-width: 0; text-align: center; }
    .sg-destajo-input-compact-money { width: 68px; }
    .sg-destajo-total { font-size: .68rem; font-weight: 700; color: #065f46; white-space: nowrap; flex: 1; text-align: right; padding-bottom: .1rem; }
    .sg-destajo-buttons { display: inline-flex; align-items: center; gap: .18rem; flex-shrink: 0; }
    .sg-destajo-save, .sg-destajo-remove { border: none; color: #fff; width: 24px; height: 24px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: .72rem; }
    .sg-destajo-save { background: #1e3a5f; }
    .sg-destajo-save:hover { background: #163052; }
    .sg-destajo-remove { background: #dc2626; }
    .sg-destajo-remove:hover { background: #b91c1c; }
    .sg-destajo-add { border: 1px dashed #94a3b8; background: #fff; color: #1e3a5f; border-radius: 7px; padding: .28rem .42rem; font-size: .6rem; font-weight: 700; width: 100%; text-align: center; }
    .sg-destajo-add:hover { background: #eff6ff; border-color: #4a6fa5; }
    .sg-empty-split { font-size: .64rem; color: #94a3b8; padding: .45rem; border: 1px dashed #e2e8f0; border-radius: 6px; background: #fff; text-align: center; }
    .sg-na { color: #cbd5e1; font-size: .88rem; }

    /* ?? Mini progress ????????????????????????????????? */
    .sg-mini-bar-wrap { height: 4px; background: #e5e7eb; border-radius: 99px; overflow: hidden; width: 58px; margin: 0 auto .18rem; }
    .sg-mini-bar { height: 100%; background: #10b981; border-radius: 99px; transition: width .3s; }
    .sg-mini-pct { font-size: .62rem; color: #6b7280; }

    .sg-modal-backdrop { position: fixed; inset: 0; background: rgba(15, 23, 42, .42); z-index: 1040; }
    .sg-modal-shell { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; padding: 1.2rem; z-index: 1050; }
    .sg-modal-card { width: min(760px, 100%); max-height: 82vh; background: #fff; border-radius: 12px; border: 1px solid #dbe3ee; box-shadow: 0 24px 50px rgba(15,23,42,.22); overflow: hidden; display: flex; flex-direction: column; }
    .sg-modal-header { display: flex; align-items: flex-start; justify-content: space-between; gap: .8rem; padding: .85rem 1rem; border-bottom: 1px solid #e8edf5; background: #f8fafc; }
    .sg-modal-title { font-size: .88rem; font-weight: 800; color: #1e3a5f; }
    .sg-modal-subtitle { font-size: .7rem; color: #64748b; margin-top: .12rem; }
    .sg-modal-close { border: none; background: transparent; color: #64748b; width: 30px; height: 30px; border-radius: 8px; }
    .sg-modal-close:hover { background: #eef2f7; color: #1e3a5f; }
    .sg-modal-body { padding: .9rem 1rem; overflow: auto; }
    .sg-modal-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: .55rem; margin-bottom: .7rem; }
    .sg-modal-kpi { border: 1px solid #e2e8f0; border-radius: 10px; background: #fff; padding: .55rem .65rem; display: flex; flex-direction: column; gap: .15rem; }
    .sg-modal-kpi-label { font-size: .62rem; text-transform: uppercase; letter-spacing: .04em; color: #64748b; }
    .sg-modal-kpi strong { font-size: .84rem; color: #1f2937; }
    .sg-modal-kpi.is-ok { border-color: #86efac; background: #f0fdf4; }
    .sg-modal-kpi.is-warn { border-color: #fde68a; background: #fffbeb; }
    .sg-modal-kpi-money { border-color: #bfdbfe; background: #eff6ff; }
