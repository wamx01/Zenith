    private readonly SemaphoreSlim _opLock = new(1, 1);

    private PedidoSerigrafiaTallaProceso? modalSeguimiento
        => modalSeguimientoId.HasValue
            ? seguimientoTallaProcesos.FirstOrDefault(s => s.Id == modalSeguimientoId.Value)
