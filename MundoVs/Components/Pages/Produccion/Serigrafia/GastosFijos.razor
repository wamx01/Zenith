@page "/serigrafia/gastos-fijos"
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@inject IRepository<GastoFijo> GastoFijoRepository
@rendermode InteractiveServer

<PageTitle>Gastos Fijos</PageTitle>

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2><i class="bi bi-building"></i> Gastos Fijos</h2>
        <button class="btn btn-success" @onclick="Nuevo">
            <i class="bi bi-plus-circle"></i> Nuevo Gasto Fijo
        </button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-0 shadow">
            <div class="card-header text-white fw-bold" style="background:#696969">
                <strong>@(editando.Id == Guid.Empty ? "Nuevo Gasto Fijo" : "Editar Gasto Fijo")</strong>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-5">
                        <label class="form-label">Concepto</label>
                        <input type="text" class="form-control" @bind="editando.Concepto" placeholder="Ej: ELECTRICIDAD PULPO/FREC." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Costo Mensual</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" class="form-control" @bind="editando.CostoMensual" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Orden</label>
                        <input type="number" class="form-control" @bind="editando.Orden" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" @onclick="Guardar"><i class="bi bi-save"></i> Guardar</button>
                    <button class="btn btn-secondary" @onclick="Cancelar"><i class="bi bi-x-circle"></i> Cancelar</button>
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow">
        <div class="card-body">
            @if (items == null)
            {
                <div class="text-center py-3"><div class="spinner-border"></div></div>
            }
            else if (!items.Any())
            {
                <div class="alert alert-info">No hay gastos fijos registrados.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead style="background:#e0e0e0">
                            <tr>
                                <th>#</th>
                                <th>Concepto</th>
                                <th>Costo Mensual</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in items)
                            {
                                <tr>
                                    <td>@item.Orden</td>
                                    <td><strong>@item.Concepto</strong></td>
                                    <td>$@item.CostoMensual.ToString("N2")</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" @onclick="() => Editar(item)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(item)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold" style="background:#e0e0e0">
                                <td colspan="2" class="text-end">TOTAL MENSUAL:</td>
                                <td>$@(items.Sum(i => i.CostoMensual).ToString("N2"))</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<GastoFijo>? items;
    private GastoFijo editando = new();
    private bool mostrarFormulario;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        items = (await GastoFijoRepository.GetAllAsync()).Where(i => i.IsActive).OrderBy(i => i.Orden);
    }

    private void Nuevo()
    {
        var maxOrden = items?.Any() == true ? items.Max(i => i.Orden) + 1 : 1;
        editando = new GastoFijo { Orden = maxOrden };
        mostrarFormulario = true;
    }

    private void Editar(GastoFijo item)
    {
        editando = new GastoFijo
        {
            Id = item.Id, Concepto = item.Concepto, CostoMensual = item.CostoMensual,
            Orden = item.Orden, CreatedAt = item.CreatedAt, IsActive = item.IsActive
        };
        mostrarFormulario = true;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(editando.Concepto)) return;
        if (editando.Id == Guid.Empty) await GastoFijoRepository.AddAsync(editando);
        else { editando.UpdatedAt = DateTime.UtcNow; await GastoFijoRepository.UpdateAsync(editando); }
        await Cargar(); Cancelar();
    }

    private async Task Eliminar(GastoFijo item)
    {
        item.IsActive = false; item.UpdatedAt = DateTime.UtcNow;
        await GastoFijoRepository.UpdateAsync(item); await Cargar();
    }

    private void Cancelar() { editando = new(); mostrarFormulario = false; }
}
