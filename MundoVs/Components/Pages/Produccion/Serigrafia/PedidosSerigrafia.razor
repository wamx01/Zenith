                                <div class="col-12 col-md-5">
                                    <label class="ps-label">Fracción</label>
                                    <InputSelect class="form-select ps-input" @bind-Value="fraccionSeleccionadaId" @bind-Value:after="OnFraccionSeleccionadaChanged" disabled="!fraccionesDisponiblesCliente.Any()">
                                        <option value="">Seleccione fracción...</option>
                                        @foreach (var fraccion in fraccionesDisponiblesCliente)
                                        {
                                            <option value="@fraccion.Id">@fraccion.Codigo - @fraccion.Nombre</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12 col-md-3">
                                    <label class="ps-label">Cuántas fracciones</label>
                                    <InputNumber class="form-control ps-input" @bind-Value="cantidadFracciones" @bind-Value:after="OnCantidadFraccionesChanged" />
                                </div>
