    private async Task ToggleProceso(Guid tipoProcesoId, object? value)
    {
        if (value is bool b && b) procesosSeleccionados.Add(tipoProcesoId);
        else procesosSeleccionados.Remove(tipoProcesoId);

        if (pedidoEditando.Id != Guid.Empty)
        {
            await CargarSeguimientosAsync(pedidoEditando.Id);
        }
    }

    private async Task OnProductoChanged()
    {
        InvalidarComprobacionInventario();
        tallasEditando = new();
        tallasDisponiblesSeleccionadas.Clear();
        variacionSeleccionada = null;
        fraccionSeleccionadaId = null;
        cantidadFracciones = 1;
        capturaEscalaSeleccionada = CapturaEscalaModo.Tallas;
        await CargarCotizacionesProductoAsync(productoSeleccionadoId);
        ConfigurarCapturaProducto();

        if (!productoSeleccionadoId.HasValue || pedidoEditando.Id != Guid.Empty)
            return;

        var cotizacion = await DbContext.CotizacionesSerigrafia
            .AsNoTracking()
            .Include(c => c.Procesos)
            .Where(c => c.ProductoId == productoSeleccionadoId.Value && c.IsActive)
            .Where(c => !clienteSeleccionadoId.HasValue || c.ClienteId == clienteSeleccionadoId.Value)
            .OrderByDescending(c => c.CreatedAt)
            .FirstOrDefaultAsync(c => !cotizacionSeleccionadaId.HasValue || c.Id == cotizacionSeleccionadaId.Value);

        procesosSeleccionados = cotizacion?.Procesos.Select(p => p.TipoProcesoId).ToHashSet() ?? new HashSet<Guid>();
    }

    private async Task OnCotizacionChanged()
    {
        InvalidarComprobacionInventario();
        if (!cotizacionSeleccionadaId.HasValue)
        {
            procesosSeleccionados = new HashSet<Guid>();
            return;
        }

        var cotizacion = await DbContext.CotizacionesSerigrafia
            .AsNoTracking()
            .Include(c => c.Procesos)
            .FirstOrDefaultAsync(c => c.Id == cotizacionSeleccionadaId.Value && c.IsActive);

        procesosSeleccionados = cotizacion?.Procesos.Select(p => p.TipoProcesoId).ToHashSet() ?? new HashSet<Guid>();
    }

    private async Task ActualizarProcesosAsync(Guid pedidoSerigrafiaId)
    {
        var existentes = DbContext.PedidoSerigrafiaProcesoDetalles.Where(p => p.PedidoSerigrafiaId == pedidoSerigrafiaId);
        DbContext.PedidoSerigrafiaProcesoDetalles.RemoveRange(existentes);

        foreach (var tipoProcesoId in procesosSeleccionados)
        {
            DbContext.PedidoSerigrafiaProcesoDetalles.Add(new PedidoSerigrafiaProcesoDetalle
            {
                Id = Guid.NewGuid(),
                PedidoSerigrafiaId = pedidoSerigrafiaId,
                TipoProcesoId = tipoProcesoId,
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });
        }

        await DbContext.SaveChangesAsync();
    }

    // ===== Cliente/Producto =====

    private async Task OnClienteChanged()
    {
        InvalidarComprobacionInventario();
        if (clienteSeleccionadoId.HasValue)
        {
            await CargarProductosClienteAsync(clienteSeleccionadoId.Value);
            productoSeleccionadoId = null;
            cotizacionSeleccionadaId = null;
            fraccionSeleccionadaId = null;
            cotizacionesProducto = [];
            procesosSeleccionados = new HashSet<Guid>();
            tallasEditando = new();
            tallasDisponiblesSeleccionadas.Clear();
            capturaEscalaSeleccionada = CapturaEscalaModo.Tallas;
            cantidadFracciones = 1;
            variacionSeleccionada = null;
        }
        else
        {
            productosCliente = null;
            productosClienteOpciones = new();
            productoSeleccionadoId = null;
            cotizacionSeleccionadaId = null;
            fraccionSeleccionadaId = null;
            cotizacionesProducto = [];
            variantesDisponiblesPorProducto = new();
            tallasDisponiblesCliente = new();
            fraccionesDisponiblesCliente = new();
            procesosSeleccionados = new HashSet<Guid>();
            tallasEditando = new();
            tallasDisponiblesSeleccionadas.Clear();
            capturaEscalaSeleccionada = CapturaEscalaModo.Tallas;
            cantidadFracciones = 1;
            variacionSeleccionada = null;
        }
    }

    private async Task CargarProductosClienteAsync(Guid? clienteId)
    {
        if (!clienteId.HasValue)
        {
            productosCliente = null;
            productosClienteOpciones = new();
            variantesDisponiblesPorProducto = new();
            tallasDisponiblesCliente = new();
            fraccionesDisponiblesCliente = new();
            return;
        }

        var asignados = await DbContext.ProductosClientes
            .AsNoTracking()
            .Include(pc => pc.Producto)
            .Where(pc => pc.ClienteId == clienteId.Value && pc.IsActive && pc.Producto.IsActive)
            .OrderBy(pc => pc.Producto.Nombre)
            .ToListAsync();

        var cotizacionesCliente = await DbContext.CotizacionesSerigrafia
            .AsNoTracking()
            .Include(c => c.Producto)
            .Where(c => c.ClienteId == clienteId.Value && c.IsActive && c.Producto.IsActive)
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();

        productosClienteOpciones = asignados
            .Select(pc => new ProductoClienteOption
            {
                ProductoId = pc.ProductoId,
                Nombre = pc.Producto.Nombre,
                TallaBaseCalzado = pc.TallaBaseCalzado,
                TieneVariantes = pc.Producto.TieneVariantes,
                UsaVariantesTalla = pc.Producto.UsaVariantesTalla,
                UsaVariantesColor = pc.Producto.UsaVariantesColor,
                AplicaFraccionCalzado = pc.AplicaFraccionCalzado,
                ClienteFraccionCalzadoId = pc.ClienteFraccionCalzadoId
            })
            .ToList();

        foreach (var cotizacion in cotizacionesCliente)
        {
            if (productosClienteOpciones.Any(p => p.ProductoId == cotizacion.ProductoId))
            {
                continue;
            }

            productosClienteOpciones.Add(new ProductoClienteOption
            {
                ProductoId = cotizacion.ProductoId,
                Nombre = cotizacion.Producto.Nombre,
                TallaBaseCalzado = null,
                TieneVariantes = cotizacion.Producto.TieneVariantes,
                UsaVariantesTalla = cotizacion.Producto.UsaVariantesTalla,
                UsaVariantesColor = cotizacion.Producto.UsaVariantesColor,
                AplicaFraccionCalzado = false,
                ClienteFraccionCalzadoId = null
            });
        }

        productosCliente = asignados
            .Select(pc => pc.Producto)
            .Concat(cotizacionesCliente.Select(c => c.Producto))
            .GroupBy(p => p.Id)
            .Select(g => g.First())
            .OrderBy(p => p.Nombre)
            .ToList();

        tallasDisponiblesCliente = await DbContext.ClientesTallasCalzado
            .AsNoTracking()
            .Where(t => t.ClienteId == clienteId.Value && t.IsActive && t.Activa)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new TallaClienteDisponible
            {
                Talla = t.Talla,
                Orden = t.Orden,
                EsTallaBaseDefault = t.EsTallaBaseDefault
            })
            .ToListAsync();

        if (!tallasDisponiblesCliente.Any())
        {
            tallasDisponiblesCliente = await DbContext.CatalogoTallasCalzado
                .AsNoTracking()
                .Where(t => t.IsActive && t.Activa)
                .OrderBy(t => t.Orden)
                .ThenBy(t => t.Talla)
                .Select(t => new TallaClienteDisponible
                {
                    Talla = t.Talla,
                    Orden = t.Orden,
                    EsTallaBaseDefault = false
                })
                .ToListAsync();
        }

        if (!tallasDisponiblesCliente.Any())
        {
            tallasDisponiblesCliente = await DbContext.CatalogoTallasCalzado
                .AsNoTracking()
                .Where(t => t.IsActive && t.Activa)
                .OrderBy(t => t.Orden)
                .ThenBy(t => t.Talla)
                .Select(t => new TallaClienteDisponible
                {
                    Talla = t.Talla,
                    Orden = t.Orden,
                    EsTallaBaseDefault = false
                })
                .ToListAsync();
        }

        fraccionesDisponiblesCliente = await DbContext.ClientesFraccionesCalzado
            .AsNoTracking()
            .Include(f => f.Detalles)
            .Where(f => f.ClienteId == clienteId.Value && f.IsActive && f.Activa)
            .OrderBy(f => f.Nombre)
            .ToListAsync();

        var productoIds = productosClienteOpciones.Select(p => p.ProductoId).ToList();
        variantesDisponiblesPorProducto = productoIds.Count == 0
            ? new()
            : await DbContext.ProductosVariantes
                .AsNoTracking()
                .Where(v => productoIds.Contains(v.ProductoId) && v.IsActive && v.Activa)
                .OrderBy(v => v.ProductoId)
                .ThenBy(v => v.Color)
                .ThenBy(v => v.Talla)
                .Select(v => new ProductoVarianteOption
                {
                    Id = v.Id,
                    ProductoId = v.ProductoId,
                    Sku = v.Sku,
                    Talla = v.Talla,
                    Color = v.Color,
                    Precio = v.PrecioOverride
                })
                .GroupBy(v => v.ProductoId)
                .ToDictionaryAsync(g => g.Key, g => g.ToList());

        if (pedidoEditando.Id != Guid.Empty)
        {
            await CargarSeguimientosAsync(pedidoEditando.Id);
        }
    }

    private async Task CargarCotizacionesProductoAsync(Guid? productoId)
    {
        if (!productoId.HasValue)
        {
            cotizacionesProducto = [];
            cotizacionSeleccionadaId = null;
            return;
        }

        cotizacionesProducto = await DbContext.CotizacionesSerigrafia
            .AsNoTracking()
            .Include(c => c.PreciosVariantes)
            .Where(c => c.ProductoId == productoId.Value && c.IsActive)
            .Where(c => !clienteSeleccionadoId.HasValue || c.ClienteId == clienteSeleccionadoId.Value)
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();

        if (cotizacionSeleccionadaId.HasValue && !cotizacionesProducto.Any(c => c.Id == cotizacionSeleccionadaId.Value))
        {
            cotizacionSeleccionadaId = null;
        }

        if (pedidoEditando.Id == Guid.Empty && !cotizacionSeleccionadaId.HasValue)
        {
            cotizacionSeleccionadaId = cotizacionesProducto.FirstOrDefault()?.Id;
        }
    }

    private string ObtenerEtiquetaCotizacion(CotizacionSerigrafia cotizacion)
    {
        var descripcion = string.IsNullOrWhiteSpace(cotizacion.Descripcion) ? "Sin descripción" : cotizacion.Descripcion.Trim();
        return $"{descripcion} · {cotizacion.CreatedAt:dd/MM/yyyy} · Contado {cotizacion.PrecioFinalContado:C2}";
    }

    private static decimal CalcularSubtotalProductoDesdeCotizacion(
        CotizacionSerigrafia cotizacion,
        IEnumerable<PedidoSerigrafiaTalla> tallas,
        string? colorSeleccionado,
        TipoPrecioEnum tipoPrecio)
    {
        var preciosAceptados = cotizacion.PreciosVariantes
            .Where(p => p.IsActive && p.Aceptada)
            .ToList();

        var precioBase = preciosAceptados.FirstOrDefault(p => p.EsPrecioBase) is { } precioBaseVariante
            ? ObtenerPrecioCotizado(precioBaseVariante, tipoPrecio)
            : tipoPrecio == TipoPrecioEnum.Credito
                ? cotizacion.PrecioCredito
                : cotizacion.PrecioFinalContado;

        decimal subtotal = 0m;
        foreach (var talla in tallas.Where(t => t.Cantidad > 0))
        {
            var precioTalla = ResolverPrecioCotizadoPorVariante(preciosAceptados, talla.Talla, colorSeleccionado, tipoPrecio, precioBase);
            subtotal += talla.Cantidad * precioTalla;
        }

        return subtotal;
    }

    private static List<PrecioTallaCotizacionResumen> ConstruirResumenPreciosCotizacion(
        CotizacionSerigrafia cotizacion,
        IEnumerable<PedidoSerigrafiaTalla> tallas,
        string? colorSeleccionado,
        TipoPrecioEnum tipoPrecio)
    {
        var preciosAceptados = cotizacion.PreciosVariantes
            .Where(p => p.IsActive && p.Aceptada)
            .ToList();

        var precioBaseRegistro = preciosAceptados.FirstOrDefault(p => p.EsPrecioBase);
        var precioBase = precioBaseRegistro is null
            ? tipoPrecio == TipoPrecioEnum.Credito
                ? cotizacion.PrecioCredito
                : cotizacion.PrecioFinalContado
            : ObtenerPrecioCotizado(precioBaseRegistro, tipoPrecio);

        return tallas
            .Where(t => t.Cantidad > 0)
            .OrderBy(t => t.Talla)
            .Select((talla, index) =>
            {
                var coincidencia = ResolverRegistroPrecioCotizado(preciosAceptados, talla.Talla, colorSeleccionado);
                var precioUnitario = coincidencia is null ? precioBase : ObtenerPrecioCotizado(coincidencia, tipoPrecio);
                return new PrecioTallaCotizacionResumen
                {
                    Orden = index + 1,
                    Talla = talla.Talla,
                    Cantidad = talla.Cantidad,
                    Etiqueta = coincidencia?.Etiqueta ?? "Precio base",
                    ColorAplicado = string.IsNullOrWhiteSpace(colorSeleccionado) ? null : colorSeleccionado.Trim(),
                    PorcentajeAplicado = coincidencia?.PorcentajeVariacionAplicado ?? 0m,
                    PrecioUnitario = precioUnitario,
                    Subtotal = talla.Cantidad * precioUnitario
                };
            })
            .ToList();
    }

    private static decimal ResolverPrecioCotizadoPorVariante(
        IReadOnlyCollection<CotizacionVariantePrecio> preciosAceptados,
        string? talla,
        string? colorSeleccionado,
        TipoPrecioEnum tipoPrecio,
        decimal precioBase)
    {
        var normalizadaTalla = string.IsNullOrWhiteSpace(talla) ? null : talla.Trim();
        var normalizadoColor = string.IsNullOrWhiteSpace(colorSeleccionado) ? null : colorSeleccionado.Trim();

        var coincidencia = ResolverRegistroPrecioCotizado(preciosAceptados, normalizadaTalla, normalizadoColor);

        return coincidencia == null ? precioBase : ObtenerPrecioCotizado(coincidencia, tipoPrecio);
    }

    private static CotizacionVariantePrecio? ResolverRegistroPrecioCotizado(
        IReadOnlyCollection<CotizacionVariantePrecio> preciosAceptados,
        string? talla,
        string? colorSeleccionado)
    {
        var normalizadaTalla = string.IsNullOrWhiteSpace(talla) ? null : talla.Trim();
        var normalizadoColor = string.IsNullOrWhiteSpace(colorSeleccionado) ? null : colorSeleccionado.Trim();

        var coincidencia = preciosAceptados.FirstOrDefault(p => !p.EsPrecioBase
            && CoincideValor(p.Talla, normalizadaTalla)
            && CoincideValor(p.Color, normalizadoColor));

        coincidencia ??= preciosAceptados.FirstOrDefault(p => !p.EsPrecioBase
            && CoincideValor(p.Talla, normalizadaTalla)
            && string.IsNullOrWhiteSpace(p.Color));

        coincidencia ??= preciosAceptados.FirstOrDefault(p => !p.EsPrecioBase
            && string.IsNullOrWhiteSpace(p.Talla)
            && CoincideValor(p.Color, normalizadoColor));

        return coincidencia;
    }

    private static bool CoincideValor(string? esperado, string? actual)
        => !string.IsNullOrWhiteSpace(esperado)
            && !string.IsNullOrWhiteSpace(actual)
            && string.Equals(esperado.Trim(), actual.Trim(), StringComparison.OrdinalIgnoreCase);

    private static decimal ObtenerPrecioCotizado(CotizacionVariantePrecio precio, TipoPrecioEnum tipoPrecio)
        => tipoPrecio == TipoPrecioEnum.Credito ? precio.PrecioCredito : precio.PrecioContado;

    private static string ObtenerResumenPrecioTallas(IEnumerable<PedidoDetalleTalla> detallesTalla)
    {
        var resumen = detallesTalla
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => $"{t.Talla}: {t.PrecioUnitario:C2}")
            .Take(4)
            .ToList();

        if (resumen.Count == 0)
        {
            return "";
        }

        var tieneMas = detallesTalla.Skip(4).Any();
        return tieneMas
            ? $"{string.Join(" · ", resumen)} · ..."
            : string.Join(" · ", resumen);
    }

