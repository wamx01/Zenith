        GenerarTallasDesdeFraccion();
        return Task.CompletedTask;
    }

    private Task OnFraccionRapidaChanged()
    {
        InvalidarComprobacionInventario();
        tallasDisponiblesSeleccionadas.Clear();
        if (fraccionSeleccionadaId.HasValue)
        {
            capturaEscalaSeleccionada = CapturaEscalaModo.Fraccion;
            GenerarTallasDesdeFraccion();
        }

        return Task.CompletedTask;
    }

    private Task OnCantidadFraccionesChanged()
    {
        InvalidarComprobacionInventario();
        if (cantidadFracciones < 1)
        {
            cantidadFracciones = 1;
        }

        GenerarTallasDesdeFraccion();
        return Task.CompletedTask;
    }

    private void ConfigurarCapturaProducto()
    {
        var producto = ProductoSeleccionadoConfig;
        if (producto == null)
        {
            nuevaTallaSeleccionada = null;
            variacionSeleccionada = null;
            fraccionSeleccionadaId = null;
            capturaEscalaSeleccionada = CapturaEscalaModo.Tallas;
            cantidadFracciones = 1;
            tallasEditando = new();
            tallasDisponiblesSeleccionadas.Clear();
            return;
        }

        if (producto.UsaVariantesColor)
        {
            variacionSeleccionada = ObtenerVariacionesDisponibles(productoSeleccionadoId)
                .FirstOrDefault(v => string.Equals(v, variacionSeleccionada, StringComparison.OrdinalIgnoreCase))
                ?? (pedidoEditando.Id == Guid.Empty ? null : ObtenerVariacionesDisponibles(productoSeleccionadoId).FirstOrDefault());
            pedidoEditando.CombinacionColor = variacionSeleccionada ?? string.Empty;
        }
        else
        {
            variacionSeleccionada = null;
            pedidoEditando.CombinacionColor ??= string.Empty;
        }

        if (!ProductoPermiteFraccion)
        {
            capturaEscalaSeleccionada = CapturaEscalaModo.Tallas;
            fraccionSeleccionadaId = null;
            cantidadFracciones = 1;
            nuevaTallaSeleccionada = ObtenerTallasDisponiblesParaCaptura().FirstOrDefault()?.Talla;
            return;
        }

        if (pedidoEditando.Id == Guid.Empty && !tallasEditando.Any())
        {
            capturaEscalaSeleccionada = producto.AplicaFraccionCalzado ? CapturaEscalaModo.Fraccion : CapturaEscalaModo.Tallas;
            fraccionSeleccionadaId = producto.ClienteFraccionCalzadoId ?? fraccionesDisponiblesCliente.FirstOrDefault()?.Id;
            if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
            {
                GenerarTallasDesdeFraccion();
            }
        }

        if (capturaEscalaSeleccionada == CapturaEscalaModo.Tallas)
        {
            nuevaTallaSeleccionada = ObtenerTallasDisponiblesParaCaptura().FirstOrDefault()?.Talla;
        }
    }

    private void GenerarTallasDesdeFraccion()
    {
        if (capturaEscalaSeleccionada != CapturaEscalaModo.Fraccion)
        {
            return;
        }

        if (ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(ObtenerColorSeleccionado()))
        {
            tallasEditando = new();
            return;
        }

        var fraccion = fraccionesDisponiblesCliente.FirstOrDefault(f => f.Id == fraccionSeleccionadaId);
        if (fraccion == null || !fraccion.Detalles.Any())
        {
            tallasEditando = new();
            return;
        }

        if (cantidadFracciones < 1)
        {
            cantidadFracciones = 1;
        }

        tallasEditando = fraccion.Detalles
            .Where(d => d.Unidades > 0)
            .OrderBy(d => d.Orden)
            .ThenBy(d => d.Talla)
            .Select(d => new PedidoSerigrafiaTalla
            {
                Talla = d.Talla,
                Cantidad = (int)Math.Round(d.Unidades * cantidadFracciones, MidpointRounding.AwayFromZero)
            })
            .Where(t => t.Cantidad > 0)
            .ToList();
    }

    private IEnumerable<string> ObtenerVariacionesDisponibles(Guid? productoId)
        => productoId.HasValue && variantesDisponiblesPorProducto.TryGetValue(productoId.Value, out var variantes)
            ? variantes
                .Select(v => v.Color)
                .Where(color => !string.IsNullOrWhiteSpace(color))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(color => color)
                .Cast<string>()
            : [];

    private IEnumerable<TallaClienteDisponible> ObtenerTallasDisponiblesParaCaptura()
        => tallasDisponiblesCliente
            .Where(t => !tallasEditando.Any(editada => string.Equals(editada.Talla, t.Talla, StringComparison.OrdinalIgnoreCase)))
            .Where(t => TallaDisponibleParaVariacion(t.Talla))
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla);

    private string? ObtenerColorSeleccionado()
        => ProductoUsaVariantesColor
            ? LimpiarTexto(variacionSeleccionada)
            : LimpiarTexto(pedidoEditando.CombinacionColor);

    private IEnumerable<PedidoSerigrafiaTalla> ObtenerTallasSinSku()
    {
        if (!productoSeleccionadoId.HasValue || ProductoSeleccionadoConfig?.TieneVariantes != true || ProductoSeleccionadoConfig.UsaVariantesTalla != true)
        {
            return [];
        }

        var colorSeleccionado = ObtenerColorSeleccionado();
        return tallasEditando.Where(t => t.Cantidad > 0 && ResolverProductoVarianteSeleccionado(productoSeleccionadoId.Value, t.Talla, colorSeleccionado) == null);
    }

    private bool TallaDisponibleParaVariacion(string talla)
    {
        if (!productoSeleccionadoId.HasValue)
        {
            return false;
        }

        if (ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(ObtenerColorSeleccionado()))
        {
            return false;
        }

        if (ProductoSeleccionadoConfig?.TieneVariantes != true || ProductoSeleccionadoConfig.UsaVariantesTalla != true)
        {
            return true;
        }

        return ResolverProductoVarianteSeleccionado(productoSeleccionadoId.Value, talla, ObtenerColorSeleccionado()) != null;
    }

    private string ObtenerMensajeCapturaTallas()
    {
        if (capturaEscalaSeleccionada == CapturaEscalaModo.Tallas && ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(ObtenerColorSeleccionado()))
        {
            return "Selecciona primero la variación/color para cargar la corrida y las tallas disponibles de ese pedido.";
        }

        if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
        {
            return ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(ObtenerColorSeleccionado())
                ? "Selecciona primero la variación/color para generar la fracción del pedido."
                : "Selecciona una fracción y cuántas fracciones quieres para generar la escala.";
        }

        if (tallasDisponiblesCliente.Any())
        {
            return "Agrega una talla puntual o carga la corrida completa para este pedido.";
        }

        return "Primero configura las tallas disponibles para este cliente; después podrás seleccionar varios SKU con la variación elegida.";
    }

    private string ObtenerEtiquetaSkuResuelto(string talla)
    {
        if (!productoSeleccionadoId.HasValue)
        {
            return "Selecciona producto";
        }

        if (ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(ObtenerColorSeleccionado()))
        {
            return "Selecciona variación";
        }

        return ObtenerSkuTallaResumen(talla, ObtenerColorSeleccionado()) is { } sku && sku != "—"
            ? sku
            : "Sin SKU";
    }

    private string ObtenerEtiquetaVariacionAplicada()
    {
        var variacion = ObtenerColorSeleccionado();
        return string.IsNullOrWhiteSpace(variacion) ? "Base" : variacion;
    }

    private string ObtenerPrecioCotizadoTallaTexto(string talla)
    {
        var precio = ObtenerPrecioCotizadoTalla(talla);
        return precio.HasValue ? precio.Value.ToString("C2") : "—";
    }

    private decimal? ObtenerPrecioCotizadoTalla(string talla)
    {
        if (!cotizacionSeleccionadaId.HasValue)
        {
            return null;
        }

        var cotizacion = cotizacionesProducto.FirstOrDefault(c => c.Id == cotizacionSeleccionadaId.Value);
        if (cotizacion == null)
        {
            return null;
        }

        var preciosAceptados = cotizacion.PreciosVariantes
            .Where(p => p.IsActive && p.Aceptada)
            .ToList();

        var precioBaseRegistro = preciosAceptados.FirstOrDefault(p => p.EsPrecioBase);
        var precioBase = precioBaseRegistro is null
            ? tipoPrecioSeleccionado == TipoPrecioEnum.Credito ? cotizacion.PrecioCredito : cotizacion.PrecioFinalContado
            : ObtenerPrecioCotizado(precioBaseRegistro, tipoPrecioSeleccionado);

        return ResolverPrecioCotizadoPorVariante(preciosAceptados, talla, ObtenerColorSeleccionado(), tipoPrecioSeleccionado, precioBase);
    }

    private string ObtenerEtiquetaTallaDisponible(string talla)
    {
        var sku = ObtenerEtiquetaSkuResuelto(talla);
        return string.IsNullOrWhiteSpace(sku)
            ? talla
            : $"{talla} · {sku}";
    }

    private string ObtenerSkuTallaResumen(string talla, string? colorSeleccionado)
    {
        if (!productoSeleccionadoId.HasValue)
        {
            return "—";
        }

        var varianteId = ResolverProductoVarianteSeleccionado(productoSeleccionadoId.Value, talla, colorSeleccionado);
        if (!varianteId.HasValue || !variantesDisponiblesPorProducto.TryGetValue(productoSeleccionadoId.Value, out var variantes))
        {
            return "—";
        }

        return variantes.FirstOrDefault(v => v.Id == varianteId.Value)?.Sku ?? "—";
    }

    private Guid? ResolverProductoVarianteSeleccionado(Guid productoId, string? talla, string? colorSeleccionado)
    {
        if (!variantesDisponiblesPorProducto.TryGetValue(productoId, out var variantes))
        {
            return null;
        }

        var query = variantes.AsEnumerable();
        if (ProductoUsaVariantesColor)
        {
            if (string.IsNullOrWhiteSpace(colorSeleccionado))
            {
                return null;
            }

            query = query.Where(v => string.Equals(v.Color, colorSeleccionado, StringComparison.OrdinalIgnoreCase));
        }

        if (ProductoSeleccionadoConfig?.UsaVariantesTalla == true)
        {
            if (string.IsNullOrWhiteSpace(talla))
            {
                return null;
            }

            query = query.Where(v => string.Equals(v.Talla, talla, StringComparison.OrdinalIgnoreCase));
        }

        return query.Select(v => (Guid?)v.Id).FirstOrDefault();
    }

    private int CalcularCantidadFraccionesSugerida()
    {
        if (!fraccionSeleccionadaId.HasValue)
        {
            return 1;
        }

        var fraccion = fraccionesDisponiblesCliente.FirstOrDefault(f => f.Id == fraccionSeleccionadaId.Value);
        if (fraccion == null || fraccion.UnidadesPorFraccion <= 0)
        {
            return 1;
        }

        var total = tallasEditando.Sum(t => t.Cantidad);
        return total <= 0
            ? 1
            : Math.Max(1, (int)Math.Round(total / fraccion.UnidadesPorFraccion, MidpointRounding.AwayFromZero));
    }

    private async Task SincronizarDetalleTallasAsync(
        Guid pedidoDetalleId,
        Guid productoId,
        CotizacionSerigrafia cotizacion,
        string? colorSeleccionado,
        TipoPrecioEnum tipoPrecio,
        string? usuarioActual,
        bool generadaDesdeFraccion)
    {
        var existentes = await DbContext.PedidosDetalleTalla
            .Where(t => t.PedidoDetalleId == pedidoDetalleId)
            .ToListAsync();

        if (existentes.Any())
        {
            DbContext.PedidosDetalleTalla.RemoveRange(existentes);
        }

        var resumenPrecios = ConstruirResumenPreciosCotizacion(cotizacion, tallasEditando, colorSeleccionado, tipoPrecio);
        var variantesProducto = await DbContext.ProductosVariantes
            .AsNoTracking()
            .Where(v => v.ProductoId == productoId && v.IsActive && v.Activa)
            .ToListAsync();

        foreach (var precio in resumenPrecios.Where(p => p.Cantidad > 0))
        {
            DbContext.PedidosDetalleTalla.Add(new PedidoDetalleTalla
            {
                Id = Guid.NewGuid(),
                PedidoDetalleId = pedidoDetalleId,
                ProductoVarianteId = ResolverProductoVarianteId(variantesProducto, precio.Talla, colorSeleccionado),
                Talla = precio.Talla,
                Orden = precio.Orden,
                Cantidad = precio.Cantidad,
                PrecioUnitario = precio.PrecioUnitario,
                Total = precio.Subtotal,
                PorcentajeVariacion = precio.PorcentajeAplicado,
                GeneradaDesdeFraccion = generadaDesdeFraccion,
                CreatedAt = DateTime.UtcNow,
                CreatedBy = usuarioActual,
                IsActive = true
            });
        }

        await DbContext.SaveChangesAsync();
    }

    private static Guid? ResolverProductoVarianteId(IEnumerable<ProductoVariante> variantes, string? talla, string? colorSeleccionado)
    {
        if (string.IsNullOrWhiteSpace(talla) && string.IsNullOrWhiteSpace(colorSeleccionado))
        {
            return null;
        }

        var normalizadaTalla = string.IsNullOrWhiteSpace(talla) ? null : talla.Trim();
        var normalizadoColor = string.IsNullOrWhiteSpace(colorSeleccionado) ? null : colorSeleccionado.Trim();

        var coincidencia = variantes.FirstOrDefault(v => CoincideValor(v.Talla, normalizadaTalla) && CoincideValor(v.Color, normalizadoColor));
        coincidencia ??= variantes.FirstOrDefault(v => CoincideValor(v.Talla, normalizadaTalla) && string.IsNullOrWhiteSpace(v.Color));
        coincidencia ??= variantes.FirstOrDefault(v => string.IsNullOrWhiteSpace(v.Talla) && CoincideValor(v.Color, normalizadoColor));

        return coincidencia?.Id;
    }

