    private async Task GenerarNotaConsolidadaInicialAsync()
    {
        errorNotaConsolidada = null;
        okNotaConsolidada = null;

        if (!Guid.TryParse(clienteNotaConsolidadaId, out var clienteId) || clienteId == Guid.Empty)
        {
            errorNotaConsolidada = "Selecciona un cliente.";
            return;
        }

        var seleccionados = pedidosElegiblesNotaConsolidada
            .Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId) && p.Elegible)
            .ToList();

        if (!seleccionados.Any())
        {
            errorNotaConsolidada = "Selecciona al menos un pedido elegible.";
            return;
        }

        lineasNotaConsolidada = (await NotaEntregaConsolidadaService.BuildLineasConsolidadasAsync(seleccionados.Select(s => s.PedidoId).ToList())).ToList();
        if (!lineasNotaConsolidada.Any())
        {
            errorNotaConsolidada = "Los pedidos seleccionados no tienen líneas entregables reales.";
            return;
        }

        lineasNotaConsolidada = lineasNotaConsolidada
            .Where(l => l.CantidadSeleccionada > 0)
            .ToList();

        if (!lineasNotaConsolidada.Any())
        {
            errorNotaConsolidada = "Captura al menos una línea con cantidad mayor a cero.";
            return;
        }

        var lineasProductoSinFg = lineasNotaConsolidada
            .Where(l => l.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto && l.CantidadDisponibleFg < l.CantidadSeleccionada)
            .ToList();

        if (lineasProductoSinFg.Any())
        {
            errorNotaConsolidada = $"No hay FG suficiente para: {string.Join(", ", lineasProductoSinFg.Select(l => $"{l.NumeroPedido} {l.Talla}"))}.";
            return;
        }

        guardandoNotaConsolidada = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var usuario = (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name;

            var cliente = await db.Clientes.AsNoTracking().FirstOrDefaultAsync(c => c.Id == clienteId);
            if (cliente == null)
            {
                errorNotaConsolidada = "No se encontró el cliente seleccionado.";
                return;
            }

            var codigoService = new MundoVs.Core.Services.CodigoNegocioService(DbFactory);
            var numeroNota = await codigoService.GetNextEntityCodeAsync(_empresaId, "NOT", "Consecutivo:NotaEntrega");
            var pedidoPrincipalId = seleccionados.First().PedidoId;

            var nota = new NotaEntrega
            {
                Id = Guid.NewGuid(),
                EmpresaId = _empresaId,
                ClienteId = clienteId,
                PedidoId = pedidoPrincipalId,
                NumeroNota = numeroNota,
                FechaNota = DateTime.Now,
                Estatus = NotaEntregaEstatus.Emitida,
                NoRequiereFactura = false,
                Observaciones = $"Nota consolidada desde lista de pedidos. Pedidos: {string.Join(", ", seleccionados.Select(s => s.NumeroPedido))}",
                Subtotal = SubtotalNotaConsolidada,
                Impuestos = ImpuestosNotaConsolidada,
                Total = TotalNotaConsolidada,
                CreatedAt = DateTime.UtcNow,
                CreatedBy = usuario,
                IsActive = true
            };

            var orden = 0;
            foreach (var item in seleccionados)
            {
                nota.PedidosRelacionados.Add(new NotaEntregaPedido
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    PedidoId = item.PedidoId,
                    Orden = orden++,
                    EsPrincipal = item.PedidoId == pedidoPrincipalId,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = usuario,
                    IsActive = true
                });
            }

            foreach (var linea in lineasNotaConsolidada)
            {
                nota.Detalles.Add(new NotaEntregaDetalle
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    PedidoDetalleId = linea.PedidoDetalleId,
                    PedidoConceptoId = linea.PedidoConceptoId,
                    Descripcion = linea.Descripcion,
                    Cantidad = linea.CantidadSeleccionada,
                    PrecioUnitario = linea.PrecioUnitario,
                    Importe = linea.Importe,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = usuario,
                    IsActive = true
                });

                nota.Asignaciones.Add(new NotaEntregaAsignacion
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    PedidoId = linea.PedidoId,
                    PedidoDetalleId = linea.PedidoDetalleId,
                    PedidoDetalleTallaId = linea.PedidoDetalleTallaId,
                    PedidoConceptoId = linea.PedidoConceptoId,
                    TipoOrigen = linea.TipoOrigen,
                    Cantidad = linea.CantidadSeleccionada,
                    CantidadFgTomada = linea.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto ? linea.CantidadSeleccionada : 0,
                    PrecioUnitario = linea.PrecioUnitario,
                    Importe = linea.Importe,
                    EsParcial = true,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = usuario,
                    IsActive = true
                });

                if (linea.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto && linea.PedidoDetalleTallaId.HasValue)
                {
                    var detalleTalla = await db.PedidosDetalleTalla
                        .Include(t => t.ProductoVariante)
                        .Include(t => t.PedidoDetalle)
                        .FirstOrDefaultAsync(t => t.Id == linea.PedidoDetalleTallaId.Value);

                    if (detalleTalla?.ProductoVarianteId is Guid varianteId && detalleTalla.ProductoVariante != null)
                    {
                        var inventarioFg = await db.InventariosFinishedGoods.FirstOrDefaultAsync(i => i.EmpresaId == _empresaId && i.ClienteId == clienteId && i.ProductoVarianteId == varianteId);
                        if (inventarioFg == null || inventarioFg.CantidadDisponible < linea.CantidadSeleccionada)
                            throw new InvalidOperationException($"FG insuficiente para {linea.NumeroPedido} {(linea.Talla ?? "")}".Trim());

                        var existenciaAnterior = inventarioFg.CantidadDisponible;
                        inventarioFg.CantidadDisponible -= linea.CantidadSeleccionada;
                        inventarioFg.UpdatedAt = DateTime.UtcNow;
                        inventarioFg.UpdatedBy = usuario;

                        db.MovimientosFinishedGoods.Add(new MovimientoFinishedGood
                        {
                            Id = Guid.NewGuid(),
                            EmpresaId = _empresaId,
                            InventarioFinishedGoodId = inventarioFg.Id,
                            TipoMovimiento = MovimientoFinishedGoodTipoEnum.SalidaNotaEntrega,
                            Cantidad = linea.CantidadSeleccionada,
                            ExistenciaAnterior = existenciaAnterior,
                            ExistenciaNueva = inventarioFg.CantidadDisponible,
                            FechaMovimiento = DateTime.UtcNow,
                            Referencia = numeroNota,
                            Observaciones = $"Salida por nota consolidada {numeroNota}",
                            PedidoId = linea.PedidoId,
                            PedidoDetalleTallaId = linea.PedidoDetalleTallaId,
                            NotaEntregaId = nota.Id,
                            CreatedAt = DateTime.UtcNow,
                            CreatedBy = usuario,
                            IsActive = true
                        });
                    }
                }
            }

            db.NotasEntrega.Add(nota);
            await db.SaveChangesAsync();
            await NotaEntregaPdfService.GenerateAndStoreAsync(nota.Id);

            var pedidosRelacionados = await db.Pedidos.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.Id)).ToListAsync();
            foreach (var pedidoRelacionado in pedidosRelacionados)
            {
                var tieneAsignacionesActivas = await db.NotasEntregaAsignaciones
                    .AnyAsync(a => a.PedidoId == pedidoRelacionado.Id && a.IsActive && a.NotaEntrega.IsActive && a.NotaEntrega.Estatus != NotaEntregaEstatus.Cancelada);

                pedidoRelacionado.Estado = tieneAsignacionesActivas ? EstadoPedidoEnum.Entregado : EstadoPedidoEnum.EnProceso;
                pedidoRelacionado.UpdatedAt = DateTime.UtcNow;
                pedidoRelacionado.UpdatedBy = usuario;
            }

            await db.SaveChangesAsync();

            okNotaConsolidada = $"Nota {numeroNota} generada correctamente.";
            pedidosNotaConsolidadaSeleccionados.Clear();
            await CargarPedidos();
            pedidosElegiblesNotaConsolidada = (await NotaEntregaConsolidadaService.GetPedidosElegiblesAsync(clienteId)).ToList();
        }
        catch (Exception ex)
        {
            errorNotaConsolidada = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardandoNotaConsolidada = false;
        }
    }

    private async Task CargarPedidos()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var pedidosExistentes = await db.PedidosSerigrafia
            .AsNoTracking()
            .Include(p => p.PedidoDetalle)
                .ThenInclude(pd => pd.Pedido)
                    .ThenInclude(ped => ped.Cliente)
            .Include(p => p.PedidoDetalle)
                .ThenInclude(pd => pd.DetallesTalla)
                    .ThenInclude(dt => dt.ProductoVariante)
            .Include(p => p.PedidoDetalle)
                .ThenInclude(pd => pd.CotizacionSerigrafia)
            .Include(p => p.TiposProceso)
                .ThenInclude(tp => tp.TipoProceso)
            .Include(p => p.Tallas)
            .Where(p => p.IsActive && (_empresaId == Guid.Empty || p.PedidoDetalle.Pedido.Cliente.EmpresaId == _empresaId))
            .OrderByDescending(p => p.FechaRecibido)
            .ToListAsync();

        var pedidosServicio = await db.Pedidos
            .AsNoTracking()
            .Include(p => p.Cliente)
            .Include(p => p.Conceptos)
            .Where(p => p.IsActive
                && (_empresaId == Guid.Empty || p.Cliente.EmpresaId == _empresaId)
                && p.Conceptos.Any(c => c.IsActive)
                && !p.Detalles.Any())
            .OrderByDescending(p => p.FechaPedido)
            .ToListAsync();

        var detallesConPedido = await db.PedidoDetalles
            .AsNoTracking()
            .Include(d => d.Pedido)
                .ThenInclude(p => p.Cliente)
            .Include(d => d.Producto)
            .Include(d => d.ProductoVariante)
            .Include(d => d.CotizacionSerigrafia)
            .Include(d => d.DetallesTalla)
                .ThenInclude(t => t.ProductoVariante)
            .Where(d => d.Pedido.IsActive
                && d.Producto.IsActive
                && (_empresaId == Guid.Empty || d.Pedido.Cliente.EmpresaId == _empresaId)
                && (d.Producto.Industria == IndustriaEnum.Serigrafia || d.Producto.Industria == IndustriaEnum.Ambas || d.CotizacionSerigrafiaId.HasValue))
            .OrderByDescending(d => d.Pedido.FechaPedido)
            .ToListAsync();

        pedidoSerigrafiaPorPedidoDetalle.Clear();
        foreach (var pedidoExistente in pedidosExistentes)
        {
            pedidoSerigrafiaPorPedidoDetalle[pedidoExistente.PedidoDetalleId] = pedidoExistente.Id;
        }

        var pedidosPorDetalle = pedidosExistentes.ToDictionary(p => p.PedidoDetalleId);
        var listaUnificada = new List<PedidoSerigrafia>();
        foreach (var detalle in detallesConPedido)
        {
            if (pedidosPorDetalle.TryGetValue(detalle.Id, out var pedidoExistente))
            {
                listaUnificada.Add(pedidoExistente);
                continue;
            }

            listaUnificada.Add(CrearPedidoSerigrafiaVirtual(detalle));
        }

        foreach (var pedidoServicio in pedidosServicio)
        {
            listaUnificada.Add(CrearPedidoSerigrafiaVirtualDesdeServicios(pedidoServicio));
        }

        pedidos = listaUnificada
            .OrderByDescending(p => p.FechaRecibido ?? p.PedidoDetalle?.Pedido?.FechaPedido)
            .ToList();
        await CargarSeguimientosPorPedidoAsync();
        ComputarColumnas();
    }

    private async Task CargarSeguimientosPorPedidoAsync()
    {
        if (pedidos == null) return;
        var ids = pedidos
            .Where(p => p.Id != Guid.Empty && pedidoSerigrafiaPorPedidoDetalle.ContainsValue(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (ids.Count == 0)
        {
            seguimientosPorPedido = new();
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var todos = await db.PedidoSerigrafiaTallaProcesos
            .Where(s => ids.Contains(s.PedidoSerigrafiaId))
            .ToListAsync();
        seguimientosPorPedido = todos.GroupBy(s => s.PedidoSerigrafiaId)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private void ComputarColumnas()
    {
        if (pedidos == null || tiposProceso == null) return;
        var usedIds = pedidos.SelectMany(p => p.TiposProceso.Select(tp => tp.TipoProcesoId)).ToHashSet();
        tablaProcesses = tiposProceso.Where(tp => usedIds.Contains(tp.Id)).OrderBy(tp => tp.Orden).ToList();
        tallasTabla = pedidos.SelectMany(p => p.Tallas.Select(t => t.Talla))
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    private static PedidoSerigrafia CrearPedidoSerigrafiaVirtual(PedidoDetalle detalle)
    {
        var color = detalle.VariacionValor ?? detalle.ProductoVariante?.Color ?? string.Empty;
        var tallas = detalle.DetallesTalla
            .Where(t => t.IsActive && t.Cantidad > 0)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new PedidoSerigrafiaTalla
            {
                Id = t.Id,
                PedidoSerigrafiaId = Guid.Empty,
                Talla = t.Talla,
                Cantidad = (int)Math.Round(t.Cantidad),
                CreatedAt = t.CreatedAt,
                UpdatedAt = t.UpdatedAt,
                CreatedBy = t.CreatedBy,
                UpdatedBy = t.UpdatedBy,
                IsActive = t.IsActive
            })
            .ToList();

        var corrida = tallas.Count == 0
            ? string.Empty
            : string.Join(", ", tallas.Select(t => $"{t.Talla}:{t.Cantidad}"));

        return new PedidoSerigrafia
        {
            Id = Guid.Empty,
            PedidoDetalleId = detalle.Id,
            PedidoDetalle = detalle,
            Estilo = detalle.Producto?.Nombre ?? string.Empty,
            CombinacionColor = color,
            Corrida = corrida,
            FechaRecibido = detalle.Pedido?.FechaPedido,
            FechaEstimada = detalle.Pedido?.FechaEntregaEstimada,
            Hecho = detalle.Pedido?.Estado is EstadoPedidoEnum.Entregado or EstadoPedidoEnum.Facturado or EstadoPedidoEnum.Pagado,
            Factura = string.Empty,
            Tallas = tallas,
            TiposProceso = new List<PedidoSerigrafiaProcesoDetalle>(),
            CreatedAt = detalle.CreatedAt,
            UpdatedAt = detalle.UpdatedAt,
            CreatedBy = detalle.CreatedBy,
            UpdatedBy = detalle.UpdatedBy,
            IsActive = detalle.IsActive
        };
    }

    private static PedidoSerigrafia CrearPedidoSerigrafiaVirtualDesdeServicios(Pedido pedido)
    {
        var conceptos = pedido.Conceptos
            .Where(c => c.IsActive)
            .OrderBy(c => c.CreatedAt)
            .ToList();

        var estilo = conceptos.Count == 1
            ? conceptos[0].Descripcion
            : $"Servicios ({conceptos.Count})";

        return new PedidoSerigrafia
        {
            Id = Guid.Empty,
            PedidoDetalleId = Guid.Empty,
            PedidoDetalle = new PedidoDetalle
            {
                Id = Guid.Empty,
                PedidoId = pedido.Id,
                Pedido = pedido,
                Producto = new Producto
                {
                    Id = Guid.Empty,
                    EmpresaId = pedido.Cliente.EmpresaId,
                    Codigo = "SERVICIO",
                    Nombre = "Servicios",
                    Industria = IndustriaEnum.Serigrafia,
                    IsActive = true,
                    CreatedAt = pedido.CreatedAt
                },
                Cantidad = conceptos.Sum(c => Math.Max(1, c.Cantidad)),
                PrecioUnitario = 0m,
                Total = conceptos.Sum(c => c.Total),
                CreatedAt = pedido.CreatedAt,
                UpdatedAt = pedido.UpdatedAt,
                CreatedBy = pedido.CreatedBy,
                UpdatedBy = pedido.UpdatedBy,
                IsActive = pedido.IsActive,
                DetallesTalla = new List<PedidoDetalleTalla>()
            },
            Estilo = estilo,
            CombinacionColor = string.Empty,
            Corrida = "Servicios",
            FechaRecibido = pedido.FechaPedido,
            FechaEstimada = pedido.FechaEntregaEstimada,
            Hecho = pedido.Estado is EstadoPedidoEnum.Entregado or EstadoPedidoEnum.Facturado or EstadoPedidoEnum.Pagado,
            Factura = string.Empty,
            Tallas = new List<PedidoSerigrafiaTalla>(),
            TiposProceso = new List<PedidoSerigrafiaProcesoDetalle>(),
            CreatedAt = pedido.CreatedAt,
            UpdatedAt = pedido.UpdatedAt,
            CreatedBy = pedido.CreatedBy,
            UpdatedBy = pedido.UpdatedBy,
            IsActive = pedido.IsActive
        };
    }

    private (int completados, int total) ProgresoTalla(Guid pedidoId, Guid tallaId, IEnumerable<Guid> procesoIds)
    {
        if (!seguimientosPorPedido.TryGetValue(pedidoId, out var segs)) return (0, 0);
        var total = procesoIds.Count();
        var completados = segs.Count(s => s.PedidoSerigrafiaTallaId == tallaId && procesoIds.Contains(s.TipoProcesoId) && s.Completado);
        return (completados, total);
    }

    private async Task ActualizarEstadoPedidoAsync(Guid pedidoSerigrafiaId)
    {
        var pedidoSerigrafia = await DbContext.PedidosSerigrafia
            .Include(p => p.TiposProceso)
            .Include(p => p.Tallas)
            .FirstOrDefaultAsync(p => p.Id == pedidoSerigrafiaId);

        if (pedidoSerigrafia == null) return;

        var detalle = await DbContext.PedidoDetalles.FindAsync(pedidoSerigrafia.PedidoDetalleId);
        if (detalle == null) return;

        var pedido = await DbContext.Pedidos.FindAsync(detalle.PedidoId);
        if (pedido == null) return;

        var procesos = pedidoSerigrafia.TiposProceso.Select(tp => tp.TipoProcesoId).ToList();
        var tallas = pedidoSerigrafia.Tallas.Select(t => t.Id).ToList();
        var segs = await DbContext.PedidoSerigrafiaTallaProcesos
            .Where(s => s.PedidoSerigrafiaId == pedidoSerigrafiaId)
            .ToListAsync();
        var conceptos = await DbContext.PedidoConceptos
            .Where(c => c.PedidoId == pedido.Id && c.IsActive)
            .ToListAsync();
        var notasEntrega = await DbContext.NotasEntrega
            .Include(n => n.Detalles)
                .ThenInclude(d => d.Tallas)
            .Include(n => n.FacturasRelacionadas)
                .ThenInclude(r => r.Factura)
            .Where(n => n.PedidoId == pedido.Id && n.IsActive)
            .ToListAsync();

        var totalComb = procesos.Count * tallas.Count;
        var completados = segs.Count(s => s.Completado && procesos.Contains(s.TipoProcesoId) && tallas.Contains(s.PedidoSerigrafiaTallaId));
        var totalConceptos = conceptos.Count;
        var conceptosCompletados = conceptos.Count(c => c.Completado);
        var serviciosEnProceso = conceptos.Any(c => c.Completado || c.FechaCompletado.HasValue);
        var serviciosCompletos = totalConceptos == 0 || conceptosCompletados == totalConceptos;
        var productoCompleto = totalComb > 0 && completados == totalComb;
        var productoEnProceso = completados > 0;

        var nuevoEstado = EstadoPedidoEnum.Nuevo;

        var totalPagado = await DbContext.PagosPedido
            .Where(pg => pg.PedidoId == pedido.Id && pg.IsActive)
            .SumAsync(pg => pg.Monto);
        var piezasPedidoTotal = pedidoSerigrafia.Tallas.Sum(t => t.Cantidad);
        var piezasEntregadas = notasEntrega.Sum(ObtenerCantidadNotaEntrega);
        var entregaCompleta = piezasPedidoTotal > 0 && piezasEntregadas >= piezasPedidoTotal;
        var tieneNotas = notasEntrega.Any();
        var notasFacturadas = notasEntrega.Count(n => n.FacturasRelacionadas.Any(r => r.IsActive && r.Factura.IsActive && r.Factura.Estatus != FacturaEstatus.Cancelado));
        var cumplimientoOperativoCompleto = productoCompleto && serviciosCompletos;
        var cumplimientoOperativoEnProceso = productoEnProceso || serviciosEnProceso;

        if (cumplimientoOperativoCompleto && entregaCompleta && tieneNotas && notasFacturadas == notasEntrega.Count)
        {
            nuevoEstado = pedido.Total > 0 && totalPagado >= pedido.Total
                ? EstadoPedidoEnum.Pagado
                : EstadoPedidoEnum.Facturado;
        }
        else if (cumplimientoOperativoCompleto && entregaCompleta && tieneNotas)
        {
            nuevoEstado = EstadoPedidoEnum.Entregado;
        }
        else if (cumplimientoOperativoCompleto)
        {
            nuevoEstado = EstadoPedidoEnum.Producido;
        }
        else if (cumplimientoOperativoEnProceso || tieneNotas)
        {
            nuevoEstado = EstadoPedidoEnum.EnProceso;
        }

        if (pedido.Estado != nuevoEstado)
        {
            pedido.Estado = nuevoEstado;
            pedido.UpdatedAt = DateTime.UtcNow;
            await DbContext.SaveChangesAsync();
        }
    }

    private static int ObtenerCantidadNotaEntrega(NotaEntrega nota)
    {
        var cantidadTallas = nota.Detalles.SelectMany(d => d.Tallas).Sum(t => t.Cantidad);
        return cantidadTallas > 0
            ? (int)Math.Round(cantidadTallas)
            : (int)Math.Round(nota.Detalles.Sum(d => d.Cantidad));
    }

