@page "/serigrafia/pedidos"
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Calzado
@using MundoVs.Core.Entities.Inventario
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Infrastructure.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject IPedidoSerigrafiaRepository PedidoSerigrafiaRepository
@inject IClienteRepository ClienteRepository
@inject IPedidoRepository PedidoRepository
@inject IProductoRepository ProductoRepository
@inject IProductoClienteRepository ProductoClienteRepository
@inject IRepository<TipoProceso> TipoProcesoRepository
@inject IRepository<PedidoDetalle> PedidoDetalleRepository
@inject INotaEntregaConsolidadaService NotaEntregaConsolidadaService
@inject INotaEntregaPdfService NotaEntregaPdfService
@inject CrmDbContext DbContext
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Pedidos</PageTitle>

<div class="ps-page">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <div>
            <h1 class="ps-title mb-1"><i class="bi bi-clipboard-check me-2"></i>Pedidos</h1>
            <p class="text-muted mb-0" style="font-size:.85rem">Gestión y seguimiento de pedidos</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn ps-btn-secondary" @onclick="AbrirModalNotaConsolidada">
                <i class="bi bi-journal-plus me-1"></i> Crear nota
            </button>
            <button class="btn ps-btn-primary" @onclick="NuevoPedido">
                <i class="bi bi-plus-circle me-1"></i> Nuevo Pedido
            </button>
        </div>
    </div>

    @if (modalNotaConsolidadaAbierto)
    {
        <div class="ps-modal-backdrop" @onclick="CerrarModalNotaConsolidada"></div>
        <div class="ps-modal-card">
            <div class="ps-form-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-journal-text fs-5"></i>
                    <h5 class="mb-0">Nota consolidada por cliente</h5>
                </div>
                <button type="button" class="btn-close" @onclick="CerrarModalNotaConsolidada"></button>
            </div>
            <div class="p-3">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="ps-label">Cliente</label>
                        <select class="form-select ps-input" value="@clienteNotaConsolidadaId" @onchange="OnClienteNotaConsolidadaChanged">
                            <option value="">Seleccione cliente...</option>
                            @if (clientes != null)
                            {
                                @foreach (var cliente in clientes)
                                {
                                    <option value="@cliente.Id">@cliente.RazonSocial</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="ps-filter-pill">@pedidosElegiblesNotaConsolidada.Count pedido(s) elegible(s)</div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorNotaConsolidada))
                {
                    <div class="alert alert-danger py-2">@errorNotaConsolidada</div>
                }
                @if (!string.IsNullOrWhiteSpace(okNotaConsolidada))
                {
                    <div class="alert alert-success py-2">@okNotaConsolidada</div>
                }

                @if (cargandoPedidosNotaConsolidada)
                {
                    <div class="text-muted">Cargando pedidos elegibles...</div>
                }
                else if (!pedidosElegiblesNotaConsolidada.Any())
                {
                    <div class="text-muted">Selecciona un cliente para ver pedidos elegibles.</div>
                }
                else
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:36px"></th>
                                    <th>Pedido</th>
                                    <th>Fecha</th>
                                    <th class="text-end">Producto pendiente</th>
                                    <th class="text-end">Servicios pendientes</th>
                                    <th>Estatus</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in pedidosElegiblesNotaConsolidada)
                                {
                                    <tr>
                                        <td>
                                            <input type="checkbox" class="form-check-input" checked="@pedidosNotaConsolidadaSeleccionados.Contains(item.PedidoId)" disabled="@(!item.Elegible)" @onchange="e => OnPedidoNotaConsolidadaChanged(item.PedidoId, e)" />
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@item.NumeroPedido</div>
                                            <div class="small text-muted">@item.TotalPedido.ToString("C2")</div>
                                        </td>
                                        <td>@item.FechaPedido.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">@item.CantidadProductoPendiente.ToString("N2")</td>
                                        <td class="text-end">@item.CantidadServiciosPendientes.ToString("N0")</td>
                                        <td>
                                            @if (item.Elegible)
                                            {
                                                <span class="badge bg-success-subtle text-success-emphasis">Elegible</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger-emphasis">@item.MotivoBloqueo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="alert alert-info py-2 mb-0">
                        <strong>Seleccionados:</strong>
                        @(pedidosNotaConsolidadaSeleccionados.Count == 0
                            ? "Ninguno"
                            : string.Join(", ", pedidosElegiblesNotaConsolidada.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId)).Select(p => p.NumeroPedido)))
                    </div>

                    @if (pedidosNotaConsolidadaSeleccionados.Any())
                    {
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="button" class="btn btn-sm ps-btn-secondary" @onclick="TomarMaximoLineasNotaConsolidada">
                                    <i class="bi bi-box-arrow-in-down-right me-1"></i>Tomar máximo
                                </button>
                                <button type="button" class="btn btn-sm ps-btn-secondary" @onclick="LimpiarLineasNotaConsolidada">
                                    <i class="bi bi-eraser me-1"></i>Limpiar
                                </button>
                            </div>
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="aplicaIvaNotaConsolidada" />
                                <label class="form-check-label">Aplica IVA</label>
                            </div>
                        </div>

                        <div class="table-responsive mt-3">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Pedido</th>
                                        <th class="text-end">Pendiente producto</th>
                                        <th class="text-end">Pendiente servicios</th>
                                        <th class="text-end">Importe base</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in pedidosElegiblesNotaConsolidada.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId)))
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.NumeroPedido</td>
                                            <td class="text-end">@item.CantidadProductoPendiente.ToString("N2")</td>
                                            <td class="text-end">@item.CantidadServiciosPendientes.ToString("N0")</td>
                                            <td class="text-end">@item.TotalPedido.ToString("C2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td class="fw-bold">Resumen</td>
                                        <td class="text-end fw-bold">@pedidosElegiblesNotaConsolidada.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId)).Sum(p => p.CantidadProductoPendiente).ToString("N2")</td>
                                        <td class="text-end fw-bold">@pedidosElegiblesNotaConsolidada.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId)).Sum(p => p.CantidadServiciosPendientes).ToString("N0")</td>
                                        <td class="text-end fw-bold">@pedidosElegiblesNotaConsolidada.Where(p => pedidosNotaConsolidadaSeleccionados.Contains(p.PedidoId)).Sum(p => p.TotalPedido).ToString("C2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-3">
                            <button type="button" class="btn ps-btn-primary" @onclick="GenerarNotaConsolidadaInicialAsync" disabled="@guardandoNotaConsolidada">
                                @if (guardandoNotaConsolidada)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                <i class="bi bi-save me-1"></i>Generar nota inicial
                            </button>
                        </div>

                        @if (lineasNotaConsolidada.Any())
                        {
                            <div class="table-responsive mt-3">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Pedido</th>
                                            <th>Tipo</th>
                                            <th>Descripción</th>
                                            <th>Talla</th>
                                        <th class="text-end">FG disp.</th>
                                        <th class="text-end">Máx.</th>
                                        <th class="text-end">Cantidad</th>
                                            <th class="text-end">Precio</th>
                                            <th class="text-end">Importe</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var linea in lineasNotaConsolidada)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@linea.NumeroPedido</td>
                                                <td>@linea.TipoOrigen</td>
                                                <td>@linea.Descripcion</td>
                                                <td>@(linea.Talla ?? "—")</td>
                                                <td class="text-end">@(linea.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto ? linea.CantidadDisponibleFg.ToString("N2") : "—")</td>
                                                <td class="text-end">@linea.CantidadMaximaTomable.ToString("N2")</td>
                                                <td class="text-end" style="min-width:110px">
                                                    <input type="number"
                                                           step="0.01"
                                                           min="0"
                                                           max="@((linea.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto ? Math.Min(linea.CantidadMaximaTomable, linea.CantidadDisponibleFg) : linea.CantidadMaximaTomable).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                                           class="form-control form-control-sm text-end"
                                                           value="@linea.CantidadSeleccionada.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                           @onchange="@(e => OnLineaNotaCantidadInput(linea, e))" />
                                                </td>
                                                <td class="text-end">@linea.PrecioUnitario.ToString("C2")</td>
                                                <td class="text-end">@linea.Importe.ToString("C2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="d-flex justify-content-end mt-3">
                                <div class="ps-box" style="min-width:280px">
                                    <div class="d-flex justify-content-between"><span>Subtotal</span><strong>@SubtotalNotaConsolidada.ToString("C2")</strong></div>
                                    <div class="d-flex justify-content-between"><span>IVA</span><strong>@ImpuestosNotaConsolidada.ToString("C2")</strong></div>
                                    <div class="d-flex justify-content-between border-top pt-2 mt-2"><span>Total</span><strong>@TotalNotaConsolidada.ToString("C2")</strong></div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    }

    <!-- Filtros -->
    <div class="ps-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Estado</label>
                <select class="form-select ps-input" @onchange="FiltrarPorEstado">
                    <option value="">Todos los pedidos</option>
                    <option value="pendientes">Pendientes</option>
                    <option value="completados">Completados</option>
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Desde</label>
                <input type="date" class="form-control ps-input" @bind="fechaDesde" />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Hasta</label>
                <input type="date" class="form-control ps-input" @bind="fechaHasta" />
            </div>
            <div class="col-12 col-sm-6 col-md-4">
                <label class="ps-label">Buscar</label>
                <input type="text"
                       class="form-control ps-input"
                       @bind="busquedaTexto"
                       @bind:event="oninput"
                       placeholder="Pedido, cliente, estilo, color..." />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <button class="btn ps-btn-secondary w-100" @onclick="FiltrarPorFechas">
                    <i class="bi bi-search me-1"></i> Buscar
                </button>
            </div>
        </div>
        <div class="ps-filter-meta">
            <span class="ps-filter-pill">@PedidosFiltrados.Count() de @(pedidos?.Count() ?? 0) pedidos</span>
            <span class="ps-filter-hint">Usa <strong>Procesar</strong> para entrar directo al seguimiento del pedido.</span>
        </div>
    </div>

    @if (mostrarFormulario)
    {
        <div class="ps-card ps-form-card mb-4">
            <div class="ps-form-header">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi @(pedidoEditando.Id == Guid.Empty ? "bi-plus-circle" : "bi-pencil-square") fs-5"></i>
                    <h5 class="mb-0">@(pedidoEditando.Id == Guid.Empty ? "Nuevo Pedido" : "Editar Pedido")</h5>
                </div>
            </div>
            <div class="p-4">
                <EditForm Model="pedidoEditando" OnValidSubmit="GuardarPedido">

                    <div class="ps-section-label">Información General</div>
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-sm-6 col-md-3">
                            <label class="ps-label">Fecha Recibido</label>
                            <InputDate class="form-control ps-input" @bind-Value="pedidoEditando.FechaRecibido" />
                        </div>
                        <div class="col-12 col-sm-6 col-md-3">
                            <label class="ps-label">Fecha Estimada</label>
                            <InputDate class="form-control ps-input" @bind-Value="pedidoEditando.FechaEstimada" />
                        </div>
                        <div class="col-12 col-sm-6 col-md-3">
                            <label class="ps-label">Cliente</label>
                            <InputSelect class="form-select ps-input" @bind-Value="clienteSeleccionadoId" @bind-Value:after="OnClienteChanged">
                                <option value="">Seleccione cliente...</option>
                                @if (clientes != null)
                                {
                                    @foreach (var cliente in clientes)
                                    {
                                        <option value="@cliente.Id">@cliente.RazonSocial</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="ps-label">Tipo de Precio</label>
                            <InputSelect class="form-select ps-input" @bind-Value="tipoPrecioSeleccionado">
                                <option value="@TipoPrecioEnum.Contado">Contado</option>
                                <option value="@TipoPrecioEnum.Credito">Crédito</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="ps-label">Tipo de captura</label>
                            <InputSelect class="form-select ps-input" @bind-Value="tipoCapturaSeleccionado">
                                <option value="@PedidoModoCaptura.Productos">Productos</option>
                                <option value="@PedidoModoCaptura.Servicios">Servicios</option>
                                <option value="@PedidoModoCaptura.Ambos">Ambos</option>
                            </InputSelect>
                        </div>
                    </div>

                    @if (MuestraProductos)
                    {
                        <div class="row g-3 mb-4">
                            <div class="col-12 col-sm-6 col-md-3">
                                <label class="ps-label">Producto</label>
                                <InputSelect class="form-select ps-input" @bind-Value="productoSeleccionadoId" @bind-Value:after="OnProductoChanged" disabled="@(productosCliente == null || !productosCliente.Any())">
                                    <option value="">@(productosCliente == null ? "Seleccione cliente primero" : productosCliente.Any() ? "Seleccione producto..." : "Sin productos asignados ni cotizados")</option>
                                    @if (productosCliente != null)
                                    {
                                        @foreach (var producto in productosCliente)
                                        {
                                            <option value="@producto.Id">@producto.Nombre</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12 col-sm-6 col-md-5">
                                <label class="ps-label">Cotización base</label>
                                <InputSelect class="form-select ps-input"
                                             @bind-Value="cotizacionSeleccionadaId"
                                             @bind-Value:after="OnCotizacionChanged"
                                             disabled="!productoSeleccionadoId.HasValue || !cotizacionesProducto.Any()">
                                    <option value="">@(productoSeleccionadoId.HasValue
                                        ? (cotizacionesProducto.Any() ? "Seleccione cotización..." : "Sin cotizaciones disponibles")
                                        : "Seleccione producto primero")</option>
                                    @foreach (var cotizacion in cotizacionesProducto)
                                    {
                                        <option value="@cotizacion.Id">@ObtenerEtiquetaCotizacion(cotizacion)</option>
                                    }
                                </InputSelect>
                                <small class="text-muted">El precio del pedido se calculará con la cotización seleccionada.</small>
                            </div>
                        </div>

                        @if (cotizacionSeleccionadaId.HasValue)
                        {
                            var cotizacionSeleccionada = cotizacionesProducto.FirstOrDefault(c => c.Id == cotizacionSeleccionadaId.Value);
                            if (cotizacionSeleccionada != null)
                            {
                                <div class="row g-3 mb-4">
                                    <div class="col-12 col-md-4">
                                        <div class="ps-box">
                                            <small class="text-muted d-block">Descripción</small>
                                            <strong>@(string.IsNullOrWhiteSpace(cotizacionSeleccionada.Descripcion) ? "Sin descripción" : cotizacionSeleccionada.Descripcion)</strong>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="ps-box">
                                            <small class="text-muted d-block">Precio contado</small>
                                            <strong>@cotizacionSeleccionada.PrecioFinalContado.ToString("C2")</strong>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <div class="ps-box">
                                            <small class="text-muted d-block">Precio crédito</small>
                                            <strong>@cotizacionSeleccionada.PrecioCredito.ToString("C2")</strong>
                                        </div>
                                    </div>
                                </div>

                                @if (tallasEditando.Any(t => t.Cantidad > 0))
                                {
                                    var resumenPrecios = ConstruirResumenPreciosCotizacion(cotizacionSeleccionada, tallasEditando, pedidoEditando.CombinacionColor, tipoPrecioSeleccionado);
                                    <div class="ps-box mb-4">
                                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                                            <div>
                                                <div class="ps-section-label mb-1" style="border-bottom:none;padding-bottom:0">Precio aplicado por talla</div>
                                                <div class="text-muted small">La cotización define el precio final. Si no hay coincidencia específica, se usa el precio base.</div>
                                            </div>
                                            <span class="ps-total-badge">Subtotal producto: @resumenPrecios.Sum(r => r.Subtotal).ToString("C2")</span>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Talla</th>
                                                        <th>SKU</th>
                                                        <th class="text-center">Cantidad</th>
                                                        <th>Precio origen</th>
                                                        <th class="text-end">% aplicado</th>
                                                        <th class="text-end">Precio unitario</th>
                                                        <th class="text-end">Subtotal</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var precio in resumenPrecios)
                                                    {
                                                        <tr>
                                                            <td class="fw-semibold">@precio.Talla</td>
                                                            <td class="small">@ObtenerSkuTallaResumen(precio.Talla, precio.ColorAplicado)</td>
                                                            <td class="text-center">@precio.Cantidad</td>
                                                            <td>
                                                                <div>@precio.Etiqueta</div>
                                                                @if (!string.IsNullOrWhiteSpace(precio.ColorAplicado))
                                                                {
                                                                    <div class="text-muted small">@precio.ColorAplicado</div>
                                                                }
                                                            </td>
                                                            <td class="text-end">@precio.PorcentajeAplicado.ToString("N2")%</td>
                                                            <td class="text-end fw-semibold">@precio.PrecioUnitario.ToString("C2")</td>
                                                            <td class="text-end">@precio.Subtotal.ToString("C2")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            }
                        }

                        <div class="ps-section-label">Detalles del Pedido</div>
                        <div class="row g-3 mb-4">
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">Estilo</label>
                                <InputText class="form-control ps-input" @bind-Value="pedidoEditando.Estilo" placeholder="Ej: Polo Básico" />
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">@(ProductoUsaVariantesColor ? "Variación" : "Combinación de Color")</label>
                                @if (ProductoUsaVariantesColor)
                                {
                                    <InputSelect class="form-select ps-input" @bind-Value="variacionSeleccionada" @bind-Value:after="OnVariacionSeleccionadaChanged">
                                        <option value="">Seleccione variación...</option>
                                        @foreach (var variacion in ObtenerVariacionesDisponibles(productoSeleccionadoId))
                                        {
                                            <option value="@variacion">@variacion</option>
                                        }
                                    </InputSelect>
                                    <small class="text-muted">La variación filtra los `SKU` disponibles para tallas y fracciones.</small>
                                }
                                else
                                {
                                    <InputText class="form-control ps-input" @bind-Value="pedidoEditando.CombinacionColor" placeholder="Ej: FIUSHA/MORADO/BLANCO" />
                                }
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">Captura de escala</label>
                                <InputSelect class="form-select ps-input" @bind-Value="capturaEscalaSeleccionada" @bind-Value:after="OnCapturaEscalaChanged">
                                    <option value="@CapturaEscalaModo.Tallas">Tallas</option>
                                    @if (ProductoPermiteFraccion)
                                    {
                                        <option value="@CapturaEscalaModo.Fraccion">Fracción</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        @if (ProductoPermiteFraccion)
                        {
                            <div class="row g-3 mb-4">
                                <div class="col-12 col-md-6">
                                    <label class="ps-label">Fracciones disponibles</label>
                                    <InputSelect class="form-select ps-input"
                                                 @bind-Value="fraccionSeleccionadaId"
                                                 @bind-Value:after="OnFraccionRapidaChanged"
                                                 disabled="!fraccionesDisponiblesCliente.Any()">
                                        <option value="">Seleccione fracción si desea generar una escala...</option>
                                        @foreach (var fraccion in fraccionesDisponiblesCliente)
                                        {
                                            <option value="@fraccion.Id">@fraccion.Codigo - @fraccion.Nombre</option>
                                        }
                                    </InputSelect>
                                    <small class="text-muted">Si eliges una fracción, primero se toma la variación y luego se generan los `SKU` relacionados.</small>
                                </div>
                            </div>
                        }

                        @if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
                        {
