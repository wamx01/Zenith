    private async Task CargarSeguimientosAsync(Guid pedidoId)
    {
        if (pedidoId == Guid.Empty)
        {
            seguimientoTallaProcesos = new();
            return;
        }

        seguimientoTallaProcesos = await DbContext.PedidoSerigrafiaTallaProcesos
            .Include(s => s.Empleado)
            .Where(s => s.PedidoSerigrafiaId == pedidoId)
            .ToListAsync();

        var tallaIds = tallasEditando.Where(t => t.Id != Guid.Empty).Select(t => t.Id).ToList();
        var procesoIds = procesosSeleccionados.ToList();

        var nuevos = new List<PedidoSerigrafiaTallaProceso>();
        foreach (var tallaId in tallaIds)
        {
            foreach (var procId in procesoIds)
            {
                if (!seguimientoTallaProcesos.Any(s => s.PedidoSerigrafiaTallaId == tallaId && s.TipoProcesoId == procId))
                {
                    nuevos.Add(new PedidoSerigrafiaTallaProceso
                    {
                        Id = Guid.NewGuid(),
                        PedidoSerigrafiaId = pedidoId,
                        PedidoSerigrafiaTallaId = tallaId,
                        TipoProcesoId = procId,
                        CreatedAt = DateTime.UtcNow,
                        IsActive = true
                    });
                }
            }
        }

        if (nuevos.Any())
        {
            DbContext.PedidoSerigrafiaTallaProcesos.AddRange(nuevos);
            await DbContext.SaveChangesAsync();
            seguimientoTallaProcesos.AddRange(nuevos);
        }
    }

    private async Task GuardarSeguimientoAsync(PedidoSerigrafiaTallaProceso seg)
    {
        seg.UpdatedAt = DateTime.UtcNow;
        seg.UpdatedBy = await ObtenerUsuarioActualAsync();
        DbContext.PedidoSerigrafiaTallaProcesos.Update(seg);
        await DbContext.SaveChangesAsync();
        await ActualizarEstadoPedidoAsync(seg.PedidoSerigrafiaId);
    }

    private async Task OnSeguimientoChecked(PedidoSerigrafiaTallaProceso seg, bool value)
    {
        seg.Completado = value;
        if (value && seg.FechaPaso == null)
        {
            seg.FechaPaso = DateTime.UtcNow;
        }
        await GuardarSeguimientoAsync(seg);
    }

    private async Task OnSeguimientoFechaChanged(PedidoSerigrafiaTallaProceso seg, DateTime? value)
    {
        seg.FechaPaso = value;
        await GuardarSeguimientoAsync(seg);
    }

    private async Task OnSeguimientoEmpleadoChanged(PedidoSerigrafiaTallaProceso seg, Guid? value)
    {
        seg.EmpleadoId = value;
        await GuardarSeguimientoAsync(seg);
    }

    // ===== Filtros =====

    private async Task FiltrarPorEstado(ChangeEventArgs e)
    {
        var estado = e.Value?.ToString();
        await CargarPedidos();

        pedidos = estado switch
        {
            "pendientes" => pedidos?.Where(p => !p.Hecho).ToList(),
            "completados" => pedidos?.Where(p => p.Hecho).ToList(),
            _ => pedidos
        };

        await CargarSeguimientosPorPedidoAsync();
        ComputarColumnas();
    }

    private async Task FiltrarPorFechas()
    {
        if (fechaDesde.HasValue && fechaHasta.HasValue)
        {
            await CargarPedidos();
            pedidos = pedidos?
                .Where(p => (p.FechaRecibido ?? p.PedidoDetalle?.Pedido?.FechaPedido) >= fechaDesde.Value
                    && (p.FechaRecibido ?? p.PedidoDetalle?.Pedido?.FechaPedido) <= fechaHasta.Value)
                .OrderBy(p => p.FechaRecibido ?? p.PedidoDetalle?.Pedido?.FechaPedido)
                .ToList();
            await CargarSeguimientosPorPedidoAsync();
            ComputarColumnas();
        }
        else
            await CargarPedidos();
    }

    // ===== Pagos =====

    private async Task CargarPagosAsync(Guid pedidoDetalleId)
    {
        var detalle = await DbContext.PedidoDetalles.FindAsync(pedidoDetalleId);
        if (detalle == null) { pagosDelPedido = new(); totalPedidoActual = 0; return; }

        var pedido = await DbContext.Pedidos.FindAsync(detalle.PedidoId);
        totalPedidoActual = pedido?.Total ?? 0;

        pagosDelPedido = await DbContext.PagosPedido
            .Where(p => p.PedidoId == detalle.PedidoId)
            .OrderBy(p => p.FechaPago)
            .ToListAsync();
    }

    private async Task AgregarPago()
    {
        if (nuevoPagoMonto <= 0) return;

        Guid pedidoId;
        if (pedidoEditando.PedidoDetalleId != Guid.Empty)
        {
            var detalle = await DbContext.PedidoDetalles.FindAsync(pedidoEditando.PedidoDetalleId);
            if (detalle == null) return;
            pedidoId = detalle.PedidoId;
        }
        else if (pedidoBaseIdEditando != Guid.Empty)
        {
            pedidoId = pedidoBaseIdEditando;
        }
        else
        {
            return;
        }

        // Validar que no exceda el saldo
        var pagadoActual = pagosDelPedido.Sum(p => p.Monto);
        var saldoRestante = totalPedidoActual - pagadoActual;
        if (nuevoPagoMonto > saldoRestante)
        {
            nuevoPagoMonto = saldoRestante;
        }
        if (nuevoPagoMonto <= 0) return;

        var pago = new PagoPedido
        {
            Id = Guid.NewGuid(),
            PedidoId = pedidoId,
            FechaPago = nuevoPagoFecha,
            Monto = nuevoPagoMonto,
            FormaPago = nuevoPagoFormaPago,
            Referencia = nuevoPagoReferencia,
            CreatedAt = DateTime.UtcNow,
            IsActive = true
        };

        DbContext.PagosPedido.Add(pago);
        await DbContext.SaveChangesAsync();

          await CargarPagosPedidoBaseAsync(pedidoId);
        ResetNuevoPago();
          if (pedidoEditando.Id != Guid.Empty)
          {
              await ActualizarEstadoPedidoAsync(pedidoEditando.Id);
          }
        await CargarPedidos();
    }

    private async Task EliminarPago(PagoPedido pago)
    {
        DbContext.PagosPedido.Remove(pago);
        await DbContext.SaveChangesAsync();
        pagosDelPedido.Remove(pago);
        await ActualizarEstadoPedidoAsync(pedidoEditando.Id);
        await CargarPedidos();
    }

    private async Task<string?> ObtenerUsuarioActualAsync()
