                                        {
                                            <span class="small text-muted">La distribución se genera automáticamente con la fracción seleccionada.</span>
                                        }
                                        else
                                        {
                                            <span class="small text-muted">Selecciona una fracción para generar las tallas del pedido.</span>
                                        }
                                    </div>
                                </div>

                                @if (tallasEditando.Any())
                                {
                                    <div class="col-12">
                                        <div class="ps-box">
                                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                                                <div>
                                                    <div class="ps-section-label mb-1" style="border-bottom:none;padding-bottom:0">SKU resuelto por fracción</div>
                                                    <div class="text-muted small">La fracción genera las tallas y la variación elegida determina los `SKU` relacionados.</div>
                                                </div>
                                                <span class="ps-total-badge">Pares: @tallasEditando.Sum(t => t.Cantidad)</span>
                                            </div>

                                            <div class="table-responsive">
                                                <table class="table table-sm align-middle mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Talla</th>
                                                            <th class="text-center">Cantidad</th>
                                                            <th>SKU resuelto</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var talla in tallasEditando.OrderBy(t => t.Talla))
                                                        {
                                                            <tr>
                                                                <td class="fw-semibold">@talla.Talla</td>
                                                                <td class="text-center">@talla.Cantidad</td>
                                                                <td>@ObtenerEtiquetaSkuResuelto(talla.Talla)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }

                    @if (MuestraProductos)
                    {
                        <div class="row g-3 mb-4">
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">OC (Orden de Compra)</label>
                                <InputText class="form-control ps-input" @bind-Value="pedidoEditando.OrdenCompra" />
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">Lote Cliente</label>
                                <InputText class="form-control ps-input" @bind-Value="pedidoEditando.LoteCliente" />
                            </div>
                            <div class="col-12 col-sm-6 col-md-4">
                                <label class="ps-label">Corrida</label>
                                <InputText class="form-control ps-input" @bind-Value="pedidoEditando.Corrida" placeholder="Ej: 25-28 o nombre interno de corrida" />
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="ps-section-label mb-0">Escala de Tallas</div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="ps-total-badge">Total: @tallasEditando.Sum(t => t.Cantidad)</span>
                                @if (capturaEscalaSeleccionada == CapturaEscalaModo.Tallas)
                                {
                                    <button type="button" class="btn ps-btn-secondary btn-sm" @onclick="AgregarCorridaDisponible" disabled="@(HayTallasDisponiblesParaCaptura ? null : "disabled")">
                                        <i class="bi bi-collection me-1"></i> Agregar todas las tallas
                                    </button>
                                    <button type="button" class="btn ps-btn-secondary btn-sm" @onclick="AgregarTallasSeleccionadas" disabled="@(HayTallasDisponiblesSeleccionadas() ? null : "disabled")">
                                        <i class="bi bi-check2-square me-1"></i> Agregar selección
                                    </button>
                                    <div class="input-group input-group-sm" style="width:260px">
                                        <InputSelect class="form-select ps-input" @bind-Value="nuevaTallaSeleccionada" disabled="@(HayTallasDisponiblesParaCaptura ? null : "disabled")">
                                            <option value="">@(HayTallasDisponiblesParaCaptura ? "Seleccione talla..." : "Sin tallas configuradas")</option>
                                            @foreach (var tallaDisponible in ObtenerTallasDisponiblesParaCaptura())
                                            {
                                                <option value="@tallaDisponible.Talla">@ObtenerEtiquetaTallaDisponible(tallaDisponible.Talla)</option>
                                            }
                                        </InputSelect>
                                        <button type="button" class="btn ps-btn-dark" @onclick="AgregarTalla" disabled="@((HayTallasDisponiblesParaCaptura && !string.IsNullOrWhiteSpace(nuevaTallaSeleccionada)) ? null : "disabled")">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="ps-filter-pill">Fracción x @cantidadFracciones</span>
                                }
                            </div>
                        </div>
                        <div class="ps-box mb-4">
                            @if (tallasEditando.Any())
                            {
                                var tallasSinSku = ObtenerTallasSinSku().Select(t => t.Talla).ToList();

                                @if (tallasSinSku.Any())
                                {
                                    <div class="alert alert-warning py-2 small mb-3">
                                        No existe `SKU` para las tallas <strong>@string.Join(", ", tallasSinSku)</strong> con la variación actual.
                                    </div>
                                }

                                <div class="row g-2">
                                    @foreach (var talla in tallasEditando.OrderBy(t => t.Talla))
                                    {
                                        <div class="col-6 col-sm-4 col-md-2">
                                            <div class="ps-talla-item">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="ps-talla-label">#@talla.Talla</span>
                                                    <button type="button" class="btn-close" style="font-size:.55rem" @onclick="() => QuitarTalla(talla)" aria-label="Quitar"></button>
                                                </div>
                                                <input type="number" class="form-control form-control-sm ps-input text-center" @bind="talla.Cantidad" @bind:after="OnCantidadesTallaChanged" min="0" />
                                                <div class="small text-muted mt-1 text-truncate" title="@ObtenerEtiquetaSkuResuelto(talla.Talla)">
                                                    SKU: @ObtenerEtiquetaSkuResuelto(talla.Talla)
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                @if (capturaEscalaSeleccionada == CapturaEscalaModo.Tallas && HayTallasDisponiblesParaCaptura)
                                {
                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-4 mb-2">
                                        <div>
                                            <div class="ps-section-label mb-1" style="border-bottom:none;padding-bottom:0">Más SKU disponibles para esta variación</div>
                                            <div class="text-muted small">Puedes seguir agregando varios SKU del mismo pedido.</div>
                                        </div>
                                        <span class="ps-total-badge">Disponibles: @ObtenerTallasDisponiblesParaCaptura().Count()</span>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width:120px" class="text-center">
                                                        <button type="button" class="ps-select-toggle @(TodasLasTallasDisponiblesSeleccionadas() ? "is-selected" : string.Empty)" @onclick="AlternarSeleccionTodasLasDisponibles">
                                                            <i class="bi @(TodasLasTallasDisponiblesSeleccionadas() ? "bi-check2-square" : "bi-square")"></i>
                                                            <span>Todas</span>
                                                        </button>
                                                    </th>
                                                    <th>Talla</th>
                                                    <th>Variación</th>
                                                    <th>SKU relacionado</th>
                                                    <th class="text-end">Precio cotizado</th>
                                                    <th style="width:90px"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var tallaDisponible in ObtenerTallasDisponiblesParaCaptura())
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <button type="button" class="ps-select-toggle @(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "is-selected" : string.Empty)" @onclick="() => AlternarSeleccionTallaDisponible(tallaDisponible.Talla)">
                                                                <i class="bi @(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "bi-check2-square" : "bi-square")"></i>
                                                                <span>@(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "Marcada" : "Marcar")</span>
                                                            </button>
                                                        </td>
                                                        <td class="fw-semibold">@tallaDisponible.Talla</td>
                                                        <td>@ObtenerEtiquetaVariacionAplicada()</td>
                                                        <td>@ObtenerEtiquetaSkuResuelto(tallaDisponible.Talla)</td>
                                                        <td class="text-end">@ObtenerPrecioCotizadoTallaTexto(tallaDisponible.Talla)</td>
                                                        <td class="text-end">
                                                            <button type="button" class="btn btn-sm ps-btn-secondary" @onclick="() => SeleccionarTallaDisponible(tallaDisponible.Talla)">
                                                                Agregar
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            }
                            else if (capturaEscalaSeleccionada == CapturaEscalaModo.Tallas && HayTallasDisponiblesParaCaptura)
                            {
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                                    <div>
                                        <div class="ps-section-label mb-1" style="border-bottom:none;padding-bottom:0">Tallas disponibles para la variación actual</div>
                                        <div class="text-muted small">Selecciona una talla puntual, agrega varias o carga todas las tallas disponibles.</div>
                                    </div>
                                    <span class="ps-total-badge">Disponibles: @ObtenerTallasDisponiblesParaCaptura().Count()</span>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                    <th style="width:120px" class="text-center">
                                                        <button type="button" class="ps-select-toggle @(TodasLasTallasDisponiblesSeleccionadas() ? "is-selected" : string.Empty)" @onclick="AlternarSeleccionTodasLasDisponibles">
                                                            <i class="bi @(TodasLasTallasDisponiblesSeleccionadas() ? "bi-check2-square" : "bi-square")"></i>
                                                            <span>Todas</span>
                                                        </button>
                                                    </th>
                                                <th>Talla</th>
                                                    <th>Variación</th>
                                                <th>SKU relacionado</th>
                                                    <th class="text-end">Precio cotizado</th>
                                                <th style="width:90px"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var tallaDisponible in ObtenerTallasDisponiblesParaCaptura())
                                            {
                                                <tr>
                                                        <td class="text-center">
                                                            <button type="button" class="ps-select-toggle @(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "is-selected" : string.Empty)" @onclick="() => AlternarSeleccionTallaDisponible(tallaDisponible.Talla)">
                                                                <i class="bi @(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "bi-check2-square" : "bi-square")"></i>
                                                                <span>@(EstaTallaDisponibleSeleccionada(tallaDisponible.Talla) ? "Marcada" : "Marcar")</span>
                                                            </button>
                                                        </td>
                                                    <td class="fw-semibold">@tallaDisponible.Talla</td>
                                                        <td>@ObtenerEtiquetaVariacionAplicada()</td>
                                                    <td>@ObtenerEtiquetaSkuResuelto(tallaDisponible.Talla)</td>
                                                        <td class="text-end">@ObtenerPrecioCotizadoTallaTexto(tallaDisponible.Talla)</td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-sm ps-btn-secondary" @onclick="() => SeleccionarTallaDisponible(tallaDisponible.Talla)">
                                                            Agregar
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-0"><i class="bi bi-info-circle me-1"></i>@ObtenerMensajeCapturaTallas()</p>
                            }
                        </div>
                    }

                    @if (MuestraServicios)
                    {
                        <div class="ps-section-label">Servicios / conceptos</div>
                        <div class="ps-box mb-4">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-3">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="min-width:130px">Tipo</th>
                                            <th>Descripción</th>
                                            <th style="min-width:90px">Cantidad</th>
                                            <th style="min-width:130px">Precio</th>
                                            <th style="min-width:120px">Total</th>
                                            <th style="width:36px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (conceptosEditando.Any())
                                        {
                                            @foreach (var concepto in conceptosEditando)
                                            {
                                                <tr>
                                                    <td>
                                                        <InputSelect class="form-select form-select-sm ps-input" @bind-Value="concepto.Tipo">
                                                            @foreach (var tipo in Enum.GetValues<PedidoConceptoTipo>())
                                                            {
                                                                <option value="@tipo">@tipo</option>
                                                            }
                                                        </InputSelect>
                                                    </td>
                                                    <td>
                                                        <InputText class="form-control form-control-sm ps-input" @bind-Value="concepto.Descripcion" />
                                                    </td>
                                                    <td>
                                                        <InputNumber class="form-control form-control-sm ps-input" @bind-Value="concepto.Cantidad" />
                                                    </td>
                                                    <td>
                                                        <InputNumber class="form-control form-control-sm ps-input" @bind-Value="concepto.PrecioUnitario" />
                                                    </td>
                                                    <td class="fw-semibold">@CalcularTotalConcepto(concepto).ToString("C2")</td>
                                                    <td>
                                                        <button type="button" class="btn ps-action-btn ps-action-delete" @onclick="() => QuitarConcepto(concepto)">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-muted small">No hay servicios capturados.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <button type="button" class="btn ps-btn-secondary btn-sm" @onclick="AgregarConcepto">
                                    <i class="bi bi-plus-circle me-1"></i> Agregar servicio
                                </button>
                                <span class="ps-total-badge">Servicios: @conceptosEditando.Sum(CalcularTotalConcepto).ToString("C2")</span>
                            </div>
                        </div>
                    }

                    @if (MuestraProductos)
                    {
                        <div class="ps-section-label">Tipos de Proceso</div>
                        <div class="ps-box mb-4">
                            @if (tiposProceso != null && tiposProceso.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var tipo in tiposProceso.OrderBy(t => t.Orden))
                                    {
                                        var isChecked = procesosSeleccionados.Contains(tipo.Id);
                                        <div class="col-6 col-sm-4 col-md-3">
                                            <label class="ps-check-pill @(isChecked ? "ps-check-active" : "")">
                                                <input type="checkbox" class="d-none"
                                                       checked="@isChecked"
                                                       @onchange="async (e) => await ToggleProceso(tipo.Id, e.Value)" />
                                                <i class="bi @(isChecked ? "bi-check-circle-fill" : "bi-circle") me-1"></i>
                                                @tipo.Nombre
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">No hay tipos de proceso configurados.</p>
                            }
                        </div>
                    }

                    @if (MuestraProductos && pedidoEditando.Id != Guid.Empty && procesosSeleccionados.Any() && tallasEditando.Any(t => t.Id != Guid.Empty))
                    {
                        var procesosSeleccion = tiposProceso?.Where(tp => procesosSeleccionados.Contains(tp.Id)).OrderBy(tp => tp.Orden).ToList() ?? new List<TipoProceso>();
                        <div class="ps-section-label">Seguimiento por talla y proceso</div>
                        <div class="ps-box mb-4">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="min-width:120px">Talla</th>
                                            @foreach (var proc in procesosSeleccion)
                                            {
                                                <th style="min-width:180px">@proc.Nombre</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var talla in tallasEditando.Where(t => t.Id != Guid.Empty).OrderBy(t => t.Talla))
                                        {
                                            <tr>
                                                <td><strong>@talla.Talla</strong> <span class="badge bg-primary">@talla.Cantidad</span></td>
                                                @foreach (var proc in procesosSeleccion)
                                                {
                                                    var seg = seguimientoTallaProcesos.FirstOrDefault(s => s.PedidoSerigrafiaTallaId == talla.Id && s.TipoProcesoId == proc.Id);
                                                    <td>
                                                        @if (seg != null)
                                                        {
                                                            <div class="form-check mb-1">
                                                                <InputCheckbox class="form-check-input"
                                                                               Value="seg.Completado"
                                                                               ValueChanged="async (bool value) => await OnSeguimientoChecked(seg, value)"
                                                                               ValueExpression="() => seg.Completado" />
                                                                <label class="form-check-label">Listo</label>
                                                            </div>
                                                            <InputDate TValue="DateTime?" class="form-control form-control-sm"
                                                                       Value="seg.FechaPaso"
                                                                       ValueChanged="async (DateTime? value) => await OnSeguimientoFechaChanged(seg, value)"
                                                                       ValueExpression="() => seg.FechaPaso" />
                                                             @if (seg.Completado || seg.EmpleadoId.HasValue)
                                                             {
                                                                 <InputSelect TValue="Guid?" class="form-select form-select-sm mt-1"
                                                                              Value="seg.EmpleadoId"
                                                                              ValueChanged="async (Guid? value) => await OnSeguimientoEmpleadoChanged(seg, value)"
                                                                              ValueExpression="() => seg.EmpleadoId">
                                                                     <option value="">Empleado...</option>
                                                                     @foreach (var empleado in empleadosActivos)
                                                                     {
                                                                         <option value="@empleado.Id">@empleado.NombreCompleto</option>
                                                                     }
                                                                 </InputSelect>
                                                             }
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @if (MuestraProductos)
                    {
                        <div class="ps-section-label">Factura / Entrega</div>
                        <div class="row g-3 mb-4">
                            <div class="col-12 col-md-7">
                                <label class="ps-label">Factura / Nota</label>
                                <InputTextArea class="form-control ps-input" rows="2" @bind-Value="pedidoEditando.Factura" placeholder="Folio o referencia de factura..." />
                            </div>
                            <div class="col-12 col-md-5">
                                <label class="ps-label">Fecha entrega (real)</label>
                                <InputDate class="form-control ps-input" @bind-Value="pedidoEditando.FechaEntregaReal" />
                            </div>
                        </div>
                    }

                    @if (MuestraProductos && pedidoEditando.Id != Guid.Empty)
                    {
                        var totalPedido = totalPedidoActual;
                        var totalPagado = pagosDelPedido.Sum(p => p.Monto);
                        var saldo = totalPedido - totalPagado;
                        var pctPagado = totalPedido > 0 ? Math.Min(100, (int)Math.Round((double)totalPagado / (double)totalPedido * 100)) : 0;
                        var saldoColor = saldo <= 0 ? "#10b981" : saldo < totalPedido ? "#f59e0b" : "#ef4444";

                        <div class="ps-section-label">Pagos</div>
                        <div class="ps-box mb-4">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div>
                                        <span style="font-size:.68rem;color:#6b7280;text-transform:uppercase;letter-spacing:.04em">Total pedido</span>
                                        <div style="font-size:1rem;font-weight:700;color:#1e3a5f">@totalPedido.ToString("C2")</div>
                                    </div>
                                    <div>
                                        <span style="font-size:.68rem;color:#6b7280;text-transform:uppercase;letter-spacing:.04em">Pagado</span>
                                        <div style="font-size:1rem;font-weight:700;color:#10b981">@totalPagado.ToString("C2")</div>
                                    </div>
                                    <div>
                                        <span style="font-size:.68rem;color:#6b7280;text-transform:uppercase;letter-spacing:.04em">Saldo</span>
                                        <div style="font-size:1rem;font-weight:700;color:@saldoColor">@saldo.ToString("C2")</div>
                                    </div>
                                </div>
                                <span class="ps-total-badge" style="background:@saldoColor">@pctPagado% pagado</span>
                            </div>
                            <div style="height:6px;background:#f0f2f5;border-radius:99px;overflow:hidden;margin-bottom:.75rem">
                                <div style="height:100%;width:@(pctPagado)%;background:@saldoColor;border-radius:99px;transition:width .3s"></div>
                            </div>

                            @if (pagosDelPedido.Any())
                            {
                                <table class="table table-sm mb-3" style="font-size:.78rem">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Forma de pago</th>
                                            <th>Referencia</th>
                                            <th class="text-end">Monto</th>
                                            <th style="width:36px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pago in pagosDelPedido.OrderBy(p => p.FechaPago))
                                        {
                                            <tr>
                                                <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                                <td>@GetFormaPagoLabel(pago.FormaPago)</td>
                                                <td>@(pago.Referencia ?? "—")</td>
                                                <td class="text-end fw-semibold" style="color:#10b981">@pago.Monto.ToString("C2")</td>
                                                <td>
                                                    <button type="button" class="btn ps-action-btn ps-action-delete" style="width:22px;height:22px;font-size:.65rem" @onclick="async () => await EliminarPago(pago)">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }

                            <div class="row g-2 align-items-end">
                                <div class="col-6 col-sm-3">
                                    <label class="ps-label">Fecha</label>
                                    <input type="date" class="form-control form-control-sm ps-input" @bind="nuevoPagoFecha" />
                                </div>
                                <div class="col-6 col-sm-2">
                                    <label class="ps-label">Monto</label>
                                    <input type="number" step="0.01" class="form-control form-control-sm ps-input" @bind="nuevoPagoMonto" placeholder="0.00" />
                                </div>
                                <div class="col-6 col-sm-2">
                                    <label class="ps-label">Forma de pago</label>
                                    <select class="form-select form-select-sm ps-input" @bind="nuevoPagoFormaPago">
                                        <option value="@FormaPagoEnum.Transferencia">Transferencia</option>
                                        <option value="@FormaPagoEnum.Efectivo">Efectivo</option>
                                        <option value="@FormaPagoEnum.Cheque">Cheque</option>
                                        <option value="@FormaPagoEnum.TarjetaCredito">Tarjeta Crédito</option>
                                        <option value="@FormaPagoEnum.TarjetaDebito">Tarjeta Débito</option>
                                        <option value="@FormaPagoEnum.Otro">Otro</option>
                                    </select>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <label class="ps-label">Referencia</label>
                                    <input type="text" class="form-control form-control-sm ps-input" @bind="nuevoPagoReferencia" placeholder="No. transferencia..." />
                                </div>
                                <div class="col-12 col-sm-2">
                                    <button type="button" class="btn ps-btn-secondary btn-sm w-100" @onclick="AgregarPago">
                                        <i class="bi bi-plus-circle me-1"></i> Agregar
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (MuestraProductos)
                    {
                        <div class="ps-section-label">Consumos e inventario</div>
                        <div class="ps-box mb-4">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="fw-semibold">Revisión previa antes de guardar</div>
                                    <div class="text-muted small">Consulta cuánto se va a usar y cuánto hay en inventario de materias primas e insumos para este pedido.</div>
                                </div>
                                @if (inventarioComprobadoEn.HasValue)
                                {
                                    <span class="ps-filter-pill">Comprobado @inventarioComprobadoEn.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                }
                            </div>

                            @if (revisandoComprobacionInventario)
                            {
                                <div class="d-flex align-items-center gap-2 text-muted small">
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                    <span>Comprobando consumos e inventario...</span>
                                </div>
                            }
                            else
                            {
                                @if (HayFaltantesInventario)
                                {
                                    <div class="alert alert-warning py-2 mb-3">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Hay materiales que no alcanzan en inventario. Esto te alerta, pero no impide guardar el pedido.
                                    </div>
                                }
                                else if (comprobacionInventarioItems.Any())
                                {
                                    <div class="alert alert-success py-2 mb-3">
                                        <i class="bi bi-check-circle me-1"></i>La comprobación terminó. Ya puedes confirmar y guardar el pedido.
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info py-2 mb-3">
                                        <i class="bi bi-info-circle me-1"></i>Presiona <strong>Comprobar consumos e inventario</strong> antes de guardar el pedido.
                                    </div>
                                }

                                @if (avisosComprobacionInventario.Any())
                                {
                                    <div class="alert alert-secondary py-2 mb-3">
                                        <ul class="mb-0 ps-3">
                                            @foreach (var aviso in avisosComprobacionInventario)
                                            {
                                                <li>@aviso</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                @if (comprobacionInventarioItems.Any())
                                {
                                    <div class="alert alert-primary py-2 mb-3">
                                        <div class="fw-semibold mb-1"><i class="bi bi-box-arrow-up-right me-1"></i>Descuento de inventario de materiales</div>
                                        <div class="small mb-2">Cuando confirmes el pedido, el sistema puede registrar la salida de materias primas e insumos con base en esta comprobación.</div>
                                        <div class="form-check">
                                            <InputCheckbox class="form-check-input" @bind-Value="descontarInventarioMaterialesAlGuardar" />
                                            <label class="form-check-label small">Sí, descontar automáticamente materias primas e insumos al guardar este pedido.</label>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0 ps-inventory-table">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Tipo</th>
                                                    <th>Concepto</th>
                                                    <th class="text-end">Voy a usar</th>
                                                    <th class="text-end">En inventario</th>
                                                    <th class="text-end">Faltante</th>
                                                    <th>Estado</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in comprobacionInventarioItems)
                                                {
                                                    <tr>
                                                        <td>@item.Tipo</td>
                                                        <td>
                                                            <div class="fw-semibold">@item.Nombre</div>
                                                            <div class="small text-muted">@item.ReferenciasTexto</div>
                                                        </td>
                                                        <td class="text-end">@item.CantidadRequerida.ToString("N4") @item.UnidadMedida</td>
                                                        <td class="text-end">@(item.ExistenciaInventario.HasValue ? $"{item.ExistenciaInventario.Value:N4} {item.UnidadMedida}" : "N/D")</td>
                                                        <td class="text-end">@(item.ExistenciaInventario.HasValue ? $"{item.Faltante:N4} {item.UnidadMedida}" : "N/D")</td>
                                                        <td><span class="ps-inventory-status @item.EstadoClase">@item.EstadoTexto</span></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            }
                        </div>
                    }

                    <div class="d-flex gap-2 pt-2" style="border-top:1px solid #f0f0f0">
                        @if (MuestraProductos)
                        {
                            <button type="button" class="btn ps-btn-secondary" @onclick="ComprobarConsumosInventario" disabled="@revisandoComprobacionInventario">
                                <i class="bi bi-clipboard2-data me-1"></i> Comprobar consumos e inventario
                            </button>
                        }
                        <button type="submit" class="btn ps-btn-primary" disabled="@(MuestraProductos && (!inventarioComprobado || revisandoComprobacionInventario))">
                            <i class="bi bi-save me-1"></i> Confirmar y guardar pedido
                        </button>
                        <button type="button" class="btn ps-btn-ghost" @onclick="CancelarEdicion">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </button>
                    </div>
                    @if (MuestraProductos && !inventarioComprobado)
                    {
                        <div class="small text-muted mt-2">Primero ejecuta <strong>Comprobar consumos e inventario</strong> y después confirma el guardado.</div>
                    }
                </EditForm>
            </div>
        </div>
    }

    <!-- Tabla de Pedidos -->
    <div class="ps-card ps-table-card">
        @if (pedidos == null)
        {
            <div class="d-flex align-items-center justify-content-center p-5">
                <div class="spinner-border text-primary me-2" role="status" style="width:1.6rem;height:1.6rem;"></div>
                <span class="text-muted">Cargando pedidos...</span>
            </div>
        }
        else if (!pedidos.Any())
        {
            <div class="text-center p-5">
                <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                <p class="text-muted mb-3">No hay pedidos registrados.</p>
                <button class="btn ps-btn-primary" @onclick="NuevoPedido">
                    <i class="bi bi-plus-circle me-1"></i> Crear primer pedido
                </button>
            </div>
        }
        else
        {
            <div class="ps-grid-wrapper">
                <table class="ps-table">
                    <thead>
                        <tr>
                            <th class="ps-col-sticky ps-col-sticky-actions" style="width:150px" rowspan="2">Acciones</th>
                            <th class="ps-col-sticky ps-col-sticky-status" style="width:44px" rowspan="2"></th>
                            <th rowspan="2">Recibido</th>
                            <th rowspan="2">Estimada</th>
                            <th rowspan="2" style="min-width:160px">Cliente</th>
                            <th rowspan="2" style="min-width:120px">Estilo</th>
                            <th rowspan="2" style="min-width:140px">Color</th>
                            <th rowspan="2" style="min-width:90px"># OC</th>
                            <th rowspan="2" style="min-width:90px">Lote</th>
                            <th rowspan="2">Corrida</th>
                            <th rowspan="2" style="min-width:240px">Cotización</th>
                            @if (tablaProcesses.Any())
                            {
                                <th colspan="@tablaProcesses.Count" class="ps-th-group ps-th-group-proc">Procesos</th>
                            }
                            @if (tallasTabla.Any())
                            {
                                <th colspan="@tallasTabla.Count" class="ps-th-group ps-th-group-talla">Tallas</th>
                            }
                            <th rowspan="2" style="min-width:180px">Factura</th>
                        </tr>
                        <tr>
                            @foreach (var proc in tablaProcesses)
                            {
                                <th class="ps-th-proc" title="@proc.Nombre">@proc.Nombre</th>
                            }
                            @foreach (var tallaCol in tallasTabla)
                            {
                                <th class="ps-th-talla">#@tallaCol</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (PedidosFiltrados.Any())
                        {
                            @foreach (var pedido in PedidosFiltrados)
                            {
                                var estadoPedido = pedido.PedidoDetalle?.Pedido?.Estado ?? EstadoPedidoEnum.Nuevo;
                                var completado = estadoPedido is EstadoPedidoEnum.Facturado or EstadoPedidoEnum.Entregado or EstadoPedidoEnum.Pagado;
                                var atrasado = pedido.FechaEstimada.HasValue && pedido.FechaEstimada.Value.Date < DateTime.Now.Date && !completado;
                                var rowClass = completado ? "ps-row-done" : atrasado ? "ps-row-late" : "";
                                seguimientosPorPedido.TryGetValue(pedido.Id, out var segsRow);
                                segsRow ??= new();
                                var procesoIdsPedido = pedido.TiposProceso.Select(tp => tp.TipoProcesoId).ToList();
                                var tallaIdsPedido = pedido.Tallas.Select(t => t.Id).ToHashSet();
                                var totalCombinaciones = procesoIdsPedido.Count * tallaIdsPedido.Count;
                                var completadasProceso = segsRow.Count(s => s.Completado && procesoIdsPedido.Contains(s.TipoProcesoId) && tallaIdsPedido.Contains(s.PedidoSerigrafiaTallaId));
                                var avancePct = totalCombinaciones > 0 ? (int)Math.Round((double)completadasProceso / totalCombinaciones * 100) : 0;
                                <tr class="@rowClass">
                                    <td class="ps-col-sticky ps-col-sticky-actions ps-td-actions">
                                        <div class="ps-row-actions">
                                            @if (pedido.PedidoDetalle?.Pedido != null)
                                            {
                                                <a class="ps-btn-procesar" href="/pedidos/@pedido.PedidoDetalle.PedidoId/seguimiento" title="Abrir seguimiento del pedido">
                                                    <i class="bi bi-play-circle-fill"></i>
                                                    <span>Procesar</span>
                                                </a>
                                            }
                                            <div class="ps-row-icons">
                                                <button class="btn ps-action-btn ps-action-edit" title="Editar" @onclick="async () => await EditarPedido(pedido)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                @if (pedido.Id != Guid.Empty)
                                                {
                                                    <button class="btn ps-action-btn ps-action-delete" title="Eliminar" @onclick="() => EliminarPedido(pedido)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                                else if (pedido.PedidoDetalle?.PedidoId != Guid.Empty)
                                                {
                                                    <button class="btn ps-action-btn ps-action-delete" title="Eliminar pedido" @onclick="() => EliminarPedidoBaseVirtual(pedido)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="ps-col-sticky ps-col-sticky-status text-center">
                                        <div class="ps-row-status">
                                            @if (estadoPedido == EstadoPedidoEnum.Pagado)
                                            {
                                                <i class="bi bi-check-circle-fill text-success" title="Pagado"></i>
                                            }
                                            else if (estadoPedido == EstadoPedidoEnum.Facturado)
                                            {
                                                <i class="bi bi-receipt-cutoff text-success" title="Facturado"></i>
                                            }
                                            else if (estadoPedido == EstadoPedidoEnum.Entregado)
                                            {
                                                <i class="bi bi-truck text-success" title="Entregado"></i>
                                            }
                                            else if (estadoPedido == EstadoPedidoEnum.Producido)
                                            {
                                                <i class="bi bi-gear-fill text-primary" title="Producido"></i>
                                            }
                                            else if (estadoPedido == EstadoPedidoEnum.EnProceso)
                                            {
                                                <i class="bi bi-hourglass-split text-warning" title="En proceso"></i>
                                            }
                                            else if (atrasado)
                                            {
                                                <i class="bi bi-exclamation-circle-fill text-danger" title="Atrasado"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-clock text-secondary" title="Pendiente"></i>
                                            }

                                            @if (totalCombinaciones > 0)
                                            {
                                                <div class="ps-row-prog-wrap" title="@completadasProceso/@totalCombinaciones operaciones completas">
                                                    <div class="ps-row-prog-bar @(avancePct == 100 ? "is-done" : string.Empty)" style="width:@avancePct%"></div>
                                                </div>
                                                <span class="ps-row-prog-lbl">@avancePct%</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="ps-td-date">@pedido.FechaRecibido?.ToString("dd/MM/yy")</td>
                                    <td class="ps-td-date @(atrasado ? "text-danger fw-semibold" : "")">@pedido.FechaEstimada?.ToString("dd/MM/yy")</td>
                                    <td style="font-weight:500">@pedido.PedidoDetalle?.Pedido?.Cliente?.RazonSocial</td>
                                    <td><strong>@pedido.Estilo</strong></td>
                                    <td>@pedido.CombinacionColor</td>
                                    <td>@pedido.OrdenCompra</td>
                                    <td>@pedido.LoteCliente</td>
                                    <td>@pedido.Corrida</td>
                                    <td style="white-space:normal;max-width:240px">
                                        @if (pedido.PedidoDetalle?.CotizacionSerigrafia != null)
                                        {
                                            <div class="fw-semibold">@pedido.PedidoDetalle.CotizacionSerigrafia.Descripcion</div>
                                            <div class="small text-muted">@ObtenerEtiquetaCotizacion(pedido.PedidoDetalle.CotizacionSerigrafia)</div>
                                            @if (pedido.PedidoDetalle.DetallesTalla.Any())
                                            {
                                                <div class="small mt-1" style="color:#1e3a5f;font-weight:600">Subtotal producto: @pedido.PedidoDetalle.DetallesTalla.Sum(t => t.Total).ToString("C2")</div>
                                                <div class="text-muted" style="font-size:.68rem">@ObtenerResumenPrecioTallas(pedido.PedidoDetalle.DetallesTalla)</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    @foreach (var proc in tablaProcesses)
                                    {
                                        var tieneProc = pedido.TiposProceso.Any(tp => tp.TipoProcesoId == proc.Id);
                                        if (tieneProc)
                                        {
                                            var totalT = pedido.Tallas.Count;
                                            var compT = segsRow.Count(s => s.TipoProcesoId == proc.Id && s.Completado);
                                            var cellCls = totalT > 0 && compT == totalT ? "ps-col-proc-done" :
                                                          compT > 0 ? "ps-col-proc-partial" : "";
                                            <td class="text-center @cellCls" title="@compT/@totalT tallas">
                                                @if (totalT > 0 && compT == totalT)
                                                {
                                                    <i class="bi bi-check-lg ps-proc-icon-done"></i>
                                                }
                                                else if (compT > 0)
                                                {
                                                    <span class="ps-proc-frac">@compT/@totalT</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-square ps-proc-icon-pending"></i>
                                                }
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="ps-col-proc-na text-center"><span>—</span></td>
                                        }
                                    }
                                    @foreach (var tallaCol in tallasTabla)
                                    {
                                        var tallaObj = pedido.Tallas.FirstOrDefault(t => t.Talla == tallaCol);
                                        if (tallaObj != null)
                                        {
                                            var (compP, totP) = ProgresoTalla(pedido.Id, tallaObj.Id, procesoIdsPedido);
                                            var tCls = totP > 0 && compP == totP ? "ps-col-talla-done" :
                                                       compP > 0 ? "ps-col-talla-partial" : "";
                                            <td class="text-center @tCls" title="@compP/@totP procesos">
                                                <strong class="ps-talla-qty">@tallaObj.Cantidad</strong>
                                                @if (totP > 0)
                                                {
                                                    <div class="ps-talla-sub">@compP/@totP</div>
                                                }
                                            </td>
                                        }
                                        else
                                        {
                                            <td></td>
                                        }
                                    }
                                    <td style="white-space:normal;font-size:.78rem;color:#666;max-width:180px">@pedido.Factura</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(12 + tablaProcesses.Count + tallasTabla.Count)" class="text-center py-4 text-muted">
                                    No hay pedidos que coincidan con la búsqueda actual.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>

<style>
    /* ── Layout ───────────────────────────────────────── */
    .ps-page { padding: 1.25rem 1rem; }
    @@media (min-width: 768px) { .ps-page { padding: 1.5rem 2rem; } }

    /* ── Title ────────────────────────────────────────── */
    .ps-title { font-size: clamp(1.3rem, 3vw, 1.7rem); font-weight: 700; color: #1e3a5f; }

    /* ── Card base ────────────────────────────────────── */
    .ps-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 1rem 1.25rem; box-shadow: 0 1px 4px rgba(0,0,0,.05); }

    /* ── Buttons ──────────────────────────────────────── */
    .ps-btn-primary   { background: #1e3a5f; color: #fff; border: none; padding: .45rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; }
    .ps-btn-primary:hover   { background: #163052; color: #fff; }
    .ps-btn-secondary { background: #4a6fa5; color: #fff; border: none; padding: .45rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; }
    .ps-btn-secondary:hover { background: #3a5f93; color: #fff; }
    .ps-btn-ghost     { background: transparent; color: #4a6fa5; border: 1.5px solid #4a6fa5; padding: .45rem 1.1rem; border-radius: 6px; font-size: .875rem; font-weight: 500; }
    .ps-btn-ghost:hover { background: #f0f4fa; }
    .ps-btn-dark      { background: #2c3e50; color: #fff; border: none; font-size: .82rem; }
    .ps-btn-dark:hover { background: #1a252f; color: #fff; }

    /* ── Form card ────────────────────────────────────── */
    .ps-form-card  { padding: 0 !important; overflow: hidden; }
    .ps-form-header { background: #1e3a5f; color: #fff; padding: .85rem 1.5rem; }

    /* ── Labels & Inputs ──────────────────────────────── */
    .ps-label { font-size: .78rem; font-weight: 600; color: #495057; margin-bottom: .3rem; display: block; }
    .ps-input { border: 1px solid #ced4da; border-radius: 6px; font-size: .875rem; color: #2c3e50; background: #fafbfc; transition: border-color .15s, box-shadow .15s; }
    .ps-input:focus { border-color: #4a6fa5; box-shadow: 0 0 0 3px rgba(74,111,165,.15); outline: none; }
    .ps-filter-meta { display: flex; align-items: center; justify-content: space-between; gap: .75rem; flex-wrap: wrap; margin-top: .7rem; padding-top: .7rem; border-top: 1px solid #e8edf5; }
    .ps-filter-pill { display: inline-flex; align-items: center; padding: .28rem .65rem; border-radius: 999px; background: #eef2fb; color: #1e3a5f; font-size: .68rem; font-weight: 700; border: 1px solid #c8d4e8; }
    .ps-filter-hint { font-size: .68rem; color: #6b7280; }

    /* ── Section labels ───────────────────────────────── */
    .ps-section-label { font-size: .68rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: #4a6fa5; border-bottom: 1px solid #e8edf5; padding-bottom: .35rem; margin-bottom: .85rem; }

    /* ── Box (procesos / tallas) ──────────────────────── */
    .ps-box { background: #f8f9fb; border: 1px solid #e5eaf2; border-radius: 8px; padding: .85rem; }

    /* ── Proceso pills ────────────────────────────────── */
    .ps-check-pill { display: flex; align-items: center; gap: .35rem; padding: .35rem .7rem; border: 1.5px solid #d1d9e0; border-radius: 20px; cursor: pointer; font-size: .8rem; background: #fff; color: #495057; transition: all .15s; user-select: none; white-space: nowrap; }
    .ps-check-pill:hover { border-color: #4a6fa5; color: #1e3a5f; }
    .ps-check-pill.ps-check-active { border-color: #1e3a5f; background: #1e3a5f; color: #fff; }

    /* ── Talla items ──────────────────────────────────── */
    .ps-talla-item { background: #fff; border: 1px solid #d1d9e0; border-radius: 6px; padding: .45rem .55rem; }
    .ps-talla-label { font-size: .78rem; font-weight: 700; color: #1e3a5f; }
    .ps-total-badge { background: #1e3a5f; color: #fff; font-size: .72rem; padding: .25rem .65rem; border-radius: 20px; font-weight: 600; white-space: nowrap; }
