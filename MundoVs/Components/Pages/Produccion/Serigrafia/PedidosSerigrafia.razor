                || (p.PedidoDetalle?.Pedido?.Cliente?.RazonSocial?.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase) ?? false)
                || (!string.IsNullOrWhiteSpace(p.Estilo) && p.Estilo.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(p.CombinacionColor) && p.CombinacionColor.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(p.OrdenCompra) && p.OrdenCompra.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(p.LoteCliente) && p.LoteCliente.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
        clientes = await ClienteRepository.GetAllAsync();
        tiposProceso = await TipoProcesoRepository.GetAllAsync();
        empleadosActivos = await DbContext.Empleados
            .AsNoTracking()
            .Where(e => e.IsActive)
            .OrderBy(e => e.Nombre)
            .ThenBy(e => e.ApellidoPaterno)
            .ToListAsync();
        await CargarPedidos();
    }

    private void AbrirModalNotaConsolidada()
    {
        modalNotaConsolidadaAbierto = true;
        clienteNotaConsolidadaId = null;
        errorNotaConsolidada = null;
        okNotaConsolidada = null;
        pedidosElegiblesNotaConsolidada = [];
        lineasNotaConsolidada = [];
        pedidosNotaConsolidadaSeleccionados.Clear();
        aplicaIvaNotaConsolidada = false;
    }

    private void CerrarModalNotaConsolidada()
    {
        modalNotaConsolidadaAbierto = false;
        clienteNotaConsolidadaId = null;
        errorNotaConsolidada = null;
        okNotaConsolidada = null;
        pedidosElegiblesNotaConsolidada = [];
        lineasNotaConsolidada = [];
        pedidosNotaConsolidadaSeleccionados.Clear();
        aplicaIvaNotaConsolidada = false;
    }

    private async Task OnClienteNotaConsolidadaChanged(ChangeEventArgs e)
    {
        clienteNotaConsolidadaId = e.Value?.ToString();
        pedidosNotaConsolidadaSeleccionados.Clear();
        pedidosElegiblesNotaConsolidada = [];
        lineasNotaConsolidada = [];
        errorNotaConsolidada = null;
        okNotaConsolidada = null;
        aplicaIvaNotaConsolidada = false;

        if (!Guid.TryParse(clienteNotaConsolidadaId, out var clienteId) || clienteId == Guid.Empty)
            return;

        cargandoPedidosNotaConsolidada = true;
        try
        {
            pedidosElegiblesNotaConsolidada = (await NotaEntregaConsolidadaService.GetPedidosElegiblesAsync(clienteId)).ToList();
        }
        catch (Exception ex)
        {
            errorNotaConsolidada = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            cargandoPedidosNotaConsolidada = false;
        }
    }

    private void OnPedidoNotaConsolidadaChanged(Guid pedidoId, ChangeEventArgs e)
    {
        var seleccionado = e.Value is bool value && value;
        if (seleccionado)
            pedidosNotaConsolidadaSeleccionados.Add(pedidoId);
        else
            pedidosNotaConsolidadaSeleccionados.Remove(pedidoId);

        lineasNotaConsolidada = [];
    }

    private void OnLineaNotaCantidadChanged(NotaEntregaLineaConsolidadaVm linea, decimal? value)
    {
        var cantidad = Math.Max(0m, value ?? 0m);
        var maximoOperativo = linea.TipoOrigen == NotaEntregaAsignacionOrigenTipo.Producto
            ? Math.Min(linea.CantidadMaximaTomable, linea.CantidadDisponibleFg)
            : linea.CantidadMaximaTomable;

        linea.CantidadSeleccionada = Math.Min(cantidad, maximoOperativo);
    }

    private void OnLineaNotaCantidadInput(NotaEntregaLineaConsolidadaVm linea, ChangeEventArgs args)
    {
        decimal? cantidad = null;
        if (args.Value is string text && decimal.TryParse(text, out var parsed))
        {
            cantidad = parsed;
        }

        OnLineaNotaCantidadChanged(linea, cantidad);
    }

    private void TomarMaximoLineasNotaConsolidada()
