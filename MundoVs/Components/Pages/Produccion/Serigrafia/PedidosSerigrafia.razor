    private void AgregarConcepto()
    {
        conceptosEditando.Add(new PedidoConcepto());
    }

    private void QuitarConcepto(PedidoConcepto concepto)
    {
        conceptosEditando.Remove(concepto);
    }

    private decimal CalcularTotalConcepto(PedidoConcepto concepto)
    {
        var cantidad = concepto.Cantidad < 0 ? 0 : concepto.Cantidad;
        var precio = concepto.PrecioUnitario < 0 ? 0 : concepto.PrecioUnitario;
        return cantidad * precio;
    }

    private List<PedidoConcepto> ObtenerConceptosValidos()
    {
        return conceptosEditando
            .Where(c => !string.IsNullOrWhiteSpace(c.Descripcion) && c.Cantidad > 0 && c.PrecioUnitario >= 0)
            .Select(c => new PedidoConcepto
            {
                Tipo = c.Tipo,
                Descripcion = c.Descripcion.Trim(),
                Cantidad = c.Cantidad,
                PrecioUnitario = c.PrecioUnitario,
                Total = CalcularTotalConcepto(c),
                IsActive = true
            })
            .ToList();
    }

    private async Task CargarConceptosAsync(Guid pedidoId)
    {
        if (pedidoId == Guid.Empty)
        {
            conceptosEditando = new();
            return;
        }

        conceptosEditando = await DbContext.PedidoConceptos
            .AsNoTracking()
            .Where(c => c.PedidoId == pedidoId && c.IsActive)
            .OrderBy(c => c.CreatedAt)
            .Select(c => new PedidoConcepto
            {
                Id = c.Id,
                PedidoId = c.PedidoId,
                Tipo = c.Tipo,
                Descripcion = c.Descripcion,
                Cantidad = c.Cantidad,
                PrecioUnitario = c.PrecioUnitario,
                Total = c.Total,
                CreatedAt = c.CreatedAt,
                CreatedBy = c.CreatedBy,
                IsActive = c.IsActive
            })
            .ToListAsync();
    }

    private async Task SincronizarConceptosAsync(Guid pedidoId, List<PedidoConcepto> conceptos, string? usuarioActual)
    {
        var existentes = await DbContext.PedidoConceptos
            .Where(c => c.PedidoId == pedidoId)
            .ToListAsync();

        if (existentes.Any())
        {
            DbContext.PedidoConceptos.RemoveRange(existentes);
        }

        if (conceptos.Any())
        {
            DbContext.PedidoConceptos.AddRange(conceptos.Select(c => new PedidoConcepto
            {
                Id = Guid.NewGuid(),
                PedidoId = pedidoId,
                Tipo = c.Tipo,
                Descripcion = c.Descripcion,
                Cantidad = c.Cantidad,
                PrecioUnitario = c.PrecioUnitario,
                Total = c.Total,
                CreatedAt = DateTime.UtcNow,
                CreatedBy = usuarioActual,
                IsActive = true
            }));
        }

        await DbContext.SaveChangesAsync();
    }

    // ===== Tallas dinámicas =====

    private void AgregarTalla()
    {
        InvalidarComprobacionInventario();
        if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion) return;
        if (string.IsNullOrWhiteSpace(nuevaTallaSeleccionada)) return;
        if (tallasEditando.Any(t => string.Equals(t.Talla, nuevaTallaSeleccionada.Trim(), StringComparison.OrdinalIgnoreCase))) return;
        tallasEditando.Add(new PedidoSerigrafiaTalla { Talla = nuevaTallaSeleccionada.Trim(), Cantidad = 1 });
        tallasDisponiblesSeleccionadas.RemoveWhere(t => string.Equals(t, nuevaTallaSeleccionada.Trim(), StringComparison.OrdinalIgnoreCase));
        nuevaTallaSeleccionada = ObtenerTallasDisponiblesParaCaptura().FirstOrDefault()?.Talla;
    }

    private void QuitarTalla(PedidoSerigrafiaTalla talla)
    {
        InvalidarComprobacionInventario();
        tallasEditando.Remove(talla);
        LimpiarSeleccionTallasDisponibles();
    }

    private void SeleccionarTallaDisponible(string talla)
    {
        nuevaTallaSeleccionada = talla;
        AgregarTalla();
    }

    private void AgregarCorridaDisponible()
    {
        InvalidarComprobacionInventario();
        if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
        {
            return;
        }

        foreach (var talla in ObtenerTallasDisponiblesParaCaptura().ToList())
        {
            tallasEditando.Add(new PedidoSerigrafiaTalla
            {
                Talla = talla.Talla,
                Cantidad = 1
            });
        }

        tallasDisponiblesSeleccionadas.Clear();
        nuevaTallaSeleccionada = ObtenerTallasDisponiblesParaCaptura().FirstOrDefault()?.Talla;
    }

    private void AgregarTallasSeleccionadas()
    {
        InvalidarComprobacionInventario();
        if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
        {
            return;
        }

        foreach (var talla in ObtenerTallasDisponiblesParaCaptura()
            .Where(t => tallasDisponiblesSeleccionadas.Contains(t.Talla))
            .ToList())
        {
            tallasEditando.Add(new PedidoSerigrafiaTalla
            {
                Talla = talla.Talla,
                Cantidad = 1
            });
        }

        tallasDisponiblesSeleccionadas.Clear();
        nuevaTallaSeleccionada = ObtenerTallasDisponiblesParaCaptura().FirstOrDefault()?.Talla;
    }

    private bool EstaTallaDisponibleSeleccionada(string talla)
        => tallasDisponiblesSeleccionadas.Contains(talla);

    private bool HayTallasDisponiblesSeleccionadas()
        => ObtenerTallasDisponiblesParaCaptura().Any(t => tallasDisponiblesSeleccionadas.Contains(t.Talla));

    private bool TodasLasTallasDisponiblesSeleccionadas()
    {
        var disponibles = ObtenerTallasDisponiblesParaCaptura().Select(t => t.Talla).ToList();
        return disponibles.Count > 0 && disponibles.All(tallasDisponiblesSeleccionadas.Contains);
    }

    private void OnTallaDisponibleSeleccionadaChanged(string talla, object? value)
    {
        var marcada = value is bool boolValue && boolValue;
        if (marcada)
        {
            tallasDisponiblesSeleccionadas.Add(talla);
        }
        else
        {
            tallasDisponiblesSeleccionadas.Remove(talla);
        }
    }

    private void OnToggleSeleccionDisponibles(ChangeEventArgs args)
    {
        var seleccionarTodas = args.Value is bool boolValue && boolValue;
        var disponibles = ObtenerTallasDisponiblesParaCaptura().Select(t => t.Talla).ToList();

        if (seleccionarTodas)
        {
            foreach (var talla in disponibles)
            {
                tallasDisponiblesSeleccionadas.Add(talla);
            }
        }
        else
        {
            tallasDisponiblesSeleccionadas.RemoveWhere(t => disponibles.Contains(t, StringComparer.OrdinalIgnoreCase));
        }
    }

    private void AlternarSeleccionTallaDisponible(string talla)
    {
        if (EstaTallaDisponibleSeleccionada(talla))
        {
            tallasDisponiblesSeleccionadas.Remove(talla);
            return;
        }

        tallasDisponiblesSeleccionadas.Add(talla);
    }

    private void AlternarSeleccionTodasLasDisponibles()
    {
        var disponibles = ObtenerTallasDisponiblesParaCaptura().Select(t => t.Talla).ToList();
        if (disponibles.Count == 0)
        {
            return;
        }

        if (disponibles.All(tallasDisponiblesSeleccionadas.Contains))
        {
            tallasDisponiblesSeleccionadas.RemoveWhere(t => disponibles.Contains(t, StringComparer.OrdinalIgnoreCase));
            return;
        }

        foreach (var talla in disponibles)
        {
            tallasDisponiblesSeleccionadas.Add(talla);
        }
    }

    private void LimpiarSeleccionTallasDisponibles()
    {
        var disponibles = ObtenerTallasDisponiblesParaCaptura().Select(t => t.Talla).ToHashSet(StringComparer.OrdinalIgnoreCase);
        tallasDisponiblesSeleccionadas.RemoveWhere(t => !disponibles.Contains(t));
    }

    private async Task ActualizarTallasAsync(Guid pedidoSerigrafiaId)
    {
        var existentes = DbContext.PedidoSerigrafiaTallas.Where(t => t.PedidoSerigrafiaId == pedidoSerigrafiaId);
        DbContext.PedidoSerigrafiaTallas.RemoveRange(existentes);

        foreach (var talla in tallasEditando.Where(t => t.Cantidad > 0))
        {
            DbContext.PedidoSerigrafiaTallas.Add(new PedidoSerigrafiaTalla
            {
                Id = Guid.NewGuid(),
                PedidoSerigrafiaId = pedidoSerigrafiaId,
                Talla = talla.Talla,
                Cantidad = talla.Cantidad,
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });
        }

        await DbContext.SaveChangesAsync();
    }

    private async Task RecargarTallasAsync(Guid pedidoSerigrafiaId)
    {
        tallasEditando = await DbContext.PedidoSerigrafiaTallas
            .Where(t => t.PedidoSerigrafiaId == pedidoSerigrafiaId)
            .OrderBy(t => t.Talla)
            .ToListAsync();
    }

