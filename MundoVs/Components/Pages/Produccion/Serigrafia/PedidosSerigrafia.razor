    private void InvalidarComprobacionInventario()
    {
        inventarioComprobado = false;
        inventarioComprobadoEn = null;
        descontarInventarioMaterialesAlGuardar = false;
        comprobacionInventarioItems.Clear();
        avisosComprobacionInventario.Clear();
    }

    private async Task DescontarInventarioMaterialesAsync(string? usuarioActual)
    {
        if (_empresaId == Guid.Empty || !comprobacionInventarioItems.Any())
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        foreach (var item in comprobacionInventarioItems.Where(i => !i.SinVinculoInventario && i.CantidadRequerida > 0))
        {
            var inventarioItemId = item.InventarioItemId;

            if (!inventarioItemId.HasValue)
            {
                continue;
            }

            var inventarioItem = await db.InventarioItems.IgnoreQueryFilters()
                .FirstOrDefaultAsync(ii => ii.EmpresaId == _empresaId && ii.IsActive && ii.Id == inventarioItemId.Value);

            if (inventarioItem == null)
            {
                continue;
            }

            var existenciaAnterior = inventarioItem.Cantidad;
            var existenciaNueva = Math.Max(0, existenciaAnterior - item.CantidadRequerida);
            inventarioItem.Cantidad = existenciaNueva;
            inventarioItem.UpdatedAt = DateTime.UtcNow;

            db.MovimientosInventario.Add(new MundoVs.Core.Entities.Inventario.MovimientoInventario
            {
                EmpresaId = _empresaId,
                Origen = inventarioItem.OrigenLegacy == MundoVs.Core.Entities.Inventario.InventarioItemOrigenLegacy.MateriaPrima
                    ? MundoVs.Core.Entities.Inventario.MovimientoInventarioOrigenEnum.MateriaPrima
                    : MundoVs.Core.Entities.Inventario.MovimientoInventarioOrigenEnum.Insumo,
                TipoMovimiento = MundoVs.Core.Entities.Inventario.MovimientoInventarioTipoEnum.Salida,
                InventarioItemId = inventarioItem.Id,
                Cantidad = item.CantidadRequerida,
                ExistenciaAnterior = existenciaAnterior,
                ExistenciaNueva = existenciaNueva,
                CostoUnitario = inventarioItem.PrecioUnitario,
                FechaMovimiento = DateTime.UtcNow,
                Referencia = pedidoBaseIdEditando == Guid.Empty ? pedidoEditando.Estilo : pedidoBaseIdEditando.ToString(),
                Observaciones = $"Salida automática por confirmación de pedido {(pedidoEditando.Estilo ?? string.Empty).Trim()}",
                CreatedAt = DateTime.UtcNow,
                CreatedBy = usuarioActual,
                IsActive = true
            });
        }

        await db.SaveChangesAsync();
    }

