    private async Task EliminarPedidoBaseVirtual(PedidoSerigrafia pedido)
    {
        if (pedido.PedidoDetalle?.Pedido == null)
            return;

        pedido.PedidoDetalle.Pedido.IsActive = false;
        pedido.PedidoDetalle.Pedido.UpdatedAt = DateTime.UtcNow;
        await PedidoRepository.UpdateAsync(pedido.PedidoDetalle.Pedido);
        await CargarPedidos();
    }

    private async Task CargarPagosPedidoBaseAsync(Guid pedidoId)
    {
        if (pedidoId == Guid.Empty)
        {
            pagosDelPedido = new();
            totalPedidoActual = 0;
            return;
        }

        var pedido = await DbContext.Pedidos.FindAsync(pedidoId);
        totalPedidoActual = pedido?.Total ?? 0;

        pagosDelPedido = await DbContext.PagosPedido
            .Where(p => p.PedidoId == pedidoId)
            .OrderBy(p => p.FechaPago)
            .ToListAsync();
    }

    private async Task GuardarPedido()
    {
        if (!clienteSeleccionadoId.HasValue) return;

        var incluyeProductos = MuestraProductos;
        var incluyeServicios = MuestraServicios;
        if (!incluyeProductos && !incluyeServicios) return;
        if (incluyeProductos && !inventarioComprobado) return;
        if (incluyeProductos && !productoSeleccionadoId.HasValue) return;
        if (incluyeProductos && !cotizacionSeleccionadaId.HasValue) return;

        var productoId = productoSeleccionadoId;
        var cotizacionId = cotizacionSeleccionadaId;
        var productoConfig = ProductoSeleccionadoConfig;
        var colorSeleccionado = ObtenerColorSeleccionado();

        if (ProductoUsaVariantesColor && string.IsNullOrWhiteSpace(colorSeleccionado)) return;
        if (capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion)
        {
            if (!fraccionSeleccionadaId.HasValue) return;
            if (cantidadFracciones <= 0) return;
        }

        pedidoEditando.CombinacionColor = colorSeleccionado ?? string.Empty;

        var cantidadTotal = incluyeProductos ? tallasEditando.Sum(t => t.Cantidad) : 0;
        if (incluyeProductos && cantidadTotal <= 0) return;

        if (incluyeProductos && productoConfig?.TieneVariantes == true)
        {
            var tallasSinSku = productoConfig.UsaVariantesTalla
                ? ObtenerTallasSinSku().ToList()
                : new List<PedidoSerigrafiaTalla>();

            if (tallasSinSku.Any()) return;
        }

        var conceptosValidos = ObtenerConceptosValidos();
        if (incluyeServicios && !conceptosValidos.Any()) return;

        decimal precioUnitario = 0;
        decimal subtotalProducto = 0;
        CotizacionSerigrafia? cotizacionPrecio = null;

        if (incluyeProductos)
        {
            cotizacionPrecio = await DbContext.CotizacionesSerigrafia
                .AsNoTracking()
                .Include(c => c.PreciosVariantes)
                .FirstOrDefaultAsync(c => c.Id == cotizacionId && c.ProductoId == productoId && c.IsActive);

            if (cotizacionPrecio == null) return;

            subtotalProducto = CalcularSubtotalProductoDesdeCotizacion(cotizacionPrecio, tallasEditando, colorSeleccionado, tipoPrecioSeleccionado);
            precioUnitario = cantidadTotal > 0
                ? Math.Round(subtotalProducto / cantidadTotal, 4)
                : 0m;
        }

        var subtotalServicios = conceptosValidos.Sum(c => c.Total);
        var subtotal = subtotalProducto + subtotalServicios;
        var iva = Math.Round(subtotal * 0.16m, 2);
        var totalConIva = subtotal + iva;
        var usuarioActual = await ObtenerUsuarioActualAsync();

        if (incluyeProductos && descontarInventarioMaterialesAlGuardar)
        {
            await DescontarInventarioMaterialesAsync(usuarioActual);
        }

        if (pedidoEditando.Id == Guid.Empty)
        {
            var pedido = new Pedido
            {
                NumeroPedido = $"SER-{DateTime.UtcNow:yyyyMMddHHmmss}",
                ClienteId = clienteSeleccionadoId.Value,
                FechaPedido = pedidoEditando.FechaRecibido ?? DateTime.UtcNow,
                Estado = EstadoPedidoEnum.Nuevo,
                TipoPrecio = tipoPrecioSeleccionado,
                Subtotal = subtotal,
                Impuestos = iva,
                Total = totalConIva,
                CreatedBy = usuarioActual
            };
            await PedidoRepository.AddAsync(pedido);
            pedidoBaseIdEditando = pedido.Id;

            await SincronizarConceptosAsync(pedido.Id, conceptosValidos, usuarioActual);

            if (!incluyeProductos)
            {
                await CargarPedidos();
                CancelarEdicion();
                NavigationManager.NavigateTo("/pedidos");
                return;
            }

            var detalle = new PedidoDetalle
            {
                PedidoId = pedido.Id,
                ProductoId = productoId!.Value,
                ProductoVarianteId = productoConfig?.TieneVariantes == true && productoConfig.UsaVariantesTalla == false
                    ? ResolverProductoVarianteSeleccionado(productoId.Value, null, colorSeleccionado)
                    : null,
                CotizacionSerigrafiaId = cotizacionId,
                Cantidad = cantidadTotal,
                PrecioUnitario = precioUnitario,
                Total = subtotalProducto,
                TallaBaseCalzado = tallasEditando.OrderBy(t => t.Talla).Select(t => t.Talla).FirstOrDefault(),
                VariacionValor = colorSeleccionado,
                AplicaFraccionCalzado = capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion,
                ClienteFraccionCalzadoId = capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion ? fraccionSeleccionadaId : null,
                CreatedBy = usuarioActual
            };
            await PedidoDetalleRepository.AddAsync(detalle);
            await SincronizarDetalleTallasAsync(detalle.Id, detalle.ProductoId, cotizacionPrecio!, colorSeleccionado, tipoPrecioSeleccionado, usuarioActual, capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion);

            pedidoEditando.PedidoDetalleId = detalle.Id;
            pedidoEditando.CreatedBy = usuarioActual;
            await PedidoSerigrafiaRepository.AddAsync(pedidoEditando);
        }
        else
        {
            pedidoEditando.UpdatedAt = DateTime.UtcNow;
            pedidoEditando.UpdatedBy = usuarioActual;
            await PedidoSerigrafiaRepository.UpdateAsync(pedidoEditando);

            var detalle = await DbContext.PedidoDetalles.FindAsync(pedidoEditando.PedidoDetalleId);
            if (detalle == null) return;

            pedidoBaseIdEditando = detalle.PedidoId;
            detalle.ProductoId = productoId!.Value;
            detalle.ProductoVarianteId = productoConfig?.TieneVariantes == true && productoConfig.UsaVariantesTalla == false
                ? ResolverProductoVarianteSeleccionado(productoId.Value, null, colorSeleccionado)
                : null;
            detalle.CotizacionSerigrafiaId = cotizacionId;
            detalle.Cantidad = cantidadTotal;
            detalle.PrecioUnitario = precioUnitario;
            detalle.Total = subtotalProducto;
            detalle.TallaBaseCalzado = tallasEditando.OrderBy(t => t.Talla).Select(t => t.Talla).FirstOrDefault();
            detalle.VariacionValor = colorSeleccionado;
            detalle.AplicaFraccionCalzado = capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion;
            detalle.ClienteFraccionCalzadoId = capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion ? fraccionSeleccionadaId : null;
            detalle.UpdatedAt = DateTime.UtcNow;
            detalle.UpdatedBy = usuarioActual;

            await SincronizarDetalleTallasAsync(detalle.Id, detalle.ProductoId, cotizacionPrecio!, colorSeleccionado, tipoPrecioSeleccionado, usuarioActual, capturaEscalaSeleccionada == CapturaEscalaModo.Fraccion);

            var pedido = await DbContext.Pedidos.FindAsync(detalle.PedidoId);
            if (pedido == null) return;

            pedido.ClienteId = clienteSeleccionadoId.Value;
            pedido.FechaPedido = pedidoEditando.FechaRecibido ?? pedido.FechaPedido;
            pedido.TipoPrecio = tipoPrecioSeleccionado;
            pedido.Subtotal = subtotal;
            pedido.Impuestos = iva;
            pedido.Total = totalConIva;
            pedido.UpdatedAt = DateTime.UtcNow;
            pedido.UpdatedBy = usuarioActual;

            await DbContext.SaveChangesAsync();
            await SincronizarConceptosAsync(pedido.Id, conceptosValidos, usuarioActual);
        }

        await ActualizarTallasAsync(pedidoEditando.Id);
        await RecargarTallasAsync(pedidoEditando.Id);
        await ActualizarProcesosAsync(pedidoEditando.Id);
        await CargarSeguimientosAsync(pedidoEditando.Id);
        await ActualizarEstadoPedidoAsync(pedidoEditando.Id);
        await CargarPedidos();
        CancelarEdicion();
    }

    private async Task ComprobarConsumosInventario()
    {
        InvalidarComprobacionInventario();

        if (!MuestraProductos || !productoSeleccionadoId.HasValue)
        {
            return;
        }

        if (!cotizacionSeleccionadaId.HasValue)
        {
            avisosComprobacionInventario.Add("Selecciona una cotización antes de revisar consumos e inventario.");
            return;
        }

        var cantidadTotal = tallasEditando.Where(t => t.Cantidad > 0).Sum(t => t.Cantidad);
        if (cantidadTotal <= 0)
        {
            avisosComprobacionInventario.Add("Captura al menos una talla con cantidad mayor a cero antes de revisar inventario.");
            return;
        }

        revisandoComprobacionInventario = true;

        try
        {
            var detallesCotizacion = await DbContext.CotizacionDetalles
                .AsNoTracking()
                .Where(d => d.CotizacionSerigrafiaId == cotizacionSeleccionadaId.Value)
                .Where(d => d.Categoria == CotizacionCategoria.Tinta || d.Categoria == CotizacionCategoria.InsumoBasico || d.Categoria == CotizacionCategoria.InsumoDiverso)
                .Select(d => new ComprobacionInventarioFuente
                {
                    Categoria = d.Categoria,
                    Concepto = d.Concepto,
                    Consumo = d.Consumo,
                    InventarioItemId = d.InventarioItemId,
                    Nombre = d.InventarioItem != null ? d.InventarioItem.Nombre : d.Concepto,
                    UnidadMedida = d.InventarioItem != null ? d.InventarioItem.UnidadMedida : string.Empty,
                    ExistenciaInventario = d.InventarioItem != null ? d.InventarioItem.Cantidad : null
                })
                .ToListAsync();

            if (!detallesCotizacion.Any(d => d.Consumo > 0))
            {
                avisosComprobacionInventario.Add("La cotización seleccionada no tiene materias primas o insumos con consumo capturado.");
                inventarioComprobado = true;
                inventarioComprobadoEn = DateTime.Now;
                return;
            }

            var referencias = string.Join(" • ", tallasEditando
                .Where(t => t.Cantidad > 0)
                .OrderBy(t => t.Talla)
                .Select(t => $"{t.Talla} x{t.Cantidad}"));

            var acumulado = new Dictionary<string, ComprobacionInventarioItem>(StringComparer.OrdinalIgnoreCase);

            foreach (var consumo in detallesCotizacion.Where(d => d.Consumo > 0))
            {
                var cantidadRequerida = consumo.Consumo * cantidadTotal;
                if (cantidadRequerida <= 0)
                {
                    continue;
                }

                var tipo = consumo.Categoria == CotizacionCategoria.Tinta ? "Material tipo tinta" : "Material de apoyo";
                var itemId = consumo.InventarioItemId;
                var nombre = consumo.Nombre;
                var unidadMedida = consumo.UnidadMedida;
                var existencia = consumo.ExistenciaInventario;
                var sinVinculoInventario = !itemId.HasValue;
                var clave = itemId.HasValue
                    ? $"{tipo}:{itemId.Value}"
                    : $"{tipo}:sin-mapeo:{(nombre ?? consumo.Concepto).Trim().ToUpperInvariant()}";

                if (!acumulado.TryGetValue(clave, out var item))
                {
                    item = new ComprobacionInventarioItem
                    {
                        Tipo = tipo,
                        InventarioItemId = consumo.InventarioItemId,
                        Nombre = string.IsNullOrWhiteSpace(nombre) ? consumo.Concepto : nombre!,
                        UnidadMedida = string.IsNullOrWhiteSpace(unidadMedida) ? string.Empty : unidadMedida!,
                        ExistenciaInventario = existencia,
                        SinVinculoInventario = sinVinculoInventario
                    };
                    acumulado[clave] = item;
                }

                item.CantidadRequerida += cantidadRequerida;
                item.Referencias.Add(referencias);
            }

            comprobacionInventarioItems.AddRange(acumulado.Values
                .OrderByDescending(item => item.HayFaltante)
                .ThenByDescending(item => item.SinVinculoInventario)
                .ThenBy(item => item.Tipo)
                .ThenBy(item => item.Nombre));

            inventarioComprobado = true;
            inventarioComprobadoEn = DateTime.Now;
        }
        finally
        {
            revisandoComprobacionInventario = false;
        }
    }

