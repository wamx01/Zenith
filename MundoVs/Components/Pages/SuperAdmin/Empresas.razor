    private IEnumerable<Empresa> FiltrarEmpresas()
    {
        IEnumerable<Empresa> consulta = empresas;

        consulta = filtroVista switch
        {
            "activas" => consulta.Where(e => e.Estado == EmpresaEstado.Activa && e.IsActive && !e.IsSuspended),
            "suspendidas" => consulta.Where(e => e.Estado == EmpresaEstado.Suspendida || e.IsSuspended),
            "canceladas" => consulta.Where(e => e.Estado == EmpresaEstado.Cancelada),
            "sin-admin" => consulta.Where(e => GetAdminEmpresa(e.Id) == null),
            "reactivacion" => consulta.Where(RequiereReactivacion),
            _ => consulta
        };

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var texto = textoBusqueda.Trim();
            consulta = consulta.Where(e =>
                e.Codigo.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || e.RazonSocial.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || (!string.IsNullOrWhiteSpace(e.Rfc) && e.Rfc.Contains(texto, StringComparison.OrdinalIgnoreCase))
                || (GetAdminEmpresa(e.Id)?.Email?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false)
                || (GetAdminEmpresa(e.Id)?.NombreCompleto?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return consulta.ToList();
    }

