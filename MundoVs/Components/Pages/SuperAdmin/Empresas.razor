@page "/superadmin/empresas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Auth
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Core.Security
@inject IDbContextFactory<MundoVs.Infrastructure.Data.CrmDbContext> DbFactory
@inject CodigoNegocioService CodigoNegocio
@inject IAuthService AuthService
@inject IAuditService AuditService
@inject IModuloAccesoService ModuloAccesoService
@inject ITenantFileStorageService TenantFileStorage
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Empresas</PageTitle>

<div class="container-fluid px-4">
    <AuthorizeView>
        <Authorized Context="auth">
            @if (!Tiene(auth, "empresas.editar"))
            {
                <div class="alert alert-warning mt-3">
                    No tienes permisos para administrar empresas.
                </div>
            }
            else
            {
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h1 class="display-6 fw-bold"><i class="bi bi-building me-2"></i>Empresas</h1>
                    <button class="btn btn-primary" @onclick="NuevaEmpresa"><i class="bi bi-plus-circle me-1"></i>Nueva Empresa</button>
                </div>

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="alert alert-danger">@mensajeError</div>
                }
                @if (!string.IsNullOrEmpty(mensajeOk))
                {
                    <div class="alert alert-success">@mensajeOk</div>
                }
                @if (!string.IsNullOrWhiteSpace(passwordTemporalGenerado))
                {
                    <div class="alert alert-warning d-flex flex-column gap-1" role="alert">
                        <div class="fw-semibold"><i class="bi bi-key me-1"></i>Contraseña temporal generada para @passwordTemporalUsuario</div>
                        <div class="small">Compártela por un canal seguro. El admin deberá cambiarla al iniciar sesión.</div>
                        <code>@passwordTemporalGenerado</code>
                    </div>
                }

                @if (mostrarFormulario)
                {
                    <div class="card mb-4">
                        <div class="card-header"><h5 class="mb-0">@(EsNuevaEmpresa ? "Nueva Empresa" : "Editar Empresa")</h5></div>
                        <div class="card-body">
                            <EditForm Model="editando" OnValidSubmit="Guardar">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Código</label>
                                        <InputText class="form-control" @bind-Value="editando.Codigo" readonly />
                                        <small class="text-muted">Se genera automáticamente al capturar la razón social o nombre comercial.</small>
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label">Razón social</label>
                                        <input class="form-control" value="@editando.RazonSocial" @oninput="OnRazonSocialInput" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre comercial</label>
                                        <input class="form-control" value="@editando.NombreComercial" @oninput="OnNombreComercialInput" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">RFC</label>
                                        <InputText class="form-control" @bind-Value="editando.Rfc" />
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label">Slogan</label>
                                        <InputText class="form-control" @bind-Value="editando.Slogan" />
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label">Giro de empresa</label>
                                        <InputText class="form-control" @bind-Value="giroEmpresa" />
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Estado</label>
                                        <InputSelect class="form-select" @bind-Value="editando.Estado">
                                            @foreach (var estado in Enum.GetValues<EmpresaEstado>())
                                            {
                                                <option value="@estado">@estado</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Trial hasta</label>
                                        <InputDate class="form-control" @bind-Value="editando.TrialEndsAt" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Activada el</label>
                                        <InputDate class="form-control" @bind-Value="editando.ActivatedAt" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Máx. usuarios</label>
                                        <InputNumber class="form-control" @bind-Value="editando.MaxUsuarios" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Plan actual</label>
                                        <InputSelect class="form-select" @bind-Value="editando.PlanActualId">
                                            <option value="">— Sin plan —</option>
                                            @foreach (var plan in planes)
                                            {
                                                <option value="@plan.Id">@plan.Nombre (@plan.PrecioMensual.ToString("C2")/mes)</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Periodicidad</label>
                                        <InputSelect class="form-select" @bind-Value="editandoSuscripcion.Periodicidad">
                                            @foreach (var periodicidad in Enum.GetValues<PeriodicidadSuscripcion>())
                                            {
                                                <option value="@periodicidad">@periodicidad</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Estado suscripción</label>
                                        <InputSelect class="form-select" @bind-Value="editandoSuscripcion.Estado">
                                            @foreach (var estadoSuscripcion in Enum.GetValues<EstadoSuscripcion>())
                                            {
                                                <option value="@estadoSuscripcion">@estadoSuscripcion</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Inicio suscripción</label>
                                        <InputDate class="form-control" @bind-Value="editandoSuscripcion.FechaInicio" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Fin suscripción</label>
                                        <InputDate class="form-control" @bind-Value="editandoSuscripcion.FechaFin" />
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-check mt-4">
                                            <InputCheckbox class="form-check-input" @bind-Value="editando.IsActive" />
                                            <label class="form-check-label">Tenant activo</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-check mt-4">
                                            <InputCheckbox class="form-check-input" @bind-Value="editando.IsSuspended" />
                                            <label class="form-check-label">Suspendido</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-check mt-4">
                                            <InputCheckbox class="form-check-input" @bind-Value="editandoSuscripcion.RenovacionAutomatica" />
                                            <label class="form-check-label">Renovación automática</label>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="card border-0 bg-light-subtle">
                                            <div class="card-body">
                                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                                    <div>
                                                        <h6 class="mb-1"><i class="bi bi-grid-1x2-fill me-1"></i>Módulos habilitados</h6>
                                                        <small class="text-muted">Definen qué áreas puede operar la empresa y qué capabilities estarán disponibles para sus roles.</small>
                                                    </div>
                                                    <span class="badge text-bg-primary">@modulosEmpresa.Count(m => m.Habilitado) activos</span>
                                                </div>

                                                @if (modulosEmpresa.Count == 0)
                                                {
                                                    <div class="text-muted small">No hay módulos configurables disponibles.</div>
                                                }
                                                else
                                                {
                                                    <div class="row g-3">
                                                        @foreach (var modulo in modulosEmpresa)
                                                        {
                                                            <div class="col-md-6 col-xl-4">
                                                                <label class="card h-100 border shadow-sm-sm empresa-modulo-card @(modulo.Habilitado ? "empresa-modulo-card--enabled" : string.Empty)">
                                                                    <div class="card-body py-3">
                                                                        <div class="form-check">
                                                                            <InputCheckbox class="form-check-input" @bind-Value="modulo.Habilitado" disabled="@EsModuloObligatorio(modulo.Clave)" />
                                                                            <span class="form-check-label fw-semibold">@modulo.Nombre</span>
                                                                        </div>
                                                                        @if (!string.IsNullOrWhiteSpace(modulo.Descripcion))
                                                                        {
                                                                            <div class="text-muted small mt-2">@modulo.Descripcion</div>
                                                                        }
                                                                        <div class="mt-2">
                                                                            <span class="badge @(modulo.Habilitado ? "text-bg-success" : "text-bg-secondary")">@(modulo.Habilitado ? "Habilitado" : "Deshabilitado")</span>
                                                                            @if (EsModuloObligatorio(modulo.Clave))
                                                                            {
                                                                                <span class="badge text-bg-dark ms-1">Obligatorio</span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                </label>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-12">
                                        <label class="form-label">Logo (opcional)</label>
                                        <InputFile OnChange="OnLogoSelected" accept="image/png,image/jpeg,image/webp,image/svg+xml" class="form-control" />
                                        <small class="text-muted">PNG, JPG, WebP o SVG. Máximo 2 MB.</small>
                                        @if (!string.IsNullOrEmpty(logoPreviewUrl))
                                        {
                                            <div class="mt-2 text-center">
                                                <img src="@logoPreviewUrl" alt="Vista previa" style="max-height:120px;max-width:100%;object-fit:contain;border:1px solid #e2e8f0;border-radius:8px;padding:.5rem;background:#fafbfc;" />
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(logoMensaje))
                                        {
                                            <div class="alert @(logoError ? "alert-danger" : "alert-success") mt-2 py-1 px-2 small mb-0">@logoMensaje</div>
                                        }
                                    </div>

                                    <div class="col-12"><hr /></div>

                                    <div class="col-12">
                                        <div class="card border-0 bg-light-subtle">
                                            <div class="card-body">
                                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                                    <div>
                                                        <h6 class="mb-1"><i class="bi bi-person-badge me-1"></i>Administrador principal</h6>
                                                        <small class="text-muted">@GetAdminAyuda()</small>
                                                    </div>
                                                    @if (!EsNuevaEmpresa)
                                                    {
                                                        <span class="badge @(adminExiste ? "text-bg-success" : "text-bg-warning")">@(adminExiste ? "Configurado" : "Sin admin")</span>
                                                    }
                                                </div>

                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Admin (nombre)</label>
                                                        <InputText class="form-control" @bind-Value="adminNombre" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Admin (email)</label>
                                                        <InputText class="form-control" @bind-Value="adminEmail" />
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Admin (password)</label>
                                                        <InputText class="form-control" @bind-Value="adminPassword" type="password" />
                                                        <small class="text-muted">@(adminExiste ? "Déjalo vacío si no deseas cambiar la contraseña." : "Se requiere para crear el admin de la empresa.")</small>
                                                    </div>
                                                    <div class="col-md-6 d-flex align-items-end">
                                                        @if (EsNuevaEmpresa)
                                                        {
                                                            <div class="form-check">
                                                                <InputCheckbox class="form-check-input" @bind-Value="crearAdmin" />
                                                                <label class="form-check-label">Crear usuario admin inicial</label>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="form-check">
                                                                <InputCheckbox class="form-check-input" @bind-Value="adminActivo" />
                                                                <label class="form-check-label">Admin activo</label>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12 d-flex gap-2">
                                        <button class="btn btn-primary" type="submit" disabled="@guardando">
                                            @if (guardando)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                <span>Guardando...</span>
                                            }
                                            else
                                            {
                                                <span>Guardar</span>
                                            }
                                        </button>
                                        <button class="btn btn-outline-secondary" type="button" @onclick="Cancelar" disabled="@guardando">Cancelar</button>
                                    </div>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                }

                @if (!EsNuevaEmpresa && editando.PlanActualId.HasValue)
                {
                    <div class="card mb-4 border-success">
                        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-credit-card me-1"></i>Pago de suscripción</h5>
                            <div class="d-flex gap-2">
                                @if (NecesitaReactivacion())
                                {
                                    <button class="btn btn-sm btn-warning" @onclick="ReactivarEmpresa" disabled="@guardando">
                                        <i class="bi bi-arrow-clockwise me-1"></i>Reactivar empresa
                                    </button>
                                }
                                <button class="btn btn-sm btn-light" @onclick="PrepararPagoSuscripcion">Registrar pago</button>
                            </div>
                        </div>
                        @if (mostrarPagoSuscripcion)
                        {
                            <div class="card-body">
                                @if (NecesitaReactivacion())
                                {
                                    <div class="alert alert-warning py-2">
                                        La empresa está suspendida, cancelada o inactiva. Puedes registrar el pago y reactivarla explícitamente.
                                    </div>
                                }

                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label class="form-label">Monto</label>
                                        <InputNumber class="form-control" @bind-Value="nuevoPagoSuscripcion.Monto" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Fecha</label>
                                        <InputDate class="form-control" @bind-Value="nuevoPagoSuscripcion.FechaPago" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Método</label>
                                        <InputSelect class="form-select" @bind-Value="nuevoPagoSuscripcion.MetodoPago">
                                            @foreach (var metodo in Enum.GetValues<MetodoPagoSuscripcion>())
                                            {
                                                <option value="@metodo">@metodo</option>
                                            }
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Referencia</label>
                                        <InputText class="form-control" @bind-Value="nuevoPagoSuscripcion.Referencia" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Notas</label>
                                        <InputText class="form-control" @bind-Value="nuevoPagoSuscripcion.Notas" />
                                    </div>
                                    <div class="col-12 d-flex gap-2">
                                        <button class="btn btn-success" type="button" @onclick="RegistrarPagoSuscripcion" disabled="@guardando">
                                            @(NecesitaReactivacion() ? "Guardar pago y reactivar" : "Guardar pago")
                                        </button>
                                        <button class="btn btn-outline-secondary" type="button" @onclick="CancelarPagoSuscripcion">Cancelar</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="card">
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
                            <div style="min-width:280px;flex:1 1 280px;">
                                <label class="form-label">Buscar</label>
                                <input class="form-control" value="@textoBusqueda" @oninput="OnTextoBusquedaChanged" placeholder="Código, razón social, RFC o admin" />
                            </div>
                            <div style="min-width:220px;">
                                <label class="form-label">Vista rápida</label>
                                <select class="form-select" value="@filtroVista" @onchange="OnFiltroVistaChanged">
                                    <option value="todas">Todas</option>
                                    <option value="activas">Activas</option>
                                    <option value="suspendidas">Suspendidas</option>
                                    <option value="canceladas">Canceladas</option>
                                    <option value="sin-admin">Sin admin</option>
                                    <option value="reactivacion">Requieren reactivación</option>
                                </select>
                            </div>
                            <div>
                                <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarFiltros">Limpiar</button>
                            </div>
                            <div class="ms-auto small text-muted pb-2">@GetResumenFiltros()</div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Código</th>
                                        <th>Razón social</th>
                                        <th>Plan</th>
                                        <th>Admin</th>
                                        <th>Suscripción</th>
                                        <th>Estado</th>
                                        <th>Trial</th>
                                        <th>Máx. usuarios</th>
                                        <th>Suspendido</th>
                                        <th>Activa</th>
                                        <th>Atención</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!empresasFiltradas.Any())
                                    {
                                        <tr>
                                            <td colspan="12" class="text-center text-muted py-4">No hay empresas con los filtros actuales.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var e in empresasFiltradas)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@e.Codigo</td>
                                                <td>@e.RazonSocial</td>
                                                <td>@(GetSuscripcionActual(e.Id)?.Plan?.Nombre ?? e.PlanActual?.Nombre ?? "—")</td>
                                                <td>@(GetAdminEmpresa(e.Id)?.Email ?? "—")</td>
                                                <td>
                                                    @if (GetSuscripcionActual(e.Id) is { } suscripcion)
                                                    {
                                                        <span class="badge @GetSuscripcionBadge(suscripcion.Estado)">@suscripcion.Estado</span>
                                                    }
                                                    else
                                                    {
                                                        <span>—</span>
                                                    }
                                                </td>
                                                <td><span class="badge @GetEstadoBadge(e)">@e.Estado</span></td>
                                                <td>@(e.TrialEndsAt?.ToString("dd/MM/yyyy") ?? "—")</td>
                                                <td>@(e.MaxUsuarios?.ToString() ?? "—")</td>
                                                <td>@(e.IsSuspended ? "Sí" : "No")</td>
                                                <td>@(e.IsActive ? "Sí" : "No")</td>
                                                <td>
                                                    <div class="d-flex flex-wrap gap-1">
                                                        @if (RequiereReactivacion(e))
                                                        {
                                                            <span class="badge text-bg-warning">Requiere reactivación</span>
                                                        }
                                                        @if (GetAdminEmpresa(e.Id) == null)
                                                        {
                                                            <span class="badge text-bg-danger">Sin admin</span>
                                                        }
                                                        @if (!RequiereReactivacion(e) && GetAdminEmpresa(e.Id) != null)
                                                        {
                                                            <span class="badge text-bg-success">OK</span>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="text-end">
                                                    <div class="d-inline-flex gap-1 flex-wrap justify-content-end">
                                                        @if (RequiereReactivacion(e))
                                                        {
                                                            <button class="btn btn-sm btn-outline-warning" title="Reactivar empresa" @onclick="async () => await ReactivarEmpresaRapido(e)" disabled="@guardando">
                                                                <i class="bi bi-arrow-clockwise"></i>
                                                            </button>
                                                        }
                                                        @if (e.PlanActualId.HasValue)
                                                        {
                                                            <button class="btn btn-sm btn-outline-success" title="Registrar pago" @onclick="async () => await AbrirPagoRapido(e)" disabled="@guardando">
                                                                <i class="bi bi-credit-card"></i>
                                                            </button>
                                                        }
                                                        @if (GetAdminEmpresa(e.Id) != null)
                                                        {
                                                            <button class="btn btn-sm btn-outline-dark" title="Resetear password del admin" @onclick="async () => await ResetearAdminRapido(e)" disabled="@guardando">
                                                                <i class="bi bi-key"></i>
                                                            </button>
                                                        }
                                                        <button class="btn btn-sm btn-outline-primary" title="Editar empresa" @onclick="async () => await EditarEmpresa(e)" disabled="@guardando">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning mt-3">Debes iniciar sesión.</div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<style>
    .empresa-modulo-card { cursor: pointer; transition: all .15s ease; }
    .empresa-modulo-card:hover { transform: translateY(-1px); box-shadow: 0 .35rem .8rem rgba(15, 23, 42, .08); }
    .empresa-modulo-card--enabled { border-color: rgba(25, 135, 84, .35) !important; background: linear-gradient(180deg, rgba(25, 135, 84, .05), rgba(25, 135, 84, .01)); }
</style>

@code {
    private List<Empresa> empresas = [];
    private List<Plan> planes = [];
    private Dictionary<Guid, SuscripcionEmpresa> suscripcionesActuales = [];
    private Dictionary<Guid, Usuario> administradoresEmpresa = [];
    private Empresa editando = new();
    private SuscripcionEmpresa editandoSuscripcion = new();
    private bool mostrarFormulario;
    private bool mostrarPagoSuscripcion;
    private bool guardando;
    private string? mensajeError;
    private string? mensajeOk;
    private string? passwordTemporalGenerado;
    private string? passwordTemporalUsuario;
    private string giroEmpresa = string.Empty;
    private string textoBusqueda = string.Empty;
    private string filtroVista = "todas";

    private const long MaxLogoSize = 2 * 1024 * 1024;
    private static readonly string[] AllowedExtensions = [".png", ".jpg", ".jpeg", ".webp", ".svg"];
    private IBrowserFile? logoFile;
    private string? logoMensaje;
    private bool logoError;
    private string? logoPreviewUrl;

    private bool crearAdmin = true;
    private Guid? adminUsuarioId;
    private bool adminExiste;
    private bool adminActivo = true;
    private string adminNombre = "Administrador";
    private string adminEmail = "";
    private string adminPassword = "";
    private PagoSuscripcion nuevoPagoSuscripcion = new() { FechaPago = DateTime.Today };
    private bool _puedeAdministrar;
    private List<EmpresaModuloEdicion> modulosEmpresa = [];
    private bool EsNuevaEmpresa => editando.Id == Guid.Empty;
    private IEnumerable<Empresa> empresasFiltradas => FiltrarEmpresas();

    protected override async Task OnInitializedAsync()
    {
        _puedeAdministrar = await PuedeAdministrarEmpresas();
        if (_puedeAdministrar)
            await Cargar();
    }

    private async Task<bool> PuedeAdministrarEmpresas()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return Tiene(state, "empresas.editar");
    }

    private async Task Cargar()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        planes = await db.Planes.IgnoreQueryFilters()
            .AsNoTracking()
            .Where(p => p.IsActive)
            .OrderBy(p => p.PrecioMensual)
            .ThenBy(p => p.Nombre)
            .ToListAsync();

        empresas = await db.Empresas.IgnoreQueryFilters()
            .Include(e => e.PlanActual)
            .AsNoTracking()
            .OrderBy(e => e.Codigo)
            .ToListAsync();

        var suscripciones = await db.SuscripcionesEmpresa.IgnoreQueryFilters()
            .Include(s => s.Plan)
            .AsNoTracking()
            .OrderByDescending(s => s.FechaInicio)
            .ThenByDescending(s => s.CreatedAt)
            .ToListAsync();

        suscripcionesActuales = suscripciones
            .GroupBy(s => s.EmpresaId)
            .ToDictionary(g => g.Key, g => g.First());

        var admins = await db.Usuarios.IgnoreQueryFilters()
            .Include(u => u.TipoUsuario)
            .AsNoTracking()
            .Where(u => u.TipoUsuario.Nombre == "Administrador")
            .OrderBy(u => u.EmpresaId)
            .ThenByDescending(u => u.IsActive)
            .ThenBy(u => u.CreatedAt)
            .ToListAsync();

        administradoresEmpresa = admins
            .GroupBy(u => u.EmpresaId)
            .ToDictionary(g => g.Key, g => g.First());
    }

