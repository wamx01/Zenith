        await Cargar();
    }

    private async Task RegistrarPagoSuscripcion()
    {
        mensajeError = null;
        mensajeOk = null;
        LimpiarPasswordTemporal();
        guardando = true;

        try
        {
            if (editando.Id == Guid.Empty || !editando.PlanActualId.HasValue)
            {
                mensajeError = "La empresa debe tener un plan asignado.";
                return;
            }

            if (nuevoPagoSuscripcion.Monto <= 0)
            {
                mensajeError = "El monto del pago debe ser mayor a cero.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var suscripcion = await db.SuscripcionesEmpresa.IgnoreQueryFilters()
                .Where(s => s.EmpresaId == editando.Id)
                .OrderByDescending(s => s.FechaInicio)
                .ThenByDescending(s => s.CreatedAt)
                .FirstOrDefaultAsync();
            if (suscripcion == null)
            {
                mensajeError = "No se encontró una suscripción activa para registrar el pago.";
                return;
            }

            db.PagosSuscripcion.Add(new PagoSuscripcion
            {
                Id = Guid.NewGuid(),
                SuscripcionEmpresaId = suscripcion.Id,
                Monto = nuevoPagoSuscripcion.Monto,
                FechaPago = nuevoPagoSuscripcion.FechaPago,
                MetodoPago = nuevoPagoSuscripcion.MetodoPago,
                Referencia = nuevoPagoSuscripcion.Referencia?.Trim(),
                Notas = nuevoPagoSuscripcion.Notas?.Trim(),
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });

            var baseFecha = suscripcion.FechaFin.HasValue && suscripcion.FechaFin.Value.Date > nuevoPagoSuscripcion.FechaPago.Date
                ? suscripcion.FechaFin.Value.Date
                : nuevoPagoSuscripcion.FechaPago.Date;
            suscripcion.FechaFin = suscripcion.Periodicidad == PeriodicidadSuscripcion.Anual ? baseFecha.AddYears(1) : baseFecha.AddMonths(1);
            suscripcion.Estado = EstadoSuscripcion.Activa;
            suscripcion.UpdatedAt = DateTime.UtcNow;

            var empresa = await db.Empresas.IgnoreQueryFilters().FirstOrDefaultAsync(e => e.Id == editando.Id);
            if (empresa != null)
            {
                empresa.Estado = EmpresaEstado.Activa;
                empresa.IsSuspended = false;
                empresa.IsActive = true;
                empresa.ActivatedAt ??= DateTime.UtcNow;
                empresa.UpdatedAt = DateTime.UtcNow;
            }

            await db.SaveChangesAsync();
            await AuditService.LogAsync("Registrar pago suscripción", nameof(PagoSuscripcion), null, $"Pago {nuevoPagoSuscripcion.Monto:C2} registrado para la empresa {editando.Codigo}.", editando.Id);

            mensajeOk = NecesitaReactivacion()
                ? "Pago registrado y empresa reactivada correctamente."
                : "Pago de suscripción registrado correctamente.";
            mostrarPagoSuscripcion = false;
            await Cargar();
            var empresaActualizada = empresas.FirstOrDefault(e => e.Id == editando.Id);
            if (empresaActualizada != null)
                await EditarEmpresa(empresaActualizada);
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

