    private async Task GuardarConfiguracionEmpresaAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Empresa empresa)
    {
        var companyName = string.IsNullOrWhiteSpace(empresa.NombreComercial) ? empresa.RazonSocial.Trim() : empresa.NombreComercial.Trim();
        var companySlogan = string.IsNullOrWhiteSpace(empresa.Slogan) ? "CRM & Producción" : empresa.Slogan.Trim();
        var giro = string.IsNullOrWhiteSpace(giroEmpresa) ? "General" : giroEmpresa.Trim();

        await UpsertAppConfigAsync(db, empresa.Id, "CompanyName", companyName, "Nombre de la empresa");
        await UpsertAppConfigAsync(db, empresa.Id, "CompanySlogan", companySlogan, "Slogan o subtítulo");
        await UpsertAppConfigAsync(db, empresa.Id, "GiroEmpresa", giro, "Giro o actividad principal de la empresa");
        await db.SaveChangesAsync();
    }

    private static async Task UpsertAppConfigAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId, string clave, string valor, string descripcion)
    {
        var config = await db.AppConfigs.IgnoreQueryFilters()
            .FirstOrDefaultAsync(c => c.EmpresaId == empresaId && c.Clave == clave);

        if (config == null)
        {
            db.AppConfigs.Add(new AppConfig
            {
                EmpresaId = empresaId,
                Clave = clave,
                Valor = valor,
                Descripcion = descripcion
            });
            return;
        }

        config.Valor = valor;
        config.Descripcion = descripcion;
        config.UpdatedAt = DateTime.UtcNow;
    }

    private static async Task SeedRolesEmpresa(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        // Excluir capacidades globales de plataforma
        var allCaps = await db.Capacidades.AsNoTracking()
            .Where(c => !c.Clave.StartsWith("empresas."))
            .ToListAsync();
        var allCapIdsByClave = allCaps
            .GroupBy(c => c.Clave, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().Id, StringComparer.OrdinalIgnoreCase);

        async Task EnsureTipo(string nombre, string desc, IEnumerable<string> claves)
        {
            var tipo = await db.TiposUsuario.IgnoreQueryFilters()
                .FirstOrDefaultAsync(t => t.EmpresaId == empresaId && t.Nombre == nombre);
            if (tipo == null)
            {
                tipo = new TipoUsuario { Nombre = nombre, Descripcion = desc, EmpresaId = empresaId, IsSystem = false, IsActive = true };
                db.TiposUsuario.Add(tipo);
                await db.SaveChangesAsync();
            }

            var actuales = await db.TipoUsuarioCapacidades
                .IgnoreQueryFilters()
                .Where(tc => tc.TipoUsuarioId == tipo.Id)
                .Select(tc => tc.CapacidadId)
                .ToListAsync();

            var capacidadesActuales = actuales.ToHashSet();
            foreach (var capacidadId in db.ChangeTracker.Entries<TipoUsuarioCapacidad>()
                .Where(e => e.State != EntityState.Deleted && e.Entity.TipoUsuarioId == tipo.Id)
                .Select(e => e.Entity.CapacidadId))
            {
                capacidadesActuales.Add(capacidadId);
            }

            foreach (var clave in claves.Distinct(StringComparer.OrdinalIgnoreCase))
            {
                if (!allCapIdsByClave.TryGetValue(clave, out var capId) || !capacidadesActuales.Add(capId))
                    continue;

                db.TipoUsuarioCapacidades.Add(new TipoUsuarioCapacidad { TipoUsuarioId = tipo.Id, CapacidadId = capId });
            }
            await db.SaveChangesAsync();
        }

        await EnsureTipo("Administrador", "Acceso total a la empresa", allCaps.Select(c => c.Clave));
    }

    private static async Task AsegurarCapacidadesAdministradorAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        var administrador = await db.TiposUsuario.IgnoreQueryFilters()
            .FirstOrDefaultAsync(t => t.EmpresaId == empresaId && t.Nombre == "Administrador");

        if (administrador == null)
            return;

        var capacidades = await db.Capacidades.IgnoreQueryFilters()
            .Where(c => c.Clave == "usuarios.ver" || c.Clave == "usuarios.editar")
            .ToListAsync();

        var actuales = await db.TipoUsuarioCapacidades
            .IgnoreQueryFilters()
            .Where(tc => tc.TipoUsuarioId == administrador.Id)
            .Select(tc => tc.CapacidadId)
            .ToListAsync();
        var capacidadesActuales = actuales.ToHashSet();

        foreach (var capacidadId in db.ChangeTracker.Entries<TipoUsuarioCapacidad>()
            .Where(e => e.State != EntityState.Deleted && e.Entity.TipoUsuarioId == administrador.Id)
            .Select(e => e.Entity.CapacidadId))
        {
            capacidadesActuales.Add(capacidadId);
        }

        foreach (var capacidadId in capacidades.Select(c => c.Id).Distinct())
        {
            if (!capacidadesActuales.Add(capacidadId))
                continue;

            db.TipoUsuarioCapacidades.Add(new TipoUsuarioCapacidad
            {
                TipoUsuarioId = administrador.Id,
                CapacidadId = capacidadId
            });
        }

        await db.SaveChangesAsync();
    }

    private static async Task<TipoUsuario> ObtenerOCrearRolAdministradorAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        var administrador = await db.TiposUsuario.IgnoreQueryFilters()
            .FirstOrDefaultAsync(t => t.EmpresaId == empresaId && t.Nombre == "Administrador");

        if (administrador != null)
            return administrador;

        administrador = new TipoUsuario
        {
            Id = Guid.NewGuid(),
            Nombre = "Administrador",
            Descripcion = "Acceso total a la empresa",
            EmpresaId = empresaId,
            IsSystem = false,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };

        db.TiposUsuario.Add(administrador);
        await db.SaveChangesAsync();

        var capacidades = await db.Capacidades.AsNoTracking()
            .Where(c => !c.Clave.StartsWith("empresas."))
            .Select(c => c.Id)
            .ToListAsync();

        var capacidadesActuales = db.ChangeTracker.Entries<TipoUsuarioCapacidad>()
            .Where(e => e.State != EntityState.Deleted && e.Entity.TipoUsuarioId == administrador.Id)
            .Select(e => e.Entity.CapacidadId)
            .ToHashSet();

        foreach (var capacidadId in capacidades.Distinct())
        {
            if (!capacidadesActuales.Add(capacidadId))
                continue;

            db.TipoUsuarioCapacidades.Add(new TipoUsuarioCapacidad
            {
                TipoUsuarioId = administrador.Id,
                CapacidadId = capacidadId
            });
        }

        await db.SaveChangesAsync();
        await AsegurarCapacidadesAdministradorAsync(db, empresaId);
        return administrador;
    }

    private static bool EsModuloObligatorio(string clave)
        => string.Equals(clave, ModuloAccesoCatalog.Administracion, StringComparison.OrdinalIgnoreCase);

    private static string ObtenerMensajeError(Exception ex)
    {
        var current = ex;
        while (current.InnerException is not null)
            current = current.InnerException;

        return ReferenceEquals(current, ex)
            ? ex.Message
            : $"{ex.Message} Detalle: {current.Message}";
    }

