    private bool NecesitaReactivacion()
        => editando.Estado is EmpresaEstado.Suspendida or EmpresaEstado.Cancelada
            || editando.IsSuspended
            || !editando.IsActive;

    private static bool RequiereReactivacion(Empresa empresa)
