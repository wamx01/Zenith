    private async Task Guardar()
    {
        mensajeError = null;
        mensajeOk = null;
        logoMensaje = null;
        logoError = false;
        guardando = true;

        try
        {
            if (!_puedeAdministrar)
            {
                mensajeError = "No tienes permisos para administrar empresas.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editando.RazonSocial))
            {
                mensajeError = "La razón social es requerida.";
                return;
            }

            if (EsNuevaEmpresa)
                ActualizarCodigoSugerido();

            var requiereAdmin = RequiereGuardarAdmin();

            if (requiereAdmin)
            {
                if (string.IsNullOrWhiteSpace(adminNombre) || string.IsNullOrWhiteSpace(adminEmail))
                {
                    mensajeError = "Completa nombre y email del administrador.";
                    return;
                }

                if (!adminExiste && string.IsNullOrWhiteSpace(adminPassword))
                {
                    mensajeError = "La contraseña del admin es obligatoria cuando se crea por primera vez.";
                    return;
                }
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            await using var transaction = await db.Database.BeginTransactionAsync();

            Plan? planSeleccionado = null;
            if (editando.PlanActualId.HasValue)
            {
                planSeleccionado = await db.Planes.IgnoreQueryFilters()
                    .FirstOrDefaultAsync(p => p.Id == editando.PlanActualId && p.IsActive);

                if (planSeleccionado == null)
                {
                    mensajeError = "El plan seleccionado no existe o está inactivo.";
                    return;
                }
            }

            var estado = editando.IsSuspended && editando.Estado != EmpresaEstado.Cancelada
                ? EmpresaEstado.Suspendida
                : editando.Estado;
            var isSuspended = estado == EmpresaEstado.Suspendida || editando.IsSuspended;
            var activatedAt = estado == EmpresaEstado.Activa
                ? editando.ActivatedAt ?? DateTime.UtcNow
                : editando.ActivatedAt;
            Empresa empresa;
            var fechaInicioSuscripcion = editandoSuscripcion.FechaInicio == default ? DateTime.Today : editandoSuscripcion.FechaInicio.Date;
            var fechaFinSuscripcion = editandoSuscripcion.FechaFin ?? (editandoSuscripcion.Estado == EstadoSuscripcion.Trial && planSeleccionado != null && planSeleccionado.TrialDays > 0 ? fechaInicioSuscripcion.AddDays(planSeleccionado.TrialDays) : null);

            if (planSeleccionado != null)
            {
                switch (editandoSuscripcion.Estado)
                {
                    case EstadoSuscripcion.Trial:
                        estado = EmpresaEstado.Demo;
                        isSuspended = false;
                        activatedAt = null;
                        editando.IsActive = true;
                        break;
                    case EstadoSuscripcion.Activa:
                        estado = EmpresaEstado.Activa;
                        isSuspended = false;
                        activatedAt ??= fechaInicioSuscripcion;
                        editando.IsActive = true;
                        break;
                    case EstadoSuscripcion.Suspendida:
                    case EstadoSuscripcion.Vencida:
                        estado = EmpresaEstado.Suspendida;
                        isSuspended = true;
                        editando.IsActive = true;
                        break;
                    case EstadoSuscripcion.Cancelada:
                        estado = EmpresaEstado.Cancelada;
                        isSuspended = true;
                        editando.IsActive = false;
                        break;
                }
            }

            if (EsNuevaEmpresa)
            {
                if (crearAdmin)
                {
                    var email = adminEmail.Trim().ToLowerInvariant();
                    if (await db.Usuarios.IgnoreQueryFilters().AnyAsync(u => u.Email == email))
                    {
                        mensajeError = "Ya existe un usuario con ese email.";
                        return;
                    }
                }

                var codigo = await CodigoNegocio.GenerateUniqueCompanyCodeAsync(db, editando.NombreComercial, editando.RazonSocial);
                editando.Codigo = codigo;

                empresa = new Empresa
                {
                    Id = Guid.NewGuid(),
                    Codigo = codigo,
                    RazonSocial = editando.RazonSocial.Trim(),
                    NombreComercial = string.IsNullOrWhiteSpace(editando.NombreComercial) ? null : editando.NombreComercial.Trim(),
                    Rfc = string.IsNullOrWhiteSpace(editando.Rfc) ? null : editando.Rfc.Trim(),
                    Slogan = string.IsNullOrWhiteSpace(editando.Slogan) ? null : editando.Slogan.Trim(),
                    Estado = estado,
                    TrialEndsAt = planSeleccionado != null && editandoSuscripcion.Estado == EstadoSuscripcion.Trial ? fechaFinSuscripcion : editando.TrialEndsAt,
                    IsSuspended = isSuspended,
                    PlanActualId = editando.PlanActualId,
                    MaxUsuarios = editando.MaxUsuarios ?? planSeleccionado?.LimiteUsuarios,
                    ActivatedAt = activatedAt,
                    IsActive = editando.IsActive,
                    CreatedAt = DateTime.UtcNow
                };
                db.Empresas.Add(empresa);
                await db.SaveChangesAsync();

                await CodigoNegocio.EnsureCompanyShortCodeAsync(db, empresa);
                await SeedAppConfigs(db, empresa.Id);
                await GuardarConfiguracionEmpresaAsync(db, empresa);
                await GuardarModulosEmpresaAsync(db, empresa.Id);
                await SeedRolesEmpresa(db, empresa.Id);
                await SincronizarCapacidadesAdministradorEmpresaAsync(db, empresa.Id);

                await GuardarAdminEmpresaAsync(db, empresa.Id);

                await AuditService.LogAsync("Crear empresa", nameof(Empresa), empresa.Id, $"Empresa {empresa.Codigo} creada con estado {empresa.Estado}.", empresa.Id);
            }
            else
            {
                empresa = await db.Empresas.IgnoreQueryFilters().FirstOrDefaultAsync(e => e.Id == editando.Id)
                    ?? throw new InvalidOperationException("No se encontró la empresa.");

                empresa.RazonSocial = editando.RazonSocial.Trim();
                empresa.NombreComercial = string.IsNullOrWhiteSpace(editando.NombreComercial) ? null : editando.NombreComercial.Trim();
                empresa.Rfc = string.IsNullOrWhiteSpace(editando.Rfc) ? null : editando.Rfc.Trim();
                empresa.Slogan = string.IsNullOrWhiteSpace(editando.Slogan) ? null : editando.Slogan.Trim();
                empresa.Estado = estado;
                empresa.TrialEndsAt = planSeleccionado != null && editandoSuscripcion.Estado == EstadoSuscripcion.Trial ? fechaFinSuscripcion : editando.TrialEndsAt;
                empresa.IsSuspended = isSuspended;
                empresa.PlanActualId = editando.PlanActualId;
                empresa.MaxUsuarios = editando.MaxUsuarios ?? planSeleccionado?.LimiteUsuarios;
                empresa.ActivatedAt = activatedAt;
                empresa.IsActive = editando.IsActive;
                empresa.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
                await CodigoNegocio.EnsureCompanyShortCodeAsync(db, empresa);
                await GuardarConfiguracionEmpresaAsync(db, empresa);
                await GuardarModulosEmpresaAsync(db, empresa.Id);
                await GuardarAdminEmpresaAsync(db, empresa.Id);
                await SincronizarCapacidadesAdministradorEmpresaAsync(db, empresa.Id);

                await AuditService.LogAsync("Editar empresa", nameof(Empresa), empresa.Id, $"Empresa {empresa.Codigo} actualizada. Estado: {empresa.Estado}. Plan: {planSeleccionado?.Nombre ?? "Sin plan"}.", empresa.Id);
            }

            var suscripcionActual = await db.SuscripcionesEmpresa.IgnoreQueryFilters()
                .Where(s => s.EmpresaId == empresa.Id)
                .OrderByDescending(s => s.FechaInicio)
                .ThenByDescending(s => s.CreatedAt)
                .FirstOrDefaultAsync();

            if (planSeleccionado != null)
            {
                if (suscripcionActual == null)
                {
                    db.SuscripcionesEmpresa.Add(new SuscripcionEmpresa
                    {
                        EmpresaId = empresa.Id,
                        PlanId = planSeleccionado.Id,
                        FechaInicio = fechaInicioSuscripcion,
                        FechaFin = fechaFinSuscripcion,
                        Estado = editandoSuscripcion.Estado,
                        Periodicidad = editandoSuscripcion.Periodicidad,
                        RenovacionAutomatica = editandoSuscripcion.RenovacionAutomatica,
                        IsActive = true,
                        CreatedAt = DateTime.UtcNow
                    });
                }
                else
                {
                    suscripcionActual.PlanId = planSeleccionado.Id;
                    suscripcionActual.FechaInicio = fechaInicioSuscripcion;
                    suscripcionActual.FechaFin = fechaFinSuscripcion;
                    suscripcionActual.Estado = editandoSuscripcion.Estado;
                    suscripcionActual.Periodicidad = editandoSuscripcion.Periodicidad;
                    suscripcionActual.RenovacionAutomatica = editandoSuscripcion.RenovacionAutomatica;
                    suscripcionActual.IsActive = true;
                    suscripcionActual.UpdatedAt = DateTime.UtcNow;
                }

                await db.SaveChangesAsync();
            }
            else if (suscripcionActual != null && suscripcionActual.Estado != EstadoSuscripcion.Cancelada)
            {
                suscripcionActual.Estado = EstadoSuscripcion.Cancelada;
                suscripcionActual.FechaFin ??= DateTime.Today;
                suscripcionActual.RenovacionAutomatica = false;
                suscripcionActual.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
            }

            await transaction.CommitAsync();
            ModuloAccesoService.InvalidarCacheEmpresa(empresa.Id);

            if (logoFile != null)
            {
                var cfg = await db.AppConfigs.IgnoreQueryFilters()
                    .FirstOrDefaultAsync(c => c.EmpresaId == empresa.Id && c.Clave == "CompanyLogo");
                var relativePath = await GuardarLogoAsync(empresa.Id, logoFile, cfg?.Valor);
                if (cfg == null)
                {
                    db.AppConfigs.Add(new AppConfig { EmpresaId = empresa.Id, Clave = "CompanyLogo", Valor = relativePath, Descripcion = "Logo de la empresa" });
                }
                else
                {
                    cfg.Valor = relativePath;
                    cfg.UpdatedAt = DateTime.UtcNow;
                }
                await db.SaveChangesAsync();
            }

            mensajeOk = EsNuevaEmpresa ? "Empresa creada correctamente." : "Empresa actualizada correctamente.";
            mostrarFormulario = false;
            await Cargar();
        }
        catch (Exception ex)
        {
            mensajeError = ObtenerMensajeError(ex);
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task CargarModulosEmpresaAsync(Guid? empresaId = null, MundoVs.Infrastructure.Data.CrmDbContext? db = null)
    {
        var disposeDb = db is null;
        db ??= await DbFactory.CreateDbContextAsync();

        try
        {
            var catalogo = await db.ModulosAcceso.IgnoreQueryFilters()
                .AsNoTracking()
                .Where(m => m.IsActive && !m.EsGlobal)
                .OrderBy(m => m.Orden)
                .ThenBy(m => m.Nombre)
                .ToListAsync();

            var asignaciones = empresaId.HasValue && empresaId.Value != Guid.Empty
                ? await db.EmpresasModulosAcceso.IgnoreQueryFilters()
                    .AsNoTracking()
                    .Where(m => m.EmpresaId == empresaId.Value)
                    .ToListAsync()
                : [];

            modulosEmpresa = catalogo
                .Select(modulo =>
                {
                    var asignacion = asignaciones.FirstOrDefault(a => a.ModuloAccesoId == modulo.Id);
                    return new EmpresaModuloEdicion
                    {
                        ModuloAccesoId = modulo.Id,
                        Clave = modulo.Clave,
                        Nombre = modulo.Nombre,
                        Descripcion = modulo.Descripcion,
                        Habilitado = EsModuloObligatorio(modulo.Clave)
                            || (asignacion?.IsActive == true && asignacion.Habilitado)
                    };
                })
                .ToList();
        }
        finally
        {
            if (disposeDb && db is not null)
                await db.DisposeAsync();
        }
    }

    private async Task CargarAdminEmpresaAsync(Guid empresaId, MundoVs.Infrastructure.Data.CrmDbContext db)
    {
        var admin = await db.Usuarios.IgnoreQueryFilters()
            .Include(u => u.TipoUsuario)
            .AsNoTracking()
            .Where(u => u.EmpresaId == empresaId && u.TipoUsuario.Nombre == "Administrador")
            .OrderByDescending(u => u.IsActive)
            .ThenBy(u => u.CreatedAt)
            .FirstOrDefaultAsync();

        if (admin == null)
        {
            adminUsuarioId = null;
            adminExiste = false;
            adminActivo = true;
            adminNombre = "Administrador";
            adminEmail = string.Empty;
            adminPassword = string.Empty;
            return;
        }

        adminUsuarioId = admin.Id;
        adminExiste = true;
        adminActivo = admin.IsActive;
        adminNombre = admin.NombreCompleto;
        adminEmail = admin.Email;
        adminPassword = string.Empty;
    }

    private bool RequiereGuardarAdmin()
    {
        if (EsNuevaEmpresa)
            return crearAdmin;

        return adminUsuarioId.HasValue
            || !string.IsNullOrWhiteSpace(adminNombre)
            || !string.IsNullOrWhiteSpace(adminEmail)
            || !string.IsNullOrWhiteSpace(adminPassword);
    }

    private async Task GuardarAdminEmpresaAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        if (!RequiereGuardarAdmin())
            return;

        var nombre = adminNombre.Trim();
        var email = adminEmail.Trim().ToLowerInvariant();
        var passwordNueva = adminPassword.Trim();

        var adminTipo = await ObtenerOCrearRolAdministradorAsync(db, empresaId);
        var admin = adminUsuarioId.HasValue
            ? await db.Usuarios.IgnoreQueryFilters().FirstOrDefaultAsync(u => u.Id == adminUsuarioId.Value && u.EmpresaId == empresaId)
            : await db.Usuarios.IgnoreQueryFilters()
                .Include(u => u.TipoUsuario)
                .Where(u => u.EmpresaId == empresaId && u.TipoUsuario.Nombre == "Administrador")
                .OrderByDescending(u => u.IsActive)
                .ThenBy(u => u.CreatedAt)
                .FirstOrDefaultAsync();

        if (admin == null)
        {
            if (await db.Usuarios.IgnoreQueryFilters().AnyAsync(u => u.Email == email))
                throw new InvalidOperationException("Ya existe un usuario con el email del admin indicado.");

            var passwordError = AuthService.ValidarPassword(passwordNueva);
            if (!string.IsNullOrWhiteSpace(passwordError))
                throw new InvalidOperationException(passwordError);

            admin = new Usuario
            {
                Id = Guid.NewGuid(),
                NombreCompleto = nombre,
                Email = email,
                PasswordHash = AuthService.HashPassword(passwordNueva),
                TipoUsuarioId = adminTipo.Id,
                EmpresaId = empresaId,
                RequiereCambioPassword = true,
                IsActive = EsNuevaEmpresa || adminActivo,
                CreatedAt = DateTime.UtcNow
            };

            db.Usuarios.Add(admin);
            await db.SaveChangesAsync();
            adminUsuarioId = admin.Id;
            adminExiste = true;
            adminActivo = admin.IsActive;
            return;
        }

        if (!string.Equals(admin.Email, email, StringComparison.OrdinalIgnoreCase)
            && await db.Usuarios.IgnoreQueryFilters().AnyAsync(u => u.Email == email && u.Id != admin.Id))
        {
            throw new InvalidOperationException("Ya existe un usuario con el email del admin indicado.");
        }

        admin.NombreCompleto = nombre;
        admin.Email = email;
        admin.TipoUsuarioId = adminTipo.Id;
        admin.IsActive = adminActivo;
        admin.UpdatedAt = DateTime.UtcNow;

        if (!string.IsNullOrWhiteSpace(passwordNueva))
        {
            var passwordError = AuthService.ValidarPassword(passwordNueva);
            if (!string.IsNullOrWhiteSpace(passwordError))
                throw new InvalidOperationException(passwordError);

            admin.PasswordHash = AuthService.HashPassword(passwordNueva);
            admin.RequiereCambioPassword = true;
            admin.PasswordChangedAt = null;
        }

        await db.SaveChangesAsync();
        adminExiste = true;
    }

    private async Task GuardarModulosEmpresaAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        var existentes = await db.EmpresasModulosAcceso.IgnoreQueryFilters()
            .Where(m => m.EmpresaId == empresaId)
            .ToListAsync();

        foreach (var modulo in modulosEmpresa)
        {
            var habilitado = EsModuloObligatorio(modulo.Clave) || modulo.Habilitado;
            var asignacion = existentes.FirstOrDefault(m => m.ModuloAccesoId == modulo.ModuloAccesoId);
            if (asignacion == null)
            {
                db.EmpresasModulosAcceso.Add(new EmpresaModuloAcceso
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = empresaId,
                    ModuloAccesoId = modulo.ModuloAccesoId,
                    Habilitado = habilitado,
                    VigenteDesde = DateTime.UtcNow.Date,
                    Origen = OrigenModuloEmpresa.Manual,
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                });
                continue;
            }

            asignacion.Habilitado = habilitado;
            asignacion.IsActive = true;
            asignacion.Origen = OrigenModuloEmpresa.Manual;
            asignacion.VigenteDesde = DateTime.UtcNow.Date;
            asignacion.UpdatedAt = DateTime.UtcNow;
        }

        await db.SaveChangesAsync();
    }

    private static async Task SincronizarCapacidadesAdministradorEmpresaAsync(MundoVs.Infrastructure.Data.CrmDbContext db, Guid empresaId)
    {
        var administrador = await db.TiposUsuario.IgnoreQueryFilters()
            .FirstOrDefaultAsync(t => t.EmpresaId == empresaId && t.Nombre == "Administrador");

        if (administrador == null)
            return;

        var hoy = DateTime.UtcNow.Date;
        var modulosHabilitadosIds = await db.EmpresasModulosAcceso.IgnoreQueryFilters()
            .Where(m => m.EmpresaId == empresaId
                && m.IsActive
                && m.Habilitado
                && m.VigenteDesde <= hoy
                && (!m.VigenteHasta.HasValue || m.VigenteHasta.Value >= hoy))
            .Select(m => m.ModuloAccesoId)
            .ToListAsync();

        var capacidadesDeseadas = await db.Capacidades.IgnoreQueryFilters()
            .Where(c => !c.Clave.StartsWith("empresas.") && modulosHabilitadosIds.Contains(c.ModuloAccesoId))
            .Select(c => c.Id)
            .ToListAsync();

        var relacionesActuales = await db.TipoUsuarioCapacidades
            .IgnoreQueryFilters()
            .Where(tc => tc.TipoUsuarioId == administrador.Id)
            .ToListAsync();

        var actualesIds = relacionesActuales
            .Select(tc => tc.CapacidadId)
            .ToHashSet();

        var deseadasIds = capacidadesDeseadas.ToHashSet();

        var porEliminar = relacionesActuales
            .Where(tc => !deseadasIds.Contains(tc.CapacidadId))
            .ToList();

        if (porEliminar.Count > 0)
        {
            db.TipoUsuarioCapacidades.RemoveRange(porEliminar);
        }

        foreach (var capacidadId in capacidadesDeseadas.Distinct())
        {
            if (!actualesIds.Add(capacidadId))
                continue;

            db.TipoUsuarioCapacidades.Add(new TipoUsuarioCapacidad
            {
                TipoUsuarioId = administrador.Id,
                CapacidadId = capacidadId
            });
        }

        await db.SaveChangesAsync();
    }

