    private async Task ReactivarEmpresa()
        => await ReactivarEmpresaCore(editando.Id, true);

    private async Task ReactivarEmpresaRapido(Empresa empresa)
        => await ReactivarEmpresaCore(empresa.Id, false);

    private async Task ReactivarEmpresaCore(Guid empresaId, bool recargarEdicion)
    {
        mensajeError = null;
        mensajeOk = null;
        LimpiarPasswordTemporal();
        guardando = true;

        try
        {
            if (empresaId == Guid.Empty)
            {
                mensajeError = "Primero selecciona una empresa válida.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var empresa = await db.Empresas.IgnoreQueryFilters().FirstOrDefaultAsync(e => e.Id == empresaId);
            if (empresa == null)
            {
                mensajeError = "No se encontró la empresa.";
                return;
            }

            empresa.Estado = EmpresaEstado.Activa;
            empresa.IsSuspended = false;
            empresa.IsActive = true;
            empresa.ActivatedAt ??= DateTime.UtcNow;
            empresa.UpdatedAt = DateTime.UtcNow;

            var suscripcion = await db.SuscripcionesEmpresa.IgnoreQueryFilters()
                .Where(s => s.EmpresaId == empresa.Id)
                .OrderByDescending(s => s.FechaInicio)
                .ThenByDescending(s => s.CreatedAt)
                .FirstOrDefaultAsync();

            if (suscripcion != null && suscripcion.Estado != EstadoSuscripcion.Cancelada)
            {
                suscripcion.Estado = EstadoSuscripcion.Activa;
                suscripcion.IsActive = true;
                suscripcion.UpdatedAt = DateTime.UtcNow;
            }

            await db.SaveChangesAsync();
            await AuditService.LogAsync("Reactivar empresa", nameof(Empresa), empresa.Id, $"Empresa {empresa.Codigo} reactivada manualmente desde superadmin.", empresa.Id);

            mensajeOk = "Empresa reactivada correctamente.";
            await Cargar();
            var empresaActualizada = empresas.FirstOrDefault(e => e.Id == empresaId);
            if (recargarEdicion && empresaActualizada != null)
                await EditarEmpresa(empresaActualizada);
        }
        catch (Exception ex)
        {
            mensajeError = ObtenerMensajeError(ex);
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task AbrirPagoRapido(Empresa empresa)
