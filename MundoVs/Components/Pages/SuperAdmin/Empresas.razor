    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        if (!_puedeAdministrar)
        {
            mensajeError = "No tienes permisos para administrar empresas.";
            return;
        }

        logoMensaje = null;
        logoError = false;
        logoPreviewUrl = null;

        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!AllowedExtensions.Contains(ext))
        {
            logoMensaje = "Formato no permitido. Use PNG, JPG, WebP o SVG.";
            logoError = true;
            logoFile = null;
            return;
        }

        if (file.Size > MaxLogoSize)
        {
            logoMensaje = "El archivo excede el límite de 2 MB.";
            logoError = true;
            logoFile = null;
            return;
        }

        logoFile = file;

        try
        {
            var buffer = new byte[file.Size];
            await using var stream = file.OpenReadStream(MaxLogoSize);
            var read = await stream.ReadAsync(buffer);
            if (read > 0)
            {
                if (read != buffer.Length)
                    Array.Resize(ref buffer, read);
                logoPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            }

            logoMensaje = "Logo listo para guardar.";
        }
        catch
        {
            // Si no se puede generar preview, igual permitimos guardar el archivo.
            logoMensaje = "Logo listo para guardar.";
        }
    }

    private async Task<string> GuardarLogoAsync(Guid empresaId, IBrowserFile file, string? existingRelativePath)
    {
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
