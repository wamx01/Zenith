@page "/rrhh/reporte-tiempo-extra"
@using System.Globalization
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Models
@using MundoVs.Core.Entities
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IRrhhTiempoExtraReporteService ReporteService
@inject IRrhhResolucionPeriodoService ResolucionPeriodo
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Reporte de tiempo extra</PageTitle>

<div class="container-fluid px-4 rrhh-rpt">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver el reporte de tiempo extra.</div>
    }
    else
    {
        <div class="rrhh-header">
            <div>
                <h1><i class="bi bi-clock-history"></i>Reporte de tiempo extra</h1>
                <p class="rrhh-subtitle">Compilado por persona y fecha. Considera sugerencia del motor, autorización a pago, autorización a banco y banco aplicado.</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ExportarCsvAsync" disabled="@(exportandoCsv || cargando || respuestaReporte is null)">
                    @if (exportandoCsv)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-filetype-csv me-1"></i>
                    }
                    Exportar CSV
                </button>
            </div>
        </div>

        <div class="rrhh-filtros">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Desde</label>
                        <InputDate @bind-Value="filtroFechaDesde" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <InputDate @bind-Value="filtroFechaHasta" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Periodicidad</label>
                        <InputSelect @bind-Value="filtroPeriodicidad" class="form-select form-select-sm">
                            <option value="">Todas</option>
                            <option value="@PeriodicidadPago.Semanal">Semanal</option>
                            <option value="@PeriodicidadPago.Quincenal">Quincenal</option>
                            <option value="@PeriodicidadPago.Mensual">Mensual</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Departamento</label>
                        <InputSelect @bind-Value="filtroDepartamento" class="form-select form-select-sm">
                            <option value="">(Todos)</option>
                            @foreach (var depto in departamentosDisponibles)
                            {
                                <option value="@depto">@depto</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Empleado</label>
                        <InputSelect @bind-Value="filtroEmpleadoId" class="form-select form-select-sm">
                            <option value="">(Todos)</option>
                            @foreach (var emp in empleadosFiltro)
                            {
                                <option value="@emp.Id">@emp.NombreCompleto</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Agrupar por</label>
                        <InputSelect @bind-Value="filtroAgrupadoPor" class="form-select form-select-sm">
                            <option value="dia">Día</option>
                            <option value="empleado">Empleado</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="row g-3 align-items-center mt-0">
                    <div class="col-md-5">
                        <span class="rrhh-presets-label">Presets de fecha</span>
                        <div class="d-flex gap-1 flex-wrap">
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AplicarPresetPeriodoNomina" disabled="@cargando">Periodo nómina</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AplicarPresetEstaSemana" disabled="@cargando">Esta semana</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AplicarPresetEsteMes" disabled="@cargando">Este mes</button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="filtroSoloSinAutorizar" class="form-check-input" id="chkSoloSinAutorizar" />
                            <label class="form-check-label" for="chkSoloSinAutorizar">Sólo sin autorizar</label>
                        </div>
                    </div>
                    <div class="col-md-2"></div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="button" class="btn btn-accent btn-sm flex-grow-1" @onclick="CargarReporteAsync" disabled="@cargando">
                            @if (cargando)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            else
                            {
                                <i class="bi bi-search me-1"></i>
                            }
                            Consultar
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RestablecerFiltrosAsync" disabled="@cargando" title="Restablecer">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        @if (respuestaReporte is not null)
        {
            <div class="row g-3 rrhh-kpis">
                <div class="col-6 col-md">
                    <div class="rrhh-kpi h-100">
                        <div class="card-body">
                            <div class="kpi-etiqueta">Horas extra (sugerido)</div>
                            <div class="kpi-valor">@respuestaReporte.Totales.TotalHorasExtraFormateado</div>
                            <div class="kpi-sub">@respuestaReporte.Totales.DiasConExtra día(s) con extra · @respuestaReporte.TotalEmpleados empleado(s)</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="rrhh-kpi h-100">
                        <div class="card-body">
                            <div class="kpi-etiqueta">Autorizado a pago</div>
                            <div class="kpi-valor">@respuestaReporte.Totales.TotalHorasExtraPagoFormateado</div>
                            <div class="kpi-sub">Lo que se liquida como tiempo extra</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="rrhh-kpi h-100">
                        <div class="card-body">
                            <div class="kpi-etiqueta">Autorizado a banco</div>
                            <div class="kpi-valor">@respuestaReporte.Totales.TotalHorasExtraBancoFormateado</div>
                            <div class="kpi-sub">Lo que se va al banco de horas</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="rrhh-kpi h-100">
                        <div class="card-body">
                            <div class="kpi-etiqueta">Banco aplicado</div>
                            <div class="kpi-valor">@respuestaReporte.Totales.TotalBancoAplicadoFormateado</div>
                            <div class="kpi-sub">Tiempo ya compensado desde el banco</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="rrhh-kpi h-100">
                        <div class="card-body">
                            <div class="kpi-etiqueta">Monto estimado total</div>
                            <div class="kpi-valor">@respuestaReporte.Totales.TotalMontoHorasExtraEstimado.ToString("C2")</div>
                            <div class="kpi-sub">Dobles @FormatearHoras(respuestaReporte.Totales.TotalHorasExtraDobles) · Triples @FormatearHoras(respuestaReporte.Totales.TotalHorasExtraTriples)</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (respuestaReporte.Empleados.Count == 0)
            {
                <div class="rrhh-empty">No hay horas extra en el rango seleccionado.</div>
            }
            else
            {
                <div class="rrhh-tabla-card">
                    <div class="rrhh-tabla-wrap te-reporte-wrap">
                        <table class="table table-sm align-middle mb-0 rrhh-tabla">
                            <thead>
                                <tr>
                                    <th>Empleado</th>
                                    <th class="text-end">Días con extra</th>
                                    <th class="text-end">Extra sugerido</th>
                                    <th class="text-end">Pago × factor</th>
                                    <th class="text-end">Dobles</th>
                                    <th class="text-end">Triples</th>
                                    <th class="text-end">Banco × factor</th>
                                    <th class="text-end">Banco aplicado</th>
                                    <th class="text-end">Monto est.</th>
                                    <th class="text-end">Retardo</th>
                                    <th class="text-end">Salida ant.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in respuestaReporte.Empleados)
                                {
                                    <tr class="rrhh-row-toggle" @onclick="() => ToggleEmpleado(emp.EmpleadoId)">
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="bi @(Expandido(emp.EmpleadoId) ? "bi-chevron-down" : "bi-chevron-right") small text-muted"></i>
                                                <div>
                                                    <div class="fw-semibold">
                                                        @emp.NombreCompleto
                                                        @if (emp.SinAutorizar)
                                                        {
                                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle ms-1" title="Extra detectado sin resolución autorizada">Sin autorizar</span>
                                                        }
                                                    </div>
                                                    <div class="small text-muted">
                                                        @emp.NumeroEmpleado
                                                        @if (!string.IsNullOrWhiteSpace(emp.Departamento))
                                                        {
                                                            <span> · @emp.Departamento</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(emp.Puesto))
                                                        {
                                                            <span> · @emp.Puesto</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">@emp.Totales.DiasConExtra</td>
                                        <td class="text-end"><span class="badge @ObtenerClaseTotal(emp.Totales.TotalMinutosExtra)">@FormatearMinutos(emp.Totales.TotalMinutosExtra)</span></td>
                                        <td class="text-end"><span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">@FormatearMinutos(emp.Totales.TotalMinutosPagoFactorado)</span></td>
                                        <td class="text-end">@FormatearHoras(emp.Totales.TotalHorasExtraDobles)</td>
                                        <td class="text-end">@FormatearHoras(emp.Totales.TotalHorasExtraTriples)</td>
                                        <td class="text-end">@FormatearMinutos(emp.Totales.TotalMinutosBancoFactorado)</td>
                                        <td class="text-end">@FormatearMinutos(emp.Totales.TotalMinutosCubiertosBancoHoras)</td>
                                        <td class="text-end">@emp.Totales.TotalMontoHorasExtraEstimado.ToString("C2")</td>
                                        <td class="text-end">@FormatearMinutos(emp.Totales.TotalMinutosRetardo)</td>
                                        <td class="text-end">@FormatearMinutos(emp.Totales.TotalMinutosSalidaAnticipada)</td>
                                    </tr>
                                    @if (Expandido(emp.EmpleadoId))
                                    {
                                        <tr>
                                            <td colspan="11" class="p-0">
                                                <div class="rrhh-detalle">
                                                    @if (emp.SinAutorizar)
                                                    {
                                                        <div class="alert alert-warning py-2 mx-3 mt-2 mb-2 small"><i class="bi bi-exclamation-triangle me-1"></i>Hay tiempo extra detectado sin resolución autorizada en el rango. Apruébalo por periodo en <strong>Asistencias Semanal</strong>.</div>
                                                    }
                                                    @if (emp.Periodos.Count > 0)
                                                    {
                                                        <div class="px-3 pt-2">
                                                            <div class="small text-muted fw-semibold mb-1">Periodos autorizados (lo aprobado)</div>
                                                            @foreach (var periodo in emp.Periodos)
                                                            {
                                                                <div class="mb-2 border rounded p-2 bg-white">
                                                                    <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                                                                        <span class="badge bg-success">@periodo.Estatus</span>
                                                                        <strong>@periodo.PeriodoEtiqueta</strong>
                                                                        <span class="small text-muted">@periodo.FechaInicio.ToString("dd/MM/yyyy")–@periodo.FechaFin.ToString("dd/MM/yyyy")</span>
                                                                        <span class="small text-muted">· Pago @FormatearMinutos(periodo.MinutosPago) · Banco @FormatearMinutos(periodo.MinutosBanco) · Monto est. @periodo.MontoEstimado.ToString("C2")</span>
                                                                        @if (!string.IsNullOrWhiteSpace(periodo.AutorizadoPor))
                                                                        {
                                                                            <span class="small text-muted ms-auto">Por @periodo.AutorizadoPor</span>
                                                                        }
                                                                        @if (_puedeAprobarTiempoExtra)
                                                                        {
                                                                            <button class="btn btn-outline-danger btn-sm ms-auto" @onclick="() => EliminarPeriodoAsync(emp.EmpleadoId, periodo.FechaInicio)" disabled="@(cargando || eliminandoPeriodoId == periodo.PeriodoKey)" title="Eliminar la autorización de este periodo (solo si no hay prenómina cerrada/aplicada)">
                                                                                @if (eliminandoPeriodoId == periodo.PeriodoKey)
                                                                                {
                                                                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <i class="bi bi-trash me-1"></i>
                                                                                }
                                                                                Eliminar
                                                                            </button>
                                                                        }
                                                                    </div>
                                                                    <table class="table table-sm table-borderless mb-0 te-reporte-lineas">
                                                                        <thead class="table-light">
                                                                            <tr><th>Destino</th><th class="text-end">Minutos</th><th>Factor</th><th class="text-end">Min. factorados</th><th class="text-end">Monto est.</th><th>Obs.</th></tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            @foreach (var linea in periodo.Lineas)
                                                                            {
                                                                                <tr>
                                                                                    <td><span class="badge @(linea.Destino == "Banco" ? "bg-info text-dark" : "bg-success")">@linea.Destino</span></td>
                                                                                    <td class="text-end">@FormatearMinutos(linea.Minutos)</td>
                                                                                    <td>x@linea.Factor</td>
                                                                                    <td class="text-end">@FormatearMinutos(linea.MinutosFactorados)</td>
                                                                                    <td class="text-end">@(linea.Destino == "Pago" ? linea.MontoEstimado.ToString("C2") : "—")</td>
                                                                                    <td class="small text-muted">@linea.Observaciones</td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (emp.Dias.Count == 0)
                                                    {
                                                        <div class="text-muted small px-3 py-2">Modo agrupado por empleado: consulta con "Día" para ver el detalle por fecha (detección diaria).</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="px-3 pb-2">
                                                            <div class="small text-muted fw-semibold mb-1 mt-2">Detección diaria (contexto)</div>
                                                            <table class="table table-sm mb-0">
                                                                <thead class="table-light">
                                                                    <tr>
                                                                        <th>Fecha</th>
                                                                        <th>Estatus</th>
                                                                        <th class="text-end">Extra sugerido</th>
                                                                        <th>Turno</th>
                                                                        <th class="text-end">Horas reales</th>
                                                                        <th>Resolución</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var dia in emp.Dias)
                                                                    {
                                                                        <tr class="@(dia.RequiereRevision ? "table-warning" : null)">
                                                                            <td>@dia.Fecha.ToString("ddd dd/MM/yyyy", CulturaEsMx)</td>
                                                                            <td><span class="badge bg-light text-dark border">@dia.Estatus</span></td>
                                                                            <td class="text-end"><span class="badge @ObtenerClaseTotal(dia.MinutosExtra)">@FormatearMinutos(dia.MinutosExtra)</span></td>
                                                                            <td>
                                                                                @if (!string.IsNullOrWhiteSpace(dia.Turno))
                                                                                {
                                                                                    <div class="small">@dia.Turno</div>
                                                                                    <div class="small text-muted">@FormatearHora(dia.HoraEntradaProgramada)–@FormatearHora(dia.HoraSalidaProgramada)</div>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <span class="text-muted small">—</span>
                                                                                }
                                                                            </td>
                                                                            <td class="text-end small">@FormatearHora(dia.HoraEntradaReal)–@FormatearHora(dia.HoraSalidaReal)</td>
                                                                            <td class="small">@(string.IsNullOrWhiteSpace(dia.ResolucionTiempoExtra) ? "—" : dia.ResolucionTiempoExtra)</td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td>Totales</td>
                                    <td class="text-end">@respuestaReporte.Totales.DiasConExtra</td>
                                    <td class="text-end">@respuestaReporte.Totales.TotalHorasExtraFormateado</td>
                                    <td class="text-end">@respuestaReporte.Totales.TotalPagoFactoradoFormateado</td>
                                    <td class="text-end">@FormatearHoras(respuestaReporte.Totales.TotalHorasExtraDobles)</td>
                                    <td class="text-end">@FormatearHoras(respuestaReporte.Totales.TotalHorasExtraTriples)</td>
                                    <td class="text-end">@respuestaReporte.Totales.TotalBancoFactoradoFormateado</td>
                                    <td class="text-end">@respuestaReporte.Totales.TotalBancoAplicadoFormateado</td>
                                    <td class="text-end">@respuestaReporte.Totales.TotalMontoHorasExtraEstimado.ToString("C2")</td>
                                    <td class="text-end">@FormatearMinutos(respuestaReporte.Totales.TotalMinutosRetardo)</td>
                                    <td class="text-end">@FormatearMinutos(respuestaReporte.Totales.TotalMinutosSalidaAnticipada)</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>

<style>
    /* Altura máxima del listado con scroll; el resto del estilo viene de custom-styles.css (.rrhh-*) */
    .te-reporte-wrap {
        max-height: calc(100vh - 380px);
        overflow: auto;
    }

    .rrhh-detalle .table {
        font-size: .82rem;
    }
</style>

@code {
    private static readonly CultureInfo CulturaEsMx = new("es-MX");

    private bool _puedeVer;
    private bool _puedeAprobarTiempoExtra;
    private string _usuarioActual = string.Empty;
    private string? eliminandoPeriodoId;
    private bool cargando;
    private bool exportandoCsv;
    private string? error;
    private string? ok;

    private DateTime filtroFechaDesde = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime filtroFechaHasta = new(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    private string? filtroDepartamento;
    private string filtroAgrupadoPor = "dia";
    private Guid? filtroEmpleadoId;
    private PeriodicidadPago? filtroPeriodicidad;
    private bool filtroSoloSinAutorizar;

    // Catálogos para los dropdowns de filtro (cargados una vez al iniciar).
    private List<EmpleadoFiltroVm> empleadosFiltro = [];
    private List<string> departamentosDisponibles = [];
    private Dictionary<PeriodicidadPago, NominaCorteRrhh> cortesPorPeriodicidad = new();

    private RrhhTiempoExtraReporteResponse? respuestaReporte;
    private readonly HashSet<Guid> _empleadosExpandidos = new();
    private Guid _empresaId;

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
        {
            await CargarFiltrosAsync();
            await CargarReporteAsync();
        }
    }

    private async Task CargarFiltrosAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        empleadosFiltro = await db.Empleados
            .AsNoTracking()
            .Where(e => e.IsActive && e.EmpresaId == _empresaId)
            .OrderBy(e => e.Nombre)
            .ThenBy(e => e.ApellidoPaterno)
            .ThenBy(e => e.ApellidoMaterno)
            .Select(e => new EmpleadoFiltroVm { Id = e.Id, NombreCompleto = e.NombreCompleto })
            .ToListAsync();

        departamentosDisponibles = await db.DepartamentosRrhh
            .AsNoTracking()
            .Where(d => d.IsActive)
            .OrderBy(d => d.Orden)
            .ThenBy(d => d.Nombre)
            .Select(d => d.Nombre)
            .ToListAsync();

        cortesPorPeriodicidad = await db.NominaCortesRrhh
            .AsNoTracking()
            .Where(c => c.EmpresaId == _empresaId && c.IsActive)
            .ToDictionaryAsync(c => c.PeriodicidadPago);
    }

    // Preset "Periodo nómina": ajusta el rango al periodo de nómina que contiene hoy para la
    // periodicidad seleccionada (o Semanal por defecto). No cambia el filtro de periodicidad.
    private void AplicarPresetPeriodoNomina()
    {
        var periodicidad = filtroPeriodicidad ?? PeriodicidadPago.Semanal;
        cortesPorPeriodicidad.TryGetValue(periodicidad, out var corte);
        var periodo = NominaPeriodoHelper.ObtenerPeriodoContenedor(periodicidad, DateTime.Today, corte);
        filtroFechaDesde = periodo.Inicio;
        filtroFechaHasta = periodo.Fin;
    }

    // Preset "Esta semana": lunes a domingo de la semana actual (cultura es-MX, lunes inicio).
    private void AplicarPresetEstaSemana()
    {
        var hoy = DateTime.Today;
        var diaSemana = (int)hoy.DayOfWeek; // Domingo = 0
        var lunes = hoy.AddDays(diaSemana == 0 ? -6 : 1 - diaSemana);
        filtroFechaDesde = lunes;
        filtroFechaHasta = lunes.AddDays(6);
    }

    // Preset "Este mes": del 1º al último día del mes actual.
    private void AplicarPresetEsteMes()
    {
        filtroFechaDesde = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        filtroFechaHasta = new DateTime(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "rrhh.tiempoextra.aprobar")
            || state.User.HasClaim("Capacidad", "nominas.ver")
            || state.User.HasClaim("Capacidad", "empleados.ver");
        _puedeAprobarTiempoExtra = state.User.HasClaim("Capacidad", "rrhh.tiempoextra.aprobar")
            || state.User.HasClaim("Capacidad", "nominas.editar");
        _usuarioActual = state.User.Identity?.Name ?? string.Empty;
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarReporteAsync()
    {
        error = null;
        ok = null;

        if (filtroFechaHasta < filtroFechaDesde)
        {
            error = "La fecha 'Hasta' no puede ser menor a 'Desde'.";
            return;
        }

        if (_empresaId == Guid.Empty)
        {
            error = "No se pudo determinar la empresa del usuario actual.";
            return;
        }

        cargando = true;
        try
        {
            var request = new RrhhTiempoExtraReporteRequest
            {
                EmpresaId = _empresaId,
                FechaDesde = DateOnly.FromDateTime(filtroFechaDesde),
                FechaHasta = DateOnly.FromDateTime(filtroFechaHasta),
                Departamento = string.IsNullOrWhiteSpace(filtroDepartamento) ? null : filtroDepartamento.Trim(),
                AgrupadoPor = filtroAgrupadoPor,
                EmpleadoId = filtroEmpleadoId,
                Periodicidad = filtroPeriodicidad,
                SoloSinAutorizar = filtroSoloSinAutorizar
            };

            respuestaReporte = await ReporteService.GenerarAsync(DbFactory, request);
            _empleadosExpandidos.Clear();
        }
        catch (ArgumentException ex)
        {
            error = ex.Message;
        }
        catch (Exception ex)
        {
            error = $"Error al consultar el reporte: {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task RestablecerFiltrosAsync()
    {
        filtroFechaDesde = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        filtroFechaHasta = new DateTime(DateTime.Today.Year, DateTime.Today.Month, DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month));
        filtroDepartamento = null;
        filtroAgrupadoPor = "dia";
        filtroEmpleadoId = null;
        filtroPeriodicidad = null;
        filtroSoloSinAutorizar = false;
        await CargarReporteAsync();
    }

    private void ToggleEmpleado(Guid empleadoId)
    {
        if (!_empleadosExpandidos.Add(empleadoId))
        {
            _empleadosExpandidos.Remove(empleadoId);
        }
    }

    private bool Expandido(Guid empleadoId) => _empleadosExpandidos.Contains(empleadoId);

    private async Task EliminarPeriodoAsync(Guid empleadoId, DateOnly fechaReferencia)
    {
        error = null;
        ok = null;

        var confirmar = await JS.InvokeAsync<bool>("confirm",
            "¿Eliminar la autorización de tiempo extra de este periodo? Se revertirán los movimientos de banco de horas generados. Solo se permite si NO hay una prenómina cerrada o aplicada para el mismo periodo.");
        if (!confirmar)
        {
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // Buscar la resolución del periodo para obtener sus claves (PeriodicidadPago, AnioPeriodo, NumeroPeriodo).
            var resolucion = await db.RrhhResolucionesTiempoExtraPeriodo
                .AsNoTracking()
                .FirstOrDefaultAsync(r => r.EmpresaId == _empresaId
                    && r.EmpleadoId == empleadoId
                    && r.FechaInicio == fechaReferencia
                    && r.Estatus == RrhhResolucionPeriodoEstatus.Autorizada);

            if (resolucion is null)
            {
                error = "No se encontró una resolución autorizada para ese periodo.";
                return;
            }

            eliminandoPeriodoId = resolucion.PeriodoKey;

            // Validar que NO exista una prenómina Cerrada o Aplicada para el mismo periodo.
            var prenominas = await db.Prenominas
                .AsNoTracking()
                .Where(p => p.EmpresaId == _empresaId
                    && p.PeriodicidadPago == resolucion.PeriodicidadPago
                    && p.AnioPeriodo == resolucion.AnioPeriodo
                    && p.NumeroPeriodo == resolucion.NumeroPeriodo
                    && p.Estatus != EstatusPrenomina.Cancelada)
                .Select(p => new { p.Estatus })
                .ToListAsync();

            if (prenominas.Any(p => p.Estatus == EstatusPrenomina.Cerrada || p.Estatus == EstatusPrenomina.Aplicada))
            {
                error = "No se puede eliminar la autorización: ya existe una prenómina cerrada o aplicada para este periodo. Reabre la prenómina primero.";
                return;
            }

            await ResolucionPeriodo.ReabrirPeriodoAsync(db, _empresaId, empleadoId, fechaReferencia, _usuarioActual);
            await db.SaveChangesAsync();

            ok = "Autorización de tiempo extra eliminada. El periodo quedó reabierto.";
            await CargarReporteAsync();
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            eliminandoPeriodoId = null;
        }
    }

    private async Task ExportarCsvAsync()
    {
        if (respuestaReporte is null)
        {
            return;
        }

        exportandoCsv = true;
        try
        {
            var csv = ConstruirCsv(respuestaReporte);
            var nombreArchivo = $"reporte-tiempo-extra-{respuestaReporte.FechaDesde:yyyyMMdd}-{respuestaReporte.FechaHasta:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("mundoVsAuth.downloadCsv", nombreArchivo, csv);
            ok = "Reporte exportado correctamente.";
        }
        catch (Exception ex)
        {
            error = $"No se pudo exportar el CSV: {ex.Message}";
        }
        finally
        {
            exportandoCsv = false;
        }
    }

    private static string ConstruirCsv(RrhhTiempoExtraReporteResponse reporte)
    {
        var sb = new StringBuilder();
        sb.Append("EmpleadoId,NumeroEmpleado,CodigoChecador,NombreCompleto,Departamento,Puesto,Fecha,Estatus,");
        sb.Append("MinutosExtra,MinutosExtraAutorizadosPago,MinutosExtraAutorizadosBanco,MinutosCubiertosBancoHoras,");
        sb.Append("MinutosRetardo,MinutosSalidaAnticipada,MinutosTrabajadosNetos,HoraEntradaProgramada,HoraSalidaProgramada,");
        sb.AppendLine("HoraEntradaReal,HoraSalidaReal,Turno,ResolucionTiempoExtra,RequiereRevision,Observaciones");

        if (reporte.AgrupadoPor.Equals("empleado", StringComparison.OrdinalIgnoreCase))
        {
            foreach (var emp in reporte.Empleados)
            {
                AgregarLineaEmpleadoResumen(sb, emp);
            }
        }
        else
        {
            foreach (var emp in reporte.Empleados)
            {
                if (emp.Dias.Count == 0)
                {
                    AgregarLineaEmpleadoResumen(sb, emp);
                    continue;
                }

                foreach (var dia in emp.Dias)
                {
                    AgregarLineaDia(sb, emp, dia);
                }
            }
        }

        // Fase 8 — bloque de periodos autorizados con sus líneas (lo aprobado, por factor/destino).
        sb.AppendLine();
        sb.AppendLine("PERIODOS AUTORIZADOS");
        sb.AppendLine("EmpleadoId,NumeroEmpleado,NombreCompleto,PeriodoKey,PeriodoEtiqueta,FechaInicio,FechaFin,Estatus,AutorizadoPor,Destino,Minutos,Factor,MinutosFactorados,MontoEstimado,Observaciones");
        foreach (var emp in reporte.Empleados)
        {
            foreach (var periodo in emp.Periodos)
            {
                foreach (var linea in periodo.Lineas)
                {
                    AgregarLineaPeriodo(sb, emp, periodo, linea);
                }
            }
        }

        return sb.ToString();
    }

    private static void AgregarLineaPeriodo(StringBuilder sb, RrhhTiempoExtraReporteEmpleadoDto emp, RrhhTiempoExtraReportePeriodoDto periodo, RrhhTiempoExtraReporteLineaDto linea)
    {
        sb.Append(Csv(emp.EmpleadoId.ToString())).Append(',');
        sb.Append(Csv(emp.NumeroEmpleado)).Append(',');
        sb.Append(Csv(emp.NombreCompleto)).Append(',');
        sb.Append(Csv(periodo.PeriodoKey)).Append(',');
        sb.Append(Csv(periodo.PeriodoEtiqueta)).Append(',');
        sb.Append(Csv(periodo.FechaInicio.ToString("yyyy-MM-dd"))).Append(',');
        sb.Append(Csv(periodo.FechaFin.ToString("yyyy-MM-dd"))).Append(',');
        sb.Append(Csv(periodo.Estatus)).Append(',');
        sb.Append(Csv(periodo.AutorizadoPor)).Append(',');
        sb.Append(Csv(linea.Destino)).Append(',');
        sb.Append(linea.Minutos).Append(',');
        sb.Append(linea.Factor).Append(',');
        sb.Append(linea.MinutosFactorados).Append(',');
        sb.Append(linea.MontoEstimado).Append(',');
        sb.Append(Csv(linea.Observaciones));
        sb.AppendLine();
    }

    // Fila RESUMEN columnar (mismo esquema que AgregarLineaDia): cuando el reporte viene
    // agrupado por empleado (o un empleado no trae días), emitimos un renglón por empleado con
    // Fecha="RESUMEN" y los totales en sus columnas correspondientes, en vez de un blob con
    // punto y coma que no se puede parsear por columnas.
    private static void AgregarLineaEmpleadoResumen(StringBuilder sb, RrhhTiempoExtraReporteEmpleadoDto emp)
    {
        sb.Append(Csv(emp.EmpleadoId.ToString())).Append(',');
        sb.Append(Csv(emp.NumeroEmpleado)).Append(',');
        sb.Append(Csv(emp.CodigoChecador)).Append(',');
        sb.Append(Csv(emp.NombreCompleto)).Append(',');
        sb.Append(Csv(emp.Departamento)).Append(',');
        sb.Append(Csv(emp.Puesto)).Append(',');
        sb.Append(Csv("RESUMEN")).Append(',');            // Fecha
        sb.Append(Csv("RESUMEN")).Append(',');            // Estatus
        sb.Append(emp.Totales.TotalMinutosExtra).Append(',');
        sb.Append(emp.Totales.TotalMinutosExtraAutorizadosPago).Append(',');
        sb.Append(emp.Totales.TotalMinutosExtraAutorizadosBanco).Append(',');
        sb.Append(emp.Totales.TotalMinutosCubiertosBancoHoras).Append(',');
        sb.Append(emp.Totales.TotalMinutosRetardo).Append(',');
        sb.Append(emp.Totales.TotalMinutosSalidaAnticipada).Append(',');
        sb.Append(emp.Totales.TotalMinutosTrabajadosNetos).Append(',');
        sb.Append(Csv(string.Empty)).Append(',');        // HoraEntradaProgramada
        sb.Append(Csv(string.Empty)).Append(',');        // HoraSalidaProgramada
        sb.Append(Csv(string.Empty)).Append(',');        // HoraEntradaReal
        sb.Append(Csv(string.Empty)).Append(',');        // HoraSalidaReal
        sb.Append(Csv(string.Empty)).Append(',');        // Turno
        sb.Append(Csv(string.Empty)).Append(',');        // ResolucionTiempoExtra
        sb.Append("No").Append(',');                     // RequiereRevision
        sb.Append(Csv($"Resumen por empleado · Dobles {emp.Totales.TotalHorasExtraDobles:0.##}h · Triples {emp.Totales.TotalHorasExtraTriples:0.##}h · Monto {emp.Totales.TotalMontoHorasExtraEstimado:0.00}")); // Observaciones
        sb.AppendLine();
    }

    private static void AgregarLineaDia(StringBuilder sb, RrhhTiempoExtraReporteEmpleadoDto emp, RrhhTiempoExtraReporteDiaDto dia)
    {
        sb.Append(Csv(emp.EmpleadoId.ToString())).Append(',');
        sb.Append(Csv(emp.NumeroEmpleado)).Append(',');
        sb.Append(Csv(emp.CodigoChecador)).Append(',');
        sb.Append(Csv(emp.NombreCompleto)).Append(',');
        sb.Append(Csv(emp.Departamento)).Append(',');
        sb.Append(Csv(emp.Puesto)).Append(',');
        sb.Append(Csv(dia.Fecha.ToString("yyyy-MM-dd"))).Append(',');
        sb.Append(Csv(dia.Estatus)).Append(',');
        sb.Append(dia.MinutosExtra).Append(',');
        sb.Append(dia.MinutosExtraAutorizadosPago).Append(',');
        sb.Append(dia.MinutosExtraAutorizadosBanco).Append(',');
        sb.Append(dia.MinutosCubiertosBancoHoras).Append(',');
        sb.Append(dia.MinutosRetardo).Append(',');
        sb.Append(dia.MinutosSalidaAnticipada).Append(',');
        sb.Append(dia.MinutosTrabajadosNetos).Append(',');
        sb.Append(Csv(FormatearHoraCsv(dia.HoraEntradaProgramada))).Append(',');
        sb.Append(Csv(FormatearHoraCsv(dia.HoraSalidaProgramada))).Append(',');
        sb.Append(Csv(FormatearHoraCsv(dia.HoraEntradaReal))).Append(',');
        sb.Append(Csv(FormatearHoraCsv(dia.HoraSalidaReal))).Append(',');
        sb.Append(Csv(dia.Turno)).Append(',');
        sb.Append(Csv(dia.ResolucionTiempoExtra)).Append(',');
        sb.Append(dia.RequiereRevision ? "Sí" : "No").Append(',');
        sb.Append(Csv(dia.Observaciones));
        sb.AppendLine();
    }

    private static string Csv(string? valor)
    {
        if (string.IsNullOrEmpty(valor))
        {
            return string.Empty;
        }

        var necesitaComillas = valor.Contains(',') || valor.Contains('"') || valor.Contains('\n') || valor.Contains('\r');
        var escapado = valor.Replace("\"", "\"\"");
        return necesitaComillas ? $"\"{escapado}\"" : escapado;
    }

    private static string? FormatearHoraCsv(TimeSpan? hora)
        => hora.HasValue ? hora.Value.ToString(@"hh\:mm") : null;

    private static string FormatearMinutos(int minutos)
    {
        if (minutos <= 0)
        {
            return "0h 0m";
        }

        var horas = minutos / 60;
        var mins = minutos % 60;
        return $"{horas}h {mins}m";
    }

    private static string FormatearHora(TimeSpan? hora)
        => hora.HasValue ? hora.Value.ToString(@"hh\:mm") : "—";

    // Horas extra dobles/triples vienen como horas decimal (de los minutos de las líneas de
    // pago con factor 2/3). Las mostramos compactas en horas (p.ej. "2.5h"), sin minutos.
    private static string FormatearHoras(decimal horas)
    {
        if (horas <= 0m)
        {
            return "0h";
        }

        return $"{horas:0.##}h";
    }

    private static string ObtenerClaseTotal(int minutos)
    {
        if (minutos <= 0)
        {
            return "bg-light text-muted border";
        }

        if (minutos < 30)
        {
            return "bg-warning-subtle text-warning-emphasis border border-warning-subtle";
        }

        if (minutos < 120)
        {
            return "bg-warning text-dark";
        }

        return "bg-success-subtle text-success-emphasis border border-success-subtle";
    }

