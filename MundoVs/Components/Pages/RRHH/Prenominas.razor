    private HashSet<Guid> ObtenerRubrosBonoPermitidosIds(Empleado empleado, IEnumerable<PrenominaBono> bonosExistentes)
    {
        var ids = empleado.Posicion?.BonoEstructuraRrhh?.Detalles
            .Where(d => d.IsActive && d.BonoRubroRrhh.IsActive)
            .OrderBy(d => d.Orden)
            .Select(d => d.BonoRubroRrhhId)
            .ToHashSet() ?? [];

        foreach (var rubroId in bonosExistentes.Where(b => b.IsActive && b.Importe > 0).Select(b => b.BonoRubroRrhhId))
            ids.Add(rubroId);

        return ids;
    }

    private List<PrenominaBonoEditable> ConstruirBonosRapidosDesdeEntidades(IReadOnlyCollection<Guid> rubrosPermitidosIds, IEnumerable<PrenominaBono> bonos)
    {
        var bonosExistentes = bonos.ToDictionary(b => b.BonoRubroRrhhId, b => b);
        return rubrosBono.Where(r => rubrosPermitidosIds.Contains(r.Id)).Select(rubro =>
        {
            var existente = bonosExistentes.GetValueOrDefault(rubro.Id);
            return new PrenominaBonoEditable
            {
                Id = existente?.Id ?? Guid.Empty,
                BonoRubroRrhhId = rubro.Id,
                Nombre = rubro.Nombre,
                Orden = rubro.Orden,
                Importe = existente?.Importe ?? 0m,
                Observaciones = existente?.Observaciones,
                IsSelected = existente is not null && existente.Importe > 0
            };
        }).ToList();
    }

