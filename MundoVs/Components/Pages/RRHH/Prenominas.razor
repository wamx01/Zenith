    private int AjustarDiasPagados(int diasPagados)
    {
        if (!reglasPrenomina.ValidarDiasPagadosContraPeriodo)
            return diasPagados;

        return Math.Min(diasPagados, ObtenerDiasPeriodoActual());
    }

    private int ObtenerDiasPeriodoActual()
        => Math.Max(1, (editando.FechaFin.Date - editando.FechaInicio.Date).Days + 1);

    private void AplicarReglasPrenomina(PrenominaDetalleEditable detalle)
    {
        detalle.DiasPagados = AjustarDiasPagados(Math.Max(0, detalle.DiasPagados));

        if (!reglasPrenomina.PermitirHorasExtraManual)
            detalle.HorasExtra = Math.Max(0m, detalle.HorasExtra);
    }

    private static bool TieneDiferenciaTiempoAprobado(PrenominaDetalleEditable detalle)
        => Math.Abs(detalle.HorasExtraBase - (detalle.HorasExtra + detalle.HorasBancoAcumuladas)) > 0.01m;

