    private async Task GuardarPrenomina()
    {
        error = ok = null;
        guardando = true;

        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para guardar prenóminas.";
                return;
            }

            if (editandoId != Guid.Empty)
            {
                await using var dbBloqueo = await DbFactory.CreateDbContextAsync();
                _nominaBloqueantePrenomina = await ObtenerNominaActivaPorPrenominaAsync(dbBloqueo, editandoId);
                if (EstaBloqueadaPorNominaProcesada)
                {
                    error = ObtenerMensajeBloqueoPrenomina();
                    return;
                }
            }

            if (string.IsNullOrWhiteSpace(editando.Periodo))
            {
                error = "El periodo es requerido.";
                return;
            }

            var empresaId = _empresaId;
            if (empresaId == Guid.Empty)
            {
                error = "No hay empresa activa.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var periodoActual = NominaPeriodoHelper.ObtenerPeriodo(editando.PeriodicidadPago, editando.FechaFin, ObtenerCortePeriodo(editando.PeriodicidadPago));
            editando.Periodo = periodoActual.Periodo;
            editando.FechaInicio = periodoActual.Inicio;
            editando.FechaFin = periodoActual.Fin;
            editando.AnioPeriodo = periodoActual.AnioPeriodo;
            editando.NumeroPeriodo = periodoActual.NumeroPeriodo;

            if (await db.Prenominas.AnyAsync(p => p.EmpresaId == empresaId
                && p.Id != editandoId
                && p.PeriodicidadPago == editando.PeriodicidadPago
                && p.AnioPeriodo == editando.AnioPeriodo
                && p.NumeroPeriodo == editando.NumeroPeriodo
                && p.Estatus != EstatusPrenomina.Cancelada))
            {
                error = "Ya existe una prenómina para ese período calendario y periodicidad.";
                return;
            }

            if (await db.Prenominas.AnyAsync(p => p.EmpresaId == empresaId
                && p.Id != editandoId
                && p.FechaInicio == editando.FechaInicio
                && p.FechaFin == editando.FechaFin))
            {
                error = "Ya existe una prenómina para ese rango de fechas. Abre la existente o cambia el período.";
                return;
            }

            Prenomina prenomina;
            if (editandoId == Guid.Empty)
            {
                editando.Folio = string.IsNullOrWhiteSpace(editando.Folio)
                    ? await CodigoNegocio.GetNextPeriodFolioAsync(empresaId, "PRE", "Consecutivo:Prenomina", editando.FechaInicio)
                    : editando.Folio.Trim();
                prenomina = new Prenomina
                {
                    EmpresaId = empresaId,
                    Folio = editando.Folio,
                    PeriodicidadPago = editando.PeriodicidadPago,
                    AnioPeriodo = editando.AnioPeriodo,
                    NumeroPeriodo = editando.NumeroPeriodo,
                    Periodo = editando.Periodo.Trim(),
                    FechaInicio = editando.FechaInicio,
                    FechaFin = editando.FechaFin,
                    Estatus = editando.Estatus,
                    Notas = editando.Notas?.Trim()
                };
                db.Prenominas.Add(prenomina);
                await db.SaveChangesAsync();
                editandoId = prenomina.Id;
                editando.Id = prenomina.Id;
            }
            else
            {
                prenomina = await db.Prenominas.FirstAsync(p => p.Id == editandoId);
                prenomina.Folio = string.IsNullOrWhiteSpace(editando.Folio) ? prenomina.Folio : editando.Folio.Trim();
                prenomina.PeriodicidadPago = editando.PeriodicidadPago;
                prenomina.AnioPeriodo = editando.AnioPeriodo;
                prenomina.NumeroPeriodo = editando.NumeroPeriodo;
                prenomina.Periodo = editando.Periodo.Trim();
                prenomina.FechaInicio = editando.FechaInicio;
                prenomina.FechaFin = editando.FechaFin;
                prenomina.Estatus = editando.Estatus;
                prenomina.Notas = editando.Notas?.Trim();
                prenomina.UpdatedAt = DateTime.UtcNow;
            }

            var usuarioActual = await ObtenerUsuarioActualAsync();
            if (editando.Estatus == EstatusPrenomina.Abierta)
            {
                prenomina.FechaCierre = null;
                prenomina.CerradaPor = null;
            }
            else if (editando.Estatus == EstatusPrenomina.Cerrada)
            {
                prenomina.FechaCierre ??= DateTime.UtcNow;
                prenomina.CerradaPor = string.IsNullOrWhiteSpace(prenomina.CerradaPor) ? usuarioActual : prenomina.CerradaPor;
            }

            var existentes = await db.PrenominaDetalles.Where(d => d.PrenominaId == prenomina.Id).ToListAsync();
            var entidadesPorEmpleado = new Dictionary<Guid, PrenominaDetalle>();
            var idsEditando = detallesEditando.Where(d => d.Id != Guid.Empty).Select(d => d.Id).ToHashSet();
            var eliminar = existentes.Where(d => !idsEditando.Contains(d.Id)).ToList();
            if (eliminar.Count > 0)
            {
                db.PrenominaDetalles.RemoveRange(eliminar);
            }

            foreach (var detalle in detallesEditando)
            {
                detalle.DiasVacacionesRestantes = Math.Max(0, detalle.DiasVacacionesDisponibles - detalle.DiasVacaciones);
                var empleado = empleados.FirstOrDefault(e => e.Id == detalle.EmpleadoId);
                if (empleado != null)
                {
            detalle.ComplementoSalarioMinimoSugerido = NominaLegalPolicy.CalcularComplementoSalarioMinimo(empleado, esquemaPagoPeriodoPorEmpleado.GetValueOrDefault(empleado.Id), detalle.DiasPagados, detalle.MontoDestajoInformativo, configuracionNomina);
                }
                var entity = detalle.Id == Guid.Empty
                    ? null
                    : existentes.FirstOrDefault(d => d.Id == detalle.Id);

                if (entity == null)
                {
                    entity = new PrenominaDetalle
                    {
                        PrenominaId = prenomina.Id,
                        EmpleadoId = detalle.EmpleadoId
                    };
                    db.PrenominaDetalles.Add(entity);
                    detalle.Id = entity.Id;
                }

                entity.DiasTrabajados = detalle.DiasTrabajados;
                entity.DiasPagados = detalle.DiasPagados;
                entity.DiasVacaciones = detalle.DiasVacaciones;
                entity.DiasFaltaJustificada = detalle.DiasFaltaJustificada;
                entity.DiasFaltaInjustificada = detalle.DiasFaltaInjustificada;
                entity.DiasIncapacidad = detalle.DiasIncapacidad;
                entity.DiasDescansoTrabajado = detalle.DiasDescansoTrabajado;
                entity.DiasConMarcacion = detalle.DiasConMarcacion;
                entity.DiasDomingoTrabajado = detalle.DiasDomingoTrabajado;
                entity.DiasFestivoTrabajado = detalle.DiasFestivoTrabajado;
                entity.HorasExtraBase = detalle.HorasExtraBase;
                entity.HorasExtra = detalle.HorasExtra;
                entity.HorasTrabajadasNetas = detalle.HorasTrabajadasNetas;
                entity.HorasBancoAcumuladas = detalle.HorasBancoAcumuladas;
                entity.HorasBancoConsumidas = detalle.HorasBancoConsumidas;
                entity.HorasDescansoTomado = detalle.HorasDescansoTomado;
                entity.HorasDescansoPagado = detalle.HorasDescansoPagado;
                entity.HorasDescansoNoPagado = detalle.HorasDescansoNoPagado;
                entity.MinutosRetardo = detalle.MinutosRetardo;
                entity.MinutosSalidaAnticipada = detalle.MinutosSalidaAnticipada;
                entity.MinutosDescuentoManual = detalle.MinutosDescuentoManual;
                entity.FactorPagoTiempoExtra = detalle.FactorPagoTiempoExtra;
                entity.MontoDestajoInformativo = detalle.MontoDestajoInformativo;
                entity.DiasVacacionesDisponibles = detalle.DiasVacacionesDisponibles;
                entity.DiasVacacionesRestantes = detalle.DiasVacacionesRestantes;
                entity.ComplementoSalarioMinimoSugerido = detalle.ComplementoSalarioMinimoSugerido;
                entity.AplicaImss = detalle.AplicaImss;
                entity.Notas = detalle.Notas?.Trim();
                entity.UpdatedAt = DateTime.UtcNow;
                entidadesPorEmpleado[detalle.EmpleadoId] = entity;
            }

            await db.SaveChangesAsync();

            var detalleIds = entidadesPorEmpleado.Values.Select(e => e.Id).ToList();
            var bonosExistentes = detalleIds.Count == 0
                ? []
                : await db.PrenominasBonos.Where(b => detalleIds.Contains(b.PrenominaDetalleId)).ToListAsync();
            var percepcionesExistentes = detalleIds.Count == 0
                ? []
                : await db.PrenominasPercepciones.Where(p => detalleIds.Contains(p.PrenominaDetalleId)).ToListAsync();

            foreach (var detalle in detallesEditando)
            {
                if (!entidadesPorEmpleado.TryGetValue(detalle.EmpleadoId, out var entity))
                    continue;

                SincronizarBonosRapidos(db, bonosExistentes, entity.Id, detalle.BonosRapidos);
                SincronizarPercepcionesRapidas(db, percepcionesExistentes, entity.Id, detalle.PercepcionesRapidas);
            }

            await db.SaveChangesAsync();
            await CargarBloqueoPrenominaAsync(prenomina.Id);
            ok = TieneNominaBorradorLigada
                ? "Prenómina guardada. Recalcula la nómina en borrador ligada para reflejar los cambios."
                : "Prenómina guardada.";
            await CargarAsync();
        }
        catch (DbUpdateException ex) when (EsDuplicadoPrenominaPorRango(ex))
        {
            error = "Ya existe una prenómina para ese rango de fechas. Abre la existente o cambia el período.";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private static bool EsDuplicadoPrenominaPorRango(DbUpdateException ex)
    {
        var mensaje = ex.InnerException?.Message ?? ex.Message;
        return mensaje.Contains("IX_Prenominas_EmpresaId_FechaInicio_FechaFin", StringComparison.OrdinalIgnoreCase)
            || mensaje.Contains("Duplicate entry", StringComparison.OrdinalIgnoreCase)
                && mensaje.Contains("Prenominas", StringComparison.OrdinalIgnoreCase);
    }

    private async Task CerrarPrenomina()
    {
        editando.Estatus = EstatusPrenomina.Cerrada;
        await GuardarPrenomina();
        if (string.IsNullOrWhiteSpace(error))
        {
            ok = "Prenómina cerrada.";
        }
    }

    private async Task ReabrirPrenominaAsync()
    {
        error = null;
        ok = null;

        if (!PuedeModificarPrenominaActual)
        {
            error = EstaBloqueadaPorNominaProcesada ? ObtenerMensajeBloqueoPrenomina() : "No tienes permisos para reabrir esta prenómina.";
            return;
        }

        if (editandoId != Guid.Empty)
        {
            await CargarBloqueoPrenominaAsync(editandoId);
            if (EstaBloqueadaPorNominaProcesada)
            {
                error = ObtenerMensajeBloqueoPrenomina();
                ok = null;
                return;
            }
        }

        editando.Estatus = EstatusPrenomina.Abierta;
        await GuardarPrenomina();
        if (string.IsNullOrWhiteSpace(error))
        {
            ok = "Prenómina reabierta.";
        }
    }

    private async Task<string?> ObtenerUsuarioActualAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        return state.User.Identity?.Name
            ?? state.User.FindFirst("name")?.Value
            ?? state.User.FindFirst("email")?.Value
            ?? state.User.FindFirst("preferred_username")?.Value;
    }

