    private void ActualizarEntero(PrenominaDetalleEditable detalle, string campo, string? valor)
    {
        var numero = int.TryParse(valor, out var resultado) ? Math.Max(0, resultado) : 0;
        switch (campo)
        {
            case nameof(PrenominaDetalleEditable.DiasTrabajados): detalle.DiasTrabajados = numero; break;
            case nameof(PrenominaDetalleEditable.DiasPagados): detalle.DiasPagados = AjustarDiasPagados(numero); break;
            case nameof(PrenominaDetalleEditable.DiasVacaciones): detalle.DiasVacaciones = numero; break;
            case nameof(PrenominaDetalleEditable.DiasFaltaJustificada): detalle.DiasFaltaJustificada = numero; break;
            case nameof(PrenominaDetalleEditable.DiasFaltaInjustificada): detalle.DiasFaltaInjustificada = numero; break;
            case nameof(PrenominaDetalleEditable.DiasIncapacidad): detalle.DiasIncapacidad = numero; break;
            case nameof(PrenominaDetalleEditable.DiasDescansoTrabajado): detalle.DiasDescansoTrabajado = numero; break;
            case nameof(PrenominaDetalleEditable.DiasDomingoTrabajado): detalle.DiasDomingoTrabajado = numero; break;
            case nameof(PrenominaDetalleEditable.DiasFestivoTrabajado): detalle.DiasFestivoTrabajado = numero; break;
        }

        detalle.DiasVacacionesRestantes = Math.Max(0, detalle.DiasVacacionesDisponibles - detalle.DiasVacaciones);
        var empleado = empleados.FirstOrDefault(e => e.Id == detalle.EmpleadoId);
        if (empleado != null)
        {
            detalle.ComplementoSalarioMinimoSugerido = NominaLegalPolicy.CalcularComplementoSalarioMinimo(empleado, esquemaPagoPeriodoPorEmpleado.GetValueOrDefault(empleado.Id), detalle.DiasPagados, detalle.MontoDestajoInformativo, configuracionNomina);
        }
    }

    private void ActualizarDecimal(PrenominaDetalleEditable detalle, string campo, string? valor)
    {
        var numero = decimal.TryParse(valor, out var resultado) ? Math.Max(0m, resultado) : 0m;
        if (campo == nameof(PrenominaDetalleEditable.HorasExtra))
        {
            if (!reglasPrenomina.PermitirHorasExtraManual)
                return;

            detalle.HorasExtra = numero;
        }
    }

