    private IEnumerable<PrenominaBonoEditable> ObtenerBonosDisponiblesParaAgregar(PrenominaDetalleEditable detalle)
    {
        var filtro = filtroBonoRapido.Trim();
        return detalle.BonosRapidos
            .Where(x => !x.IsSelected)
            .Where(x => string.IsNullOrWhiteSpace(filtro) || x.Nombre.Contains(filtro, StringComparison.OrdinalIgnoreCase))
            .OrderBy(x => x.Orden)
            .ThenBy(x => x.Nombre)
            .Take(12);
    }

    private void OnFiltroBonoRapidoInput(ChangeEventArgs args)
    {
        filtroBonoRapido = args.Value?.ToString() ?? string.Empty;
        indiceBonoRapido = 0;
    }

    private void OnFiltroBonoRapidoKeyDown(KeyboardEventArgs args, PrenominaDetalleEditable? detalle)
    {
        if (!PuedeModificarPrenominaActual)
            return;

        if (detalle == null)
            return;

        var bonosDisponibles = ObtenerBonosDisponiblesParaAgregar(detalle).ToList();
        if (bonosDisponibles.Count == 0)
            return;

        if (string.Equals(args.Key, "ArrowDown", StringComparison.OrdinalIgnoreCase))
        {
            indiceBonoRapido = (indiceBonoRapido + 1) % bonosDisponibles.Count;
            return;
        }

        if (string.Equals(args.Key, "ArrowUp", StringComparison.OrdinalIgnoreCase))
        {
            indiceBonoRapido = (indiceBonoRapido - 1 + bonosDisponibles.Count) % bonosDisponibles.Count;
            return;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            indiceBonoRapido = Math.Clamp(indiceBonoRapido, 0, bonosDisponibles.Count - 1);
            AgregarBonoRapido(detalle, bonosDisponibles[indiceBonoRapido].BonoRubroRrhhId);
        }
    }

    private void AgregarBonoRapido(PrenominaDetalleEditable detalle, Guid rubroId)
    {
        if (!PuedeModificarPrenominaActual)
            return;

        var bono = detalle.BonosRapidos.FirstOrDefault(x => x.BonoRubroRrhhId == rubroId);
        if (bono == null)
            return;

        bono.IsSelected = true;
        if (bono.Importe < 0)
            bono.Importe = 0m;

        filtroBonoRapido = string.Empty;
        indiceBonoRapido = 0;
    }

