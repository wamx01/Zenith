    private static void SincronizarBonosRapidos(CrmDbContext db, List<PrenominaBono> existentes, Guid prenominaDetalleId, IReadOnlyCollection<PrenominaBonoEditable> bonos)
    {
        var existentesDetalle = existentes.Where(b => b.PrenominaDetalleId == prenominaDetalleId).ToDictionary(b => b.BonoRubroRrhhId, b => b);
        var seleccionados = bonos.Where(b => b.IsSelected && b.Importe > 0).ToList();

        foreach (var eliminar in existentesDetalle.Values.Where(b => seleccionados.All(x => x.BonoRubroRrhhId != b.BonoRubroRrhhId)).ToList())
            db.PrenominasBonos.Remove(eliminar);

        foreach (var bono in seleccionados)
        {
            if (!existentesDetalle.TryGetValue(bono.BonoRubroRrhhId, out var actual))
            {
                db.PrenominasBonos.Add(new PrenominaBono
                {
                    Id = Guid.NewGuid(),
                    PrenominaDetalleId = prenominaDetalleId,
                    BonoRubroRrhhId = bono.BonoRubroRrhhId,
                    Importe = bono.Importe,
                    Observaciones = string.IsNullOrWhiteSpace(bono.Observaciones) ? null : bono.Observaciones.Trim(),
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
                continue;
            }

            actual.Importe = bono.Importe;
            actual.Observaciones = string.IsNullOrWhiteSpace(bono.Observaciones) ? null : bono.Observaciones.Trim();
            actual.UpdatedAt = DateTime.UtcNow;
        }
    }

    private static void SincronizarPercepcionesRapidas(CrmDbContext db, List<PrenominaPercepcion> existentes, Guid prenominaDetalleId, IReadOnlyCollection<PrenominaPercepcionEditable> percepciones)
    {
        var existentesDetalle = existentes.Where(p => p.PrenominaDetalleId == prenominaDetalleId).ToDictionary(p => p.TipoPercepcionId, p => p);
        var seleccionadas = percepciones.Where(p => p.IsSelected && p.Importe > 0).ToList();

        foreach (var eliminar in existentesDetalle.Values.Where(p => seleccionadas.All(x => x.TipoPercepcionId != p.TipoPercepcionId)).ToList())
            db.PrenominasPercepciones.Remove(eliminar);

        foreach (var percepcion in seleccionadas)
        {
            if (!existentesDetalle.TryGetValue(percepcion.TipoPercepcionId, out var actual))
            {
                db.PrenominasPercepciones.Add(new PrenominaPercepcion
                {
                    Id = Guid.NewGuid(),
                    PrenominaDetalleId = prenominaDetalleId,
                    TipoPercepcionId = percepcion.TipoPercepcionId,
                    Importe = percepcion.Importe,
                    Referencia = string.IsNullOrWhiteSpace(percepcion.Referencia) ? null : percepcion.Referencia.Trim(),
                    Observaciones = string.IsNullOrWhiteSpace(percepcion.Observaciones) ? null : percepcion.Observaciones.Trim(),
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
                continue;
            }

            actual.Importe = percepcion.Importe;
            actual.Referencia = string.IsNullOrWhiteSpace(percepcion.Referencia) ? null : percepcion.Referencia.Trim();
            actual.Observaciones = string.IsNullOrWhiteSpace(percepcion.Observaciones) ? null : percepcion.Observaciones.Trim();
            actual.UpdatedAt = DateTime.UtcNow;
        }
    }

