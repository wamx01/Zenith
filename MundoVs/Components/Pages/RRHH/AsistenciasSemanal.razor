@page "/rrhh/asistencias-semanal"
@using System.Globalization
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Entities
@using MundoVs.Core.Models
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Resumen semanal de asistencias</PageTitle>

<style>
    .asis-week-table th {
        font-size: .74rem;
        white-space: nowrap;
        vertical-align: middle;
    }

    .asis-week-table-wrap {
        max-height: calc(100vh - 260px);
        overflow: auto;
        position: relative;
        isolation: isolate;
        border-radius: .5rem;
    }

    .asis-week-table {
        min-width: max-content;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
    }

    .asis-week-table thead {
        position: sticky;
        top: 0;
        z-index: 6;
    }

    .asis-week-table thead tr {
        position: sticky;
        top: 0;
        z-index: 6;
    }

    .asis-week-table thead th {
        position: sticky;
        top: 0;
        z-index: 7;
        background: #212529;
        box-shadow: inset 0 -1px 0 rgba(255, 255, 255, .08);
    }

    .asis-week-sticky-col {
        position: sticky;
        z-index: 2;
        background-clip: padding-box;
    }

    .asis-week-sticky-col--employee {
        left: 0;
        min-width: 210px;
        width: 210px;
    }

    .asis-week-sticky-col--number {
        left: 210px;
        min-width: 72px;
        width: 72px;
    }

    .asis-week-sticky-col--worked {
        left: 282px;
        min-width: 110px;
        width: 110px;
    }

    .asis-week-table thead .asis-week-sticky-col {
        z-index: 9;
        background: #212529;
        box-shadow: inset -1px 0 0 rgba(255, 255, 255, .08), inset 0 -1px 0 rgba(255, 255, 255, .08);
    }

    .asis-week-table tbody .asis-week-sticky-col {
        background: #fff;
        box-shadow: inset -1px 0 0 #e2e8f0;
    }

    .asis-week-table tbody tr.table-light .asis-week-sticky-col {
        background: #f8f9fa;
    }

    .asis-week-table .asis-week-sticky-col--worked {
        box-shadow: inset -2px 0 0 #cbd5e1, inset -1px 0 0 #e2e8f0;
    }

    .asis-week-table td {
        font-size: .82rem;
        vertical-align: middle;
    }

    .asis-week-date {
        min-width: 84px;
    }

    .asis-week-date-label {
        font-size: .7rem;
        color: #64748b;
    }

    .asis-week-cell {
        text-align: center;
        font-variant-numeric: tabular-nums;
    }

    .asis-week-cell__button {
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: .75rem;
        background: #fff;
        padding: .45rem .4rem;
        display: flex;
        flex-direction: column;
        gap: .15rem;
        align-items: center;
        transition: all .15s ease;
        font-variant-numeric: tabular-nums;
    }

    .asis-week-cell__button:hover {
        transform: translateY(-1px);
        box-shadow: 0 .4rem 1rem rgba(15, 23, 42, .08);
    }

    .asis-week-cell__main {
        font-weight: 700;
        color: #0f172a;
    }

    .asis-week-cell__sub {
        font-size: .68rem;
        color: #64748b;
    }

    .asis-week-cell__delta {
        font-size: .67rem;
        font-weight: 700;
    }

    .asis-week-cell__button--ok {
        background: #dcfce7;
        border-color: #4ade80;
    }

    .asis-week-cell__button--warn {
        background: #fefce8;
        border-color: #fde68a;
    }

    .asis-week-cell__button--danger {
        background: #fef2f2;
        border-color: #fca5a5;
    }

    .asis-week-cell__button--extra-pending {
        background: #f3e8ff;
        border-color: #a855f7;
    }

    .asis-week-cell__button--extra-reviewed {
        background: #dcfce7;
        border-color: #166534;
    }

    .asis-week-cell__button--muted {
        background: #f8fafc;
        border-color: #e2e8f0;
    }

    .asis-week-cell--weekend {
        background: #f8fafc;
    }

    .asis-week-total {
        min-width: 96px;
        text-align: right;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
    }

    .asis-week-metric {
        min-width: 92px;
        padding: .4rem !important;
        vertical-align: middle;
        font-variant-numeric: tabular-nums;
        background: #fff;
    }

    .asis-week-metric--primary {
        min-width: 108px;
        background: #fff;
    }

    .asis-week-metric--group-start {
        border-left: 2px solid #dbe4f0;
    }

    .asis-week-metric--retardo {
        background: #fff8e1;
    }

    .asis-week-metric--salida {
        background: #fee2e2;
    }

    .asis-week-metric--descuento {
        background: #fff7ed;
    }

    .asis-week-metric__card {
        width: 100%;
        min-height: 4.5rem;
        border: 1px solid #e2e8f0;
        border-radius: .85rem;
        background: #f8fafc;
        padding: .45rem .5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: .15rem;
        text-align: center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.75);
    }

    .asis-week-metric--primary .asis-week-metric__card {
        background: #eef6ff;
        border-color: #93c5fd;
    }

    .asis-week-metric--retardo .asis-week-metric__card {
        background: #fef3c7;
        border-color: #f59e0b;
    }

    .asis-week-metric--salida .asis-week-metric__card {
        background: #fee2e2;
        border-color: #ef4444;
    }

    .asis-week-metric--descuento .asis-week-metric__card {
        background: #ffedd5;
        border-color: #fb923c;
    }

    .asis-week-metric__label {
        display: block;
        font-size: .66rem;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .asis-week-metric__value {
        display: block;
        font-size: .88rem;
        font-weight: 700;
        color: #0f172a;
    }

    .asis-week-legend {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        padding: .85rem 1rem;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .asis-week-legend__item {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        font-size: .74rem;
        color: #334155;
    }

    .asis-week-legend__dot {
        width: .9rem;
        height: .9rem;
        border-radius: 999px;
        border: 1px solid rgba(15, 23, 42, .08);
    }

    .asis-week-legend__dot--ok { background: #4ade80; }
    .asis-week-legend__dot--warn { background: #fde68a; }
    .asis-week-legend__dot--danger { background: #fca5a5; }
    .asis-week-legend__dot--muted { background: #e2e8f0; }
    .asis-week-legend__dot--extra-pending { background: #a855f7; }
    .asis-week-legend__dot--extra-reviewed { background: #166534; }
</style>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver el resumen semanal de asistencias.</div>
    }
    else
    {
        <div class="d-flex align-items-start justify-content-between mb-3 gap-3 flex-wrap">
            <div>
                <h1 class="display-6 fw-bold"><i class="bi bi-calendar-week me-2"></i>Resumen semanal</h1>
                <p class="text-muted mb-0">Consulta horas trabajadas por empleado y día usando las asistencias ya procesadas.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-outline-secondary" href="/rrhh/asistencias"><i class="bi bi-arrow-left me-1"></i>Volver a asistencias</a>
                <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <div class="row g-3 mb-4">
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Empleados</div><div class="fs-4 fw-bold">@resumenes.Count</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Días en rango</div><div class="fs-4 fw-bold">@diasPeriodo.Count</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Horas del periodo</div><div class="fs-4 fw-bold">@FormatearMinutos(totalMinutosPeriodo)</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Promedio por empleado</div><div class="fs-4 fw-bold">@FormatearMinutos(promedioMinutosEmpleado)</div></div></div></div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white">Filtros</div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Desde</label>
                        <InputDate class="form-control" @bind-Value="filtroDesde" @bind-Value:after="GuardarFiltrosPersistidosAsync" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <InputDate class="form-control" @bind-Value="filtroHasta" @bind-Value:after="GuardarFiltrosPersistidosAsync" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Empleado</label>
                        <InputText class="form-control" @bind-Value="filtroEmpleado" @bind-Value:after="GuardarFiltrosPersistidosAsync" placeholder="Nombre, número o código" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Turno</label>
                        <InputSelect class="form-select" @bind-Value="filtroTurnoIdTexto" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="">Todos</option>
                            @foreach (var turno in turnos)
                            {
                                <option value="@turno.Id.ToString()">@turno.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estatus</label>
                        <InputSelect class="form-select" @bind-Value="filtroEstatus" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="todos">Todos</option>
                            @foreach (var estatus in estatusDisponibles)
                            {
                                <option value="@((int)estatus).ToString()">@ObtenerTextoEstatus(estatus)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Revisión</label>
                        <InputSelect class="form-select" @bind-Value="filtroRevision" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="todos">Todos</option>
                            <option value="si">Con revisión</option>
                            <option value="no">Sin revisión</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ordenar por</label>
                        <InputSelect class="form-select" @bind-Value="filtroOrden" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="nombre">Nombre</option>
                            <option value="numero">No.</option>
                            <option value="checador">Checador</option>
                        </InputSelect>
                    </div>
                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-search me-1"></i>Aplicar filtros</button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarFiltrosAsync" disabled="@cargando">Limpiar</button>
                        <button class="btn btn-outline-success" @onclick="ExportarCsvAsync" disabled="@(cargando || exportandoCsv || resumenes.Count == 0)"><i class="bi bi-filetype-csv me-1"></i>@(exportandoCsv ? "Exportando..." : "Exportar CSV")</button>
                    </div>
                    <div class="col-12">
                        <small class="text-muted">Rango máximo: 31 días. La información se obtiene de `RrhhAsistencias`, es decir, de las asistencias ya procesadas.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="asis-week-legend">
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--ok"></span>En objetivo o arriba del debido</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--warn"></span>Faltante leve</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--danger"></span>Faltante fuerte</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--extra-pending"></span>Tiempo extra pendiente</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--extra-reviewed"></span>Tiempo extra revisado</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--muted"></span>Sin tiempo registrado</span>
                </div>
                <div class="asis-week-table-wrap">
                    <table class="table table-hover table-sm mb-0 align-middle asis-week-table">
                        <thead class="table-dark">
                            <tr>
                                <th class="asis-week-sticky-col asis-week-sticky-col--employee">Empleado</th>
                                <th class="asis-week-sticky-col asis-week-sticky-col--number">No.</th>
                                <th class="text-end asis-week-sticky-col asis-week-sticky-col--worked">Trabajado</th>
                                @foreach (var dia in diasPeriodo)
                                {
                                    <th class="asis-week-date text-center @(EsFinSemana(dia) ? "asis-week-cell--weekend" : string.Empty)">
                                        <div>@ObtenerAbreviaturaDia(dia)</div>
                                        <div class="asis-week-date-label">@dia.ToString("dd/MM")</div>
                                    </th>
                                }
                                 <th class="text-end">Extra</th>
                                 <th class="text-end">Pago</th>
                                 <th class="text-end">Banco</th>
                                 <th class="text-end">Permisos</th>
                                 <th class="text-end">Comp.</th>
                                  <th class="text-end">Descuento min</th>
                                  <th class="text-end">Retardo min</th>
                                 <th class="text-end">Salida ant. min</th>
                                 <th class="text-end">Días trab.</th>
                                 <th class="text-end">Festivo trab.</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (resumenes.Count == 0)
                            {
                                <tr>
                                     <td colspan="@(diasPeriodo.Count + 8)" class="text-center text-muted py-4">No hay asistencias procesadas para el rango seleccionado.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var resumen in resumenes)
                                {
                                    <tr>
                                        <td class="asis-week-sticky-col asis-week-sticky-col--employee">
                                            <div class="fw-semibold">@resumen.NombreCompleto</div>
                                            <div class="small text-muted">@(string.IsNullOrWhiteSpace(resumen.CodigoChecador) ? "Sin código" : resumen.CodigoChecador)</div>
                                        </td>
                                        <td class="asis-week-sticky-col asis-week-sticky-col--number">@(string.IsNullOrWhiteSpace(resumen.NumeroEmpleado) ? "—" : resumen.NumeroEmpleado)</td>
                                    <td class="asis-week-metric asis-week-metric--primary asis-week-sticky-col asis-week-sticky-col--worked"><span class="asis-week-metric__label">Visible</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutos)</span></td>
                                        @foreach (var dia in diasPeriodo)
                                        {
                                             var presentacionDia = ObtenerPresentacionDia(resumen, dia);
                                             <td class="asis-week-cell @(EsFinSemana(dia) ? "asis-week-cell--weekend" : string.Empty)">
                                                 <button type="button" class="asis-week-cell__button @presentacionDia.CssClass" title="@presentacionDia.Tooltip" @onclick="() => AbrirCorreccionDiaAsync(resumen.EmpleadoId, dia)">
                                                     <span class="asis-week-cell__main">@presentacionDia.Visible</span>
                                                     <span class="asis-week-cell__sub">Debe @presentacionDia.Debido</span>
                                                     <span class="asis-week-cell__delta">@presentacionDia.Delta</span>
                                                 </button>
                                             </td>
                                        }
                                     <td class="asis-week-metric asis-week-metric--group-start"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Detectado</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutosExtra)</span></div></td>
                                     <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Pago</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutosExtraAprobadoPago)</span></div></td>
                                     <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Banco</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutosExtraAprobadoBanco)</span></div></td>
                                     <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Permisos</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutosPermiso)</span></div></td>
                                     <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Comp.</span><span class="asis-week-metric__value">@FormatearMinutos(resumen.TotalMinutosCompensacion)</span></div></td>
                                       <td class="asis-week-metric asis-week-metric--descuento @ObtenerClaseMetricaDescuento(resumen.TotalMinutosDescuento)" title="@ObtenerTooltipDescuento(resumen)"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Descuento</span><span class="asis-week-metric__value">@resumen.TotalMinutosDescuento min</span></div></td>
                                       <td class="asis-week-metric @ObtenerClaseMetricaRetardo(resumen.TotalMinutosRetardo)" title="@ObtenerTooltipRetardo(resumen)"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Retardo</span><span class="asis-week-metric__value">@resumen.TotalMinutosRetardo min</span></div></td>
                                      <td class="asis-week-metric @ObtenerClaseMetricaSalidaAnticipada(resumen.TotalMinutosSalidaAnticipada)" title="@ObtenerTooltipSalidaAnticipada(resumen)"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Salida ant.</span><span class="asis-week-metric__value">@resumen.TotalMinutosSalidaAnticipada min</span></div></td>
                                      <td class="asis-week-metric" title="@ObtenerTooltipDiasTrabajados(resumen)"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Trabajados</span><span class="asis-week-metric__value">@resumen.TotalDiasTrabajados día(s)</span></div></td>
                                      <td class="asis-week-metric" title="@ObtenerTooltipFestivoTrabajado(resumen)"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Festivo trab.</span><span class="asis-week-metric__value">@resumen.TotalDiasFestivoTrabajado día(s)</span></div></td>
                                        <td class="asis-week-total">@FormatearMinutos(resumen.TotalMinutos)</td>
                                    </tr>
                                }

                                <tr class="table-light fw-semibold">
                                    <td class="asis-week-sticky-col asis-week-sticky-col--employee">Totales</td>
                                    <td class="asis-week-sticky-col asis-week-sticky-col--number">—</td>
                                <td class="asis-week-metric asis-week-metric--primary asis-week-sticky-col asis-week-sticky-col--worked"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Visible</span><span class="asis-week-metric__value">@FormatearMinutos(totalMinutosPeriodo)</span></div></td>
                                    @foreach (var dia in diasPeriodo)
                                    {
                                        <td class="asis-week-cell @(EsFinSemana(dia) ? "asis-week-cell--weekend" : string.Empty)">@FormatearMinutos(totalesPorDia.GetValueOrDefault(dia))</td>
                                    }
                                 <td class="asis-week-metric asis-week-metric--group-start"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Detectado</span><span class="asis-week-metric__value">@FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtra))</span></div></td>
                                 <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Pago</span><span class="asis-week-metric__value">@FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtraAprobadoPago))</span></div></td>
                                 <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Banco</span><span class="asis-week-metric__value">@FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtraAprobadoBanco))</span></div></td>
                                 <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Permisos</span><span class="asis-week-metric__value">@FormatearMinutos(resumenes.Sum(x => x.TotalMinutosPermiso))</span></div></td>
                                 <td class="asis-week-metric"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Comp.</span><span class="asis-week-metric__value">@FormatearMinutos(resumenes.Sum(x => x.TotalMinutosCompensacion))</span></div></td>
                                   <td class="asis-week-metric asis-week-metric--descuento @ObtenerClaseMetricaDescuento(resumenes.Sum(x => x.TotalMinutosDescuento))"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Descuento</span><span class="asis-week-metric__value">@resumenes.Sum(x => x.TotalMinutosDescuento) min</span></div></td>
                                   <td class="asis-week-metric @ObtenerClaseMetricaRetardo(resumenes.Sum(x => x.TotalMinutosRetardo))"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Retardo</span><span class="asis-week-metric__value">@resumenes.Sum(x => x.TotalMinutosRetardo) min</span></div></td>
                                  <td class="asis-week-metric @ObtenerClaseMetricaSalidaAnticipada(resumenes.Sum(x => x.TotalMinutosSalidaAnticipada))"><div class="asis-week-metric__card"><span class="asis-week-metric__label">Salida ant.</span><span class="asis-week-metric__value">@resumenes.Sum(x => x.TotalMinutosSalidaAnticipada) min</span></div></td>
                                  <td class="asis-week-metric"><span class="asis-week-metric__label">Trabajados</span><span class="asis-week-metric__value">@resumenes.Sum(x => x.TotalDiasTrabajados) día(s)</span></td>
                                  <td class="asis-week-metric"><span class="asis-week-metric__label">Festivo trab.</span><span class="asis-week-metric__value">@resumenes.Sum(x => x.TotalDiasFestivoTrabajado) día(s)</span></td>
                                    <td class="asis-week-total">@FormatearMinutos(totalMinutosPeriodo)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<AsistenciasCorreccionModal
    Visible="@(mostrarCorreccionDia && asistenciaSeleccionada != null)"
    Asistencia="asistenciaSeleccionada"
    Turnos="turnos"
    PuedeReprocesar="_puedeReprocesar"
    PuedeAprobarTiempoExtra="_puedeAprobarTiempoExtra"
    OnClose="CerrarCorreccionDia"
    OnUpdated="RecargarResumenSemanalAsync" />

@code {
    private static readonly CultureInfo CulturaEsMx = new("es-MX");
    private static readonly List<RrhhAsistenciaEstatus> estatusDisponibles = Enum.GetValues<RrhhAsistenciaEstatus>().ToList();
    private List<DateOnly> diasPeriodo = [];
    private List<ResumenSemanalEmpleado> resumenes = [];
    private List<TurnoBase> turnos = [];
    private Dictionary<DateOnly, int> totalesPorDia = new();
    private Dictionary<string, int> permisosPorEmpleado = new();
    private bool _puedeVer;
    private bool _puedeReprocesar;
    private bool _puedeAprobarTiempoExtra;
    private bool _filtrosInicialesCargados;
    private bool mostrarCorreccionDia;
    private Guid _empresaId;
    private bool cargando;
    private bool exportandoCsv;
    private string? error;
    private string? ok;
    private RrhhAsistencia? asistenciaSeleccionada;
    private DateTime? filtroDesde = DateTime.Today.AddDays(-15);
    private DateTime? filtroHasta = DateTime.Today;
    private string filtroTurnoIdTexto = string.Empty;
    private string filtroEstatus = "todos";
    private string filtroRevision = "todos";
    private string filtroOrden = "nombre";
    private string? filtroEmpleado;
    private int totalMinutosPeriodo;
    private int promedioMinutosEmpleado;
    private Dictionary<string, int> compensacionesPorDia = new();
    private Dictionary<string, int> permisosPorDia = new();
    private Dictionary<string, RrhhAsistencia> asistenciasPorEmpleadoDia = new();
    private HashSet<DateOnly> festivosPeriodo = [];

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_puedeVer || _filtrosInicialesCargados)
        {
            return;
        }

        try
        {
            await CargarFiltrosPersistidosAsync();
            _filtrosInicialesCargados = true;
            await CargarAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "empleados.ver") || state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeReprocesar = state.User.HasClaim("Capacidad", "empleados.editar") || state.User.HasClaim("Capacidad", "nominas.editar");
        _puedeAprobarTiempoExtra = state.User.HasClaim("Capacidad", "rrhh.tiempoextra.aprobar") || state.User.HasClaim("Capacidad", "nominas.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarAsync()
    {
        cargando = true;
        error = null;
        ok = null;

        try
        {
            if (_empresaId == Guid.Empty)
            {
                error = "No hay empresa activa.";
                return;
            }

            var (desde, hasta) = ObtenerRangoValidado();
            diasPeriodo = Enumerable.Range(0, hasta.DayNumber - desde.DayNumber + 1)
                .Select(desde.AddDays)
                .ToList();

            await using var db = await DbFactory.CreateDbContextAsync();
            turnos = await db.TurnosBase
                .Include(t => t.Detalles)
                .AsNoTracking()
                .Where(t => t.EmpresaId == _empresaId && t.IsActive)
                .OrderBy(t => t.Nombre)
                .ToListAsync();

            var asistencias = await ConstruirConsulta(db, desde, hasta)
                .OrderBy(a => a.Empleado.Nombre)
                .ThenBy(a => a.Empleado.ApellidoPaterno)
                .ThenBy(a => a.Empleado.ApellidoMaterno)
                .ThenBy(a => a.Fecha)
                .ToListAsync();

            festivosPeriodo = await db.FestivosRrhh
                .AsNoTracking()
                .Where(f => f.IsActive && f.Fecha >= desde.ToDateTime(TimeOnly.MinValue) && f.Fecha <= hasta.ToDateTime(TimeOnly.MinValue))
                .Select(f => DateOnly.FromDateTime(f.Fecha.Date))
                .ToHashSetAsync();

            asistenciasPorEmpleadoDia = asistencias.ToDictionary(a => CrearClaveAsistencia(a.EmpleadoId, a.Fecha));

            compensacionesPorDia = await ConstruirCompensacionesPorDiaAsync(db, asistencias);
            permisosPorEmpleado = await ConstruirPermisosPorEmpleadoAsync(db, asistencias, desde, hasta);
            permisosPorDia = await ConstruirPermisosPorDiaAsync(db, asistencias, desde, hasta);

            resumenes = asistencias
                .GroupBy(a => new
                {
                    a.EmpleadoId,
                    Nombre = a.Empleado.NombreCompleto,
                    a.Empleado.NumeroEmpleado,
                    a.Empleado.CodigoChecador
                })
                .Select(grupo => new ResumenSemanalEmpleado
                {
                    EmpleadoId = grupo.Key.EmpleadoId,
                    NombreCompleto = grupo.Key.Nombre,
                    NumeroEmpleado = grupo.Key.NumeroEmpleado,
                    CodigoChecador = grupo.Key.CodigoChecador,
                    TotalMinutosExtra = grupo.Sum(a => Math.Max(0, a.MinutosExtra)),
                    TotalMinutosExtraAprobadoPago = grupo.Sum(a => Math.Max(0, a.MinutosExtraAutorizadosPago)),
                    TotalMinutosExtraAprobadoBanco = grupo.Sum(a => Math.Max(0, a.MinutosExtraAutorizadosBanco)),
                     TotalMinutosDescuento = grupo.Sum(a => RrhhTiempoExtraPolicy.ObtenerMinutosDescuentoTotal(a, 0, ObtenerMinutosPermisoAplicados(a))),
                    TotalMinutosRetardo = grupo.Sum(a => RrhhTiempoExtraPolicy.ObtenerMinutosRetardoEfectivos(a)),
                    TotalMinutosSalidaAnticipada = grupo.Sum(a => RrhhTiempoExtraPolicy.ObtenerMinutosSalidaAnticipadaEfectivos(a)),
                     MinutosDescuentoPorDia = grupo.GroupBy(a => a.Fecha).ToDictionary(g => g.Key, g => g.Sum(x => RrhhTiempoExtraPolicy.ObtenerMinutosDescuentoTotal(x, 0, ObtenerMinutosPermisoAplicados(x)))),
                    TotalDiasTrabajados = grupo.Where(a => a.Estatus is RrhhAsistenciaEstatus.AsistenciaNormal or RrhhAsistenciaEstatus.Retardo or RrhhAsistenciaEstatus.Incompleta or RrhhAsistenciaEstatus.DescansoTrabajado).Select(a => a.Fecha).Distinct().Count(),
                    TotalDiasFestivoTrabajado = grupo.Where(a => a.Estatus is RrhhAsistenciaEstatus.AsistenciaNormal or RrhhAsistenciaEstatus.Retardo or RrhhAsistenciaEstatus.Incompleta or RrhhAsistenciaEstatus.DescansoTrabajado).Count(a => EsFestivoTrabajado(a.Fecha)),
                    MinutosRetardoPorDia = grupo.GroupBy(a => a.Fecha).ToDictionary(g => g.Key, g => g.Sum(x => RrhhTiempoExtraPolicy.ObtenerMinutosRetardoEfectivos(x))),
                    MinutosSalidaAnticipadaPorDia = grupo.GroupBy(a => a.Fecha).ToDictionary(g => g.Key, g => g.Sum(x => RrhhTiempoExtraPolicy.ObtenerMinutosSalidaAnticipadaEfectivos(x))),
                    DiasTrabajadosDetalle = grupo.Where(a => a.Estatus is RrhhAsistenciaEstatus.AsistenciaNormal or RrhhAsistenciaEstatus.Retardo or RrhhAsistenciaEstatus.Incompleta or RrhhAsistenciaEstatus.DescansoTrabajado).Select(a => a.Fecha).Distinct().ToList(),
                    DiasFestivoTrabajadoDetalle = grupo.Where(a => a.Estatus is RrhhAsistenciaEstatus.AsistenciaNormal or RrhhAsistenciaEstatus.Retardo or RrhhAsistenciaEstatus.Incompleta or RrhhAsistenciaEstatus.DescansoTrabajado).Select(a => a.Fecha).Where(EsFestivoTrabajado).Distinct().ToList(),
                    TotalMinutosCompensacion = grupo.Sum(a => ObtenerMinutosCompensados(a)),
                    TotalMinutosPermiso = permisosPorEmpleado.GetValueOrDefault(grupo.Key.EmpleadoId.ToString("N")),
                    MinutosPorDia = grupo
                        .GroupBy(a => a.Fecha)
                        .ToDictionary(g => g.Key, g => g.Sum(x => ObtenerMinutosTrabajadosVisibles(x))),
                    MinutosDebidosPorDia = grupo
                        .GroupBy(a => a.Fecha)
                        .ToDictionary(g => g.Key, g => g.Sum(x => Math.Max(0, x.MinutosJornadaNetaProgramada)))
                })
                .ToList();

            resumenes = filtroOrden switch
            {
                "numero" => resumenes.OrderBy(x => x.NumeroEmpleado).ThenBy(x => x.NombreCompleto).ToList(),
                "checador" => resumenes.OrderBy(x => x.CodigoChecador).ThenBy(x => x.NombreCompleto).ToList(),
                _ => resumenes.OrderBy(x => x.NombreCompleto).ThenBy(x => x.NumeroEmpleado).ToList()
            };

            totalMinutosPeriodo = resumenes.Sum(x => x.TotalMinutos);
            promedioMinutosEmpleado = resumenes.Count == 0 ? 0 : totalMinutosPeriodo / resumenes.Count;
            totalesPorDia = diasPeriodo.ToDictionary(dia => dia, dia => resumenes.Sum(x => x.MinutosPorDia.GetValueOrDefault(dia)));
            await GuardarFiltrosPersistidosAsync();
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
            diasPeriodo = [];
            resumenes = [];
            turnos = [];
            totalesPorDia = new();
            compensacionesPorDia = new();
            permisosPorEmpleado = new();
            permisosPorDia = new();
            asistenciasPorEmpleadoDia = new();
            festivosPeriodo = [];
            totalMinutosPeriodo = 0;
            promedioMinutosEmpleado = 0;
        }
        finally
        {
            cargando = false;
        }
    }

    private IQueryable<RrhhAsistencia> ConstruirConsulta(CrmDbContext db, DateOnly desde, DateOnly hasta)
    {
        var query = db.RrhhAsistencias
            .AsNoTracking()
            .Include(a => a.Empleado)
            .Include(a => a.TurnoBase)
            .Where(a => a.EmpresaId == _empresaId && a.Fecha >= desde && a.Fecha <= hasta);

        if (Guid.TryParse(filtroTurnoIdTexto, out var turnoId) && turnoId != Guid.Empty)
        {
            query = query.Where(a => a.TurnoBaseId == turnoId);
        }

        if (int.TryParse(filtroEstatus, out var estatusValor) && Enum.IsDefined(typeof(RrhhAsistenciaEstatus), estatusValor))
        {
            var estatus = (RrhhAsistenciaEstatus)estatusValor;
            query = query.Where(a => a.Estatus == estatus);
        }

        query = filtroRevision switch
        {
            "si" => query.Where(a => a.RequiereRevision),
            "no" => query.Where(a => !a.RequiereRevision),
            _ => query
        };

        if (!string.IsNullOrWhiteSpace(filtroEmpleado))
        {
            var texto = filtroEmpleado.Trim();
            query = query.Where(a =>
                a.Empleado.Nombre.Contains(texto) ||
                (a.Empleado.ApellidoPaterno != null && a.Empleado.ApellidoPaterno.Contains(texto)) ||
                (a.Empleado.ApellidoMaterno != null && a.Empleado.ApellidoMaterno.Contains(texto)) ||
                (a.Empleado.NumeroEmpleado != null && a.Empleado.NumeroEmpleado.Contains(texto)) ||
                (a.Empleado.CodigoChecador != null && a.Empleado.CodigoChecador.Contains(texto)));
        }

        return query;
    }

    private (DateOnly Desde, DateOnly Hasta) ObtenerRangoValidado()
    {
        if (!filtroDesde.HasValue || !filtroHasta.HasValue)
        {
            throw new InvalidOperationException("Selecciona un rango de fechas.");
        }

        var desde = DateOnly.FromDateTime(filtroDesde.Value.Date);
        var hasta = DateOnly.FromDateTime(filtroHasta.Value.Date);
        if (desde > hasta)
        {
            throw new InvalidOperationException("La fecha inicial no puede ser mayor a la final.");
        }

        if (hasta.DayNumber - desde.DayNumber > 30)
        {
            throw new InvalidOperationException("El resumen semanal permite consultar un máximo de 31 días.");
        }

        return (desde, hasta);
    }

    private async Task LimpiarFiltrosAsync()
    {
        AplicarFiltros(RrhhAsistenciasFiltroState.CreateDefault());
        await LimpiarFiltrosPersistidosAsync();
        await CargarAsync();
    }

    private async Task CargarFiltrosPersistidosAsync()
    {
        try
        {
            var filtrosJson = await JS.InvokeAsync<string?>("mundoVsAuth.getLocal", RrhhAsistenciasFiltroState.WeeklyStorageKey);
            if (string.IsNullOrWhiteSpace(filtrosJson))
            {
                filtrosJson = await JS.InvokeAsync<string?>("mundoVsAuth.getLocal", RrhhAsistenciasFiltroState.StorageKey);
                if (!string.IsNullOrWhiteSpace(filtrosJson))
                {
                    var filtrosHeredados = JsonSerializer.Deserialize<RrhhAsistenciasFiltroState>(filtrosJson);
                    var filtrosIniciales = filtrosHeredados ?? RrhhAsistenciasFiltroState.CreateDefault();
                    AplicarFiltros(filtrosIniciales);
                    await GuardarFiltrosPersistidosAsync();
                    return;
                }

                AplicarFiltros(RrhhAsistenciasFiltroState.CreateDefault());
                return;
            }

            var filtros = JsonSerializer.Deserialize<RrhhAsistenciasFiltroState>(filtrosJson);
            AplicarFiltros(filtros ?? RrhhAsistenciasFiltroState.CreateDefault());
        }
        catch
        {
            AplicarFiltros(RrhhAsistenciasFiltroState.CreateDefault());
        }
    }

    private async Task GuardarFiltrosPersistidosAsync()
    {
        var filtros = CrearEstadoFiltros();
        var filtrosJson = JsonSerializer.Serialize(filtros);
        await JS.InvokeVoidAsync("mundoVsAuth.setLocal", RrhhAsistenciasFiltroState.WeeklyStorageKey, filtrosJson);
    }

    private async Task LimpiarFiltrosPersistidosAsync()
        => await JS.InvokeVoidAsync("mundoVsAuth.removeLocal", RrhhAsistenciasFiltroState.WeeklyStorageKey);

    private RrhhAsistenciasFiltroState CrearEstadoFiltros()
        => new()
        {
            Desde = filtroDesde,
            Hasta = filtroHasta,
            TurnoIdTexto = filtroTurnoIdTexto,
            Estatus = filtroEstatus,
            Revision = filtroRevision,
            Orden = filtroOrden,
            Empleado = string.IsNullOrWhiteSpace(filtroEmpleado) ? null : filtroEmpleado.Trim()
        };

    private void AplicarFiltros(RrhhAsistenciasFiltroState filtros)
    {
        filtroDesde = filtros.Desde;
        filtroHasta = filtros.Hasta;
        filtroTurnoIdTexto = filtros.TurnoIdTexto ?? string.Empty;
        filtroEstatus = string.IsNullOrWhiteSpace(filtros.Estatus) ? "todos" : filtros.Estatus;
        filtroRevision = string.IsNullOrWhiteSpace(filtros.Revision) ? "todos" : filtros.Revision;
        filtroOrden = string.IsNullOrWhiteSpace(filtros.Orden) ? "nombre" : filtros.Orden;
        filtroEmpleado = string.IsNullOrWhiteSpace(filtros.Empleado) ? null : filtros.Empleado.Trim();
    }

    private static string ObtenerTextoEstatus(RrhhAsistenciaEstatus estatus)
        => estatus switch
        {
            RrhhAsistenciaEstatus.AsistenciaNormal => "Normal",
            RrhhAsistenciaEstatus.Retardo => "Retardo",
            RrhhAsistenciaEstatus.Falta => "Falta",
            RrhhAsistenciaEstatus.Descanso => "Descanso",
            RrhhAsistenciaEstatus.DescansoTrabajado => "Descanso trabajado",
            RrhhAsistenciaEstatus.Incompleta => "Incompleta",
            RrhhAsistenciaEstatus.TurnoNoAsignado => "Sin turno",
            RrhhAsistenciaEstatus.MarcaNoReconocida => "Marca no reconocida",
            _ => "Pendiente"
        };

    private async Task ExportarCsvAsync()
    {
        if (resumenes.Count == 0)
        {
            error = "No hay información para exportar.";
            return;
        }

        exportandoCsv = true;
        error = null;
        ok = null;

        try
        {
            var builder = new StringBuilder();
            var encabezados = new List<string> { "Empleado", "NumeroEmpleado", "CodigoChecador" };
            encabezados.AddRange(diasPeriodo.Select(d => d.ToString("yyyy-MM-dd")));
            encabezados.Add("TiempoExtraSemanal");
            encabezados.Add("TiempoExtraSemanalMin");
            encabezados.Add("TiempoExtraAprobadoPagoSemanal");
            encabezados.Add("TiempoExtraAprobadoPagoSemanalMin");
            encabezados.Add("TiempoExtraAprobadoBancoSemanal");
            encabezados.Add("TiempoExtraAprobadoBancoSemanalMin");
            encabezados.Add("PermisosSemanal");
            encabezados.Add("PermisosSemanalMin");
            encabezados.Add("CompensacionesSemanal");
            encabezados.Add("CompensacionesSemanalMin");
            encabezados.Add("TotalHoras");
            encabezados.Add("TotalMinutos");
            builder.AppendLine(string.Join(",", encabezados.Select(EscapeCsv)));

            foreach (var resumen in resumenes)
            {
                var columnas = new List<string>
                {
                    EscapeCsv(resumen.NombreCompleto),
                    EscapeCsv(resumen.NumeroEmpleado),
                    EscapeCsv(resumen.CodigoChecador)
                };

                columnas.AddRange(diasPeriodo.Select(dia => EscapeCsv(FormatearMinutos(resumen.MinutosPorDia.GetValueOrDefault(dia)))));
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutosExtra)));
                columnas.Add(resumen.TotalMinutosExtra.ToString());
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutosExtraAprobadoPago)));
                columnas.Add(resumen.TotalMinutosExtraAprobadoPago.ToString());
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutosExtraAprobadoBanco)));
                columnas.Add(resumen.TotalMinutosExtraAprobadoBanco.ToString());
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutosPermiso)));
                columnas.Add(resumen.TotalMinutosPermiso.ToString());
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutosCompensacion)));
                columnas.Add(resumen.TotalMinutosCompensacion.ToString());
                columnas.Add(EscapeCsv(FormatearMinutos(resumen.TotalMinutos)));
                columnas.Add(resumen.TotalMinutos.ToString());
                builder.AppendLine(string.Join(",", columnas));
            }

            var totales = new List<string>
            {
                EscapeCsv("Totales"),
                EscapeCsv(null),
                EscapeCsv(null)
            };

            totales.AddRange(diasPeriodo.Select(dia => EscapeCsv(FormatearMinutos(totalesPorDia.GetValueOrDefault(dia)))));
            totales.Add(EscapeCsv(FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtra))));
            totales.Add(resumenes.Sum(x => x.TotalMinutosExtra).ToString());
            totales.Add(EscapeCsv(FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtraAprobadoPago))));
            totales.Add(resumenes.Sum(x => x.TotalMinutosExtraAprobadoPago).ToString());
            totales.Add(EscapeCsv(FormatearMinutos(resumenes.Sum(x => x.TotalMinutosExtraAprobadoBanco))));
            totales.Add(resumenes.Sum(x => x.TotalMinutosExtraAprobadoBanco).ToString());
            totales.Add(EscapeCsv(FormatearMinutos(resumenes.Sum(x => x.TotalMinutosPermiso))));
            totales.Add(resumenes.Sum(x => x.TotalMinutosPermiso).ToString());
            totales.Add(EscapeCsv(FormatearMinutos(resumenes.Sum(x => x.TotalMinutosCompensacion))));
            totales.Add(resumenes.Sum(x => x.TotalMinutosCompensacion).ToString());
            totales.Add(EscapeCsv(FormatearMinutos(totalMinutosPeriodo)));
            totales.Add(totalMinutosPeriodo.ToString());
            builder.AppendLine(string.Join(",", totales));

            var nombreArchivo = $"asistencias-semanal-{DateTime.Now:yyyyMMdd-HHmmss}.csv";
            await JS.InvokeVoidAsync("mundoVsAuth.downloadCsv", nombreArchivo, builder.ToString());
            ok = $"CSV generado correctamente con {resumenes.Count} empleado(s).";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            exportandoCsv = false;
        }
    }

    private static string ObtenerAbreviaturaDia(DateOnly fecha)
    {
        var texto = fecha.ToString("ddd", CulturaEsMx);
        return string.IsNullOrWhiteSpace(texto)
            ? fecha.DayOfWeek.ToString()
            : char.ToUpperInvariant(texto[0]) + texto[1..].TrimEnd('.');
    }

    private static bool EsFinSemana(DateOnly fecha)
        => fecha.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;

    private static string FormatearMinutos(int minutos)
    {
        if (minutos <= 0)
        {
            return "—";
        }

        var horas = minutos / 60;
        var resto = minutos % 60;
        return $"{horas:D2}:{resto:D2}";
    }

    private static string EscapeCsv(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
        {
            return "\"\"";
        }

        return $"\"{valor.Replace("\"", "\"\"")}\"";
    }

    private int ObtenerMinutosTrabajadosVisibles(RrhhAsistencia asistencia)
        => RrhhTiempoExtraPolicy.ObtenerMinutosTrabajadosVisibles(asistencia, ObtenerMinutosCompensados(asistencia));

    private int ObtenerMinutosCompensados(RrhhAsistencia asistencia)
        => compensacionesPorDia.TryGetValue(CrearClaveCompensacion(asistencia.EmpleadoId, asistencia.Fecha), out var minutos)
            ? Math.Max(0, minutos)
            : 0;

    private int ObtenerMinutosPermisoAplicados(RrhhAsistencia asistencia)
        => permisosPorDia.TryGetValue(CrearClaveCompensacion(asistencia.EmpleadoId, asistencia.Fecha), out var minutos)
            ? Math.Max(0, minutos)
            : Math.Max(0, asistencia.MinutosCubiertosBancoHoras);

    private static string CrearClaveCompensacion(Guid empleadoId, DateOnly fecha)
        => $"{empleadoId:N}:{fecha:yyyyMMdd}";

    private static string CrearClaveAsistencia(Guid empleadoId, DateOnly fecha)
        => $"{empleadoId:N}:{fecha:yyyyMMdd}";

    private PresentacionCeldaSemanal ObtenerPresentacionDia(ResumenSemanalEmpleado resumen, DateOnly dia)
    {
        var visible = resumen.MinutosPorDia.GetValueOrDefault(dia);
        var debido = resumen.MinutosDebidosPorDia.GetValueOrDefault(dia);
        var delta = visible - debido;
        asistenciasPorEmpleadoDia.TryGetValue(CrearClaveAsistencia(resumen.EmpleadoId, dia), out var asistencia);
        var minutosExtra = asistencia == null ? 0 : Math.Max(0, asistencia.MinutosExtra);
        var minutosExtraAprobados = asistencia == null ? 0 : Math.Max(0, asistencia.MinutosExtraAutorizadosPago + asistencia.MinutosExtraAutorizadosBanco);
        var extraResuelto = asistencia != null && (minutosExtraAprobados > 0 || !string.IsNullOrWhiteSpace(asistencia.ResolucionTiempoExtra) || !asistencia.RequiereRevision);

        var cssClass = minutosExtra > 0 && !extraResuelto
            ? "asis-week-cell__button--extra-pending"
            : minutosExtra > 0 && extraResuelto
                ? "asis-week-cell__button--extra-reviewed"
                : visible <= 0 && debido <= 0
                    ? "asis-week-cell__button--muted"
                    : delta >= 0
                        ? "asis-week-cell__button--ok"
                        : Math.Abs(delta) <= 30
                            ? "asis-week-cell__button--warn"
                            : "asis-week-cell__button--danger";

        var deltaTexto = delta == 0
            ? "En objetivo"
            : delta > 0
                ? $"+{FormatearMinutos(delta)}"
                : $"-{FormatearMinutos(Math.Abs(delta))}";

        if (minutosExtra > 0)
        {
            deltaTexto = extraResuelto
                ? $"Extra rev. {FormatearMinutos(minutosExtraAprobados)}"
                : $"Extra pend. {FormatearMinutos(minutosExtra)}";
        }

        var tooltipExtra = minutosExtra > 0
            ? $" | Extra detectado: {FormatearMinutos(minutosExtra)} | Extra aprobado: {FormatearMinutos(minutosExtraAprobados)}"
            : string.Empty;

        return new PresentacionCeldaSemanal(
            visible > 0 ? FormatearMinutos(visible) : "—",
            debido > 0 ? FormatearMinutos(debido) : "—",
            deltaTexto,
            cssClass,
            $"Visible: {(visible > 0 ? FormatearMinutos(visible) : "—")} | Debe: {(debido > 0 ? FormatearMinutos(debido) : "—")} | Diferencia: {(delta == 0 ? "En objetivo" : delta > 0 ? "+" + FormatearMinutos(delta) : "-" + FormatearMinutos(Math.Abs(delta)))}{tooltipExtra}");
    }

    private Task AbrirCorreccionDiaAsync(Guid empleadoId, DateOnly fecha)
    {
        if (asistenciasPorEmpleadoDia.TryGetValue(CrearClaveAsistencia(empleadoId, fecha), out var asistencia))
        {
            asistenciaSeleccionada = asistencia;
            mostrarCorreccionDia = true;
        }

        return Task.CompletedTask;
    }

    private void CerrarCorreccionDia()
    {
        mostrarCorreccionDia = false;
        asistenciaSeleccionada = null;
    }

    private Task RecargarResumenSemanalAsync()
        => CargarAsync();

    private async Task<Dictionary<string, int>> ConstruirCompensacionesPorDiaAsync(CrmDbContext db, IReadOnlyCollection<RrhhAsistencia> asistencias)
    {
        if (asistencias.Count == 0)
        {
            return new Dictionary<string, int>();
        }

        var logs = await db.RrhhLogsChecador
            .AsNoTracking()
            .Where(l => l.EmpresaId == _empresaId
                && l.Detalle != null
                && l.Mensaje.Contains("compensación aprobada de permiso"))
            .OrderByDescending(l => l.FechaUtc)
            .ToListAsync();

        return asistencias.ToDictionary(
            a => CrearClaveCompensacion(a.EmpleadoId, a.Fecha),
            a => RrhhTiempoExtraPolicy.ObtenerMinutosPermisoCompensadosAprobados(logs, a.EmpleadoId, a.Fecha));
    }

    private async Task<Dictionary<string, int>> ConstruirPermisosPorEmpleadoAsync(CrmDbContext db, IReadOnlyCollection<RrhhAsistencia> asistencias, DateOnly desde, DateOnly hasta)
    {
        if (asistencias.Count == 0)
        {
            return new Dictionary<string, int>();
        }

        var empleadoIds = asistencias.Select(a => a.EmpleadoId).Distinct().ToList();
        var permisos = await db.RrhhAusencias
            .AsNoTracking()
            .Where(a => a.EmpresaId == _empresaId
                && empleadoIds.Contains(a.EmpleadoId)
                && a.IsActive
                && a.Tipo == TipoAusenciaRrhh.Permiso
                && (a.Estatus == EstatusAusenciaRrhh.Aprobada || a.Estatus == EstatusAusenciaRrhh.Aplicada)
                && a.FechaInicio <= hasta
                && a.FechaFin >= desde)
            .ToListAsync();

        return permisos
            .GroupBy(a => a.EmpleadoId.ToString("N"))
            .ToDictionary(
                g => g.Key,
                g => g.Sum(a => (int)Math.Round(Math.Max(0m, a.Horas) * 60m, MidpointRounding.AwayFromZero)));
    }

    private async Task<Dictionary<string, int>> ConstruirPermisosPorDiaAsync(CrmDbContext db, IReadOnlyCollection<RrhhAsistencia> asistencias, DateOnly desde, DateOnly hasta)
    {
        if (asistencias.Count == 0)
        {
            return new Dictionary<string, int>();
        }

        var empleadoIds = asistencias.Select(a => a.EmpleadoId).Distinct().ToList();
        var permisos = await db.RrhhAusencias
            .AsNoTracking()
            .Where(a => a.EmpresaId == _empresaId
                && empleadoIds.Contains(a.EmpleadoId)
                && a.IsActive
                && a.Tipo == TipoAusenciaRrhh.Permiso
                && (a.Estatus == EstatusAusenciaRrhh.Aprobada || a.Estatus == EstatusAusenciaRrhh.Aplicada)
                && a.FechaInicio <= hasta
                && a.FechaFin >= desde)
            .ToListAsync();

        var resultado = new Dictionary<string, int>();
        foreach (var permiso in permisos)
        {
            var inicio = permiso.FechaInicio < desde ? desde : permiso.FechaInicio;
            var fin = permiso.FechaFin > hasta ? hasta : permiso.FechaFin;
            var minutosPorDia = (int)Math.Round(Math.Max(0m, permiso.Horas) * 60m, MidpointRounding.AwayFromZero);
            for (var fecha = inicio; fecha <= fin; fecha = fecha.AddDays(1))
            {
                resultado[CrearClaveCompensacion(permiso.EmpleadoId, fecha)] = minutosPorDia;
            }
        }

        return resultado;
    }

    private bool EsFestivoTrabajado(DateOnly fecha)
        => festivosPeriodo.Contains(fecha);

    private string ObtenerTooltipRetardo(ResumenSemanalEmpleado resumen)
    {
        var dias = resumen.MinutosRetardoPorDia
            .Where(x => x.Value > 0)
            .OrderBy(x => x.Key)
            .Select(x => $"{x.Key:dd/MM}: {x.Value} min")
            .ToList();

        return dias.Count == 0
            ? "Sin retardo en el período."
            : $"Retardo calculado con: {string.Join(" | ", dias)}";
    }

