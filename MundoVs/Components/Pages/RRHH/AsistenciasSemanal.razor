@page "/rrhh/asistencias-semanal"
@using System.Globalization
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Entities
@using MundoVs.Core.Models
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@using MundoVs.Core.Interfaces
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IRrhhResolucionPeriodoService ResolucionPeriodo
@rendermode InteractiveServer

<PageTitle>Resumen semanal de asistencias</PageTitle>


<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver el resumen semanal de asistencias.</div>
    }
    else
    {
        <div class="d-flex align-items-start justify-content-between mb-3 gap-3 flex-wrap">
            <div>
                <h1 class="display-6 fw-bold"><i class="bi bi-calendar-week me-2"></i>Resumen semanal</h1>
                <p class="text-muted mb-0">Consulta horas trabajadas por empleado y día usando las asistencias ya procesadas.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-outline-secondary" href="/rrhh/asistencias"><i class="bi bi-arrow-left me-1"></i>Volver a asistencias</a>
                <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <div class="row g-3 mb-4">
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Empleados</div><div class="fs-4 fw-bold">@resumenes.Count</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Días del periodo</div><div class="fs-4 fw-bold">@diasPeriodo.Count</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Horas pagadas</div><div class="fs-4 fw-bold">@FormatearMinutos(totalMinutosPagadosPeriodo)</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Promedio pagado</div><div class="fs-4 fw-bold">@FormatearMinutos(promedioMinutosPagadosEmpleado)</div></div></div></div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white">Filtros</div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Periodicidad de nómina</label>
                        <InputSelect class="form-select" @bind-Value="periodicidadSeleccionada" @bind-Value:after="AlCambiarPeriodicidadAsync">
                            <option value="@((int)PeriodicidadPago.Semanal)">Semanal</option>
                            <option value="@((int)PeriodicidadPago.Quincenal)">Quincenal</option>
                            <option value="@((int)PeriodicidadPago.Mensual)">Mensual</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Periodo de nómina</label>
                        <div class="input-group">
                            <button class="btn btn-outline-secondary" @onclick="() => MoverPeriodoAsync(-1)" disabled="@cargando" title="Periodo anterior"><i class="bi bi-chevron-left"></i></button>
                            <input type="text" class="form-control text-center fw-semibold" readonly value="@periodoEtiquetaActual" />
                            <button class="btn btn-outline-secondary" @onclick="() => MoverPeriodoAsync(1)" disabled="@cargando" title="Periodo siguiente"><i class="bi bi-chevron-right"></i></button>
                            <button class="btn btn-outline-secondary" @onclick="IrAPeriodoActualAsync" disabled="@cargando" title="Ir al periodo que contiene hoy"><i class="bi bi-calendar3"></i></button>
                        </div>
                        <small class="text-muted d-block mt-1">Ventana: @periodoFechaInicio.ToString("dd/MM/yyyy") – @periodoFechaFin.ToString("dd/MM/yyyy")</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Empleado</label>
                        <InputText class="form-control" @bind-Value="filtroEmpleado" @bind-Value:after="GuardarFiltrosPersistidosAsync" placeholder="Nombre, número o código" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Turno</label>
                        <InputSelect class="form-select" @bind-Value="filtroTurnoIdTexto" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="">Todos</option>
                            @foreach (var turno in turnos)
                            {
                                <option value="@turno.Id.ToString()">@turno.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Estatus</label>
                        <InputSelect class="form-select" @bind-Value="filtroEstatus" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="todos">Todos</option>
                            @foreach (var estatus in estatusDisponibles)
                            {
                                <option value="@((int)estatus).ToString()">@ObtenerTextoEstatus(estatus)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Revisión</label>
                        <InputSelect class="form-select" @bind-Value="filtroRevision" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="todos">Todos</option>
                            <option value="si">Con revisión</option>
                            <option value="no">Sin revisión</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ordenar por</label>
                        <InputSelect class="form-select" @bind-Value="filtroOrden" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                            <option value="nombre">Nombre</option>
                            <option value="numero">No.</option>
                            <option value="checador">Checador</option>
                        </InputSelect>
                    </div>
                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-search me-1"></i>Aplicar filtros</button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarFiltrosAsync" disabled="@cargando">Limpiar</button>
                        <button class="btn btn-outline-success" @onclick="ExportarCsvAsync" disabled="@(cargando || exportandoCsv || resumenes.Count == 0)"><i class="bi bi-filetype-csv me-1"></i>@(exportandoCsv ? "Exportando..." : "Exportar CSV")</button>
                    </div>
                    <div class="col-12">
                        <small class="text-muted">La ventana se alinea al ciclo de nómina configurado (DiaCorteSemana/DiaCorteMes). Solo se muestran empleados con la periodicidad seleccionada; los de destajo se excluyen. La información viene de `RrhhAsistencias` ya procesadas.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="asis-week-legend">
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--ok"></span>En objetivo o arriba del debido</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--warn"></span>Faltante leve</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--danger"></span>Faltante fuerte</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--extra-pending"></span>Tiempo extra pendiente</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--extra-reviewed"></span>Tiempo extra revisado</span>
                    <span class="asis-week-legend__item"><span class="asis-week-legend__dot asis-week-legend__dot--muted"></span>Sin tiempo registrado</span>
                </div>
                @if (_puedeAprobarTiempoExtra && EmpleadosConExtraCount > 0)
                {
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 px-3 py-2 border-bottom bg-light">
                        <div class="small">
                            @if (PendientesAceptacionCount == 0)
                            {
                                <span class="text-success"><i class="bi bi-check2-circle me-1"></i>Tiempo del periodo aceptado — puedes generar la prenómina.</span>
                            }
                            else
                            {
                                <span class="text-warning-emphasis"><i class="bi bi-stopwatch me-1"></i>@AceptadosCount de @EmpleadosConExtraCount con tiempo aceptado — faltan @PendientesAceptacionCount para habilitar la prenómina.</span>
                            }
                        </div>
                        @if (PendientesAceptacionCount > 0)
                        {
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-success" @onclick="() => AbrirConfirmacionLote(true)" disabled="@cargando"><i class="bi bi-check2-all me-1"></i>Aceptar y pagar todo</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirConfirmacionLote(false)" disabled="@cargando"><i class="bi bi-check2 me-1"></i>Aceptar sin pagar</button>
                            </div>
                        }
                    </div>
                }
                <div class="asis-week-table-wrap">
                    <table class="table table-hover table-sm mb-0 align-middle asis-week-table asis-week-table--compact">
                        <colgroup>
                            <col class="asis-week-col--employee" />
                            <col class="asis-week-col--days" />
                            <col class="asis-week-col--num" />
                            <col class="asis-week-col--num" />
                            <col class="asis-week-col--action" />
                        </colgroup>
                        <thead class="table-dark">
                            <tr>
                                <th class="asis-week-sticky-col asis-week-sticky-col--employee">Empleado</th>
                                <th class="asis-week-col-days__head">Días del periodo (@diasPeriodo.Count)</th>
                                <th class="text-end">Pagadas</th>
                                <th class="text-end">Visible</th>
                                <th class="text-center">Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (resumenes.Count == 0)
                            {
                                <tr>
                                    <td colspan="@ObtenerTotalColumnasTabla()" class="text-center text-muted py-4">No hay asistencias procesadas para el rango seleccionado.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var resumen in resumenes)
                                {
                                    var resolucionEmpleado = resolucionPorEmpleado.GetValueOrDefault(resumen.EmpleadoId);
                                    var autorizadaEmpleado = resolucionEmpleado is { Estatus: RrhhResolucionPeriodoEstatus.Autorizada };
                                    <tr class="@(_detalleVisible && _detalleEmpleadoId == resumen.EmpleadoId ? "asis-week-row--active" : string.Empty)">
                                        <td class="asis-week-sticky-col asis-week-sticky-col--employee">
                                            <div class="fw-semibold">@resumen.NombreCompleto</div>
                                            <div class="small text-muted">
                                                @(string.IsNullOrWhiteSpace(resumen.NumeroEmpleado) ? "—" : resumen.NumeroEmpleado)
                                                @(string.IsNullOrWhiteSpace(resumen.CodigoChecador) ? string.Empty : $" · {resumen.CodigoChecador}")
                                            </div>
                                            @if (resumen.EsPorHoras)
                                            {
                                                <div class="mt-1">
                                                    <span class="badge bg-info-subtle text-info-emphasis" title="Esquema por horas: se paga el tiempo trabajado"><i class="bi bi-clock-history me-1"></i>Por horas</span>
                                                </div>
                                            }
                                            @if (_puedeAprobarTiempoExtra && (resumen.TotalMinutosExtra > 0 || resolucionPorEmpleado.ContainsKey(resumen.EmpleadoId)))
                                            {
                                                <div class="d-flex flex-wrap gap-1 align-items-center mt-1">
                                                    <span class="badge @ObtenerClaseEstatusResolucion(resolucionEmpleado)">@ObtenerEtiquetaEstatusResolucion(resolucionEmpleado)</span>
                                                </div>
                                            }
                                        </td>
                                        <td class="asis-week-col-days__cell">
                                            <div class="asis-strip">
                                                @foreach (var dia in diasPeriodo)
                                                {
                                                    var presentacionDia = ObtenerPresentacionDia(resumen, dia);
                                                    <button type="button" class="asis-strip__cell @presentacionDia.CssClass @(EsFinSemana(dia) ? "asis-strip__cell--weekend" : string.Empty)" title="@presentacionDia.Tooltip" @onclick="() => AbrirCorreccionDiaAsync(resumen.EmpleadoId, dia)">
                                                        <span class="asis-strip__dow">@ObtenerAbreviaturaDia(dia)</span>
                                                        <span class="asis-strip__day">@dia.ToString("dd")</span>
                                                        <span class="asis-strip__value">@presentacionDia.Visible</span>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-end asis-week-num">@FormatearMinutos(resumen.TotalMinutosPagados)</td>
                                        <td class="text-end asis-week-num asis-week-num--total">@FormatearMinutos(resumen.TotalMinutos)</td>
                                        <td class="asis-week-col-action__cell">
                                            <div class="d-flex flex-column gap-1 align-items-stretch">
                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirDetalleAsync(resumen.EmpleadoId)">
                                                    <i class="bi bi-eye me-1"></i>Ver detalle
                                                </button>
                                                @if (_puedeAprobarTiempoExtra && (resumen.TotalMinutosExtra > 0 || resolucionPorEmpleado.ContainsKey(resumen.EmpleadoId)))
                                                {
                                                    <button type="button" class="btn btn-sm @(autorizadaEmpleado ? "btn-outline-success" : "btn-outline-primary")" @onclick="() => AbrirResolucionAsync(resumen)">
                                                        <i class="bi @(autorizadaEmpleado ? "bi-check2-circle" : "bi-stopwatch") me-1"></i>@(autorizadaEmpleado ? "Aceptado" : "Aceptar tiempo")
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }

                                <tr class="table-light fw-semibold">
                                    <td class="asis-week-sticky-col asis-week-sticky-col--employee">Totales</td>
                                    <td class="asis-week-col-days__cell">
                                        <div class="asis-strip asis-strip--totals">
                                            @foreach (var dia in diasPeriodo)
                                            {
                                                <div class="asis-strip__cell asis-strip__cell--total @(EsFinSemana(dia) ? "asis-strip__cell--weekend" : string.Empty)" title="@dia.ToString("dddd, dd/MM/yyyy", CulturaEsMx)">
                                                    <span class="asis-strip__dow">@ObtenerAbreviaturaDia(dia)</span>
                                                    <span class="asis-strip__day">@dia.ToString("dd")</span>
                                                    <span class="asis-strip__value">@FormatearMinutos(totalesPorDia.GetValueOrDefault(dia))</span>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end asis-week-num">@FormatearMinutos(totalMinutosPagadosPeriodo)</td>
                                    <td class="text-end asis-week-num asis-week-num--total">@FormatearMinutos(totalMinutosPeriodo)</td>
                                    <td class="asis-week-col-action__cell"></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<AsistenciasCorreccionModal
    Visible="@(mostrarCorreccionDia && asistenciaSeleccionada != null)"
    Asistencia="asistenciaSeleccionada"
    Turnos="turnos"
    PuedeReprocesar="@_puedeReprocesar"
    PuedeAprobarTiempoExtra="@_puedeAprobarTiempoExtra"
    OnClose="CerrarCorreccionDia"
    OnUpdated="RecargarResumenSemanalAsync"
    OnCambioDiaSolicitado="CambiarDiaCorreccionAsync"
    FechaMinimaPeriodo="@(diasPeriodo.Count > 0 ? diasPeriodo[0] : (DateOnly?)null)"
    FechaMaximaPeriodo="@(diasPeriodo.Count > 0 ? diasPeriodo[^1] : (DateOnly?)null)" />

<AsistenciasResolucionModal
    Visible="@_resolucionVisible"
    EmpleadoId="@_resolucionEmpleadoId"
    NombreEmpleado="@_resolucionNombre"
    FechaReferencia="@(DateOnly.FromDateTime(fechaReferenciaPeriodo))"
    MinutosExtraDetectado="@_resolucionMinutosExtra"
    SaldoBancoHoras="@_resolucionSaldoBanco"
    PuedeAprobarTiempoExtra="@_puedeAprobarTiempoExtra"
    OnClose="CerrarResolucion"
    OnUpdated="RecargarResumenSemanalAsync" />

@if (_mostrarConfirmacionLote)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@( _lotePagarTodo ? "Aceptar y pagar todo el tiempo" : "Aceptar sin pagar el tiempo")</h5>
                    <button type="button" class="btn-close" @onclick="CancelarLote" disabled="@cargando" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p>Se aceptará el tiempo extra de <strong>@PendientesAceptacionCount</strong> empleado(s) del periodo.</p>
                    @if (_lotePagarTodo)
                    {
                        <p class="text-muted small mb-0">Cada empleado se autoriza con <em>PagarTodo</em> al factor de configuración (nada al banco). Si alguien necesita parte al banco o distintos factores, edítalo uno a uno con <strong>Aceptar tiempo</strong>.</p>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">El tiempo detectado se acepta <strong>sin pago ni compensación</strong>: el extra se descarta y el faltante/retardo del periodo se descuenta <strong>completo</strong> en la nómina. Úsalo cuando no vas a autorizar el extra — el periodo sí queda autorizado y desbloquea la prenómina.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelarLote" disabled="@cargando">Cancelar</button>
                    <button type="button" class="btn @(_lotePagarTodo ? "btn-success" : "btn-primary")" @onclick="ConfirmarLoteAsync" disabled="@cargando">
                        @(cargando ? "Procesando..." : (_lotePagarTodo ? "Aceptar y pagar todo" : "Aceptar sin pagar"))
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (_detalleVisible && DetalleResumen is { } detalle)
{
    var resolucionDetalle = resolucionPorEmpleado.GetValueOrDefault(detalle.EmpleadoId);
    var autorizadaDetalle = resolucionDetalle is { Estatus: RrhhResolucionPeriodoEstatus.Autorizada };
    <div class="asis-drawer-backdrop" @onclick="CerrarDetalle"></div>
    <aside class="asis-drawer">
        <header class="asis-drawer__header">
            <div>
                <h5 class="mb-0 fw-bold">@detalle.NombreCompleto</h5>
                <div class="small text-muted">
                    @(string.IsNullOrWhiteSpace(detalle.NumeroEmpleado) ? "Sin número" : detalle.NumeroEmpleado)
                    @(string.IsNullOrWhiteSpace(detalle.CodigoChecador) ? string.Empty : $" · {detalle.CodigoChecador}")
                    · @periodoEtiquetaActual
                </div>
            </div>
            <button type="button" class="btn-close" aria-label="Cerrar" @onclick="CerrarDetalle"></button>
        </header>

        <div class="asis-drawer__body">
            <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                <span class="badge @ObtenerClaseEstatusResolucion(resolucionDetalle)">@ObtenerEtiquetaEstatusResolucion(resolucionDetalle)</span>
                @if (detalle.TotalIncidencias > 0)
                {
                    <span class="badge bg-danger-subtle text-danger-emphasis" title="Ausentismo / Retardo / Incompleto">@detalle.TotalIncidencias incidencia(s)</span>
                }
                @if (_puedeAprobarTiempoExtra && (detalle.TotalMinutosExtra > 0 || resolucionPorEmpleado.ContainsKey(detalle.EmpleadoId)))
                {
                    <button type="button" class="btn btn-sm @(autorizadaDetalle ? "btn-outline-success" : "btn-primary")" @onclick="() => AbrirResolucionAsync(detalle)">
                        <i class="bi @(autorizadaDetalle ? "bi-check2-circle" : "bi-stopwatch") me-1"></i>@(autorizadaDetalle ? "Aceptado" : "Aceptar tiempo")
                    </button>
                }
            </div>

            @if (detalle.TotalIncidencias > 0)
            {
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (detalle.TotalDiasAusentismo > 0)
                    {
                        <span class="badge bg-danger-subtle text-danger-emphasis"><i class="bi bi-person-x me-1"></i>Ausentismo: @detalle.TotalDiasAusentismo</span>
                    }
                    @if (detalle.TotalDiasRetardo > 0)
                    {
                        <span class="badge bg-warning-subtle text-warning-emphasis"><i class="bi bi-clock me-1"></i>Retardo: @detalle.TotalDiasRetardo</span>
                    }
                    @if (detalle.TotalDiasIncompleto > 0)
                    {
                        <span class="badge bg-info-subtle text-info-emphasis"><i class="bi bi-hourglass-split me-1"></i>Incompleto: @detalle.TotalDiasIncompleto</span>
                    }
                </div>
            }

            <h6 class="asis-drawer__section">Días del periodo</h6>
            <div class="asis-strip asis-strip--detail">
                @foreach (var dia in diasPeriodo)
                {
                    var presentacionDia = ObtenerPresentacionDia(detalle, dia, _detalleBrutoPorDia);
                    <button type="button" class="asis-strip__cell @presentacionDia.CssClass @(EsFinSemana(dia) ? "asis-strip__cell--weekend" : string.Empty)" title="@presentacionDia.Tooltip" @onclick="() => AbrirCorreccionDiaAsync(detalle.EmpleadoId, dia)">
                        <span class="asis-strip__dow">@ObtenerAbreviaturaDia(dia)</span>
                        <span class="asis-strip__day">@dia.ToString("dd")</span>
                        <span class="asis-strip__value">@presentacionDia.Visible</span>
                        <span class="asis-strip__delta">@presentacionDia.Delta</span>
                    </button>
                }
            </div>

            <h6 class="asis-drawer__section mt-3">Tiempo reloj vs visible</h6>
            <div class="asis-detail-grid">
                <div class="asis-detail-card asis-detail-card--info" title="Tiempo reloj = span(primera → última marca) menos los pares del medio (descansos), calculado bajo demanda desde las marcaciones del empleado. Tal cual del reloj, sin reglas (neteo, umbral). Los descansos no tomados no se descuentan."><span class="asis-detail-card__label">Tiempo reloj</span><span class="asis-detail-card__value">@FormatearMinutos(_detalleTotalBruto)</span></div>
                <div class="asis-detail-card asis-detail-card--primary" title="Visible = base pagada + permiso con goce + compensación + extra aprobado. Es el tiempo que muestra la tabla."><span class="asis-detail-card__label">Visible</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutos)</span></div>
                <div class="asis-detail-card asis-detail-card--bad" title="Lo que recortan las reglas: descansos no pagados, neteo del periodo, umbral de extra, permisos sin goce. Tiempo reloj − visible."><span class="asis-detail-card__label">Diferencia</span><span class="asis-detail-card__value">@FormatearMinutos(Math.Max(0, _detalleTotalBruto - detalle.TotalMinutos))</span></div>
            </div>

            <h6 class="asis-drawer__section mt-3">Métricas del periodo</h6>
            <div class="asis-detail-grid">
                <div class="asis-detail-card asis-detail-card--info"><span class="asis-detail-card__label">Normales</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosNormales)</span></div>
                <div class="asis-detail-card asis-detail-card--info"><span class="asis-detail-card__label">Perm. c/goce</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosPermisoConGoce)</span></div>
                <div class="asis-detail-card asis-detail-card--info"><span class="asis-detail-card__label">Perm. s/goce</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosPermisoSinGoce)</span></div>
                <div class="asis-detail-card asis-detail-card--info"><span class="asis-detail-card__label">Compensación</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosCompensacion)</span></div>
                <div class="asis-detail-card asis-detail-card--good"><span class="asis-detail-card__label">Banco aplicado</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosBancoAplicado)</span></div>
                <div class="asis-detail-card asis-detail-card--good"><span class="asis-detail-card__label">Extra pagado</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosExtraAprobadoPago)</span></div>
                <div class="asis-detail-card asis-detail-card--good" title="Minutos reales acumulados al banco por movimientos de horas extra"><span class="asis-detail-card__label">A banco acum.</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosExtraAprobadoBanco)</span></div>
                <div class="asis-detail-card asis-detail-card--bad" title="@ObtenerTooltipDescuento(detalle)"><span class="asis-detail-card__label">Descuento</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosDescuento)</span></div>
                <div class="asis-detail-card asis-detail-card--warn" title="@ObtenerTooltipRetardo(detalle)"><span class="asis-detail-card__label">Retardo</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosRetardo)</span></div>
                <div class="asis-detail-card asis-detail-card--bad" title="@ObtenerTooltipSalidaAnticipada(detalle)"><span class="asis-detail-card__label">Salida anticipada</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.TotalMinutosSalidaAnticipada)</span></div>
                <div class="asis-detail-card asis-detail-card--info" title="@ObtenerTooltipDiasTrabajados(detalle)"><span class="asis-detail-card__label">Días trabajados</span><span class="asis-detail-card__value">@detalle.TotalDiasTrabajados día(s)</span></div>
                <div class="asis-detail-card asis-detail-card--info" title="@ObtenerTooltipFestivoTrabajado(detalle)"><span class="asis-detail-card__label">Festivo trab.</span><span class="asis-detail-card__value">@detalle.TotalDiasFestivoTrabajado día(s)</span></div>
                <div class="asis-detail-card asis-detail-card--good" title="Saldo del banco de horas acumulado hasta el corte"><span class="asis-detail-card__label">Saldo banco</span><span class="asis-detail-card__value">@FormatearMinutos(detalle.SaldoBancoHoras)</span></div>
            </div>
        </div>

        <footer class="asis-drawer__footer">
            <button type="button" class="btn btn-outline-secondary" @onclick="CerrarDetalle"><i class="bi bi-x-lg me-1"></i>Cerrar</button>
        </footer>
    </aside>
}

