@using MundoVs.Core.Entities

@if (Visible && AsistenciaActual != null)
{
    <div class="modal fade show d-block asis-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-xxl modal-dialog-scrollable asis-modal-dialog-wide">
            <div class="modal-content border-0 shadow-lg asis-modal-shell">

                <div class="asis-modal-header d-flex align-items-center justify-content-between px-3 py-2">
                    <div class="d-flex align-items-center gap-2 min-w-0">
                        <span class="asis-modal-header__icon"><i class="bi bi-calendar-check"></i></span>
                        <div class="min-w-0">
                            <div class="asis-modal-header__name text-truncate">@AsistenciaActual.Empleado.NombreCompleto</div>
                            <div class="asis-modal-header__date">@AsistenciaActual.Fecha.ToString("dddd dd/MM/yyyy", new System.Globalization.CultureInfo("es-MX"))</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-shrink-0">
                        <span class="badge @ObtenerClaseEstatus(AsistenciaActual) asis-status-badge">@ObtenerTextoEstatus(AsistenciaActual.Estatus)</span>
                        @if (_tieneCambiosPendientes)
                        {
                            <span class="badge text-bg-warning">Cambios pendientes</span>
                        }
                        <button type="button" class="asis-help-button" @onclick="AbrirAyudaReglas" title="Ver reglas aplicadas">
                            <i class="bi bi-question-lg"></i>
                        </button>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarAsync" aria-label="Cerrar"></button>
                    </div>
                </div>

                <div class="asis-metrics-strip border-bottom px-3 py-2">
                    @if (_tieneCambiosPendientes)
                    {
                        <div class="asis-local-preview-banner mb-2">
                            <i class="bi bi-info-circle me-1"></i>Vista previa local del empleado. Los cambios se guardan al cerrar o al usar el botón Guardar cambios.
                        </div>
                    }
                    <div class="d-flex flex-wrap align-items-center gap-1">
                        <span class="asis-metric-block">
                            <span class="asis-metric-block__label">Prog.</span>
                            <span class="asis-metric-block__val">@(AsistenciaActual.HoraEntradaProgramada?.ToString("hh\\:mm") ?? "—") <i class="bi bi-arrow-right"></i> @(AsistenciaActual.HoraSalidaProgramada?.ToString("hh\\:mm") ?? "—")</span>
                        </span>
                        <span class="asis-metric-sep">|</span>
                        <span class="asis-metric-block">
                            <span class="asis-metric-block__label">Real</span>
                            <span class="asis-metric-block__val">@(AsistenciaActual.HoraEntradaReal?.ToString("hh\\:mm") ?? "—") <i class="bi bi-arrow-right"></i> @(AsistenciaActual.HoraSalidaReal?.ToString("hh\\:mm") ?? "—")</span>
                        </span>
                        <span class="asis-metric-sep">|</span>
                        <span class="asis-chip asis-chip--muted asis-chip--xs"><i class="bi bi-person-workspace me-1"></i>@(AsistenciaActual.TurnoBase?.Nombre ?? "Sin turno")</span>
                        <span class="asis-chip asis-chip--info asis-chip--xs" title="Visible = base trabajada + compensación aprobada del mismo día + extra aprobada"><i class="bi bi-eye me-1"></i>Visible @FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</span>
                        <span class="asis-chip asis-chip--muted asis-chip--xs" title="Base trabajada sin extra no aprobada"><i class="bi bi-stopwatch me-1"></i>Base @FormatearMinutos(ObtenerMinutosTrabajadosBaseVisibles(AsistenciaActual))</span>
                        @if (ObtenerMinutosRetardoVisible(AsistenciaActual) > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaIncidencia(ObtenerMinutosRetardoVisible(AsistenciaActual)) asis-chip--xs"><i class="bi bi-alarm me-1"></i>Ret. @FormatearMinutosCortos(ObtenerMinutosRetardoVisible(AsistenciaActual))</span>
                        }
                        @if (ObtenerMinutosSalidaAnticipadaVisible(AsistenciaActual) > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaIncidencia(ObtenerMinutosSalidaAnticipadaVisible(AsistenciaActual)) asis-chip--xs"><i class="bi bi-box-arrow-left me-1"></i>S.Ant. @FormatearMinutosCortos(ObtenerMinutosSalidaAnticipadaVisible(AsistenciaActual))</span>
                        }
                        @if (AsistenciaActual.MinutosExtra > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaExtra(AsistenciaActual.MinutosExtra) asis-chip--xs" title="Extra detectada (no aprobada)"><i class="bi bi-plus-circle me-1"></i>Extra @FormatearMinutosCortos(AsistenciaActual.MinutosExtra)</span>
                        }
                        @if (ObtenerMinutosExtraAprobados(AsistenciaActual) > 0)
                        {
                            <span class="asis-chip asis-chip--success asis-chip--xs" title="Solo la extra aprobada se suma al visible"><i class="bi bi-check2-circle me-1"></i>Extra aprobada @FormatearMinutosCortos(ObtenerMinutosExtraAprobados(AsistenciaActual))</span>
                        }
                        @if (ObtenerMinutosCompensadosAprobadosActual() > 0)
                        {
                            <span class="asis-chip asis-chip--resolved asis-chip--xs" title="Compensación aprobada del mismo día"><i class="bi bi-arrow-left-right me-1"></i>Comp. día @FormatearMinutosCortos(ObtenerMinutosCompensadosAprobadosActual())</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(ObtenerUltimaCorreccionResumen()))
                        {
                            <span class="asis-chip asis-chip--muted asis-chip--xs ms-auto" title="Última corrección"><i class="bi bi-pencil-square me-1"></i>@ObtenerUltimaCorreccionResumen()</span>
                        }
                    </div>

                    @if (TieneAusenciaActual() || TieneSenalRevisionOperativa(AsistenciaActual))
                    {
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @if (TieneAusenciaActual())
                            {
                                <div class="asis-banner asis-banner--info"><i class="bi bi-calendar-x me-1"></i>@ObtenerResumenAusenciaActual()</div>
                            }
                            @if (TieneSenalRevisionOperativa(AsistenciaActual))
                            {
                                <div class="asis-banner asis-banner--warn"><i class="bi bi-exclamation-triangle me-1"></i>@ObtenerSenalRevisionOperativa(AsistenciaActual): @(string.IsNullOrWhiteSpace(AsistenciaActual.Observaciones) ? "Jornada no coincide con el turno." : AsistenciaActual.Observaciones)</div>
                            }
                        </div>
                    }

                                                    <div class="asis-marcaciones-quick mt-3">
                                                        <div class="asis-marcaciones-quick__head">
                                                            <div>
                                                                <div class="asis-dayline-card__title">Checadas del día</div>
                                                                <div class="asis-dayline-card__text">Déjalas colapsadas para enfocarte en el resumen y ábrelas cuando necesites corregir marcajes.</div>
                                                            </div>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary asis-btn-xs" @onclick="AlternarMarcacionesDia">
                                                                <i class="bi @(_mostrarMarcacionesDia ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>@(_mostrarMarcacionesDia ? "Ocultar" : "Mostrar")
                                                            </button>
                                                        </div>

                                                        @if (_mostrarMarcacionesDia)
                                                        {
                                                            <AsistenciasCorreccionMarcacionesTab
                                                                MarcacionesDia="marcacionesDia"
                                                                ManualHoraTexto="manualHoraTexto"
                                                                OnManualHoraTextoChanged="@(value => manualHoraTexto = value)"
                                                                ManualClasificacion="manualClasificacion"
                                                                OnManualClasificacionChanged="@(value => manualClasificacion = value)"
                                                                ManualObservacion="manualObservacion"
                                                                OnManualObservacionChanged="@(value => manualObservacion = value)"
                                                                Cargando="cargando"
                                                                OnGuardarMarcacionManual="GuardarMarcacionManualDiaAsync"
                                                                ObtenerHoraMarcacion="ObtenerHoraMarcacion"
                                                                ObtenerAuditoriaMarcacion="ObtenerAuditoriaMarcacionPresentacion"
                                                                MarcacionManualEditandoId="marcacionManualEditandoId"
                                                                MarcacionManualEditandoHoraTexto="marcacionManualEditandoHoraTexto"
                                                                OnMarcacionManualEditandoHoraTextoChanged="@(value => marcacionManualEditandoHoraTexto = value)"
                                                                MarcacionManualEditandoObservacion="marcacionManualEditandoObservacion"
                                                                OnMarcacionManualEditandoObservacionChanged="@(value => marcacionManualEditandoObservacion = value)"
                                                                OnIniciarEdicionMarcacionManual="IniciarEdicionMarcacionManual"
                                                                OnGuardarEdicionMarcacionManual="GuardarEdicionMarcacionManualAsync"
                                                                OnCancelarEdicionMarcacionManual="@(() => CancelarEdicionMarcacionManual())"
                                                                OnAlternarAnulacionMarcacion="AlternarAnulacionMarcacionAsync"
                                                                OnCambiarClasificacion="CambiarClasificacionMarcacionDesdeUiAsync" />
                                                        }
                                                    </div>
                </div>

                @if (asesorCorreccionActual != null)
                {
                    <div class="asis-wizard-banner px-3 py-2 border-bottom">
                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                            <div>
                                <div class="asis-wizard-banner__eyebrow">Qué debes hacer ahora</div>
                                <div class="asis-wizard-banner__title">@asesorCorreccionActual.Titulo</div>
                                <div class="asis-wizard-banner__text">@asesorCorreccionActual.Descripcion</div>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-primary btn-sm" @onclick="IrATabSugerida" style="width: auto;">
                                    <i class="bi bi-arrow-right-circle me-1"></i>@asesorCorreccionActual.AccionPrincipalTexto
                                </button>
                                @if (EsEscenarioSalidaTempranaCompensaDescanso())
                                {
                                    <button class="btn btn-outline-info btn-sm" @onclick="ConfirmarSalidaTempranaCompensaDescansoAsync" disabled="@TieneConfirmacionSalidaTempranaCompensaDescanso()">
                                        <i class="bi bi-check2-circle me-1"></i>@(TieneConfirmacionSalidaTempranaCompensaDescanso() ? "Regla confirmada" : "Confirmar regla")
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="asis-timeline asis-timeline--compact mt-2 mb-2">
                            @foreach (var segmento in ObtenerSegmentosBaseTimeline())
                            {
                                <div class="asis-timeline__segment @segmento.CssClass" style="width:@($"{segmento.WidthPercent}%")" title="@($"{segmento.Titulo}: {segmento.TextoCorto}")"></div>
                            }
                        </div>
                        <div class="asis-timeline-legend asis-timeline-legend--compact">
                            @foreach (var segmento in ObtenerSegmentosBaseTimeline())
                            {
                                <span class="asis-timeline-legend__item">
                                    <span class="asis-timeline-legend__dot @segmento.CssClass.Replace("asis-timeline__segment", "asis-timeline-legend__dot")"></span>
                                    <span>@segmento.Titulo: @segmento.TextoCorto</span>
                                </span>
                            }
                            @foreach (var segmento in ObtenerSegmentosAjusteTimeline())
                            {
                                <span class="asis-timeline-legend__item">
                                    <span class="asis-timeline-legend__dot @segmento.CssClass.Replace("asis-timeline__segment", "asis-timeline-legend__dot")"></span>
                                    <span>@segmento.Titulo: @segmento.TextoCorto</span>
                                </span>
                            }
                        </div>
                    </div>
                }

                <div class="modal-body p-0">
                    <div class="p-3">
                        @if (!string.IsNullOrWhiteSpace(error))
                        {
                            <div class="alert alert-danger py-2 mb-2 small"><i class="bi bi-x-circle me-1"></i>@error</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(ok))
                        {
                            <div class="alert alert-success py-2 mb-2 small"><i class="bi bi-check-circle me-1"></i>@ok</div>
                        }

                        <div class="asis-layout asis-layout--compact">
                            <div class="asis-layout__main">
                                <div class="asis-wizard-panel">
                                    <div class="asis-wizard-panel__head">
                                        <div>
                                            <div class="asis-wizard-panel__title">Corrección del día</div>
                                            <div class="asis-wizard-panel__text">Timeline central con acciones rápidas de tiempo extra, permiso y turno.</div>
                                        </div>
                                        <span class="badge @ObtenerClaseEstadoPermisoSeccion()">@ObtenerEstadoCorreccionActual()</span>
                                    </div>

                                    <div class="asis-wizard-panel__body">
                                            <div class="asis-summary-layout mb-3">
                                                <div class="asis-summary-layout__main">
                                                    <div class="asis-summary-top asis-summary-top--compact mb-2">
                                                        <div class="asis-summary-top__hero">
                                                            <div class="asis-summary-top__eyebrow">Tiempo visible del día</div>
                                                            <div class="asis-summary-top__value">@FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</div>
                                                            <div class="asis-summary-top__formula">@ObtenerResumenVisibleExplicado()</div>
                                                            <div class="asis-summary-top__formula">@ObtenerResumenCompensacionPermiso()</div>
                                                            <div class="asis-summary-top__formula">@ObtenerResumenDestinoTiempoActual()</div>
                                                            <div class="asis-summary-top__formula">@ObtenerResumenSaldoBancoHoras()</div>
                                                            <div class="d-flex flex-wrap gap-1 mt-2">
                                                                @if (AsistenciaActual.MinutosExtraAutorizadosPago > 0)
                                                                {
                                                                    <span class="asis-chip asis-chip--success asis-chip--xs"><i class="bi bi-cash-stack me-1"></i>Pago @FormatearMinutos(AsistenciaActual.MinutosExtraAutorizadosPago)</span>
                                                                }
                                                                @if (AsistenciaActual.MinutosExtraAutorizadosBanco > 0)
                                                                {
                                                                    <span class="asis-chip asis-chip--info asis-chip--xs"><i class="bi bi-bank me-1"></i>Banco @FormatearMinutos(AsistenciaActual.MinutosExtraAutorizadosBanco)</span>
                                                                }
                                                                @if (ObtenerMinutosCompensadosAprobadosActual() > 0)
                                                                {
                                                                    <span class="asis-chip asis-chip--resolved asis-chip--xs"><i class="bi bi-arrow-left-right me-1"></i>Compensación @FormatearMinutos(ObtenerMinutosCompensadosAprobadosActual())</span>
                                                                }
                                                                <span class="asis-chip asis-chip--muted asis-chip--xs"><i class="bi bi-hourglass-split me-1"></i>Saldo banco @FormatearMinutos(Math.Max(0, saldoBancoHorasSeleccionado))</span>
                                                            </div>
                                                            <div class="asis-quick-actions mt-2">
                                                                @if (PuedeAprobarTiempoExtra && PuedeMostrarResolucionTiempo())
                                                                {
                                                                    <button type="button" class="btn btn-sm btn-outline-warning" @onclick="AlternarAccionesRapidasTiempo">
                                                                        <i class="bi bi-lightning-charge me-1"></i>Tiempo extra
                                                                    </button>
                                                                }
                                                                <button type="button" class="btn btn-sm btn-outline-info" @onclick="AlternarAccionesRapidasPermiso">
                                                                    <i class="bi bi-shield-check me-1"></i>Permiso
                                                                </button>
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AlternarAccionesRapidasTurno">
                                                                    <i class="bi bi-arrow-left-right me-1"></i>Turno
                                                                </button>
                                                            </div>
                                                        </div>
                                                        <div class="asis-summary-top__meta @ObtenerClaseEstadoCorreccionActual()">
                                                            <div class="asis-summary-top__meta-label">Qué sigue</div>
                                                            <div class="asis-summary-top__meta-title">@ObtenerSiguientePasoCorreccionActual()</div>
                                                            <div class="asis-summary-top__meta-text">@ObtenerDecisionRapidaWizard()</div>
                                                        </div>
                                                    </div>

                                                    @if (_mostrarAccionesRapidasTiempo && PuedeAprobarTiempoExtra && PuedeMostrarResolucionTiempo())
                                                    {
                                                        <div class="asis-quick-card asis-quick-card--compact mb-2">
                                                            <div class="asis-quick-card__head">
                                                                <strong>Tiempo extra / banco</strong>
                                                                <button type="button" class="btn-close" @onclick="AlternarAccionesRapidasTiempo"></button>
                                                            </div>
                                                            <div class="asis-quick-card__body">
                                                                <div class="asis-quick-grid asis-quick-grid--compact mb-2">
                                                                    <div><span>Detectada</span><strong>@FormatearMinutos(AsistenciaActual.MinutosExtra)</strong></div>
                                                                    <div><span>Aprobable</span><strong>@FormatearMinutos(ObtenerMinutosResolubles(AsistenciaActual))</strong></div>
                                                                    <div><span>Aprobada</span><strong>@FormatearMinutos(ObtenerMinutosExtraAprobados(AsistenciaActual))</strong></div>
                                                                </div>
                                                                <div class="asis-quick-hint mb-2">@ObtenerResumenAprobacionBaseTiempo()</div>
                                                                <div class="asis-quick-hint mb-1">@ObtenerResumenDestinoTiempoActual()</div>
                                                                <div class="asis-quick-hint mb-2">@ObtenerResumenSaldoBancoHoras()</div>
                                                                <div class="row g-2 align-items-end">
                                                                    <div class="col-md-4">
                                                                        <label class="asis-field-label">Resolución</label>
                                                                        <InputSelect class="form-select form-select-sm" @bind-Value="tipoResolucionTiempoExtra">
                                                                            @foreach (var opcion in asesorCorreccionActual?.ResolucionesDisponibles ?? [])
                                                                            {
                                                                                <option value="@opcion.Value">@opcion.Label</option>
                                                                            }
                                                                        </InputSelect>
                                                                    </div>
                                                                    <div class="col-md-3">
                                                                        <label class="asis-field-label">Pago base</label>
                                                                        <InputText class="form-control form-control-sm" Value="@minutosExtraPagoTexto" ValueChanged="@((string value) => { minutosExtraPagoTexto = value; minutosExtraPagoCaptura = ParsearMinutosCaptura(value); })" ValueExpression="@(() => minutosExtraPagoTexto)" />
                                                                    </div>
                                                                    <div class="col-md-3">
                                                                        <label class="asis-field-label">Banco base</label>
                                                                        <InputText class="form-control form-control-sm" Value="@minutosExtraBancoTexto" ValueChanged="@((string value) => { minutosExtraBancoTexto = value; minutosExtraBancoCaptura = ParsearMinutosCaptura(value); })" ValueExpression="@(() => minutosExtraBancoTexto)" />
                                                                    </div>
                                                                    <div class="col-md-2 d-grid">
                                                                        <button type="button" class="btn btn-sm btn-warning" @onclick="AplicarResolucionTiempoAsync" disabled="@(minutosExtraPagoCaptura + minutosExtraBancoCaptura > ObtenerMaximoMinutosBaseDisponibles())">Aplicar</button>
                                                                    </div>
                                                                </div>
                                                                <div class="row g-2 align-items-end mt-1">
                                                                    <div class="col-md-3">
                                                                        <div class="form-check mt-1">
                                                                            <InputCheckbox class="form-check-input" @bind-Value="usarFactorTiempoExtraOverride" id="chkFactorOverride" />
                                                                            <label class="form-check-label" for="chkFactorOverride">Override factor</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-3">
                                                                        <label class="asis-field-label">Factor</label>
                                                                        <InputNumber class="form-control form-control-sm" @bind-Value="factorTiempoExtraOverrideCaptura" step="0.1" min="0.1" disabled="@(!usarFactorTiempoExtraOverride)" />
                                                                    </div>
                                                                    <div class="col-md-6">
                                                                        <div class="asis-quick-hint mt-1">@ObtenerResumenFactorTiempoExtra()</div>
                                                                    </div>
                                                                </div>
                                                                <div class="asis-quick-hint mt-2">Captura horas base en formato <strong>HH:mm</strong>. El factor de pago se usa después para nómina, no para inflar el tiempo visible del día.</div>
                                                            </div>
                                                        </div>
                                                    }

                                                    @if (_mostrarAccionesRapidasPermiso)
                                                    {
                                                        <div class="asis-quick-card asis-quick-card--compact mb-2">
                                                            <div class="asis-quick-card__head">
                                                                <strong>Permiso rápido</strong>
                                                                <button type="button" class="btn-close" @onclick="AlternarAccionesRapidasPermiso"></button>
                                                            </div>
                                                            <div class="asis-quick-card__body">
                                                                <div class="row g-2 align-items-end">
                                                                    <div class="col-md-3">
                                                                        <label class="asis-field-label">Horas</label>
                                                                        <InputNumber class="form-control form-control-sm" @bind-Value="horasPermisoDiaCaptura" min="0" step="0.25" />
                                                                    </div>
                                                                    <div class="col-md-2">
                                                                        <div class="form-check mt-4">
                                                                            <InputCheckbox class="form-check-input" @bind-Value="permisoDiaConGoceCaptura" id="chkQuickGoce" />
                                                                            <label class="form-check-label" for="chkQuickGoce">Con goce</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-md-5">
                                                                        <label class="asis-field-label">Motivo</label>
                                                                        <InputText class="form-control form-control-sm" @bind-Value="permisoDiaMotivo" />
                                                                    </div>
                                                                    <div class="col-md-2 d-grid">
                                                                        <button type="button" class="btn btn-sm btn-info" @onclick="GuardarPermisoDiaAsync">Aplicar</button>
                                                                    </div>
                                                                    @if (permisoDiaSeleccionado != null)
                                                                    {
                                                                        <div class="col-md-12 d-flex justify-content-end mt-1">
                                                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="QuitarPermisoDiaAsync">Quitar permiso</button>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }

                                                    <div class="asis-quick-card asis-quick-card--compact mb-2">
                                                        <div class="asis-quick-card__head">
                                                            <strong>Perdón manual de minutos</strong>
                                                        </div>
                                                        <div class="asis-quick-card__body">
                                                            <div class="row g-2 align-items-end">
                                                                <div class="col-md-4">
                                                                    <label class="asis-field-label">Minutos perdonados</label>
                                                                    <InputNumber class="form-control form-control-sm" @bind-Value="minutosPerdonManualCaptura" min="0" />
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <div class="asis-quick-hint">Úsalo cuando quieras perdonar minutos pequeños del día, por ejemplo 7:58 contra 8:00.</div>
                                                                </div>
                                                                <div class="col-md-2 d-grid">
                                                                    <button type="button" class="btn btn-sm btn-outline-success" @onclick="GuardarPerdonManualAsync">Aplicar</button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @if (_mostrarAccionesRapidasTurno)
                                                    {
                                                        <div class="asis-quick-card asis-quick-card--compact mb-2">
                                                            <div class="asis-quick-card__head">
                                                                <strong>Cambio rápido de turno</strong>
                                                                <button type="button" class="btn-close" @onclick="AlternarAccionesRapidasTurno"></button>
                                                            </div>
                                                            <div class="asis-quick-card__body">
                                                                <div class="row g-2 align-items-end">
                                                                    <div class="col-md-7">
                                                                        <label class="asis-field-label">Turno</label>
                                                                        <InputSelect class="form-select form-select-sm" @bind-Value="turnoDiaSeleccionadoIdTexto">
                                                                            <option value="">(sin turno)</option>
                                                                            @foreach (var turno in Turnos)
                                                                            {
                                                                                <option value="@turno.Id.ToString()">@turno.Nombre</option>
                                                                            }
                                                                        </InputSelect>
                                                                    </div>
                                                                    <div class="col-md-3">
                                                                        <label class="asis-field-label">Nota</label>
                                                                        <InputText class="form-control form-control-sm" @bind-Value="turnoDiaObservaciones" />
                                                                    </div>
                                                                    <div class="col-md-2 d-grid">
                                                                        <button type="button" class="btn btn-sm btn-secondary" @onclick="GuardarTurnoDiaAsync">Aplicar</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }

                                                    @if (ObtenerTimelineSegmentosDia().Count > 0)
                                                    {
                                                    <div class="asis-dayline-card asis-dayline-card--compact">
                                                            <div class="asis-dayline-card__head">
                                                                <div>
                                                                    <div class="asis-dayline-card__title">Timeline del día</div>
                                                                    <div class="asis-dayline-card__text">Cada tramo resume cómo se leyó el día desde las marcaciones cargadas.</div>
                                                                </div>
                                                                <div class="asis-dayline-card__meta">Bloque principal @FormatearMinutos(ObtenerDuracionBloquePrincipal())</div>
                                                            </div>
                                                            <div class="asis-dayline-list mt-2">
                                                                @{ var indiceVisualSegmento = 0; }
                                                                @foreach (var segmento in ObtenerTimelineSegmentosDia())
                                                                {
                                                                    if (!segmento.EsReferenciaTurno)
                                                                    {
                                                                        indiceVisualSegmento++;
                                                                    }
                                                                    <div class="asis-dayline-list__item @(segmento.EsReferenciaTurno ? "asis-dayline-list__item--turno" : string.Empty)">
                                                                        <div class="asis-dayline-list__meta">
                                                                            <div class="asis-dayline-list__title">@ObtenerTituloVisualSegmento(segmento, indiceVisualSegmento)</div>
                                                                            <div class="asis-dayline-list__range">@segmento.Rango · @FormatearMinutos(segmento.Minutos)</div>
                                                                        </div>
                                                                        <div class="asis-dayline-bar">
                                                                            <div class="asis-dayline-bar__fill @segmento.CssClass" style="width:@($"{segmento.WidthPercent}%")"></div>
                                                                        </div>
                                                                        @if (MostrarDetalleLargoSegmento(segmento))
                                                                        {
                                                                            <div class="asis-dayline-list__detail">@segmento.Detalle</div>
                                                                        }
                                                                        @if (segmento.Accion == "descanso")
                                                                        {
                                                                            <div class="asis-dayline-list__detail asis-dayline-list__detail--metrics">
                                                                                @if (segmento.NumeroDescanso.HasValue)
                                                                                {
                                                                                    <span>D@(segmento.NumeroDescanso.Value) · </span>
                                                                                }
                                                                                else if (segmento.Titulo == "Pausa sugerida")
                                                                                {
                                                                                    <span>Pausa base · </span>
                                                                                }
                                                                                Detectado: @FormatearMinutos(segmento.Minutos)
                                                                                @if (segmento.MinutosProgramados.HasValue)
                                                                                {
                                                                                    <span> · Programado: @FormatearMinutos(segmento.MinutosProgramados.Value)</span>
                                                                                }
                                                                                @if (segmento.MinutosAplicados.HasValue)
                                                                                {
                                                                                    <span> · Aplicado: @FormatearMinutos(segmento.MinutosAplicados.Value)</span>
                                                                                    @if (!string.IsNullOrWhiteSpace(segmento.OrigenAplicado))
                                                                                    {
                                                                                        <span> (@segmento.OrigenAplicado)</span>
                                                                                    }
                                                                                }
                                                                            </div>
                                                                            <div class="asis-dayline-list__detail">@ObtenerFormulaDescanso(segmento)</div>
                                                                        }
                                                                        @if (!segmento.EsReferenciaTurno)
                                                                        {
                                                                            <div class="asis-dayline-list__status @ObtenerClaseEstadoVisualSegmento(segmento)">
                                                                                @ObtenerEstadoVisualSegmento(segmento)
                                                                            </div>
                                                                            @if (MostrarSugerenciaAlternada(segmento))
                                                                            {
                                                                                <div class="asis-dayline-list__detail">@ObtenerEtiquetaSugerenciaAlternada(segmento)</div>
                                                                            }
                                                                        }
                                                                        @if (PuedeEditarSegmento(segmento))
                                                                        {
                                                                            <div class="asis-dayline-list__actions mt-2">
                                                                                @if (EsSegmentoEnEdicion(segmento))
                                                                                {
                                                                                    <select class="form-select form-select-sm asis-dayline-select" @bind="segmentoAccionSeleccionada" disabled="@(cargando || EsSegmentoGuardando(segmento))">
                                                                                        @foreach (var opcion in ObtenerOpcionesAccionSegmento(segmento))
                                                                                        {
                                                                                            <option value="@opcion.Clave">@opcion.Etiqueta</option>
                                                                                        }
                                                                                    </select>
                                                                                    @if (segmentoAccionSeleccionada == "descanso")
                                                                                    {
                                                                                        <InputNumber class="form-control form-control-sm asis-dayline-minutes-input" @bind-Value="segmentoMinutosAplicadosCaptura" min="0" />
                                                                                    }
                                                                                    <div class="asis-dayline-list__help">@ObtenerAyudaAccionSegmentoSeleccionada(segmento)</div>
                                                                                    <button type="button" class="btn btn-sm btn-primary" @onclick="() => AplicarEdicionSegmentoAsync(segmento)" disabled="@(cargando || EsSegmentoGuardando(segmento))">@(EsSegmentoGuardando(segmento) ? "Aplicando..." : "Aplicar")</button>
                                                                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicionSegmento" disabled="@(cargando || EsSegmentoGuardando(segmento))">Cancelar</button>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => EditarSegmento(segmento)" disabled="@cargando">Editar segmento</button>
                                                                                }
                                                                            </div>
                                                                            @if (EsSegmentoGuardando(segmento))
                                                                            {
                                                                                <div class="asis-dayline-list__loading">Reprocesando el día y actualizando segmentos...</div>
                                                                            }
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>

                                                <div class="asis-summary-layout__side">
                                                    <div class="asis-summary-side">
                                                        <div class="asis-summary-side__title">Resumen lateral</div>
                                                        @foreach (var item in ObtenerResumenLateralTimeline())
                                                        {
                                                            <div class="asis-summary-side__item @item.CssClass">
                                                                <span>@item.Etiqueta</span>
                                                                <strong>@item.Valor</strong>
                                                            </div>
                                                        }
                                                    </div>

                                                    <div class="asis-calculation-grid mt-3">
                                                        @foreach (var item in ObtenerResumenCalculoDia())
                                                        {
                                                            <div class="asis-calculation-grid__item @(item.CssClass ?? string.Empty)">
                                                                <div class="asis-calculation-grid__label">@item.Etiqueta</div>
                                                                <div class="asis-calculation-grid__value">@item.Valor</div>
                                                                @if (!string.IsNullOrWhiteSpace(item.Nota))
                                                                {
                                                                    <div class="asis-calculation-grid__note">@item.Nota</div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row g-2 mt-1">
                                                <div class="col-12">
                                                    <div class="asis-wizard-side__section h-100">
                                                        <div class="d-flex align-items-center justify-content-between gap-2">
                                                            <div class="asis-wizard-side__title mb-0">Bitácora</div>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary asis-btn-xs" @onclick="AlternarBitacora">
                                                                <i class="bi @(_mostrarBitacora ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>@(_mostrarBitacora ? "Ocultar" : "Mostrar")
                                                            </button>
                                                        </div>
                                                        @if (_mostrarBitacora)
                                                        {
                                                            @if (bitacoraCorreccionDia.Count == 0)
                                                            {
                                                                <div class="asis-wizard-side__note mt-2">Sin movimientos todavía.</div>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var log in bitacoraCorreccionDia.Take(6))
                                                                {
                                                                    <div class="asis-wizard-side__text mt-2"><strong>@FormatearFechaBitacora(log)</strong> · @FormatearMensajeBitacora(log)</div>
                                                                }
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                    </div>
                                </div>
                            </div>

                            <div class="asis-layout__side">
                                <div class="asis-wizard-side">
                                    <div class="asis-wizard-side__section">
                                        <div class="asis-wizard-side__title">Decisión rápida</div>
                                        <div class="asis-wizard-side__text">@ObtenerDecisionRapidaWizard()</div>
                                    </div>

                                    <div class="asis-wizard-side__section">
                                        <div class="asis-wizard-side__title">Cómo se calcula</div>
                                        <div class="asis-formula-row"><span>Base trabajada</span><strong>@FormatearMinutos(ObtenerMinutosTrabajadosBaseVisibles(AsistenciaActual))</strong></div>
                                        <div class="asis-formula-row"><span>+ Compensación aprobada</span><strong>@FormatearMinutos(ObtenerMinutosCompensadosAprobadosActual())</strong></div>
                                        <div class="asis-formula-row"><span>+ Extra aprobada</span><strong>@FormatearMinutos(ObtenerMinutosExtraAprobados(AsistenciaActual))</strong></div>
                                        <div class="asis-formula-row"><span>= Tiempo visible</span><strong>@FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</strong></div>
                                        <div class="asis-wizard-side__note">El permiso no suma como trabajado. El descanso no se suma.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer py-2 border-top">
                    @if (_tieneCambiosPendientes)
                    {
                        <div class="me-auto small text-warning-emphasis fw-semibold">Hay cambios locales sin guardar.</div>
                        <button type="button" class="btn btn-sm btn-success" @onclick="GuardarYCerrarAsync">
                            <i class="bi bi-save me-1"></i>Guardar cambios
                        </button>
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CerrarAsync"><i class="bi bi-x me-1"></i>Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    @if (mostrarAyudaReglas)
    {
        <div class="modal fade show d-block asis-modal-backdrop asis-modal-backdrop--inner" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content shadow">
                    <div class="modal-header">
                        <div>
                            <h5 class="modal-title mb-0">Reglas del modal</h5>
                            <div class="small text-muted">Ayuda para entender cómo se interpreta la jornada y por qué se sugiere cada acción.</div>
                        </div>
                        <button type="button" class="btn-close" @onclick="CerrarAyudaReglas" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-4">
                            <div class="asis-section-title">Reglas generales</div>
                            <ol class="asis-help-list small text-muted">
                                @foreach (var regla in ObtenerReglasAyudaGenerales())
                                {
                                    <li>@regla</li>
                                }
                            </ol>
                        </div>

                        <div>
                            <div class="asis-section-title">Aplicado a este día</div>
                            <div class="alert alert-light border small mb-3">
                                <strong>Diagnóstico actual:</strong> @asesorCorreccionActual?.Titulo
                            </div>
                            <ol class="asis-help-list small text-muted">
                                @foreach (var regla in ObtenerReglasAyudaActual())
                                {
                                    <li>@regla</li>
                                }
                            </ol>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CerrarAyudaReglas">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_mostrarConfirmacionCierre)
    {
        <div class="modal fade show d-block asis-modal-backdrop asis-modal-backdrop--inner" tabindex="-1">
            <div class="modal-dialog modal-md modal-dialog-centered">
                <div class="modal-content shadow">
                    <div class="modal-header">
                        <h5 class="modal-title mb-0">Guardar cambios del día</h5>
                        <button type="button" class="btn-close" @onclick="() => _mostrarConfirmacionCierre = false" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        Hiciste cambios en este empleado. ¿Quieres guardarlos antes de cerrar el modal?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => _mostrarConfirmacionCierre = false">Cancelar</button>
                        <button type="button" class="btn btn-outline-danger" @onclick="CerrarSinGuardarAsync">Descartar</button>
                        <button type="button" class="btn btn-primary" @onclick="GuardarYCerrarAsync">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
