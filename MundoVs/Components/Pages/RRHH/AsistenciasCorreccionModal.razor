@using MundoVs.Core.Entities

@if (Visible && AsistenciaActual != null)
{
    <div class="modal fade show d-block asis-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg asis-modal-shell">

                <div class="asis-modal-header d-flex align-items-center justify-content-between px-3 py-2">
                    <div class="d-flex align-items-center gap-2 min-w-0">
                        <span class="asis-modal-header__icon"><i class="bi bi-calendar-check"></i></span>
                        <div class="min-w-0">
                            <div class="asis-modal-header__name text-truncate">@AsistenciaActual.Empleado.NombreCompleto</div>
                            <div class="asis-modal-header__date">@AsistenciaActual.Fecha.ToString("dddd dd/MM/yyyy", new System.Globalization.CultureInfo("es-MX"))</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-shrink-0">
                        <span class="badge @ObtenerClaseEstatus(AsistenciaActual) asis-status-badge">@ObtenerTextoEstatus(AsistenciaActual.Estatus)</span>
                        <button type="button" class="asis-help-button" @onclick="AbrirAyudaReglas" title="Ver reglas aplicadas">
                            <i class="bi bi-question-lg"></i>
                        </button>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarAsync" aria-label="Cerrar"></button>
                    </div>
                </div>

                <div class="asis-metrics-strip border-bottom px-3 py-2">
                    <div class="d-flex flex-wrap align-items-center gap-1">
                        <span class="asis-metric-block">
                            <span class="asis-metric-block__label">Prog.</span>
                            <span class="asis-metric-block__val">@(AsistenciaActual.HoraEntradaProgramada?.ToString("hh\\:mm") ?? "—") <i class="bi bi-arrow-right"></i> @(AsistenciaActual.HoraSalidaProgramada?.ToString("hh\\:mm") ?? "—")</span>
                        </span>
                        <span class="asis-metric-sep">|</span>
                        <span class="asis-metric-block">
                            <span class="asis-metric-block__label">Real</span>
                            <span class="asis-metric-block__val">@(AsistenciaActual.HoraEntradaReal?.ToString("hh\\:mm") ?? "—") <i class="bi bi-arrow-right"></i> @(AsistenciaActual.HoraSalidaReal?.ToString("hh\\:mm") ?? "—")</span>
                        </span>
                        <span class="asis-metric-sep">|</span>
                        <span class="asis-chip asis-chip--muted asis-chip--xs"><i class="bi bi-person-workspace me-1"></i>@(AsistenciaActual.TurnoBase?.Nombre ?? "Sin turno")</span>
                        <span class="asis-chip asis-chip--info asis-chip--xs" title="Visible = base trabajada + compensación aprobada del mismo día + extra aprobada"><i class="bi bi-eye me-1"></i>Visible @FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</span>
                        <span class="asis-chip asis-chip--muted asis-chip--xs" title="Base trabajada sin extra no aprobada"><i class="bi bi-stopwatch me-1"></i>Base @FormatearMinutos(ObtenerMinutosTrabajadosBaseVisibles(AsistenciaActual))</span>
                        @if (AsistenciaActual.MinutosRetardo > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaIncidencia(AsistenciaActual.MinutosRetardo) asis-chip--xs"><i class="bi bi-alarm me-1"></i>Ret. @FormatearMinutosCortos(AsistenciaActual.MinutosRetardo)</span>
                        }
                        @if (AsistenciaActual.MinutosSalidaAnticipada > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaIncidencia(AsistenciaActual.MinutosSalidaAnticipada) asis-chip--xs"><i class="bi bi-box-arrow-left me-1"></i>S.Ant. @FormatearMinutosCortos(AsistenciaActual.MinutosSalidaAnticipada)</span>
                        }
                        @if (AsistenciaActual.MinutosExtra > 0)
                        {
                            <span class="asis-chip @ObtenerClaseMetricaExtra(AsistenciaActual.MinutosExtra) asis-chip--xs" title="Extra detectada (no aprobada)"><i class="bi bi-plus-circle me-1"></i>Extra @FormatearMinutosCortos(AsistenciaActual.MinutosExtra)</span>
                        }
                        @if (ObtenerMinutosExtraAprobados(AsistenciaActual) > 0)
                        {
                            <span class="asis-chip asis-chip--success asis-chip--xs" title="Solo la extra aprobada se suma al visible"><i class="bi bi-check2-circle me-1"></i>Extra aprobada @FormatearMinutosCortos(ObtenerMinutosExtraAprobados(AsistenciaActual))</span>
                        }
                        @if (ObtenerMinutosCompensadosAprobadosActual() > 0)
                        {
                            <span class="asis-chip asis-chip--resolved asis-chip--xs" title="Compensación aprobada del mismo día"><i class="bi bi-arrow-left-right me-1"></i>Comp. día @FormatearMinutosCortos(ObtenerMinutosCompensadosAprobadosActual())</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(ObtenerUltimaCorreccionResumen()))
                        {
                            <span class="asis-chip asis-chip--muted asis-chip--xs ms-auto" title="Última corrección"><i class="bi bi-pencil-square me-1"></i>@ObtenerUltimaCorreccionResumen()</span>
                        }
                    </div>

                    @if (TieneAusenciaActual() || TieneSenalRevisionOperativa(AsistenciaActual))
                    {
                        <div class="d-flex flex-wrap gap-1 mt-1">
                            @if (TieneAusenciaActual())
                            {
                                <div class="asis-banner asis-banner--info"><i class="bi bi-calendar-x me-1"></i>@ObtenerResumenAusenciaActual()</div>
                            }
                            @if (TieneSenalRevisionOperativa(AsistenciaActual))
                            {
                                <div class="asis-banner asis-banner--warn"><i class="bi bi-exclamation-triangle me-1"></i>@ObtenerSenalRevisionOperativa(AsistenciaActual): @(string.IsNullOrWhiteSpace(AsistenciaActual.Observaciones) ? "Jornada no coincide con el turno." : AsistenciaActual.Observaciones)</div>
                            }
                        </div>
                    }
                </div>

                @if (asesorCorreccionActual != null)
                {
                    <div class="asis-wizard-banner px-3 py-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                            <div>
                                <div class="asis-wizard-banner__eyebrow">Qué debes hacer ahora</div>
                                <div class="asis-wizard-banner__title">@asesorCorreccionActual.Titulo</div>
                                <div class="asis-wizard-banner__text">@asesorCorreccionActual.Descripcion</div>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-primary btn-sm" @onclick="IrATabSugerida" style="width: auto;">
                                    <i class="bi bi-arrow-right-circle me-1"></i>@asesorCorreccionActual.AccionPrincipalTexto
                                </button>
                                @if (EsEscenarioSalidaTempranaCompensaDescanso())
                                {
                                    <button class="btn btn-outline-info btn-sm" @onclick="ConfirmarSalidaTempranaCompensaDescansoAsync" disabled="@TieneConfirmacionSalidaTempranaCompensaDescanso()">
                                        <i class="bi bi-check2-circle me-1"></i>@(TieneConfirmacionSalidaTempranaCompensaDescanso() ? "Regla confirmada" : "Confirmar regla")
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="asis-timeline asis-timeline--compact mt-3 mb-2">
                            @foreach (var segmento in ObtenerSegmentosBaseTimeline())
                            {
                                <div class="asis-timeline__segment @segmento.CssClass" style="width:@($"{segmento.WidthPercent}%")" title="@($"{segmento.Titulo}: {segmento.TextoCorto}")"></div>
                            }
                        </div>
                        <div class="asis-timeline-legend">
                            @foreach (var segmento in ObtenerSegmentosBaseTimeline())
                            {
                                <span class="asis-timeline-legend__item">
                                    <span class="asis-timeline-legend__dot @segmento.CssClass.Replace("asis-timeline__segment", "asis-timeline-legend__dot")"></span>
                                    <span>@segmento.Titulo: @segmento.TextoCorto</span>
                                </span>
                            }
                            @foreach (var segmento in ObtenerSegmentosAjusteTimeline())
                            {
                                <span class="asis-timeline-legend__item">
                                    <span class="asis-timeline-legend__dot @segmento.CssClass.Replace("asis-timeline__segment", "asis-timeline-legend__dot")"></span>
                                    <span>@segmento.Titulo: @segmento.TextoCorto</span>
                                </span>
                            }
                        </div>
                    </div>
                }

                <div class="modal-body p-0">
                    <div class="asis-main-tabs px-3 py-2 border-bottom">
                        <button type="button" class="@ObtenerClaseTabPrincipal(TabModalResumen)" @onclick="() => SeleccionarTabPrincipal(TabModalResumen)">
                            <i class="bi bi-bar-chart-line me-1"></i>Resumen del día
                        </button>
                        <button type="button" class="@ObtenerClaseTabPrincipal(TabModalAjustes)" @onclick="() => SeleccionarTabPrincipal(TabModalAjustes)">
                            <i class="bi bi-sliders me-1"></i>Ajustes
                        </button>
                    </div>

                    <div class="p-3">
                        @if (!string.IsNullOrWhiteSpace(error))
                        {
                            <div class="alert alert-danger py-2 mb-2 small"><i class="bi bi-x-circle me-1"></i>@error</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(ok))
                        {
                            <div class="alert alert-success py-2 mb-2 small"><i class="bi bi-check-circle me-1"></i>@ok</div>
                        }

                        <div class="asis-layout">
                            <div class="asis-layout__main">
                                <div class="asis-wizard-panel">
                                    <div class="asis-wizard-panel__head">
                                        <div>
                                            <div class="asis-wizard-panel__title">@ObtenerTituloVistaActual()</div>
                                            <div class="asis-wizard-panel__text">@ObtenerDescripcionVistaActual()</div>
                                        </div>
                                        <span class="badge @ObtenerClaseEstadoPermisoSeccion()">@ObtenerEstadoCorreccionActual()</span>
                                    </div>

                                    <div class="asis-wizard-panel__body">
                                        @if (_tabModalActiva == TabModalResumen)
                                        {
                                            <div class="asis-summary-top mb-3">
                                                <div class="asis-summary-top__hero">
                                                    <div class="asis-summary-top__eyebrow">Tiempo visible del día</div>
                                                    <div class="asis-summary-top__value">@FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</div>
                                                    <div class="asis-summary-top__formula">@ObtenerResumenVisibleExplicado()</div>
                                                </div>
                                                <div class="asis-summary-top__meta @ObtenerClaseEstadoCorreccionActual()">
                                                    <div class="asis-summary-top__meta-label">Qué sigue</div>
                                                    <div class="asis-summary-top__meta-title">@ObtenerSiguientePasoCorreccionActual()</div>
                                                    <div class="asis-summary-top__meta-text">@ObtenerDecisionRapidaWizard()</div>
                                                </div>
                                            </div>

                                            <div class="asis-summary-bars">
                                                @foreach (var barra in ObtenerBarrasResumen())
                                                {
                                                    <div class="asis-time-bar-card">
                                                        <div class="asis-time-bar-card__head">
                                                            <div class="asis-time-bar-card__title-wrap">
                                                                <span class="asis-time-bar-card__icon"><i class="@barra.Icono"></i></span>
                                                                <div>
                                                                    <div class="asis-time-bar-card__title">@barra.Titulo</div>
                                                                    <div class="asis-time-bar-card__state">@barra.Estado</div>
                                                                </div>
                                                            </div>
                                                            <div class="asis-time-bar-card__value-wrap">
                                                                <div class="asis-time-bar-card__value">@FormatearMinutos(barra.Minutos)</div>
                                                                @if (!string.IsNullOrWhiteSpace(barra.Aprobacion))
                                                                {
                                                                    <div class="asis-time-bar-card__approval">@barra.Aprobacion</div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="asis-time-bar">
                                                            <div class="asis-time-bar__fill @barra.CssClass" style="width:@($"{ObtenerPorcentajeBarraResumen(barra.Minutos)}%")"></div>
                                                        </div>
                                                        <div class="asis-time-bar-card__actions">
                                                            @if (barra.Clave == "extra" && PuedeAprobarTiempoExtra && PuedeMostrarResolucionTiempo())
                                                            {
                                                                <div class="asis-quick-editor">
                                                                    <select class="form-select form-select-sm asis-inline-select" value="@tipoResolucionTiempoExtra" @onchange="OnResumenTipoResolucionChanged">
                                                                        @foreach (var opcion in asesorCorreccionActual?.ResolucionesDisponibles ?? [])
                                                                        {
                                                                            <option value="@opcion.Value">@opcion.Label</option>
                                                                        }
                                                                    </select>

                                                                    @if (tipoResolucionTiempoExtra == "PagarTodo")
                                                                    {
                                                                        <div class="asis-quick-editor__field">
                                                                            <label class="asis-field-label">@ObtenerTituloCapturaTiempoResumen()</label>
                                                                            <input type="number" class="form-control form-control-sm" min="0" max="@ObtenerMaximoMinutosResolublesResumen()" @bind="minutosExtraPagoCaptura" />
                                                                        </div>
                                                                    }
                                                                    else if (tipoResolucionTiempoExtra == "BancoTodo")
                                                                    {
                                                                        <div class="asis-quick-editor__field">
                                                                            <label class="asis-field-label">@ObtenerTituloCapturaTiempoResumen()</label>
                                                                            <input type="number" class="form-control form-control-sm" min="0" max="@ObtenerMaximoMinutosResolublesResumen()" @bind="minutosExtraBancoCaptura" />
                                                                        </div>
                                                                    }
                                                                    else if (tipoResolucionTiempoExtra == "MitadMitad")
                                                                    {
                                                                        <div class="asis-quick-editor__grid">
                                                                            <div class="asis-quick-editor__field">
                                                                                <label class="asis-field-label">Minutos a pagar</label>
                                                                                <input type="number" class="form-control form-control-sm" min="0" max="@ObtenerMaximoMinutosResolublesResumen()" @bind="minutosExtraPagoCaptura" />
                                                                            </div>
                                                                            <div class="asis-quick-editor__field">
                                                                                <label class="asis-field-label">Minutos a banco</label>
                                                                                <input type="number" class="form-control form-control-sm" min="0" max="@ObtenerMaximoMinutosResolublesResumen()" @bind="minutosExtraBancoCaptura" />
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    else if (tipoResolucionTiempoExtra == "CubrirFaltanteConBanco")
                                                                    {
                                                                        <div class="asis-quick-editor__field">
                                                                            <label class="asis-field-label">@ObtenerTituloCapturaTiempoResumen()</label>
                                                                            <input type="number" class="form-control form-control-sm" min="0" max="@ObtenerMaximoMinutosCubrirBancoResumen()" @bind="minutosCubrirBancoCaptura" />
                                                                        </div>
                                                                    }

                                                                    <div class="asis-quick-editor__hint">@ObtenerAyudaCapturaTiempoResumen()</div>
                                                                    <div class="asis-quick-editor__actions">
                                                                        <button type="button" class="btn btn-sm btn-primary" @onclick="AplicarResolucionTiempoAsync">Aplicar</button>
                                                                        @if (TieneResolucionTiempoActual())
                                                                        {
                                                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="QuitarResolucionTiempoAsync">Quitar</button>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                            else if (barra.Clave == "permiso")
                                                            {
                                                                <div class="asis-quick-editor asis-quick-editor--permission">
                                                                    <div class="asis-quick-editor__grid">
                                                                        <div class="asis-quick-editor__field">
                                                                            <label class="asis-field-label">Horas permiso</label>
                                                                            <input type="number" class="form-control form-control-sm" min="0" step="0.25" @bind="horasPermisoDiaCaptura" />
                                                                        </div>
                                                                        <div class="asis-quick-editor__field">
                                                                            <label class="asis-field-label">Pago</label>
                                                                            <select class="form-select form-select-sm" @bind="permisoDiaConGoceCaptura">
                                                                                <option value="true">Con goce</option>
                                                                                <option value="false">Sin goce</option>
                                                                            </select>
                                                                        </div>
                                                                    </div>
                                                                    <div class="asis-quick-editor__hint">@ObtenerResumenPermisoRapido()</div>
                                                                    <div class="asis-quick-editor__actions">
                                                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="PrepararPermisoSugeridoResumen">Usar sugerido</button>
                                                                        <button type="button" class="btn btn-sm btn-primary" @onclick="GuardarPermisoDiaAsync" disabled="@(cargando || guardandoPermisoDia)">@(permisoDiaSeleccionado == null ? "Guardar permiso" : "Actualizar permiso")</button>
                                                                        @if (permisoDiaSeleccionado != null)
                                                                        {
                                                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="QuitarPermisoDiaAsync" disabled="@guardandoPermisoDia">Quitar</button>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                            else if (barra.Clave == "compensacion")
                                                            {
                                                                <button type="button" class="btn btn-sm btn-outline-info" @onclick="AprobarCompensacionSugeridaResumenAsync" disabled="@(!PuedeAprobarCompensacionPermiso())">@(TieneCompensacionPermisoAprobada() ? "Actualizar compensación" : "Aprobar compensación")</button>
                                                            }
                                                            else if (barra.Clave == "faltante")
                                                            {
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AbrirTiempoDesdeResumen">Revisar resolución</button>
                                                            }
                                                            else
                                                            {
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AbrirMarcacionesDesdeResumen">Ver marcaciones</button>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            <div class="row g-3 mt-1">
                                                <div class="col-lg-6">
                                                    <div class="asis-wizard-side__section h-100">
                                                        <div class="asis-wizard-side__title">Resumen rápido</div>
                                                        <div class="asis-wizard-check"><span>Marcaciones</span><strong>@ObtenerResumenWizardMarcaciones()</strong></div>
                                                        <div class="asis-wizard-check"><span>Permiso</span><strong>@ObtenerResumenWizardPermiso()</strong></div>
                                                        <div class="asis-wizard-check"><span>Compensación</span><strong>@ObtenerResumenWizardCompensacion()</strong></div>
                                                        <div class="asis-wizard-check"><span>Resolución</span><strong>@ObtenerResumenResolucion(AsistenciaActual)</strong></div>
                                                    </div>
                                                </div>
                                                <div class="col-lg-6">
                                                    <div class="asis-wizard-side__section h-100">
                                                        <div class="asis-wizard-side__title">Turno y observaciones</div>
                                                        <div class="asis-wizard-side__text"><strong>Turno:</strong> @ObtenerResumenTurnoActual(AsistenciaActual)</div>
                                                        <div class="asis-wizard-side__text mt-2"><strong>Horario:</strong> @ObtenerHorarioTurnoSeleccionadoDia()</div>
                                                        <div class="asis-wizard-side__text mt-2"><strong>Descansos:</strong> @ObtenerDescansosTurnoSeleccionadoDia()</div>
                                                        <div class="asis-wizard-side__note mt-2">@ObtenerBitacoraCorreccionResumen()</div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="asis-detail-tabs mb-3">
                                                <button type="button" class="@ObtenerClaseSeccionAjuste(TabModalMarcaciones)" @onclick="() => SeleccionarSeccionAjustes(TabModalMarcaciones)">Marcaciones</button>
                                                <button type="button" class="@ObtenerClaseSeccionAjuste(TabModalPermisos)" @onclick="() => SeleccionarSeccionAjustes(TabModalPermisos)">Permiso y compensación</button>
                                                <button type="button" class="@ObtenerClaseSeccionAjuste(TabModalTiempo)" @onclick="() => SeleccionarSeccionAjustes(TabModalTiempo)">Tiempo / banco</button>
                                            </div>

                                            @if (_seccionAjustesActiva == TabModalMarcaciones)
                                            {
                                                <AsistenciasCorreccionMarcacionesTab
                                                    MarcacionesDia="marcacionesDia"
                                                    ManualHoraTexto="manualHoraTexto"
                                                    OnManualHoraTextoChanged="@(value => manualHoraTexto = value)"
                                                    ManualClasificacion="manualClasificacion"
                                                    OnManualClasificacionChanged="@(value => manualClasificacion = value)"
                                                    ManualObservacion="manualObservacion"
                                                    OnManualObservacionChanged="@(value => manualObservacion = value)"
                                                    Cargando="cargando"
                                                    OnGuardarMarcacionManual="GuardarMarcacionManualDiaAsync"
                                                    ObtenerHoraMarcacion="ObtenerHoraMarcacion"
                                                    ObtenerAuditoriaMarcacion="ObtenerAuditoriaMarcacionPresentacion"
                                                    MarcacionManualEditandoId="marcacionManualEditandoId"
                                                    MarcacionManualEditandoHoraTexto="marcacionManualEditandoHoraTexto"
                                                    OnMarcacionManualEditandoHoraTextoChanged="@(value => marcacionManualEditandoHoraTexto = value)"
                                                    MarcacionManualEditandoObservacion="marcacionManualEditandoObservacion"
                                                    OnMarcacionManualEditandoObservacionChanged="@(value => marcacionManualEditandoObservacion = value)"
                                                    OnIniciarEdicionMarcacionManual="IniciarEdicionMarcacionManual"
                                                    OnGuardarEdicionMarcacionManual="GuardarEdicionMarcacionManualAsync"
                                                    OnCancelarEdicionMarcacionManual="@(() => CancelarEdicionMarcacionManual())"
                                                    OnAlternarAnulacionMarcacion="AlternarAnulacionMarcacionAsync"
                                                    OnCambiarClasificacion="CambiarClasificacionMarcacionDesdeUiAsync" />
                                            }

                                            @if (_seccionAjustesActiva == TabModalPermisos)
                                            {
                                                <AsistenciasCorreccionPermisosTab
                                                    HayPermisoRegistrado="@(permisoDiaSeleccionado != null)"
                                                    ClaseEstadoPermisoSeccion="@ObtenerClaseEstadoPermisoSeccion()"
                                                    EstadoPermisoSeccion="@ObtenerEstadoPermisoSeccion()"
                                                    NotaPermiso="@asesorCorreccionActual?.NotaPermiso"
                                                    GuiaRapidaPermiso="@ObtenerGuiaRapidaPermiso()"
                                                    ResumenPermisoDiaCaptura="@ObtenerResumenPermisoDiaCaptura()"
                                                    MostrarResumenOperativo="@(AsistenciaActual != null)"
                                                    ResumenPermisoSugerido="@ObtenerResumenPermisoSugerido()"
                                                    FaltanteNetoTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosPermisoSugeridos(AsistenciaActual)))"
                                                    PermisoCapturadoTexto="@FormatearMinutos(ObtenerMinutosPermisoCapturados())"
                                                    FaltanteRemanenteTexto="@FormatearMinutos(ObtenerMinutosFaltanteRemanenteActual())"
                                                    TrabajoVisibleTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual)))"
                                                    DescansoExcluidoTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosDescansoNoPagadoExcluidosDelPermiso(AsistenciaActual)))"
                                                    DeshabilitarGuardarPermiso="@(cargando || guardandoPermisoDia)"
                                                    OnAplicarPermisoSugerido="AplicarPermisoDiaSugerido"
                                                    HorasPermisoDiaCaptura="horasPermisoDiaCaptura"
                                                    OnHorasPermisoDiaCapturaChanged="@(value => horasPermisoDiaCaptura = value)"
                                                    PermisoDiaConGoceCaptura="permisoDiaConGoceCaptura"
                                                    OnPermisoDiaConGoceCapturaChanged="@(value => permisoDiaConGoceCaptura = value)"
                                                    PermisoDiaMotivo="permisoDiaMotivo"
                                                    OnPermisoDiaMotivoChanged="@(value => permisoDiaMotivo = value)"
                                                    PermisoDiaObservaciones="permisoDiaObservaciones"
                                                    OnPermisoDiaObservacionesChanged="@(value => permisoDiaObservaciones = value)"
                                                    TextoGuardarPermiso="@(guardandoPermisoDia ? "Guardando..." : (permisoDiaSeleccionado == null ? "Registrar permiso" : "Actualizar permiso"))"
                                                    OnGuardarPermisoDia="GuardarPermisoDiaAsync"
                                                    OnQuitarPermisoDia="QuitarPermisoDiaAsync"
                                                    SaldoBancoHorasTexto="@($"{saldoBancoHorasSeleccionado} min.")"
                                                    TieneCompensacionPermisoAprobada="@TieneCompensacionPermisoAprobada()"
                                                    ClaseEstadoCompensacionSeccion="@ObtenerClaseEstadoCompensacionSeccion()"
                                                    EstadoCompensacionSeccion="@ObtenerEstadoCompensacionSeccion()"
                                                    GuiaCompensacionPermiso="@ObtenerGuiaCompensacionPermiso()"
                                                    ResumenCompensacionPermiso="@ObtenerResumenCompensacionPermiso()"
                                                    RecuperableDetectadoTexto="@FormatearMinutos(minutosRecuperablesPermisoAprobables)"
                                                    SugeridoAprobarTexto="@FormatearMinutos(ObtenerMinutosCompensacionPermisoSugeridosAprobacion())"
                                                    AprobadoActualTexto="@FormatearMinutos(minutosCompensadosPermisoAprobados)"
                                                    MinutosCompensacionPermisoCaptura="minutosCompensacionPermisoCaptura"
                                                    OnMinutosCompensacionPermisoCapturaChanged="@(value => minutosCompensacionPermisoCaptura = value)"
                                                    MaximoMinutosCompensacionPermisoEditable="@ObtenerMaximoMinutosCompensacionPermisoEditable()"
                                                    DeshabilitarCompensacion="@(guardandoPermisoDia || !PuedeAprobarCompensacionPermiso())"
                                                    GuardandoPermisoDia="guardandoPermisoDia"
                                                    OnAprobarCompensacionPermiso="AprobarCompensacionPermisoAsync"
                                                    OnQuitarCompensacionPermiso="QuitarCompensacionPermisoAsync"
                                                    Turnos="Turnos"
                                                    TurnoDiaSeleccionadoIdTexto="turnoDiaSeleccionadoIdTexto"
                                                    OnTurnoDiaSeleccionadoIdTextoChanged="@(value => turnoDiaSeleccionadoIdTexto = value)"
                                                    TurnoDiaObservaciones="turnoDiaObservaciones"
                                                    OnTurnoDiaObservacionesChanged="@(value => turnoDiaObservaciones = value)"
                                                    Cargando="cargando"
                                                    OnGuardarTurnoDia="GuardarTurnoDiaAsync"
                                                    HorarioTurnoSeleccionadoDia="@ObtenerHorarioTurnoSeleccionadoDia()"
                                                    DescansosTurnoSeleccionadoDia="@ObtenerDescansosTurnoSeleccionadoDia()" />
                                            }

                                            @if (_seccionAjustesActiva == TabModalTiempo)
                                            {
                                                <AsistenciasCorreccionTiempoTab
                                                    PuedeMostrarResolucion="@(PuedeAprobarTiempoExtra && PuedeMostrarResolucionTiempo())"
                                                    ClaseEstadoTiempoSeccion="@ObtenerClaseEstadoTiempoSeccion()"
                                                    EstadoTiempoSeccion="@ObtenerEstadoTiempoSeccion()"
                                                    NotaTiempo="@asesorCorreccionActual?.NotaTiempo"
                                                    GuiaTiempoResolucion="@ObtenerGuiaTiempoResolucion()"
                                                    ExtraDetectadaTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(AsistenciaActual.MinutosExtra))"
                                                    ExtraResolubleTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosResolubles(AsistenciaActual)))"
                                                    ExtraAprobadaTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosExtraAprobados(AsistenciaActual)))"
                                                    ExplicacionAprobacionTexto="@ObtenerExplicacionTiempoExtraWizard()"
                                                    FaltanteNetoTexto="@(AsistenciaActual == null ? "0:00 h" : FormatearMinutos(ObtenerMinutosFaltanteBanco(AsistenciaActual)))"
                                                    SaldoBancoTexto="@FormatearMinutos(saldoBancoHorasSeleccionado)"
                                                    ResolucionesDisponibles="@(asesorCorreccionActual?.ResolucionesDisponibles ?? [])"
                                                    TipoResolucionTiempoExtra="tipoResolucionTiempoExtra"
                                                    OnTipoResolucionTiempoExtraChanged="CambiarTipoResolucionTiempoExtra"
                                                    OpcionSeleccionada="@(asesorCorreccionActual?.ResolucionesDisponibles.FirstOrDefault(o => o.Value == tipoResolucionTiempoExtra))"
                                                    ResolucionTiempoExtraObservaciones="resolucionTiempoExtraObservaciones"
                                                    OnResolucionTiempoExtraObservacionesChanged="@((string? value) => resolucionTiempoExtraObservaciones = value)"
                                                    MinutosExtraPagoCaptura="minutosExtraPagoCaptura"
                                                    OnMinutosExtraPagoCapturaChanged="@((int value) => minutosExtraPagoCaptura = value)"
                                                    MinutosExtraBancoCaptura="minutosExtraBancoCaptura"
                                                    OnMinutosExtraBancoCapturaChanged="@((int value) => minutosExtraBancoCaptura = value)"
                                                    MinutosCubrirBancoCaptura="minutosCubrirBancoCaptura"
                                                    OnMinutosCubrirBancoCapturaChanged="@((int value) => minutosCubrirBancoCaptura = value)"
                                                    BancoHorasHabilitadoConfigurado="bancoHorasHabilitadoConfigurado"
                                                    NetoTrabajadoTexto="@(AsistenciaActual == null ? "0 min" : $"{ObtenerMinutosTrabajadosBaseVisibles(AsistenciaActual)} min")"
                                                    VisibleTrabajadoTexto="@(AsistenciaActual == null ? "0 min" : $"{ObtenerMinutosTrabajadosVisibles(AsistenciaActual)} min")"
                                                    ResumenResolucionActual="@(AsistenciaActual == null ? string.Empty : ObtenerResumenResolucion(AsistenciaActual))"
                                                    Cargando="cargando"
                                                    OnAplicarResolucionTiempo="AplicarResolucionTiempoAsync"
                                                    OnQuitarResolucionTiempo="QuitarResolucionTiempoAsync"
                                                    PuedeQuitarResolucion="@TieneResolucionTiempoActual()"
                                                    BitacoraCorreccionDia="bitacoraCorreccionDia"
                                                    FormatearMensajeBitacora="FormatearMensajeBitacora"
                                                    FormatearFechaBitacora="FormatearFechaBitacora" />
                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="asis-layout__side">
                                <div class="asis-wizard-side">
                                    <div class="asis-wizard-side__section">
                                        <div class="asis-wizard-side__title">Decisión rápida</div>
                                        <div class="asis-wizard-side__text">@ObtenerDecisionRapidaWizard()</div>
                                    </div>

                                    <div class="asis-wizard-side__section">
                                        <div class="asis-wizard-side__title">Cómo se calcula</div>
                                        <div class="asis-formula-row"><span>Base trabajada</span><strong>@FormatearMinutos(ObtenerMinutosTrabajadosBaseVisibles(AsistenciaActual))</strong></div>
                                        <div class="asis-formula-row"><span>+ Compensación aprobada</span><strong>@FormatearMinutos(ObtenerMinutosCompensadosAprobadosActual())</strong></div>
                                        <div class="asis-formula-row"><span>+ Extra aprobada</span><strong>@FormatearMinutos(ObtenerMinutosExtraAprobados(AsistenciaActual))</strong></div>
                                        <div class="asis-formula-row"><span>= Tiempo visible</span><strong>@FormatearMinutos(ObtenerMinutosTrabajadosVisibles(AsistenciaActual))</strong></div>
                                        <div class="asis-wizard-side__note">El permiso no suma como trabajado. El descanso no se suma.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer py-2 border-top">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SeleccionarTabPrincipal(TabModalResumen)">
                        <i class="bi bi-bar-chart-line me-1"></i>Resumen
                    </button>
                    <button type="button" class="btn btn-sm btn-primary" @onclick="() => SeleccionarTabPrincipal(TabModalAjustes)">
                        <i class="bi bi-sliders me-1"></i>Ajustes
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CerrarAsync"><i class="bi bi-x me-1"></i>Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    @if (mostrarAyudaReglas)
    {
        <div class="modal fade show d-block asis-modal-backdrop asis-modal-backdrop--inner" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content shadow">
                    <div class="modal-header">
                        <div>
                            <h5 class="modal-title mb-0">Reglas del modal</h5>
                            <div class="small text-muted">Ayuda para entender cómo se interpreta la jornada y por qué se sugiere cada acción.</div>
                        </div>
                        <button type="button" class="btn-close" @onclick="CerrarAyudaReglas" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-4">
                            <div class="asis-section-title">Reglas generales</div>
                            <ol class="asis-help-list small text-muted">
                                @foreach (var regla in ObtenerReglasAyudaGenerales())
                                {
                                    <li>@regla</li>
                                }
                            </ol>
                        </div>

                        <div>
                            <div class="asis-section-title">Aplicado a este día</div>
                            <div class="alert alert-light border small mb-3">
                                <strong>Diagnóstico actual:</strong> @asesorCorreccionActual?.Titulo
                            </div>
                            <ol class="asis-help-list small text-muted">
                                @foreach (var regla in ObtenerReglasAyudaActual())
                                {
                                    <li>@regla</li>
                                }
                            </ol>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CerrarAyudaReglas">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
