        public int MinutosDescansoPagado { get; set; }
        public int MinutosDescansoNoPagado { get; set; }
        public int MinutosPlaneadosTrabajados { get; set; }

        public static TurnoDuracionVm operator +(TurnoDuracionVm left, TurnoDuracionVm right)
            => new()
            {
                MinutosJornadaBruta = left.MinutosJornadaBruta + right.MinutosJornadaBruta,
                MinutosDescansoPagado = left.MinutosDescansoPagado + right.MinutosDescansoPagado,
                MinutosDescansoNoPagado = left.MinutosDescansoNoPagado + right.MinutosDescansoNoPagado,
                MinutosPlaneadosTrabajados = left.MinutosPlaneadosTrabajados + right.MinutosPlaneadosTrabajados
            };
    }
