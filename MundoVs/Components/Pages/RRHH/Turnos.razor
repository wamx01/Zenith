    {
        public Guid Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string? Descripcion { get; set; }
        public bool IsActive { get; set; }
        public int EmpleadosAsignados { get; set; }
        public string Resumen { get; set; } = string.Empty;
        public int MinutosSemanales { get; set; }
        public List<TurnoDiaChipVm> DiasChips { get; set; } = [];
    }

    private sealed class TurnoDiaChipVm
    {
        public string Abrev { get; set; } = string.Empty;
        public string Horario { get; set; } = string.Empty;
        public string Tooltip { get; set; } = string.Empty;
        public bool Labora { get; set; }
    }

    private sealed class TurnoEditVm
    {
        public Guid Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string? Descripcion { get; set; }
        public bool IsActive { get; set; } = true;
        public List<TurnoDiaEditVm> Dias { get; set; } = [];
    }

    private sealed class TurnoDiaEditVm
    {
        public DiaSemanaTurno DiaSemana { get; set; }
        public string NombreDia { get; set; } = string.Empty;
        public bool Labora { get; set; }
        public string HoraEntradaTexto { get; set; } = string.Empty;
        public string HoraSalidaTexto { get; set; } = string.Empty;
        public byte CantidadDescansos { get; set; }
        public string Descanso1InicioTexto { get; set; } = string.Empty;
        public string Descanso1FinTexto { get; set; } = string.Empty;
        public bool Descanso1EsPagado { get; set; }
        public string Descanso2InicioTexto { get; set; } = string.Empty;
        public string Descanso2FinTexto { get; set; } = string.Empty;
        public bool Descanso2EsPagado { get; set; }
        public string DiaDestinoDuplicadoTexto { get; set; } = string.Empty;
    }

    private sealed class TurnoDuracionVm
    {
        public int MinutosJornadaBruta { get; set; }
        public int MinutosDescansoPagado { get; set; }
        public int MinutosDescansoNoPagado { get; set; }
        public int MinutosPlaneadosTrabajados { get; set; }

        public static TurnoDuracionVm operator +(TurnoDuracionVm left, TurnoDuracionVm right)
            => new()
            {
                MinutosJornadaBruta = left.MinutosJornadaBruta + right.MinutosJornadaBruta,
                MinutosDescansoPagado = left.MinutosDescansoPagado + right.MinutosDescansoPagado,
                MinutosDescansoNoPagado = left.MinutosDescansoNoPagado + right.MinutosDescansoNoPagado,
                MinutosPlaneadosTrabajados = left.MinutosPlaneadosTrabajados + right.MinutosPlaneadosTrabajados
            };
    }
