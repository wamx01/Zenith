@page "/rrhh/turnos"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Turnos</PageTitle>

<style>
    .turnos-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .turnos-toolbar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.1rem;
        border: 1px solid #e2e8f0;
        border-radius: .9rem;
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        box-shadow: 0 10px 25px rgba(15, 23, 42, .05);
    }

    .turnos-toolbar-copy {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        min-width: 18rem;
    }

    .turnos-eyebrow {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #64748b;
        font-weight: 700;
    }

    .turnos-title {
        font-size: 1.5rem;
        line-height: 1.1;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
    }

    .turnos-subtitle {
        margin: 0;
        color: #64748b;
        font-size: .9rem;
        max-width: 45rem;
    }

    .turnos-toolbar-actions {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
    }

    .turnos-kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
        gap: .75rem;
    }

    .turnos-kpi {
        padding: .75rem .85rem;
        border: 1px solid #e2e8f0;
        border-radius: .8rem;
        background: #fff;
    }

    .turnos-kpi-label {
        display: block;
        font-size: .7rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 700;
        margin-bottom: .2rem;
    }

    .turnos-kpi-value {
        display: block;
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.1;
    }

    .turnos-kpi-note {
        display: block;
        font-size: .74rem;
        color: #64748b;
        margin-top: .15rem;
    }

    .turnos-form-card .card-header,
    .turnos-list-card .card-header {
        padding: .8rem 1rem;
    }

    .turnos-form-card .card-body {
        padding: 1rem;
    }

    .turnos-section-note {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: .5rem 1rem;
        margin-bottom: .75rem;
    }

    .turnos-section-note p {
        margin: 0;
    }

    .turnos-mini-summary {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .turnos-mini-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .55rem;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        background: #f8fafc;
        color: #334155;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .turnos-editor-table {
        min-width: 980px;
    }

    .turnos-editor-table thead th {
        vertical-align: middle;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        white-space: nowrap;
    }

    .turnos-editor-table tbody td {
        padding-top: .45rem;
        padding-bottom: .45rem;
        vertical-align: top;
    }

    .turnos-editor-table tbody tr + tr td {
        border-top: 1px solid #e2e8f0;
    }

    .turno-dia-row--descanso {
        background: #f8fafc;
        color: #94a3b8;
    }

    .turno-dia-row--laborable {
        background: #fff;
    }

    .turno-dia-nombre {
        min-width: 6rem;
        font-size: .82rem;
        font-weight: 700;
    }

    .turno-dia-detalle {
        margin-top: .3rem;
        font-size: .68rem;
        line-height: 1.25;
        color: #64748b;
        max-width: 13rem;
    }

    .turno-hora-stack {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        align-items: center;
    }

    .turno-hora-label {
        font-size: .64rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .turno-hora-input {
        width: 5.5rem !important;
        font-size: .8rem !important;
        text-align: center;
    }

    .turno-descanso-block {
        display: flex;
        flex-direction: column;
        gap: .25rem;
        padding: .3rem .4rem;
        border: 1px solid #e2e8f0;
        border-radius: .5rem;
        background: #fff;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
    }

    .turno-descanso-row {
        display: flex;
        align-items: center;
        gap: .25rem;
    }

    .turno-descansos-stack {
        display: flex;
        flex-direction: column;
        gap: .4rem;
        min-width: 14rem;
    }

    .turno-descanso-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
    }

    .turno-descanso-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .45rem;
        flex-wrap: wrap;
    }

    .turno-descanso-toolbar .badge {
        font-size: .68rem;
    }

    .turno-descanso-label {
        font-size: .72rem;
        font-weight: 700;
        color: #334155;
    }

    .turno-descanso-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 2.6rem;
        padding: .35rem .5rem;
        border: 1px dashed #cbd5e1;
        border-radius: .5rem;
        background: #f8fafc;
        color: #64748b;
        font-size: .72rem;
    }

    .turno-pagado-check {
        font-size: .72rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: .25rem;
        padding-left: .1rem;
    }

    .turno-planeado-badge {
        font-size: .74rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .turno-planeado-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: .2rem;
    }

    .turno-planeado-meta small {
        font-size: .68rem;
        color: #64748b;
    }

    .turno-copy-box {
        display: flex;
        flex-direction: column;
        gap: .35rem;
        min-width: 8.6rem;
    }

    .turno-copy-row {
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .turno-copy-row .form-select {
        min-width: 5.2rem;
    }

    .turno-copy-hint {
        font-size: .66rem;
        color: #64748b;
        line-height: 1.2;
    }

    .turno-pill {
        display: inline-flex;
        align-items: center;
        padding: .15rem .5rem;
        border-radius: 999px;
        font-size: .68rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .turno-pill--work { background: #dcfce7; color: #166534; }
    .turno-pill--rest { background: #f1f5f9; color: #64748b; }
    .turno-pill--pend { background: #fef9c3; color: #854d0e; }

    .turno-card-dia {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .55rem;
        border-radius: .5rem;
        background: #f1f5f9;
        font-size: .74rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .turno-card-dia i { font-size: .7rem; }

    .turno-summary-row {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        margin-top: .4rem;
    }

    .turnos-list-card .card-body {
        padding: .9rem 1rem .7rem;
    }

    .turnos-card-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-top: .7rem;
    }

    .turnos-card-metric {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .55rem;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        font-size: .72rem;
        color: #475569;
        font-weight: 700;
    }

    .turnos-empty {
        padding: 3rem 1rem;
        text-align: center;
        color: #64748b;
    }

    .turnos-empty i {
        color: #94a3b8;
    }
</style>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver turnos.</div>
    }
    else
    {
        <div class="turnos-shell">
            <div class="turnos-toolbar">
                <div class="turnos-toolbar-copy">
                    <span class="turnos-eyebrow">RRHH · Configuración base</span>
                    <h1 class="turnos-title"><i class="bi bi-clock-history me-2"></i>Turnos</h1>
                    <p class="turnos-subtitle">Define jornadas semanales, descansos y horas planeadas con una vista compacta para escritorio.</p>
                </div>
                <div class="turnos-toolbar-actions">
                    @if (_puedeEditar)
                    {
                        <button class="btn btn-primary" @onclick="Nuevo"><i class="bi bi-plus-circle me-1"></i>Nuevo turno</button>
                    }
                </div>
            </div>

            <div class="turnos-kpi-grid">
                <div class="turnos-kpi">
                    <span class="turnos-kpi-label">Turnos configurados</span>
                    <span class="turnos-kpi-value">@lista.Count</span>
                    <span class="turnos-kpi-note">@ContarTurnosActivos() activos</span>
                </div>
                <div class="turnos-kpi">
                    <span class="turnos-kpi-label">Plantilla asignada</span>
                    <span class="turnos-kpi-value">@TotalEmpleadosAsignados()</span>
                    <span class="turnos-kpi-note">empleado(s) en turnos base</span>
                </div>
                <div class="turnos-kpi">
                    <span class="turnos-kpi-label">Horas semanales</span>
                    <span class="turnos-kpi-value">@FormatearMinutos(TotalMinutosSemanales())</span>
                    <span class="turnos-kpi-note">suma planeada visible</span>
                </div>
                <div class="turnos-kpi">
                    <span class="turnos-kpi-label">Editor</span>
                    <span class="turnos-kpi-value">@(mostrarForm ? "Abierto" : "Listo")</span>
                    <span class="turnos-kpi-note">@(mostrarForm ? editando.Nombre ?? string.Empty : "Selecciona o crea un turno")</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger py-2 small">@error</div>
            }

            @if (!string.IsNullOrWhiteSpace(ok))
            {
                <div class="alert alert-success py-2 small">@ok</div>
            }

            @if (mostrarForm)
            {
                <div class="card mb-4 border-0 shadow-sm turnos-form-card">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-pencil-square me-2"></i>@(editando.Id == Guid.Empty ? "Nuevo turno" : $"Editando: {editando.Nombre}")</span>
                    <span class="badge @(editando.IsActive ? "bg-success" : "bg-secondary")">@(editando.IsActive ? "Activo" : "Inactivo")</span>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Nombre</label>
                            <InputText class="form-control" @bind-Value="editando.Nombre" placeholder="Ej. Turno matutino" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold small">Descripción</label>
                            <InputText class="form-control" @bind-Value="editando.Descripcion" placeholder="Opcional" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.IsActive" />
                                <label class="form-check-label small">Activo</label>
                            </div>
                        </div>
                    </div>

                    <div class="turnos-section-note">
                        <p class="small text-muted"><i class="bi bi-lightbulb me-1"></i>Configura un día y usa <strong>Copiar &rarr;</strong> para replicarlo a otro día o a toda la semana.</p>
                        <div class="turnos-mini-summary">
                            <span class="turnos-mini-pill"><i class="bi bi-calendar-week"></i>@editando.Dias.Count(d => d.Labora) laborable(s)</span>
                            <span class="turnos-mini-pill"><i class="bi bi-pause-circle"></i>@editando.Dias.Sum(d => d.Descansos.Count) descanso(s)</span>
                            <span class="turnos-mini-pill"><i class="bi bi-clock"></i>@FormatearMinutos(CalcularTotalesSemanales(editando.Dias).MinutosPlaneadosTrabajados)</span>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 border turnos-editor-table">
                            <thead class="table-dark">
                                <tr>
                                    <th style="min-width:7rem">Día</th>
                                    <th class="text-center" style="width:4rem">Labora</th>
                                    <th style="width:6rem">Entrada</th>
                                    <th style="width:6rem">Salida</th>
                                    <th style="min-width:20rem">Descansos</th>
                                    <th style="min-width:11rem">Copiar a</th>
                                    <th class="text-end" style="width:6.5rem">Planeado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dia in editando.Dias)
                                {
                                    var durDia = CalcularDuracionDia(dia);
                                    var rowClass = dia.Labora ? "turno-dia-row--laborable" : "turno-dia-row--descanso";
                                    var pillLabel = !dia.Labora ? "Descanso" : (durDia.MinutosPlaneadosTrabajados > 0 ? "Labora" : "Pendiente");
                                    var pillClass = !dia.Labora ? "turno-pill--rest" : (durDia.MinutosPlaneadosTrabajados > 0 ? "turno-pill--work" : "turno-pill--pend");

                                    <tr class="@rowClass">
                                        <td class="turno-dia-nombre">
                                            <div>@dia.NombreDia</div>
                                            <span class="turno-pill @pillClass">@pillLabel</span>
                                            <div class="turno-dia-detalle">@ObtenerResumenDia(dia)</div>
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input" @bind="dia.Labora" />
                                        </td>
                                        <td>
                                            <div class="turno-hora-stack">
                                                <span class="turno-hora-label">Entrada</span>
                                                <input type="text"
                                                       class="form-control form-control-sm turno-hora-input"
                                                       placeholder="08:00"
                                                       value="@dia.HoraEntradaTexto"
                                                       @onchange="e => dia.HoraEntradaTexto = e.Value?.ToString() ?? string.Empty"
                                                       disabled="@(!dia.Labora)" />
                                            </div>
                                        </td>
                                        <td>
                                            <div class="turno-hora-stack">
                                                <span class="turno-hora-label">Salida</span>
                                                <input type="text"
                                                       class="form-control form-control-sm turno-hora-input"
                                                       placeholder="17:00"
                                                       value="@dia.HoraSalidaTexto"
                                                       @onchange="e => dia.HoraSalidaTexto = e.Value?.ToString() ?? string.Empty"
                                                       disabled="@(!dia.Labora)" />
                                            </div>
                                        </td>
                                        <td>
                                            <div class="turno-descansos-stack">
                                                <div class="turno-descanso-toolbar">
                                                    <span class="badge text-bg-light border">@dia.Descansos.Count descanso(s)</span>
                                                    <button class="btn btn-outline-primary btn-sm" type="button"
                                                            @onclick="() => AgregarDescanso(dia.DiaSemana)"
                                                            disabled="@(!dia.Labora || guardando)">
                                                        <i class="bi bi-plus-circle me-1"></i>Agregar
                                                    </button>
                                                </div>

                                                @if (dia.Descansos.Count == 0)
                                                {
                                                    <div class="turno-descanso-empty">Sin descansos configurados.</div>
                                                }
                                                else
                                                {
                                                    @foreach (var descanso in dia.Descansos.OrderBy(d => d.Orden))
                                                    {
                                                        <div class="turno-descanso-block">
                                                            <div class="turno-descanso-head">
                                                                <span class="turno-descanso-label">Descanso @descanso.Orden</span>
                                                                <button class="btn btn-link btn-sm text-danger p-0" type="button"
                                                                        title="Eliminar descanso"
                                                                        @onclick="() => EliminarDescanso(dia.DiaSemana, descanso.Orden)"
                                                                        disabled="@(!dia.Labora || guardando)">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </div>
                                                            <div class="turno-descanso-row">
                                                                <input type="text" class="form-control form-control-sm turno-hora-input" placeholder="13:00"
                                                                       value="@descanso.HoraInicioTexto"
                                                                       @onchange="e => descanso.HoraInicioTexto = e.Value?.ToString() ?? string.Empty"
                                                                       disabled="@(!dia.Labora)" />
                                                                <span class="text-muted small">–</span>
                                                                <input type="text" class="form-control form-control-sm turno-hora-input" placeholder="13:30"
                                                                       value="@descanso.HoraFinTexto"
                                                                       @onchange="e => descanso.HoraFinTexto = e.Value?.ToString() ?? string.Empty"
                                                                       disabled="@(!dia.Labora)" />
                                                            </div>
                                                            <label class="turno-pagado-check">
                                                                <input type="checkbox" class="form-check-input" @bind="descanso.EsPagado" disabled="@(!dia.Labora)" />
                                                                Pagado
                                                            </label>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="turno-copy-box">
                                                <div class="turno-copy-row">
                                                    <InputSelect class="form-select form-select-sm" @bind-Value="dia.DiaDestinoDuplicadoTexto" disabled="@guardando">
                                                        <option value="">Día...</option>
                                                        @foreach (var destino in ObtenerDestinosDuplicado(dia.DiaSemana))
                                                        {
                                                            <option value="@((int)destino).ToString()">@ObtenerNombreDia(destino)</option>
                                                        }
                                                    </InputSelect>
                                                    <button class="btn btn-outline-primary btn-sm px-2" type="button"
                                                            title="Copiar al día seleccionado"
                                                            @onclick="() => CopiarDiaADestino(dia.DiaSemana)"
                                                            disabled="@(guardando || string.IsNullOrWhiteSpace(dia.DiaDestinoDuplicadoTexto))">
                                                        <i class="bi bi-arrow-right"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm px-2" type="button"
                                                            title="Copiar a todos los días"
                                                            @onclick="() => CopiarDiaATodos(dia.DiaSemana)"
                                                            disabled="@guardando">
                                                        <i class="bi bi-copy"></i>
                                                    </button>
                                                </div>
                                                <div class="turno-copy-hint">Copia este día a otro o replícalo en toda la semana.</div>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <div class="turno-planeado-meta">
                                                <span class="turno-planeado-badge @(durDia.MinutosPlaneadosTrabajados > 0 ? "text-success" : "text-muted")">
                                                    @(durDia.MinutosPlaneadosTrabajados > 0 ? FormatearMinutos(durDia.MinutosPlaneadosTrabajados) : "—")
                                                </span>
                                                <small>Bruta @FormatearMinutos(durDia.MinutosJornadaBruta)</small>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @{
                        var totales = CalcularTotalesSemanales(editando.Dias);
                    }
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <span class="badge text-bg-light border"><i class="bi bi-calendar-check me-1"></i>@editando.Dias.Count(d => d.Labora) días</span>
                        <span class="badge text-bg-light border">Bruta @FormatearMinutos(totales.MinutosJornadaBruta)</span>
                        @if (totales.MinutosDescansoPagado > 0)
                        {
                            <span class="badge text-bg-light border">Desc. pagado @FormatearMinutos(totales.MinutosDescansoPagado)</span>
                        }
                        @if (totales.MinutosDescansoNoPagado > 0)
                        {
                            <span class="badge text-bg-light border">Desc. no pagado @FormatearMinutos(totales.MinutosDescansoNoPagado)</span>
                        }
                        <span class="badge text-bg-primary"><i class="bi bi-clock me-1"></i>Planeado @FormatearMinutos(totales.MinutosPlaneadosTrabajados)</span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-success" @onclick="Guardar" disabled="@guardando">
                            <i class="bi bi-save me-1"></i>@(guardando ? "Guardando..." : "Guardar turno")
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CerrarFormulario" disabled="@guardando">Cancelar</button>
                    </div>
                </div>
                </div>
            }

            <div class="card border-0 shadow-sm turnos-list-card">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-list-ul me-2"></i>Turnos configurados</span>
                    <span class="badge bg-secondary">@lista.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (lista.Count == 0)
                    {
                        <div class="turnos-empty">
                            <i class="bi bi-clock display-6 d-block mb-2"></i>
                            No hay turnos configurados. Crea el primero con el botón de arriba.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3 p-3">
                            @foreach (var item in lista)
                            {
                                <div class="col-md-6 col-xl-4">
                                    <div class="card h-100 border-0 shadow-sm">
                                        <div class="card-body pb-2">
                                            <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                                <div>
                                                    <div class="fw-bold">@item.Nombre</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                    {
                                                        <div class="small text-muted">@item.Descripcion</div>
                                                    }
                                                </div>
                                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary") flex-shrink-0">@(item.IsActive ? "Activo" : "Inactivo")</span>
                                            </div>
                                            <div class="small text-muted">@item.Resumen</div>
                                            <div class="turno-summary-row">
                                                @foreach (var chip in item.DiasChips)
                                                {
                                                    <span class="turno-card-dia" title="@chip.Tooltip">
                                                        <i class="bi @(chip.Labora ? "bi-check-circle-fill text-success" : "bi-moon-fill text-secondary")"></i>
                                                        @chip.Abrev
                                                        @if (chip.Labora)
                                                        {
                                                            <span class="text-muted fw-normal">@chip.Horario</span>
                                                        }
                                                    </span>
                                                }
                                            </div>
                                            <div class="turnos-card-metrics">
                                                <span class="turnos-card-metric"><i class="bi bi-people"></i>@item.EmpleadosAsignados empleado(s)</span>
                                                @if (item.MinutosSemanales > 0)
                                                {
                                                    <span class="turnos-card-metric"><i class="bi bi-clock"></i>@FormatearMinutos(item.MinutosSemanales)/sem</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center pt-1">
                                            <div class="small text-muted">Semana @FormatearMinutos(item.MinutosSemanales)</div>
                                            @if (_puedeEditar)
                                            {
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(item.Id)">
                                                    <i class="bi bi-pencil me-1"></i>Editar
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TurnoResumenVm> lista = [];
    private TurnoEditVm editando = CrearTurnoVacio();
    private bool mostrarForm;
    private bool guardando;
    private bool _puedeVer;
    private bool _puedeEditar;
    private string? error;
    private string? ok;

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
        {
            await CargarAsync();
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "empleados.ver") || state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "empleados.editar") || state.User.HasClaim("Capacidad", "nominas.editar");
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var turnos = await db.TurnosBase
            .Include(t => t.Detalles)
                    .ThenInclude(d => d.Descansos)
            .Include(t => t.Empleados)
            .AsNoTracking()
            .OrderBy(t => t.Nombre)
            .ToListAsync();

        lista = turnos.Select(t => new TurnoResumenVm
            {
                Id = t.Id,
                Nombre = t.Nombre,
                Descripcion = t.Descripcion,
                IsActive = t.IsActive,
                EmpleadosAsignados = t.Empleados.Count(e => e.IsActive),
                Resumen = ConstruirResumenSemanal(t.Detalles),
                MinutosSemanales = t.Detalles.Select(CalcularDuracionDia).Sum(d => d.MinutosPlaneadosTrabajados),
                DiasChips = Enum.GetValues<DiaSemanaTurno>()
                    .OrderBy(d => d)
                    .Select(d =>
                    {
                        var det = t.Detalles.FirstOrDefault(x => x.DiaSemana == d);
                        var labora = det?.Labora ?? false;
                        var horario = labora && det!.HoraEntrada.HasValue && det.HoraSalida.HasValue
                            ? $"{det.HoraEntrada.Value:hh\\:mm}-{det.HoraSalida.Value:hh\\:mm}"
                            : string.Empty;
                        var tooltip = labora ? (string.IsNullOrWhiteSpace(horario) ? ObtenerNombreDia(d) : $"{ObtenerNombreDia(d)}: {horario}") : $"{ObtenerNombreDia(d)}: descanso";
                        return new TurnoDiaChipVm
                        {
                            Abrev = ObtenerAbrevDia(d),
                            Horario = horario,
                            Tooltip = tooltip,
                            Labora = labora
                        };
                    })
                    .ToList()
            })
            .ToList();
    }

    private void Nuevo()
    {
        if (!_puedeEditar)
        {
            error = "No tienes permisos para crear turnos.";
            return;
        }

        error = ok = null;
        editando = CrearTurnoVacio();
        mostrarForm = true;
    }

    private async Task Editar(Guid id)
    {
        if (!_puedeEditar)
        {
            error = "No tienes permisos para editar turnos.";
            return;
        }

        error = ok = null;
        await using var db = await DbFactory.CreateDbContextAsync();
        var turno = await db.TurnosBase
            .Include(t => t.Detalles)
                .ThenInclude(d => d.Descansos)
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.Id == id);

        if (turno == null)
        {
            error = "No se encontró el turno.";
            return;
        }

        editando = new TurnoEditVm
        {
            Id = turno.Id,
            Nombre = turno.Nombre,
            Descripcion = turno.Descripcion,
            IsActive = turno.IsActive,
            Dias = CrearDiasSemana(turno.Detalles)
        };
        mostrarForm = true;
    }

    private async Task Guardar()
    {
        error = ok = null;
        if (!_puedeEditar)
        {
            error = "No tienes permisos para guardar turnos.";
            return;
        }

        if (string.IsNullOrWhiteSpace(editando.Nombre))
        {
            error = "El nombre del turno es requerido.";
            return;
        }

        guardando = true;

        try
        {
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out var empresaId);
            if (empresaId == Guid.Empty)
            {
                error = "No hay empresa activa.";
                return;
            }

            var usuario = state.User.Identity?.Name;
            await using var db = await DbFactory.CreateDbContextAsync();
            TurnoBase turno;

            if (editando.Id == Guid.Empty)
            {
                turno = new TurnoBase
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = empresaId,
                    Nombre = editando.Nombre.Trim(),
                    Descripcion = string.IsNullOrWhiteSpace(editando.Descripcion) ? null : editando.Descripcion.Trim(),
                    IsActive = editando.IsActive,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = usuario
                };
                db.TurnosBase.Add(turno);
            }
            else
            {
                turno = await db.TurnosBase
                    .Include(t => t.Detalles)
                        .ThenInclude(d => d.Descansos)
                    .FirstOrDefaultAsync(t => t.Id == editando.Id)
                    ?? throw new InvalidOperationException("No se encontró el turno a guardar.");

                turno.Nombre = editando.Nombre.Trim();
                turno.Descripcion = string.IsNullOrWhiteSpace(editando.Descripcion) ? null : editando.Descripcion.Trim();
                turno.IsActive = editando.IsActive;
                turno.UpdatedAt = DateTime.UtcNow;
                turno.UpdatedBy = usuario;
            }

            var detallesExistentes = turno.Detalles.ToDictionary(d => d.DiaSemana);
            foreach (var dia in editando.Dias.OrderBy(d => d.DiaSemana))
            {
                var entrada = dia.Labora ? ConvertirHora(dia.HoraEntradaTexto) : null;
                var salida = dia.Labora ? ConvertirHora(dia.HoraSalidaTexto) : null;
                var descansos = dia.Labora
                    ? dia.Descansos
                        .OrderBy(d => d.Orden)
                        .Select((d, index) => new TurnoBaseDetalleDescanso
                        {
                            Id = Guid.NewGuid(),
                            TurnoBaseDetalleId = Guid.Empty,
                            Orden = (byte)(index + 1),
                            HoraInicio = ConvertirHora(d.HoraInicioTexto),
                            HoraFin = ConvertirHora(d.HoraFinTexto),
                            EsPagado = d.EsPagado,
                            CreatedAt = DateTime.UtcNow,
                            CreatedBy = usuario,
                            IsActive = true
                        })
                        .Where(d => d.HoraInicio.HasValue && d.HoraFin.HasValue)
                        .ToList()
                    : [];

                if (detallesExistentes.TryGetValue(dia.DiaSemana, out var detalleExistente))
                {
                    detalleExistente.Labora = dia.Labora;
                    detalleExistente.HoraEntrada = entrada;
                    detalleExistente.HoraSalida = salida;
                    detalleExistente.Descansos.Clear();
                    foreach (var descanso in descansos)
                    {
                        descanso.TurnoBaseDetalleId = detalleExistente.Id;
                        detalleExistente.Descansos.Add(descanso);
                    }
                    detalleExistente.IsActive = true;
                    detalleExistente.UpdatedAt = DateTime.UtcNow;
                    detalleExistente.UpdatedBy = usuario;
                    continue;
                }

                turno.Detalles.Add(new TurnoBaseDetalle
                {
                    Id = Guid.NewGuid(),
                    TurnoBaseId = turno.Id,
                    DiaSemana = dia.DiaSemana,
                    Labora = dia.Labora,
                    HoraEntrada = entrada,
                    HoraSalida = salida,
                    Descansos = descansos,
                    CreatedAt = DateTime.UtcNow,
                    CreatedBy = usuario,
                    IsActive = true
                });
            }

            var diasEditados = editando.Dias.Select(d => d.DiaSemana).ToHashSet();
            var detallesObsoletos = turno.Detalles.Where(d => !diasEditados.Contains(d.DiaSemana)).ToList();
            if (detallesObsoletos.Count > 0)
                db.TurnosBaseDetalle.RemoveRange(detallesObsoletos);

            await db.SaveChangesAsync();
            ok = "Turno guardado.";
            mostrarForm = false;
            await CargarAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            error = "El turno cambió en la base de datos mientras lo editabas. Vuelve a abrirlo e intenta guardar de nuevo.";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void CerrarFormulario()
    {
        mostrarForm = false;
        error = ok = null;
        editando = CrearTurnoVacio();
    }

    private void CopiarDiaADestino(DiaSemanaTurno origenDia)
    {
        error = ok = null;

        var origen = ObtenerDia(origenDia);
        if (origen == null)
        {
            error = "No se encontró el día origen.";
            return;
        }

        if (!TryObtenerDiaSemana(origen.DiaDestinoDuplicadoTexto, out var destinoDia))
        {
            error = "Selecciona el día destino para copiar la configuración.";
            return;
        }

        var destino = ObtenerDia(destinoDia);
        if (destino == null)
        {
            error = "No se encontró el día destino.";
            return;
        }

        CopiarConfiguracionDia(origen, destino);
        origen.DiaDestinoDuplicadoTexto = string.Empty;
        ok = $"Se copió {origen.NombreDia} a {destino.NombreDia}.";
    }

    private void CopiarDiaATodos(DiaSemanaTurno origenDia)
    {
        error = ok = null;

        var origen = ObtenerDia(origenDia);
        if (origen == null)
        {
            error = "No se encontró el día origen.";
            return;
        }

        foreach (var destino in editando.Dias.Where(d => d.DiaSemana != origenDia))
        {
            CopiarConfiguracionDia(origen, destino);
        }

        origen.DiaDestinoDuplicadoTexto = string.Empty;
        ok = $"Se copió la configuración de {origen.NombreDia} al resto de los días.";
    }

    private TurnoDiaEditVm? ObtenerDia(DiaSemanaTurno diaSemana)
        => editando.Dias.FirstOrDefault(d => d.DiaSemana == diaSemana);

    private static IEnumerable<DiaSemanaTurno> ObtenerDestinosDuplicado(DiaSemanaTurno origenDia)
        => Enum.GetValues<DiaSemanaTurno>()
            .Where(dia => dia != origenDia)
            .OrderBy(dia => dia);

    private static bool TryObtenerDiaSemana(string? valor, out DiaSemanaTurno diaSemana)
    {
        diaSemana = default;
        if (!int.TryParse(valor, out var diaValor) || !Enum.IsDefined(typeof(DiaSemanaTurno), diaValor))
        {
            return false;
        }

        diaSemana = (DiaSemanaTurno)diaValor;
        return true;
    }

    private static void CopiarConfiguracionDia(TurnoDiaEditVm origen, TurnoDiaEditVm destino)
    {
        destino.Labora = origen.Labora;
        destino.HoraEntradaTexto = origen.Labora ? origen.HoraEntradaTexto : string.Empty;
        destino.HoraSalidaTexto = origen.Labora ? origen.HoraSalidaTexto : string.Empty;
        destino.Descansos = origen.Labora
            ? origen.Descansos
                .OrderBy(d => d.Orden)
                .Select(d => new TurnoDescansoEditVm
                {
                    Orden = d.Orden,
                    HoraInicioTexto = d.HoraInicioTexto,
                    HoraFinTexto = d.HoraFinTexto,
                    EsPagado = d.EsPagado
                })
                .ToList()
            : [];
        destino.DiaDestinoDuplicadoTexto = string.Empty;
    }

    private void AgregarDescanso(DiaSemanaTurno diaSemana)
    {
        var dia = ObtenerDia(diaSemana);
        if (dia == null || !dia.Labora)
        {
            return;
        }

        dia.Descansos.Add(new TurnoDescansoEditVm
        {
            Orden = (byte)(dia.Descansos.Count + 1)
        });
    }

    private void EliminarDescanso(DiaSemanaTurno diaSemana, byte orden)
    {
        var dia = ObtenerDia(diaSemana);
        if (dia == null)
        {
            return;
        }

        var descanso = dia.Descansos.FirstOrDefault(d => d.Orden == orden);
        if (descanso == null)
        {
            return;
        }

        dia.Descansos.Remove(descanso);
        ReordenarDescansos(dia.Descansos);
    }

    private static TurnoEditVm CrearTurnoVacio()
        => new()
        {
            Dias = CrearDiasSemana([])
        };

    private static List<TurnoDiaEditVm> CrearDiasSemana(IEnumerable<TurnoBaseDetalle> detalles)
    {
        var mapa = detalles.ToDictionary(d => d.DiaSemana, d => d);
        return Enum.GetValues<DiaSemanaTurno>()
            .OrderBy(d => d)
            .Select(dia =>
            {
                mapa.TryGetValue(dia, out var detalle);
                return new TurnoDiaEditVm
                {
                    DiaSemana = dia,
                    NombreDia = ObtenerNombreDia(dia),
                    Labora = detalle?.Labora ?? false,
                    HoraEntradaTexto = detalle?.HoraEntrada?.ToString("hh':'mm") ?? string.Empty,
                    HoraSalidaTexto = detalle?.HoraSalida?.ToString("hh':'mm") ?? string.Empty,
                    Descansos = detalle?.Descansos
                        .OrderBy(d => d.Orden)
                        .Select(d => new TurnoDescansoEditVm
                        {
                            Orden = d.Orden,
                            HoraInicioTexto = d.HoraInicio?.ToString("hh':'mm") ?? string.Empty,
                            HoraFinTexto = d.HoraFin?.ToString("hh':'mm") ?? string.Empty,
                            EsPagado = d.EsPagado
                        })
                        .ToList() ?? []
                };
            })
            .ToList();
    }

    private static string ObtenerNombreDia(DiaSemanaTurno dia) => dia switch
    {
        DiaSemanaTurno.Lunes => "Lunes",
        DiaSemanaTurno.Martes => "Martes",
        DiaSemanaTurno.Miercoles => "Miércoles",
        DiaSemanaTurno.Jueves => "Jueves",
        DiaSemanaTurno.Viernes => "Viernes",
        DiaSemanaTurno.Sabado => "Sábado",
        DiaSemanaTurno.Domingo => "Domingo",
        _ => dia.ToString()
    };

    private static void ReordenarDescansos(List<TurnoDescansoEditVm> descansos)
    {
        for (var index = 0; index < descansos.Count; index++)
        {
            descansos[index].Orden = (byte)(index + 1);
        }
    }

    private static string ObtenerAbrevDia(DiaSemanaTurno dia) => dia switch
    {
        DiaSemanaTurno.Lunes => "Lun",
        DiaSemanaTurno.Martes => "Mar",
        DiaSemanaTurno.Miercoles => "Mié",
        DiaSemanaTurno.Jueves => "Jue",
        DiaSemanaTurno.Viernes => "Vie",
        DiaSemanaTurno.Sabado => "Sáb",
        DiaSemanaTurno.Domingo => "Dom",
        _ => dia.ToString()[..3]
    };

    private static TimeSpan? ConvertirHora(string? valor)
        => string.IsNullOrWhiteSpace(valor)
            ? null
            : TimeSpan.TryParse(valor, out var hora)
                ? hora
                : null;

    private static string ObtenerResumenDia(TurnoDiaEditVm dia)
    {
        if (!dia.Labora)
        {
            return "Descanso";
        }

        var entrada = ConvertirHora(dia.HoraEntradaTexto);
        var salida = ConvertirHora(dia.HoraSalidaTexto);
        if (!entrada.HasValue || !salida.HasValue)
        {
            return "Horario pendiente";
        }

        var duracion = CalcularDuracionDia(dia);
        var etiquetaHoras = duracion.MinutosJornadaBruta > 0 ? $" · Bruta {FormatearMinutos(duracion.MinutosJornadaBruta)}" : string.Empty;
        var descansos = dia.Descansos
            .OrderBy(d => d.Orden)
            .Select(d => $"D{d.Orden} {d.HoraInicioTexto}-{d.HoraFinTexto}{(d.EsPagado ? " pagado" : string.Empty)}".Trim())
            .ToList();

        var resumenDescansos = descansos.Count == 0 ? string.Empty : $" · {string.Join(" · ", descansos)}";
        var etiquetaPlaneado = $" · Planeado {FormatearMinutos(duracion.MinutosPlaneadosTrabajados)}";
        return $"{FormatearHora(entrada)} - {FormatearHora(salida)}{etiquetaHoras}{resumenDescansos}{etiquetaPlaneado}";
    }

    private static string ObtenerTiempoPlaneadoDia(TurnoDiaEditVm dia)
    {
        if (!dia.Labora)
        {
            return "—";
        }

        var duracion = CalcularDuracionDia(dia);
        return duracion.MinutosPlaneadosTrabajados <= 0
            ? "Pendiente"
            : FormatearMinutos(duracion.MinutosPlaneadosTrabajados);
    }

    private static string ConstruirResumenSemanal(IEnumerable<TurnoBaseDetalle> detalles)
    {
        var diasLaborables = detalles
            .Where(d => d.Labora)
            .OrderBy(d => d.DiaSemana)
            .Select(d =>
            {
                var descansos = d.Descansos
                    .OrderBy(x => x.Orden)
                    .Select(x => $"D{x.Orden} {FormatearHora(x.HoraInicio)}-{FormatearHora(x.HoraFin)}{(x.EsPagado ? " pag." : string.Empty)}")
                    .ToList();

                var resumenDescansos = descansos.Count == 0 ? string.Empty : $" ({string.Join(", ", descansos)})";
                return $"{ObtenerNombreDia(d.DiaSemana)} {FormatearHora(d.HoraEntrada)}-{FormatearHora(d.HoraSalida)}{resumenDescansos}";
            })
            .ToList();

        var totalPlaneado = detalles
            .Select(CalcularDuracionDia)
            .Sum(d => d.MinutosPlaneadosTrabajados);

        return diasLaborables.Count == 0
            ? "Sin días laborables"
            : $"{string.Join(" · ", diasLaborables)} · Planeado sem. {FormatearMinutos(totalPlaneado)}";
    }

    private static string FormatearHora(TimeSpan? hora)
        => hora.HasValue ? hora.Value.ToString("hh':'mm") : "--:--";

    private static TurnoDuracionVm CalcularTotalesSemanales(IEnumerable<TurnoDiaEditVm> dias)
        => dias.Aggregate(new TurnoDuracionVm(), (acumulado, dia) => acumulado + CalcularDuracionDia(dia));

    private static TurnoDuracionVm CalcularDuracionDia(TurnoDiaEditVm dia)
    {
        var entrada = ConvertirHora(dia.HoraEntradaTexto);
        var salida = ConvertirHora(dia.HoraSalidaTexto);
        if (!dia.Labora || !entrada.HasValue || !salida.HasValue)
        {
            return new TurnoDuracionVm();
        }

        var jornadaBruta = Math.Max(0, (int)Math.Round((salida.Value - entrada.Value).TotalMinutes));
        var descansos = dia.Descansos
            .Select(d => new
            {
                Minutos = CalcularMinutosRango(ConvertirHora(d.HoraInicioTexto), ConvertirHora(d.HoraFinTexto)),
                d.EsPagado
            })
            .ToList();
        var descansoPagado = descansos.Where(d => d.EsPagado).Sum(d => d.Minutos);
        var descansoNoPagado = descansos.Where(d => !d.EsPagado).Sum(d => d.Minutos);

        return new TurnoDuracionVm
        {
            MinutosJornadaBruta = jornadaBruta,
            MinutosDescansoPagado = descansoPagado,
            MinutosDescansoNoPagado = descansoNoPagado,
            MinutosPlaneadosTrabajados = Math.Max(0, jornadaBruta - descansoNoPagado)
        };
    }

    private static TurnoDuracionVm CalcularDuracionDia(TurnoBaseDetalle detalle)
    {
        if (!detalle.Labora || !detalle.HoraEntrada.HasValue || !detalle.HoraSalida.HasValue)
        {
            return new TurnoDuracionVm();
        }

        var jornadaBruta = Math.Max(0, (int)Math.Round((detalle.HoraSalida.Value - detalle.HoraEntrada.Value).TotalMinutes));
        var descansos = detalle.Descansos
            .Select(d => new
            {
                Minutos = CalcularMinutosRango(d.HoraInicio, d.HoraFin),
                d.EsPagado
            })
            .ToList();
        var descansoPagado = descansos.Where(d => d.EsPagado).Sum(d => d.Minutos);
        var descansoNoPagado = descansos.Where(d => !d.EsPagado).Sum(d => d.Minutos);

        return new TurnoDuracionVm
        {
            MinutosJornadaBruta = jornadaBruta,
            MinutosDescansoPagado = descansoPagado,
            MinutosDescansoNoPagado = descansoNoPagado,
            MinutosPlaneadosTrabajados = Math.Max(0, jornadaBruta - descansoNoPagado)
        };
    }

    private static int CalcularMinutosRango(TimeSpan? inicio, TimeSpan? fin)
        => !inicio.HasValue || !fin.HasValue
            ? 0
            : Math.Max(0, (int)Math.Round((fin.Value - inicio.Value).TotalMinutes));

    private static string FormatearMinutos(int minutos)
    {
        var horas = minutos / 60;
        var restantes = minutos % 60;
        return $"{horas}:{restantes:00} h";
    }

    private int ContarTurnosActivos() => lista.Count(t => t.IsActive);

    private int TotalEmpleadosAsignados() => lista.Sum(t => t.EmpleadosAsignados);

    private int TotalMinutosSemanales() => lista.Sum(t => t.MinutosSemanales);

    private sealed class TurnoResumenVm
    {
        public Guid Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string? Descripcion { get; set; }
        public bool IsActive { get; set; }
        public int EmpleadosAsignados { get; set; }
        public string Resumen { get; set; } = string.Empty;
        public int MinutosSemanales { get; set; }
        public List<TurnoDiaChipVm> DiasChips { get; set; } = [];
    }

    private sealed class TurnoDiaChipVm
    {
        public string Abrev { get; set; } = string.Empty;
        public string Horario { get; set; } = string.Empty;
