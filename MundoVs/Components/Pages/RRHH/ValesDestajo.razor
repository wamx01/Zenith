    private async Task GuardarBorrador() => await GuardarVale(EstatusValeDestajo.Borrador);
    private async Task AprobarVale() => await GuardarVale(EstatusValeDestajo.Aprobado);

    private async Task GuardarVale(EstatusValeDestajo estatus)
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar) { error = "No tienes permisos."; return; }
            if (!editandoEmpleadoId.HasValue || editandoEmpleadoId.Value == Guid.Empty) { error = "Seleccione un empleado."; return; }
            if (detallesEditando.Count == 0) { error = "Agregue al menos una línea."; return; }
            if (detallesEditando.Any(d => d.TipoProcesoId == Guid.Empty)) { error = "Seleccione el proceso en todas las líneas."; return; }
            if (detallesEditando.Any(d => d.Cantidad <= 0)) { error = "La cantidad debe ser mayor a cero en todas las líneas."; return; }

            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out var empresaId);
            if (empresaId == Guid.Empty) { error = "No hay empresa activa."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();

            if (editandoId == Guid.Empty)
            {
                var vale = new ValeDestajo
                {
                    EmpresaId = empresaId, Folio = editandoFolio,
                    EmpleadoId = editandoEmpleadoId.Value, Fecha = editandoFecha,
                    Estatus = estatus, EsquemaPagoId = esquemaActivoId,
                    Observaciones = editandoObservaciones?.Trim()
                };
                foreach (var d in detallesEditando)
                {
                    var detalleId = Guid.NewGuid();
                    vale.Detalles.Add(new ValeDestajoDetalle
                    {
                        Id = detalleId,
                        TipoProcesoId = d.TipoProcesoId,
                        PedidoId = d.PedidoId.HasValue && d.PedidoId.Value != Guid.Empty ? d.PedidoId : null,
                        Cantidad = d.Cantidad,
                        TarifaAplicada = d.TarifaAplicada,
                        EsquemaPagoTarifaId = d.EsquemaPagoTarifaId,
                        TiempoMinutos = d.TiempoMinutos,
                        Importe = d.Cantidad * d.TarifaAplicada
                    });
                }
                db.ValesDestajo.Add(vale);
                await VincularRegistrosOrigenAsync(db, vale.Detalles, detallesEditando);
            }
            else
            {
                var vale = await db.ValesDestajo.Include(v => v.Detalles).FirstOrDefaultAsync(v => v.Id == editandoId);
                if (vale == null) return;
                if (vale.Estatus != EstatusValeDestajo.Borrador) { error = "Solo se pueden editar vales en borrador."; return; }
                var nuevosDetalles = new List<ValeDestajoDetalle>();

                vale.EmpleadoId = editandoEmpleadoId.Value;
                vale.Fecha = editandoFecha;
                vale.Estatus = estatus;
                vale.EsquemaPagoId = esquemaActivoId;
                vale.Observaciones = editandoObservaciones?.Trim();
                vale.UpdatedAt = DateTime.UtcNow;

                // Sync detalles
                await LiberarRegistrosOrigenAsync(db, vale.Detalles.Select(d => d.Id).ToList());
                db.ValesDestajoDetalle.RemoveRange(vale.Detalles);
                vale.Detalles.Clear();
                foreach (var d in detallesEditando)
                {
                    var detalleId = Guid.NewGuid();
                    var detalleNuevo = new ValeDestajoDetalle
                    {
                        Id = detalleId,
                        ValeDestajoId = vale.Id,
                        TipoProcesoId = d.TipoProcesoId,
                        PedidoId = d.PedidoId.HasValue && d.PedidoId.Value != Guid.Empty ? d.PedidoId : null,
                        Cantidad = d.Cantidad,
                        TarifaAplicada = d.TarifaAplicada,
                        EsquemaPagoTarifaId = d.EsquemaPagoTarifaId,
                        TiempoMinutos = d.TiempoMinutos,
                        Importe = d.Cantidad * d.TarifaAplicada
                    };
                    vale.Detalles.Add(detalleNuevo);
                    nuevosDetalles.Add(detalleNuevo);
                }

                await VincularRegistrosOrigenAsync(db, nuevosDetalles, detallesEditando);
            }

            await db.SaveChangesAsync();
            editandoEstatus = estatus;
            ok = estatus == EstatusValeDestajo.Aprobado ? "Vale aprobado." : "Borrador guardado.";
            mostrarForm = false; await Cargar();
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private async Task CancelarVale()
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar) { error = "No tienes permisos."; return; }
            await using var db = await DbFactory.CreateDbContextAsync();
            var vale = await db.ValesDestajo.Include(v => v.Detalles).FirstOrDefaultAsync(v => v.Id == editandoId);
            if (vale == null) return;
            if (vale.Estatus != EstatusValeDestajo.Aprobado) { error = "Solo se pueden cancelar vales aprobados."; return; }

            await LiberarRegistrosOrigenAsync(db, vale.Detalles.Select(d => d.Id).ToList());
            vale.Estatus = EstatusValeDestajo.Cancelado;
            vale.UpdatedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();
            ok = "Vale cancelado."; mostrarForm = false; await Cargar();
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private async Task<string> GenerarFolio()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var ultimo = await db.ValesDestajo.OrderByDescending(v => v.Folio).Select(v => v.Folio).FirstOrDefaultAsync();
        if (string.IsNullOrEmpty(ultimo) || !ultimo.StartsWith("VD-")) return "VD-0001";
        var num = int.TryParse(ultimo[3..], out var n) ? n + 1 : 1;
        return $"VD-{num:D4}";
    }

    private string ObtenerNombrePosicion(Empleado emp)
        => posiciones.FirstOrDefault(p => p.Id == emp.PosicionId)?.Nombre ?? emp.Puesto ?? "—";

    private string ObtenerNombreProceso(Guid procesoId)
        => procesos.FirstOrDefault(p => p.Id == procesoId)?.Nombre ?? "—";

    private string ObtenerNumeroPedido(Guid? pedidoId)
    {
        if (!pedidoId.HasValue) return "(libre)";
        var ped = pedidosActivos.FirstOrDefault(p => p.Id == pedidoId.Value);
        if (ped == null) return "—";
        return $"{ped.NumeroPedido} — {ped.Cliente?.RazonSocial ?? "—"}";
    }

    private async Task AutocargarDesdeProduccion()
    {
        error = ok = null;
        if (!editandoEmpleadoId.HasValue || editandoEmpleadoId == Guid.Empty)
        {
            error = "Seleccione un empleado para autocargar registros.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var detalleActualIds = editandoId == Guid.Empty
            ? []
            : await db.ValesDestajoDetalle
                .Where(d => d.ValeDestajoId == editandoId)
                .Select(d => d.Id)
                .ToListAsync();

        var desde = editandoFecha.Date;
        var hasta = desde.AddDays(1);

        var registros = await db.RegistrosDestajoProceso
            .Include(r => r.PedidoSerigrafia)
                .ThenInclude(ps => ps.PedidoDetalle)
            .AsNoTracking()
            .Where(r => r.IsActive
                && r.EmpleadoId == editandoEmpleadoId.Value
                && r.Fecha >= desde
                && r.Fecha < hasta
                && (!r.ValeDestajoDetalleId.HasValue || detalleActualIds.Contains(r.ValeDestajoDetalleId.Value)))
            .OrderBy(r => r.Fecha)
            .ThenBy(r => r.CreatedAt)
            .ToListAsync();

        if (!registros.Any())
        {
            error = "No hay registros de producción pendientes para el empleado y fecha seleccionados.";
            detallesEditando = [];
            registrosPendientesProduccion = 0;
            return;
        }

        detallesEditando = registros
            .GroupBy(r => new { r.TipoProcesoId, r.PedidoSerigrafiaId, r.TarifaUnitario })
            .Select(g => new DetalleEditable
            {
                TipoProcesoId = g.Key.TipoProcesoId,
                PedidoId = g.Select(r => r.PedidoSerigrafia.PedidoDetalle.PedidoId).FirstOrDefault(),
                Cantidad = g.Sum(r => Math.Max(0, r.CantidadProcesada)),
                TarifaAplicada = g.Key.TarifaUnitario,
                TiempoMinutos = g.Sum(r => r.TiempoMinutos ?? 0),
                TarifaOrigen = "Autocargado desde seguimiento de producción.",
                RegistroOrigenIds = g.Select(r => r.Id).ToList()
            })
            .OrderBy(d => ObtenerNombreProceso(d.TipoProcesoId))
            .ThenBy(d => ObtenerNumeroPedido(d.PedidoId))
            .ToList();

        ok = $"Se cargaron {registros.Count} registro(s) de producción en {detallesEditando.Count} línea(s).";
        await ActualizarRegistrosPendientesProduccionAsync();
    }

    private ResultadoTarifa ResolverTarifaOperacion(TipoProceso proceso, Empleado empleado, decimal minutosPorPieza)
    {
        var resultado = DestajoTarifaResolver.Resolver(proceso, empleado.PosicionId, minutosPorPieza, tarifasEsquemaActivo);
        return new ResultadoTarifa
        {
            Tarifa = resultado.Tarifa,
            EsquemaPagoTarifaId = resultado.EsquemaPagoTarifaId,
            Origen = resultado.Origen
        };
    }

    private async Task ActualizarRegistrosPendientesProduccionAsync()
    {
        registrosPendientesProduccion = 0;
        if (!editandoEmpleadoId.HasValue || editandoEmpleadoId == Guid.Empty)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var desde = editandoFecha.Date;
        var hasta = desde.AddDays(1);
        registrosPendientesProduccion = await db.RegistrosDestajoProceso
            .AsNoTracking()
            .CountAsync(r => r.IsActive
                && r.EmpleadoId == editandoEmpleadoId.Value
                && r.Fecha >= desde
                && r.Fecha < hasta
                && !r.ValeDestajoDetalleId.HasValue);
    }

    private static async Task LiberarRegistrosOrigenAsync(CrmDbContext db, List<Guid> detalleIds)
    {
        if (detalleIds.Count == 0)
        {
            return;
        }

        var registros = await db.RegistrosDestajoProceso
            .Where(r => r.ValeDestajoDetalleId.HasValue && detalleIds.Contains(r.ValeDestajoDetalleId.Value))
            .ToListAsync();

        foreach (var registro in registros)
        {
            registro.ValeDestajoDetalleId = null;
            registro.UpdatedAt = DateTime.UtcNow;
        }
    }

    private static async Task VincularRegistrosOrigenAsync(CrmDbContext db, ICollection<ValeDestajoDetalle> detallesGuardados, IEnumerable<DetalleEditable> detallesEditables)
    {
        var mapaDetalles = detallesGuardados
            .Zip(detallesEditables, (guardado, editable) => new { guardado.Id, editable.RegistroOrigenIds })
            .Where(x => x.RegistroOrigenIds.Count > 0)
            .ToList();

        foreach (var item in mapaDetalles)
        {
            var registros = await db.RegistrosDestajoProceso
                .Where(r => item.RegistroOrigenIds.Contains(r.Id))
                .ToListAsync();

            foreach (var registro in registros)
            {
                registro.ValeDestajoDetalleId = item.Id;
                registro.UpdatedAt = DateTime.UtcNow;
            }
        }
    }

    private decimal ObtenerMinutosEstandarPorPieza(Pedido pedido, Guid tipoProcesoId)
    {
        var detallesCotizados = pedido.Detalles
            .Where(d => d.IsActive && d.Cantidad > 0 && d.CotizacionSerigrafia != null)
            .Select(d => new
            {
                d.Cantidad,
                Minutos = d.CotizacionSerigrafia!.Detalles
                    .Where(cd => cd.IsActive && cd.Categoria == CotizacionCategoria.ManoObra && cd.TipoProcesoId == tipoProcesoId && cd.Tiempo.HasValue)
                    .Sum(cd => cd.Tiempo ?? 0m)
            })
            .Where(x => x.Minutos > 0)
            .ToList();

        var totalPiezas = detallesCotizados.Sum(x => x.Cantidad);
        var totalMinutos = detallesCotizados.Sum(x => x.Minutos);
        return totalPiezas > 0 ? totalMinutos / totalPiezas : 0m;
    }

    private string? ObtenerAdvertenciaOperacion(Empleado empleado, TipoProceso? proceso)
    {
        if (proceso?.PosicionId == null || empleado.PosicionId == proceso.PosicionId)
        {
            return null;
        }

        var nombrePosicionProceso = posiciones.FirstOrDefault(p => p.Id == proceso.PosicionId.Value)?.Nombre ?? "otra posición";
        return $"Aviso: no es su operación natural ({nombrePosicionProceso}).";
    }

    private static int ObtenerEnteroConfig(Dictionary<string, string> values, string clave, int defaultValue)
        => values.TryGetValue(clave, out var value) && int.TryParse(value, out var result) ? result : defaultValue;

    private static decimal ObtenerDecimalConfig(Dictionary<string, string> values, string clave, decimal defaultValue)
        => values.TryGetValue(clave, out var value)
            && decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var result)
                ? result
                : defaultValue;

