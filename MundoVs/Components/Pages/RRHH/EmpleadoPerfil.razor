@page "/rrhh/empleados/{Id:guid}/perfil"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@rendermode InteractiveServer

<PageTitle>Perfil de @(_data?.Empleado.NombreCompleto ?? "Empleado")</PageTitle>

<div class="container-fluid px-4 ep-perfil">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver el perfil de empleados.</div>
    }
    else if (cargando)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:40vh">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
        </div>
    }
    else if (_data is null)
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
    else
    {
        var e = _data.Empleado;
        var iniciales = ObtenerIniciales(e.NombreCompleto);

        <div class="ep-profile-header d-flex flex-wrap align-items-center gap-3 mb-3 mt-2">
            <div class="ep-avatar">@iniciales</div>
            <div class="flex-fill min-w-0">
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <h4 class="mb-0 text-truncate">@e.NombreCompleto</h4>
                    <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Activo" : "Inactivo")</span>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-1">
                    <span class="ep-header-meta"><i class="bi bi-building me-1"></i>@(e.Departamento ?? "Sin depto.")</span>
                    <span class="ep-header-meta"><i class="bi bi-person-badge me-1"></i>@(_data.Posicion?.Nombre ?? e.Puesto ?? "Sin puesto")</span>
                    <span class="ep-header-meta"><i class="bi bi-hash me-1"></i>@e.NumeroEmpleado</span>
                </div>
            </div>
            <div class="ms-auto">
                <a href="/rrhh/empleados" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
            </div>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--vacaciones border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Vacaciones</div>
                        <div class="fs-5 fw-bold">@_data.VacacionesDisponibles.ToString("0.##") días</div>
                        <div class="small text-muted">@(_data.CicloVacacional?.TieneDerechoVacaciones == true ? $"Ciclo {_data.CicloVacacional.InicioCiclo:dd/MM/yyyy}–{_data.CicloVacacional.FinCiclo:dd/MM/yyyy}" : "Sin derecho")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--banco border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Banco de horas</div>
                        <div class="fs-5 fw-bold">@_data.SaldoBancoHoras.ToString("0.##") h</div>
                        <div class="small text-muted">@_data.MovimientosBancoHoras.Count mov. recientes</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--esquema border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Esquema</div>
                        <div class="fs-6 fw-bold">@_data.EsquemaVigente</div>
                        <div class="small text-muted">@e.SueldoSemanal.ToString("C2") / @e.PeriodicidadPago</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--turno border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Turno</div>
                        <div class="fs-6 fw-bold">@(_data.TurnoVigente?.Nombre ?? "Sin turno")</div>
                        <div class="small text-muted">Contratación: @(e.FechaContratacion?.ToString("dd/MM/yyyy") ?? "—")</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--asistencias border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Asistencias (30d)</div>
                        <div class="fs-5 fw-bold">@_data.AsistenciasRecientes.Count</div>
                        <div class="small text-muted">@_data.AsistenciasRecientes.Count(a => a.RequiereRevision) por revisar</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-md-3 col-xl-2">
                <div class="card ep-kpi-card ep-kpi-card--estatus border-0 shadow-sm h-100">
                    <div class="card-body py-2">
                        <div class="small text-muted text-uppercase">Estatus</div>
                        <div><span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Activo" : "Inactivo")</span></div>
                        <div class="mt-1">
                            @if (e.AplicaImss) { <span class="badge bg-info text-dark me-1">IMSS</span> }
                            @if (e.AplicaIsr) { <span class="badge bg-warning text-dark me-1">ISR</span> }
                            @if (e.AplicaInfonavit) { <span class="badge bg-danger me-1">Infonavit</span> }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs nav-tabs-sm ep-tabs">
            <li class="nav-item"><button class="nav-link @TabClass("resumen")" @onclick="@(() => CambiarTab("resumen"))"><i class="bi bi-person-badge me-1"></i>Resumen</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("personal")" @onclick="@(() => CambiarTab("personal"))"><i class="bi bi-person me-1"></i>Personal</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("turnos")" @onclick="@(() => CambiarTab("turnos"))"><i class="bi bi-clock me-1"></i>Horario</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("laboral")" @onclick="@(() => CambiarTab("laboral"))"><i class="bi bi-briefcase me-1"></i>Laboral</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("nomina")" @onclick="@(() => CambiarTab("nomina"))"><i class="bi bi-cash-stack me-1"></i>Nómina</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("asistencias")" @onclick="@(() => CambiarTab("asistencias"))"><i class="bi bi-calendar-check me-1"></i>Asistencias</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("ausencias")" @onclick="@(() => CambiarTab("ausencias"))"><i class="bi bi-calendar-x me-1"></i>Ausencias</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("saldos")" @onclick="@(() => CambiarTab("saldos"))"><i class="bi bi-bank me-1"></i>Saldos</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("conceptos")" @onclick="@(() => CambiarTab("conceptos"))"><i class="bi bi-list-check me-1"></i>Conceptos</button></li>
            <li class="nav-item"><button class="nav-link @TabClass("notas")" @onclick="@(() => CambiarTab("notas"))"><i class="bi bi-chat-left-text me-1"></i>Notas</button></li>
        </ul>

        <div class="card border-top-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="ep-tab-panel" @key="_tabActiva">
                @switch (_tabActiva)
                {
                    case "resumen":
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="ep-seccion-title"><i class="bi bi-person me-1"></i>Identidad</div>
                                <div class="row g-2">
                                    <div class="col-sm-6"><div class="ep-field-label">Nombre completo</div><div class="ep-field-value">@e.NombreCompleto</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">No. empleado</div><div class="ep-field-value">@e.NumeroEmpleado</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">Código checador</div><div class="ep-field-value">@(e.CodigoChecador ?? "—")</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Posición / Puesto</div><div class="ep-field-value">@(_data.Posicion?.Nombre ?? e.Puesto ?? "—")</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">Departamento</div><div class="ep-field-value">@(e.Departamento ?? "—")</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">Tipo nómina</div><div class="ep-field-value">@e.TipoNomina</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">CURP</div><div class="ep-field-value">@(e.Curp ?? "—")</div></div>
                                    <div class="col-sm-3"><div class="ep-field-label">NSS</div><div class="ep-field-value">@(e.Nss ?? "—")</div></div>
                                    <div class="col-sm-4"><div class="ep-field-label">Sueldo</div><div class="ep-field-value">@e.SueldoSemanal.ToString("C2") / @e.PeriodicidadPago</div></div>
                                    <div class="col-sm-4"><div class="ep-field-label">Esquema vigente</div><div class="ep-field-value">@_data.EsquemaVigente</div></div>
                                    <div class="col-sm-4"><div class="ep-field-label">Turno vigente</div><div class="ep-field-value">@(_data.TurnoVigente?.Nombre ?? "—")</div></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="ep-seccion-title"><i class="bi bi-graph-up me-1"></i>Resumen reciente</div>
                                <div class="row g-2">
                                    <div class="col-sm-6"><div class="ep-field-label">Asistencias (30 días)</div><div class="ep-field-value">@_data.AsistenciasRecientes.Count</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Por revisar</div><div class="ep-field-value">@_data.AsistenciasRecientes.Count(a => a.RequiereRevision)</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Ausencias activas</div><div class="ep-field-value">@_data.AusenciasRecientes.Count</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Conceptos nómina</div><div class="ep-field-value">@_data.ConceptosNomina.Count</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Vacaciones disponibles</div><div class="ep-field-value">@_data.VacacionesDisponibles.ToString("0.##") días</div></div>
                                    <div class="col-sm-6"><div class="ep-field-label">Banco de horas</div><div class="ep-field-value">@FormatearHorasBanco(_data.SaldoBancoHoras)</div></div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(e.Notas))
                                {
                                    <div class="mt-3"><div class="ep-field-label">Notas</div><div class="small text-muted">@e.Notas</div></div>
                                }
                            </div>
                        </div>
                        break;
                    case "personal":
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="bi bi-person me-1"></i>Datos personales</h6>
                            @if (_puedeEditar && !_editandoPersonal)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="IniciarEdicionPersonal"><i class="bi bi-pencil me-1"></i>Editar</button>
                            }
                        </div>
                        @if (_editandoPersonal)
                        {
                            <EditForm Model="_editando" OnValidSubmit="GuardarPersonalAsync">
                                <div class="row g-3">
                                    <div class="col-md-3"><label class="form-label">Nombre</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Nombre" /></div>
                                    <div class="col-md-3"><label class="form-label">Apellido paterno</label><InputText class="form-control form-control-sm" @bind-Value="_editando.ApellidoPaterno" /></div>
                                    <div class="col-md-3"><label class="form-label">Apellido materno</label><InputText class="form-control form-control-sm" @bind-Value="_editando.ApellidoMaterno" /></div>
                                    <div class="col-md-3"><label class="form-label">No. empleado</label><InputText class="form-control form-control-sm" @bind-Value="_editando.NumeroEmpleado" /></div>
                                    <div class="col-md-3"><label class="form-label">Código checador</label><InputText class="form-control form-control-sm" @bind-Value="_editando.CodigoChecador" /></div>
                                    <div class="col-md-3"><label class="form-label">CURP</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Curp" /></div>
                                    <div class="col-md-3"><label class="form-label">NSS</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Nss" /></div>
                                    <div class="col-md-3"><label class="form-label">Teléfono</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Telefono" /></div>
                                    <div class="col-md-3"><label class="form-label">Email</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Email" /></div>
                                    <div class="col-md-6"><label class="form-label">Dirección</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Direccion" /></div>
                                    <div class="col-md-3"><label class="form-label">Fecha nacimiento</label><InputDate class="form-control form-control-sm" @bind-Value="_editando.FechaNacimiento" /></div>
                                    <div class="col-md-3"><label class="form-label">Fecha contratación</label><InputDate class="form-control form-control-sm" @bind-Value="_editando.FechaContratacion" /></div>
                                    <div class="col-md-1"><div class="form-check mt-4"><InputCheckbox class="form-check-input" @bind-Value="_editando.IsActive" /><label class="form-check-label">Activo</label></div></div>
                                    <div class="col-12"><div class="d-flex gap-2"><button type="submit" class="btn btn-primary btn-sm" disabled="@_guardando"><i class="bi bi-check me-1"></i>Guardar</button><button type="button" class="btn btn-outline-secondary btn-sm" @onclick="@(() => _editandoPersonal = false)">Cancelar</button></div></div>
                                </div>
                            </EditForm>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-md-3"><div class="ep-field-label">Nombre</div><div class="ep-field-value">@e.Nombre</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Apellido paterno</div><div class="ep-field-value">@(e.ApellidoPaterno ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Apellido materno</div><div class="ep-field-value">@(e.ApellidoMaterno ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">No. empleado</div><div class="ep-field-value">@e.NumeroEmpleado</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Código checador</div><div class="ep-field-value">@(e.CodigoChecador ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">CURP</div><div class="ep-field-value">@(e.Curp ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">NSS</div><div class="ep-field-value">@(e.Nss ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Teléfono</div><div class="ep-field-value">@(e.Telefono ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Email</div><div class="ep-field-value">@(e.Email ?? "—")</div></div>
                                <div class="col-md-6"><div class="ep-field-label">Dirección</div><div class="ep-field-value">@(e.Direccion ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Fecha nacimiento</div><div class="ep-field-value">@(e.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Fecha contratación</div><div class="ep-field-value">@(e.FechaContratacion?.ToString("dd/MM/yyyy") ?? "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Estatus</div><div class="ep-field-value"><span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Activo" : "Inactivo")</span></div></div>
                            </div>
                        }
                        break;
                    case "laboral":
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="bi bi-briefcase me-1"></i>Datos laborales</h6>
                            @if (_puedeEditar && !_editandoLaboral)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="IniciarEdicionLaboral"><i class="bi bi-pencil me-1"></i>Editar</button>
                            }
                        </div>
                        @if (_editandoLaboral)
                        {
                            <EditForm Model="_editando" OnValidSubmit="GuardarLaboralAsync">
                                <div class="row g-3">
                                    <div class="col-md-4"><label class="form-label">Posición</label><InputSelect class="form-select form-select-sm" @bind-Value="_editando.PosicionId"><option value="">Sin posición</option>@foreach(var p in _data!.Posiciones){<option value="@p.Id">@p.Nombre</option>}</InputSelect></div>
                                    <div class="col-md-4"><label class="form-label">Puesto</label><InputText class="form-control form-control-sm" @bind-Value="_editando.Puesto" /></div>
                                    <div class="col-md-4"><label class="form-label">Departamento</label><InputSelect class="form-select form-select-sm" @bind-Value="_editando.Departamento"><option value="">Sin depto.</option>@foreach(var d in DepartamentosDisponibles){<option value="@d">@d</option>}</InputSelect></div>
                                    <div class="col-md-4"><label class="form-label">Fecha contratación</label><InputDate class="form-control form-control-sm" @bind-Value="_editando.FechaContratacion" /></div>
                                    <div class="col-md-4"><label class="form-label">Turno</label><InputSelect class="form-select form-select-sm" @bind-Value="_turnoSeleccionadoId"><option value="">Sin turno</option>@foreach(var t in _data!.TurnosBase){<option value="@t.Id">@ObtenerEtiquetaTurno(t)</option>}</InputSelect></div>
                                    <div class="col-md-4"><label class="form-label">Vigencia desde</label><InputDate class="form-control form-control-sm" @bind-Value="_turnoVigenteDesde" /></div>
                                    <div class="col-md-4"><label class="form-label">Vigencia hasta</label><InputDate class="form-control form-control-sm" @bind-Value="_turnoVigenteHasta" /></div>
                                    <div class="col-md-4"><label class="form-label">Obs. turno</label><InputText class="form-control form-control-sm" @bind-Value="_turnoObservaciones" /></div>
                                    <div class="col-md-1"><div class="form-check mt-4"><InputCheckbox class="form-check-input" @bind-Value="_editando.IsActive" /><label class="form-check-label">Activo</label></div></div>
                                    <div class="col-12"><div class="d-flex gap-2"><button type="submit" class="btn btn-primary btn-sm" disabled="@_guardando"><i class="bi bi-check me-1"></i>Guardar</button><button type="button" class="btn btn-outline-secondary btn-sm" @onclick="@(() => _editandoLaboral = false)">Cancelar</button></div></div>
                                </div>
                            </EditForm>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-md-4"><div class="ep-field-label">Posición</div><div class="ep-field-value">@(_data!.Posicion?.Nombre ?? "—")</div></div>
                                <div class="col-md-4"><div class="ep-field-label">Puesto</div><div class="ep-field-value">@(e.Puesto ?? "—")</div></div>
                                <div class="col-md-4"><div class="ep-field-label">Departamento</div><div class="ep-field-value">@(e.Departamento ?? "—")</div></div>
                                <div class="col-md-4"><div class="ep-field-label">Fecha contratación</div><div class="ep-field-value">@(e.FechaContratacion?.ToString("dd/MM/yyyy") ?? "—")</div></div>
                                <div class="col-md-4"><div class="ep-field-label">Turno vigente</div><div class="ep-field-value">@(_data.TurnoVigente?.Nombre ?? "—")</div></div>
                                <div class="col-md-4"><div class="ep-field-label">Estatus</div><div class="ep-field-value"><span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Activo" : "Inactivo")</span></div></div>
                            </div>
                        }
                        @if (_data!.HistorialTurnos.Count > 0)
                        {
                            <details class="mt-3">
                                <summary class="text-muted small">Historial de turnos (@_data.HistorialTurnos.Count)</summary>
                                <div class="table-responsive mt-1"><table class="table table-sm table-striped table-hover table-bordered"><thead class="table-light"><tr><th>Turno</th><th>Desde</th><th>Hasta</th><th>Obs.</th></tr></thead><tbody>@foreach(var h in _data.HistorialTurnos.Take(10)){<tr><td>@h.TurnoBase?.Nombre</td><td>@h.VigenteDesde.ToString("dd/MM/yyyy")</td><td>@(h.VigenteHasta?.ToString("dd/MM/yyyy") ?? "(vigente)")</td><td>@(string.IsNullOrWhiteSpace(h.Observaciones) ? "—" : h.Observaciones)</td></tr>}</tbody></table></div>
                            </details>
                        }
                        @if (_data!.HistorialEsquemas.Count > 0)
                        {
                            <details class="mt-2">
                                <summary class="text-muted small">Historial de esquemas (@_data.HistorialEsquemas.Count)</summary>
                                <div class="table-responsive mt-1"><table class="table table-sm table-striped table-hover table-bordered"><thead class="table-light"><tr><th>Esquema</th><th>Desde</th><th>Hasta</th><th>Sueldo override</th></tr></thead><tbody>@foreach(var esq in _data.HistorialEsquemas.Take(10)){<tr><td>@esq.EsquemaPago?.Nombre</td><td>@esq.VigenteDesde.ToString("dd/MM/yyyy")</td><td>@(esq.VigenteHasta?.ToString("dd/MM/yyyy") ?? "(vigente)")</td><td>@(esq.SueldoBaseOverride.HasValue ? esq.SueldoBaseOverride.Value.ToString("C2") : "—")</td></tr>}</tbody></table></div>
                            </details>
                        }
                        break;
                    case "nomina":
                        <h6 class="mb-3"><i class="bi bi-cash-stack me-1"></i>Datos de nómina</h6>
                        <div class="row g-3">
                            <div class="col-md-3"><div class="ep-field-label">Sueldo</div><div class="ep-field-value">@e.SueldoSemanal.ToString("C2")</div></div>
                            <div class="col-md-3"><div class="ep-field-label">Periodicidad</div><div class="ep-field-value">@e.PeriodicidadPago</div></div>
                            <div class="col-md-3"><div class="ep-field-label">Tipo nómina</div><div class="ep-field-value">@e.TipoNomina</div></div>
                            <div class="col-md-3"><div class="ep-field-label">Esquema vigente</div><div class="ep-field-value">@_data.EsquemaVigente</div></div>
                            @if (_data!.EsquemaAsignacionVigente is not null)
                            {
                                <div class="col-md-3"><div class="ep-field-label">Sueldo override</div><div class="ep-field-value">@(_data.EsquemaAsignacionVigente.SueldoBaseOverride.HasValue ? _data.EsquemaAsignacionVigente.SueldoBaseOverride.Value.ToString("C2") : "—")</div></div>
                                <div class="col-md-3"><div class="ep-field-label">Vigencia esquema</div><div class="ep-field-value">@_data.EsquemaAsignacionVigente.VigenteDesde.ToString("dd/MM/yyyy") – @(_data.EsquemaAsignacionVigente.VigenteHasta?.ToString("dd/MM/yyyy") ?? "presente")</div></div>
                            }
                            <div class="col-md-2"><div class="ep-field-label">IMSS</div><div class="ep-field-value"><span class="badge @(e.AplicaImss ? "bg-success" : "bg-secondary")">@(e.AplicaImss ? "Sí" : "No")</span></div></div>
                            <div class="col-md-2"><div class="ep-field-label">ISR</div><div class="ep-field-value"><span class="badge @(e.AplicaIsr ? "bg-success" : "bg-secondary")">@(e.AplicaIsr ? "Sí" : "No")</span></div></div>
                            <div class="col-md-2"><div class="ep-field-label">INFONAVIT</div><div class="ep-field-value"><span class="badge @(e.AplicaInfonavit ? "bg-success" : "bg-secondary")">@(e.AplicaInfonavit ? "Sí" : "No")</span></div></div>
                            @if (e.AplicaInfonavit)
                            {
                                <div class="col-md-3"><div class="ep-field-label">Crédito INFONAVIT</div><div class="ep-field-value">@(e.NumeroCreditoInfonavit ?? "—")</div></div>
                                <div class="col-md-2"><div class="ep-field-label">Factor desc.</div><div class="ep-field-value">@e.FactorDescuentoInfonavit</div></div>
                            }
                        </div>
                        break;
                    case "turnos":
                        <h6 class="mb-3"><i class="bi bi-clock me-1"></i>Horario semanal</h6>
                        @if (_data!.TurnoVigente is null)
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-clock"></i>
                                <p>Sin turno asignado</p>
                            </div>
                        }
                        else
                        {
                            <div class="mb-2">
                                <span class="badge bg-primary">@_data.TurnoVigente.Nombre</span>
                                @if (_data.TurnoAsignacionVigente is not null)
                                {
                                    <span class="text-muted ms-2 small">Vigencia: @_data.TurnoAsignacionVigente.VigenteDesde.ToString("dd/MM/yyyy") – @(_data.TurnoAsignacionVigente.VigenteHasta?.ToString("dd/MM/yyyy") ?? "presente")</span>
                                }
                            </div>
                            <div class="ep-horario-grid">
                                @{
                                    var dias = new[] { (DiaSemanaTurno.Lunes, "Lun", "Lunes"), (DiaSemanaTurno.Martes, "Mar", "Martes"), (DiaSemanaTurno.Miercoles, "Mié", "Miércoles"), (DiaSemanaTurno.Jueves, "Jue", "Jueves"), (DiaSemanaTurno.Viernes, "Vie", "Viernes"), (DiaSemanaTurno.Sabado, "Sáb", "Sábado"), (DiaSemanaTurno.Domingo, "Dom", "Domingo") };
                                }
                                @foreach (var (diaEnum, diaLabel, diaCompleto) in dias)
                                {
                                    var detalle = _data.TurnoVigente.Detalles?.FirstOrDefault(d => d.DiaSemana == diaEnum);
                                    var horasTrabajadas = detalle is not null && detalle.Labora && detalle.HoraEntrada is not null && detalle.HoraSalida is not null
                                        ? (detalle.HoraSalida.Value - detalle.HoraEntrada.Value).TotalHours
                                        : 0.0;
                                    var tooltip = detalle is null || !detalle.Labora ? "Descanso" : $"{horasTrabajadas:F1}h trabajadas";
                                    <div class="ep-horario-dia @(_esHoy(diaEnum) ? "ep-horario-dia--hoy" : "")" title="@tooltip" data-bs-toggle="tooltip">
                                        <div class="ep-horario-dia__header @(_esHoy(diaEnum) ? "ep-horario-dia__header--hoy" : "")">
                                            <span class="ep-horario-dia__label">@diaLabel</span>
                                            <span class="ep-horario-dia__nombre">@diaCompleto</span>
                                            @if (_esHoy(diaEnum))
                                            {
                                                <span class="badge bg-white text-primary ms-1" style="font-size:0.6rem;font-weight:700">Hoy</span>
                                            }
                                        </div>
                                        @if (detalle is null || !detalle.Labora)
                                        {
                                            <div class="ep-horario-dia__body ep-horario-dia__body--descanso">
                                                <i class="bi bi-moon"></i>
                                                <span>Descanso</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="ep-horario-dia__body">
                                                <div class="ep-horario-segment ep-horario-segment--trabajo">
                                                    <i class="bi bi-box-arrow-in-right"></i>
                                                    <span>@(detalle.HoraEntrada?.ToString("hh\\:mm") ?? "—")</span>
                                                </div>
                                                <div class="ep-horario-segment ep-horario-segment--salida">
                                                    <i class="bi bi-box-arrow-right"></i>
                                                    <span>@(detalle.HoraSalida?.ToString("hh\\:mm") ?? "—")</span>
                                                </div>
                                                @if (detalle.Descansos?.Count > 0)
                                                {
                                                    foreach (var desc in detalle.Descansos.OrderBy(d => d.Orden))
                                                    {
                                                        <div class="ep-horario-segment ep-horario-segment--descanso">
                                                            <i class="bi bi-cup-hot"></i>
                                                            <span>@(desc.HoraInicio?.ToString("hh\\:mm") ?? "—")–@(desc.HoraFin?.ToString("hh\\:mm") ?? "—")</span>
                                                            @if (desc.EsPagado)
                                                            {
                                                                <span class="badge bg-info text-dark" style="font-size:0.55rem">Pagado</span>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        @if (_data!.HistorialTurnos.Count > 0)
                        {
                            <details class="mt-3">
                                <summary class="text-muted small">Historial de turnos (@_data.HistorialTurnos.Count)</summary>
                                <div class="table-responsive mt-1"><table class="table table-sm table-striped table-hover table-bordered"><thead class="table-light"><tr><th>Turno</th><th>Desde</th><th>Hasta</th><th>Obs.</th></tr></thead><tbody>@foreach (var h in _data.HistorialTurnos.Take(10)){<tr><td>@h.TurnoBase?.Nombre</td><td>@h.VigenteDesde.ToString("dd/MM/yyyy")</td><td>@(h.VigenteHasta?.ToString("dd/MM/yyyy") ?? "(vigente)")</td><td>@(string.IsNullOrWhiteSpace(h.Observaciones) ? "—" : h.Observaciones)</td></tr>}</tbody></table></div>
                            </details>
                        }
                        break;
                    case "asistencias":
                        <h6 class="mb-3"><i class="bi bi-calendar-check me-1"></i>Asistencias recientes (30 días)</h6>
                        @if (_data!.AsistenciasRecientes.Count == 0)
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-calendar-check"></i>
                                <p>Sin asistencias registradas en los últimos 30 días</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr><th>Fecha</th><th>Entrada prog.</th><th>Entrada real</th><th>Salida prog.</th><th>Salida real</th><th>Min. netos</th><th>Retardo</th><th>Extra</th><th>Estatus</th><th>Revisión</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var a in _data.AsistenciasRecientes)
                                        {
                                            var minNetos = a.MinutosTrabajadosNetos;
                                            var horas = minNetos / 60;
                                            var mins = minNetos % 60;
                                            <tr>
                                                <td class="text-nowrap">@a.Fecha.ToString("dd/MM/yyyy")</td>
                                                <td>@(a.HoraEntradaProgramada?.ToString("hh\\:mm") ?? "—")</td>
                                                <td>@(a.HoraEntradaReal?.ToString("hh\\:mm") ?? "—")</td>
                                                <td>@(a.HoraSalidaProgramada?.ToString("hh\\:mm") ?? "—")</td>
                                                <td>@(a.HoraSalidaReal?.ToString("hh\\:mm") ?? "—")</td>
                                                <td class="text-center">@($"{horas}h{mins:D2}m")</td>
                                                <td class="text-center @(a.MinutosRetardo > 0 ? "text-warning fw-bold" : "")">@(a.MinutosRetardo > 0 ? $"{a.MinutosRetardo} min" : "—")</td>
                                                <td class="text-center @(a.MinutosExtra > 0 ? "text-success fw-bold" : "")">@(a.MinutosExtra > 0 ? $"{a.MinutosExtra} min" : "—")</td>
                                                <td><span class="badge @ObtenerClaseEstatus(a.Estatus)">@ObtenerEtiquetaEstatus(a.Estatus)</span></td>
                                                <td class="text-center">@if(a.RequiereRevision){<i class="bi bi-exclamation-triangle-fill text-warning"></i>}else{<i class="bi bi-check-circle text-success"></i>}</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;
                    case "ausencias":
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="bi bi-calendar-x me-1"></i> Ausencias y permisos</h6>
                            @if (_puedeEditar && !_nuevaAusencia)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="IniciarNuevaAusencia"><i class="bi bi-plus-circle me-1"></i>Nuevo permiso</button>
                            }
                        </div>
                        @if (_nuevaAusencia)
                        {
                            <div class="card border-primary mb-3">
                                <div class="card-header bg-primary text-white py-2"><strong>Nueva ausencia / permiso</strong></div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <label class="form-label">Tipo</label>
                                            <select class="form-select form-select-sm" @bind="_ausenciaEditando.Tipo" @bind:event="onchange">
                                                <option value="@TipoAusenciaRrhh.Vacaciones">Vacaciones</option>
                                                <option value="@TipoAusenciaRrhh.Permiso">Permiso</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Estatus</label>
                                            <select class="form-select form-select-sm" @bind="_ausenciaEditando.Estatus">
                                                @foreach (var est in Enum.GetValues<EstatusAusenciaRrhh>())
                                                {
                                                    <option value="@est">@ObtenerEtiquetaEstatusAusencia(est)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Fecha inicio</label>
                                            <input type="date" class="form-control form-control-sm" @bind="_ausenciaFechaInicio" @bind:format="yyyy-MM-dd" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Fecha fin</label>
                                            <input type="date" class="form-control form-control-sm" @bind="_ausenciaFechaFin" @bind:format="yyyy-MM-dd" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label">Días</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ausenciaEditando.Dias" min="0" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label">Horas</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ausenciaEditando.Horas" min="0" step="0.5" />
                                        </div>
                                        <div class="col-md-2 d-flex align-items-end">
                                            <div class="form-check mb-2">
                                                <input type="checkbox" class="form-check-input" @bind="_ausenciaEditando.ConGocePago" disabled="@(_ausenciaEditando.Tipo == TipoAusenciaRrhh.Vacaciones)" />
                                                <label class="form-check-label">Con goce</label>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Motivo</label>
                                            <input type="text" class="form-control form-control-sm" @bind="_ausenciaEditando.Motivo" placeholder="Motivo de la ausencia" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Observaciones</label>
                                            <input type="text" class="form-control form-control-sm" @bind="_ausenciaEditando.Observaciones" placeholder="Observaciones adicionales" />
                                        </div>
                                        <div class="col-12 d-flex gap-2">
                                            <button class="btn btn-success btn-sm" disabled="@_guardando" @onclick="GuardarNuevaAusenciaAsync"><i class="bi bi-check me-1"></i>Guardar</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelarNuevaAusencia">Cancelar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (_data!.AusenciasRecientes.Count > 0 || _nuevaAusencia)
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <label class="form-label mb-0 small">Filtrar:</label>
                                <select class="form-select form-select-sm" style="width:auto" @bind="_filtroAusenciaTipo">
                                    <option value="">Todos</option>
                                    <option value="@TipoAusenciaRrhh.Vacaciones">Vacaciones</option>
                                    <option value="@TipoAusenciaRrhh.Permiso">Permisos</option>
                                </select>
                                <span class="text-muted small">@AusenciasFiltradas.Count registro(s)</span>
                            </div>
                        }
                        @if (AusenciasFiltradas.Count == 0 && !_nuevaAusencia)
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-calendar-x"></i>
                                <p>@(_filtroAusenciaTipo.HasValue ? "Sin resultados para el filtro seleccionado" : "Sin ausencias o permisos registrados")</p>
                            </div>
                        }
                        else if (AusenciasFiltradas.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-striped table-hover table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Tipo</th>
                                            <th>Periodo</th>
                                            <th>Días</th>
                                            <th>Horas</th>
                                            <th>Goce</th>
                                            <th>Estatus</th>
                                            <th>Motivo</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var a in AusenciasFiltradas)
                                        {
                                            <tr>
                                                <td><span class="badge @(a.Tipo == TipoAusenciaRrhh.Vacaciones ? "bg-info text-dark" : "bg-warning text-dark")">@ObtenerEtiquetaAusenciaTipo(a.Tipo)</span></td>
                                                <td class="text-nowrap">@a.FechaInicio.ToString("dd/MM/yyyy") – @a.FechaFin.ToString("dd/MM/yyyy")</td>
                                                <td class="text-center">@a.Dias</td>
                                                <td class="text-center">@a.Horas.ToString("0.##")</td>
                                                <td class="text-center">@if(a.ConGocePago){<i class="bi bi-check-circle-fill text-success"></i>}else{<i class="bi bi-x-circle text-danger"></i>}</td>
                                                <td><span class="badge @ObtenerClaseEstatusAusencia(a.Estatus)">@ObtenerEtiquetaEstatusAusencia(a.Estatus)</span></td>
                                                <td class="text-truncate" style="max-width:180px" title="@a.Motivo">@(string.IsNullOrWhiteSpace(a.Motivo) ? "—" : a.Motivo)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;
                    case "saldos":
                        <h6 class="mb-3"><i class="bi bi-bank me-1"></i> Banco de horas</h6>
                        @if (_data!.MovimientosBancoHoras.Count == 0)
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-bank"></i>
                                <p>Sin movimientos en el banco de horas</p>
                            </div>
                        }
                        else
                        {
                            <div class="row g-2 mb-3">
                                <div class="col-auto">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body py-2 px-3">
                                            <div class="ep-field-label">Saldo actual</div>
                                            <div class="fs-5 fw-bold">@FormatearHorasBanco(_data.SaldoBancoHoras)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Tipo</th>
                                            <th>Horas</th>
                                            <th>Saldo acumulado</th>
                                            <th>Observaciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var movsOrdenados = _data.MovimientosBancoHoras.OrderBy(m => m.Fecha).ToList();
                                            var saldosAcumulados = new decimal[movsOrdenados.Count];
                                            decimal saldo = 0;
                                            for (var i = 0; i < movsOrdenados.Count; i++)
                                            {
                                                saldo += movsOrdenados[i].Horas;
                                                saldosAcumulados[i] = saldo;
                                            }
                                        }
                                        @for (var i = movsOrdenados.Count - 1; i >= 0; i--)
                                        {
                                            var m = movsOrdenados[i];
                                            <tr>
                                                <td class="text-nowrap">@m.Fecha.ToString("dd/MM/yyyy")</td>
                                                <td><span class="badge @(m.Horas >= 0 ? "bg-success" : "bg-danger")">@ObtenerEtiquetaMovimientoBanco(m.TipoMovimiento)</span></td>
                                                <td class="text-center @(m.Horas >= 0 ? "text-success" : "text-danger") fw-bold">@FormatearHorasBanco(m.Horas)</td>
                                                <td class="text-center fw-bold">@FormatearHorasBanco(saldosAcumulados[i])</td>
                                                <td class="text-truncate" style="max-width:200px" title="@m.Observaciones">@(string.IsNullOrWhiteSpace(m.Observaciones) ? "—" : m.Observaciones)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;
                    case "conceptos":
                        <h6 class="mb-3"><i class="bi bi-list-check me-1"></i>Conceptos de nómina</h6>
                        @if (_data!.ConceptosNomina.Count == 0)
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-list-check"></i>
                                <p>Sin conceptos de nómina asignados</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr><th>Concepto</th><th>Naturaleza</th><th>Tipo cálculo</th><th>Monto</th><th>%</th><th>Cant.</th><th>Tarifa</th><th>Saldo</th><th>Recurrente</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var c in _data.ConceptosNomina)
                                        {
                                            <tr>
                                                <td>@c.ConceptoConfig.Nombre</td>
                                                <td><span class="badge @(c.ConceptoConfig.Naturaleza == NaturalezaConceptoNominaRrhh.Percepcion ? "bg-success" : c.ConceptoConfig.Naturaleza == NaturalezaConceptoNominaRrhh.Deduccion ? "bg-danger" : "bg-secondary")">@ObtenerEtiquetaNaturaleza(c.ConceptoConfig.Naturaleza)</span></td>
                                                <td class="text-muted small">@ObtenerEtiquetaTipoCalculo(c.ConceptoConfig.TipoCalculo)</td>
                                                <td class="text-center">@(c.Monto > 0 ? c.Monto.ToString("C2") : "—")</td>
                                                <td class="text-center">@(c.Porcentaje > 0 ? $"{c.Porcentaje}%" : "—")</td>
                                                <td class="text-center">@(c.Cantidad > 0 ? c.Cantidad.ToString() : "—")</td>
                                                <td class="text-center">@(c.Tarifa > 0 ? c.Tarifa.ToString("C2") : "—")</td>
                                                <td class="text-center">@(c.Saldo > 0 ? c.Saldo.ToString("C2") : "—")</td>
                                                <td class="text-center">@if(c.EsRecurrente){<i class="bi bi-check-circle text-success"></i>}else{<i class="bi bi-dash-circle text-secondary"></i>}</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;
                    case "notas":
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0"><i class="bi bi-chat-left-text me-1"></i>Notas del empleado</h6>
                            @if (_puedeEditar && !_editandoNotas)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="IniciarEdicionNotas"><i class="bi bi-pencil me-1"></i>Editar</button>
                            }
                        </div>
                        @if (_editandoNotas)
                        {
                            <div class="mb-2">
                                <textarea class="form-control form-control-sm" rows="6" @bind="_notasEditando" placeholder="Escribe notas sobre el empleado..."></textarea>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary btn-sm" disabled="@_guardando" @onclick="GuardarNotasAsync"><i class="bi bi-check me-1"></i>Guardar</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => _editandoNotas = false)">Cancelar</button>
                            </div>
                        }
                        else if (string.IsNullOrWhiteSpace(e.Notas))
                        {
                            <div class="ep-empty-state">
                                <i class="bi bi-chat-left-text"></i>
                                <p>Sin notas registradas</p>
                            </div>
                        }
                        else
                        {
                            <div class="ep-note-card">
                                <div class="ep-note-card__body">
                                    <i class="bi bi-quote ep-note-card__quote-icon"></i>
                                    <p class="ep-note-card__text">@e.Notas</p>
                                </div>
                                @if (_data!.Empleado.UpdatedAt is not null)
                                {
                                    <div class="ep-note-card__footer">
                                        <i class="bi bi-clock-history me-1"></i>Última actualización: @_data.Empleado.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                }
                            </div>
                        }
                        break;
                }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
}