@page "/rrhh/asistencias"
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Entities
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject IRrhhAsistenciaProcessor RrhhAsistenciaProcessor
@inject IRrhhTiempoExtraResolutionService TiempoExtraResolutionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Asistencias</PageTitle>


<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver asistencias.</div>
    }
    else
    {
        <div class="asis-page-shell">
            <div class="asis-page-hero">
                <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                    <div>
                        <div class="asis-page-hero__eyebrow">Seguimiento diario de RRHH</div>
                        <h1 class="asis-page-hero__title"><i class="bi bi-calendar-check me-2"></i>Asistencias</h1>
                        <p class="asis-page-hero__subtitle">Consulta asistencias calculadas, detecta qué días requieren revisión y abre el wizard de corrección cuando haga falta.</p>
                        <div class="asis-page-hero__summary">
                            <span class="asis-top-pill"><i class="bi bi-list-check"></i>@lista.Count registro(s)</span>
                            <span class="asis-top-pill"><i class="bi bi-exclamation-triangle"></i>@lista.Count(a => a.RequiereRevision) por revisar</span>
                            <span class="asis-top-pill"><i class="bi bi-eye"></i>Visible @FormatearMinutos(lista.Sum(a => ObtenerMinutosTrabajadosVisibles(a)))</span>
                        </div>
                    </div>
                    <div class="asis-toolbar-actions">
                        <a class="btn btn-outline-secondary" href="/rrhh/prenominas"><i class="bi bi-calendar2-week me-1"></i>Ir a prenómina</a>
                        <a class="btn btn-success shadow-sm" href="/rrhh/asistencias-semanal"><i class="bi bi-calendar-week me-1"></i>Resumen semanal</a>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-list me-1"></i>Más opciones
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <a class="dropdown-item" href="/configuracion/asistencia"><i class="bi bi-sliders me-2"></i>Reglas descansos</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/rrhh/control-tiempo"><i class="bi bi-stopwatch me-2"></i>Control de tiempos</a>
                                </li>
                            </ul>
                        </div>
                        @if (_puedeReprocesar)
                        {
                            <button class="btn btn-outline-primary" @onclick="AlternarReproceso" disabled="@cargando"><i class="bi bi-arrow-clockwise me-1"></i>@(mostrarReproceso ? "Ocultar reproceso" : "Reprocesar")</button>
                        }
                        <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-arrow-repeat me-1"></i>Actualizar</button>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">@error</div>
            }

            @if (!string.IsNullOrWhiteSpace(ok))
            {
                <div class="alert alert-success">@ok</div>
            }

            @if (_puedeReprocesar && mostrarReproceso)
            {
                <div class="asis-filter-card">
                    <div class="asis-filter-card__head">
                        <div class="asis-filter-card__title">Reproceso de asistencias</div>
                        <div class="asis-filter-card__text">Úsalo cuando cambian marcaciones, turnos o relaciones de checador y necesitas recalcular días anteriores.</div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-2">
                                <label class="form-label">Desde</label>
                                <InputDate class="form-control" @bind-Value="reprocesoDesde" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Hasta</label>
                                <InputDate class="form-control" @bind-Value="reprocesoHasta" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Empleado</label>
                                <InputSelect class="form-select" @bind-Value="reprocesoEmpleadoIdTexto">
                                    <option value="">Todos</option>
                                    @foreach (var empleado in empleadosReproceso)
                                    {
                                        <option value="@empleado.Id.ToString()">@empleado.NombreCompleto (@empleado.NumeroEmpleado)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Motivo</label>
                                <InputText class="form-control" @bind-Value="reprocesoMotivo" placeholder="Ej. alta tardía de empleados o corrección de turno" />
                            </div>
                            <div class="col-12 d-flex gap-2 flex-wrap">
                                <button class="btn btn-primary" @onclick="EjecutarReprocesoAsync" disabled="@reprocesando">
                                    <i class="bi bi-arrow-repeat me-1"></i>@(reprocesando ? "Reprocesando..." : "Ejecutar reproceso")
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="AlternarReproceso" disabled="@reprocesando">Cancelar</button>
                            </div>
                            <div class="col-12">
                                <small class="text-muted">El reproceso vuelve a intentar ligar marcaciones sin empleado usando `CodigoChecador` y luego recalcula la asistencia del rango seleccionado.</small>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row g-3">
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card">
                        <span class="asis-stat-card__icon"><i class="bi bi-list-check"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Mostradas</div>
                            <div class="asis-stat-card__value">@lista.Count</div>
                            <div class="asis-stat-card__hint">Registros actualmente visibles con los filtros activos.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card asis-stat-card--warn">
                        <span class="asis-stat-card__icon"><i class="bi bi-exclamation-triangle"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Con revisión</div>
                            <div class="asis-stat-card__value">@lista.Count(a => a.RequiereRevision)</div>
                            <div class="asis-stat-card__hint">Días que todavía necesitan validación operativa o ajuste manual.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card asis-stat-card--danger">
                        <span class="asis-stat-card__icon"><i class="bi bi-alarm"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Retardos</div>
                            <div class="asis-stat-card__value">@lista.Count(a => a.MinutosRetardo > 0)</div>
                            <div class="asis-stat-card__hint">Días con entrada tardía registrada.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card asis-stat-card--warn">
                        <span class="asis-stat-card__icon"><i class="bi bi-calendar-x"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Sin turno</div>
                            <div class="asis-stat-card__value">@lista.Count(a => a.TurnoBaseId == null)</div>
                            <div class="asis-stat-card__hint">Días que probablemente necesitan revisar turno o captura.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card asis-stat-card--success">
                        <span class="asis-stat-card__icon"><i class="bi bi-stopwatch"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Trabajo neto</div>
                            <div class="asis-stat-card__value">@FormatearMinutos(lista.Sum(a => a.MinutosTrabajadosNetos))</div>
                            <div class="asis-stat-card__hint">Sin contar extra ni aprobaciones.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="asis-stat-card asis-stat-card--resolved">
                        <span class="asis-stat-card__icon"><i class="bi bi-eye"></i></span>
                        <div>
                            <div class="asis-stat-card__label">Trabajo visible</div>
                            <div class="asis-stat-card__value">@FormatearMinutos(lista.Sum(a => ObtenerMinutosTrabajadosVisibles(a)))</div>
                            <div class="asis-stat-card__hint">Base trabajada + compensación aprobada + extra aprobada.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="asis-filter-card">
                <div class="asis-filter-card__head">
                    <div class="asis-filter-card__title">Filtros de búsqueda</div>
                    <div class="asis-filter-card__text">Usa filtros para concentrarte en empleados, días y tipos de incidencia específicos.</div>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-2">
                            <label class="form-label">Desde</label>
                            <InputDate class="form-control" @bind-Value="filtroDesde" @bind-Value:after="GuardarFiltrosPersistidosAsync" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Hasta</label>
                            <InputDate class="form-control" @bind-Value="filtroHasta" @bind-Value:after="GuardarFiltrosPersistidosAsync" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Turno</label>
                            <InputSelect class="form-select" @bind-Value="filtroTurnoIdTexto" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                                <option value="">Todos</option>
                                @foreach (var turno in turnos)
                                {
                                    <option value="@turno.Id.ToString()">@turno.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Estatus</label>
                            <InputSelect class="form-select" @bind-Value="filtroEstatus" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                                <option value="todos">Todos</option>
                                @foreach (var estatus in estatusDisponibles)
                                {
                                    <option value="@((int)estatus).ToString()">@ObtenerTextoEstatus(estatus)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Empleado</label>
                            <InputText class="form-control" @bind-Value="filtroEmpleado" @bind-Value:after="GuardarFiltrosPersistidosAsync" placeholder="Nombre, número o código" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Revisión</label>
                            <InputSelect class="form-select" @bind-Value="filtroRevision" @bind-Value:after="GuardarFiltrosPersistidosAsync">
                                <option value="todos">Todos</option>
                                <option value="si">Con revisión</option>
                                <option value="no">Sin revisión</option>
                            </InputSelect>
                        </div>
                        <div class="col-12 d-flex gap-2 flex-wrap">
                            <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando"><i class="bi bi-search me-1"></i>Aplicar filtros</button>
                            <button class="btn btn-outline-secondary" @onclick="LimpiarFiltros" disabled="@cargando">Limpiar</button>
                            <button class="btn btn-outline-success" @onclick="ExportarCsvAsync" disabled="@(cargando || exportandoCsv)"><i class="bi bi-filetype-csv me-1"></i>@(exportandoCsv ? "Exportando..." : "Exportar CSV")</button>
                        </div>
                    </div>
                </div>

            <div class="asis-table-wrap">
                <div class="asis-table-topbar">
                    <div>
                        <div class="asis-table-topbar__title">Listado de asistencias</div>
                        <div class="asis-table-topbar__subtitle">Cada fila resume el día y te permite abrir corrección cuando haga falta.</div>
                    </div>
                    <div class="asis-legend-bar">
                        <span class="asis-legend-pill"><span class="asis-legend-pill__dot asis-legend-pill__dot--review"></span>Requiere revisión</span>
                        <span class="asis-legend-pill"><span class="asis-legend-pill__dot asis-legend-pill__dot--resolved"></span>Día atendido</span>
                        <span class="asis-legend-pill"><span class="asis-legend-pill__dot asis-legend-pill__dot--normal"></span>Sin señal crítica</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0 align-middle asis-table">
                        <thead class="table-dark">
                            <tr>
                                <th class="asis-fecha-cell">Fecha</th>
                                <th>Empleado</th>
                                <th>Horario</th>
                                <th>Trabajado</th>
                                <th>Incidencias</th>
                                <th>Estatus / Revisión</th>
                                <th>Descansos</th>
                                <th>Ajuste / Aus.</th>
                                @if (_puedeReprocesar)
                                {
                                    <th></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (lista.Count == 0)
                            {
                                <tr><td colspan="@(_puedeReprocesar ? 9 : 8)" class="asis-empty-list">No hay asistencias para los filtros seleccionados.</td></tr>
                            }
                            else
                            {
                                @foreach (var item in lista)
                                {
                                    var revisionVisual = ObtenerVisualRevision(item);
                                    var descansoVisual = ObtenerVisualDescansos(item);
                                    var resolucionVisual = ObtenerVisualResolucion(item);
                                    var ausenciaVisual = ObtenerVisualAusencia(item);
                                    var observacionesTooltip = ObtenerTooltipObservaciones(item);
                                    var inicialNombre = item.Empleado.Nombre.Length > 0 ? item.Empleado.Nombre[0].ToString().ToUpperInvariant() : "?";
                                    var avatarClass = item.RequiereRevision ? "asis-avatar--warn" : (TieneResolucionTiempoAplicada(item) ? "asis-avatar--success" : "asis-avatar--muted");

                                    <tr class="@ObtenerClaseFilaAsistencia(item)">
                                        
                                        <td class="asis-fecha-cell">
                                            <div class="asis-fecha-dow">@ObtenerDiaSemanaCorto(item.Fecha)</div>
                                            <div class="asis-fecha-dia">@item.Fecha.Day.ToString("D2")</div>
                                            <div class="asis-fecha-mes">@item.Fecha.ToString("MMM yy")</div>
                                        </td>
                                        
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="asis-avatar @avatarClass">@inicialNombre</span>
                                                <div class="asis-stack">
                                                    <div class="asis-cell-title asis-truncate asis-truncate--empleado">@item.Empleado.NombreCompleto</div>
                                                    <div class="asis-cell-subtitle">
                                                        <i class="bi bi-hash"></i>@item.Empleado.NumeroEmpleado
                                                        @if (!string.IsNullOrWhiteSpace(item.TurnoBase?.Nombre))
                                                        {
                                                            <span class="ms-1 text-muted">· @item.TurnoBase.Nombre</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="ms-1 text-warning">· Sin turno</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-time-block">
                                                <div class="asis-time-block__row">
                                                    <span class="asis-time-block__badge">Prog</span>
                                                    <span class="asis-time-block__val @(item.HoraEntradaProgramada == null ? "asis-time-block__val--empty" : "")">@FormatearHoraCompacta(item.HoraEntradaProgramada)</span>
                                                    <i class="bi bi-arrow-right asis-sep-arrow"></i>
                                                    <span class="asis-time-block__val @(item.HoraSalidaProgramada == null ? "asis-time-block__val--empty" : "")">@FormatearHoraCompacta(item.HoraSalidaProgramada)</span>
                                                </div>
                                                <div class="asis-time-block__row">
                                                    <span class="asis-time-block__badge">Real</span>
                                                    <span class="asis-time-block__val @(item.HoraEntradaReal == null ? "asis-time-block__val--empty" : "")">@FormatearHoraCompacta(item.HoraEntradaReal)</span>
                                                    <i class="bi bi-arrow-right asis-sep-arrow"></i>
                                                    <span class="asis-time-block__val @(item.HoraSalidaReal == null ? "asis-time-block__val--empty" : "")">@FormatearHoraCompacta(item.HoraSalidaReal)</span>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-stack">
                                                <div class="asis-cell-title">@FormatearMinutos(ObtenerMinutosTrabajadosVisibles(item))</div>
                                                <div class="asis-cell-subtitle" title="Bruto detectado"><i class="bi bi-hourglass me-1"></i>@FormatearMinutos(item.MinutosTrabajadosBrutos)</div>
                                                @if (item.MinutosJornadaNetaProgramada > 0)
                                                {
                                                    <div class="asis-cell-subtitle" title="Jornada neta programada"><i class="bi bi-calendar-range me-1"></i>@FormatearMinutos(item.MinutosJornadaNetaProgramada)</div>
                                                }
                                                @if (ObtenerMinutosCompensados(item) > 0)
                                                {
                                                    <span class="asis-chip asis-chip--info asis-chip--xs" title="Compensación integrada"><i class="bi bi-plus"></i>comp</span>
                                                }
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-incidencias-group">
                                                @if (item.MinutosRetardo > 0)
                                                {
                                                    <span class="asis-chip asis-chip--warn" title="Retardo"><i class="bi bi-alarm me-1"></i>@FormatearMinutosCortos(item.MinutosRetardo)</span>
                                                }
                                                @if (item.MinutosSalidaAnticipada > 0)
                                                {
                                                    <span class="asis-chip asis-chip--warn" title="Salida anticipada"><i class="bi bi-box-arrow-left me-1"></i>@FormatearMinutosCortos(item.MinutosSalidaAnticipada)</span>
                                                }
                                                @if (item.MinutosExtra > 0)
                                                {
                                                    <span class="asis-chip asis-chip--success" title="Tiempo extra detectado"><i class="bi bi-lightning-charge me-1"></i>@FormatearMinutosCortos(item.MinutosExtra)</span>
                                                }
                                                @if (item.MinutosRetardo == 0 && item.MinutosSalidaAnticipada == 0 && item.MinutosExtra == 0)
                                                {
                                                    <span class="asis-chip asis-chip--muted asis-chip--xs"><i class="bi bi-check2"></i> ok</span>
                                                }
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-estado-dia" title="@observacionesTooltip">
                                                <span class="badge @ObtenerClaseEstatus(item)">@ObtenerTextoEstatusCorto(item.Estatus)</span>
                                                <span class="asis-chip @revisionVisual.BadgeClass asis-detail-trigger" title="@revisionVisual.Tooltip">
                                                    <i class="bi @revisionVisual.Icono"></i>@revisionVisual.Titulo
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(ObtenerObservacionPrincipal(item)) && ObtenerObservacionPrincipal(item) != "—")
                                                {
                                                    <div class="asis-note asis-truncate asis-truncate--nota" title="@observacionesTooltip">@TruncarTexto(ObtenerObservacionPrincipal(item), 55)</div>
                                                }
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-break-card @descansoVisual.CardClass" title="@descansoVisual.Tooltip">
                                                <span class="asis-chip @descansoVisual.BadgeClass asis-detail-trigger"><i class="bi @descansoVisual.Icono me-1"></i>@descansoVisual.Titulo</span>
                                                <div class="asis-cell-subtitle mt-1">@descansoVisual.ResumenMinutos</div>
                                            </div>
                                        </td>
                                        
                                        <td>
                                            <div class="asis-stack">
                                                <span class="asis-chip @resolucionVisual.BadgeClass asis-detail-trigger" title="@resolucionVisual.Tooltip">
                                                    <i class="bi @resolucionVisual.Icono me-1"></i>@resolucionVisual.Titulo
                                                </span>
                                                @if (resolucionVisual.ResumenCorto != "Sin pend." && resolucionVisual.ResumenCorto != "Revisar")
                                                {
                                                    <div class="asis-cell-subtitle">@resolucionVisual.ResumenCorto</div>
                                                }
                                                <span class="asis-chip @ausenciaVisual.BadgeClass asis-chip--xs" title="@ausenciaVisual.Tooltip">
                                                    <i class="bi @ausenciaVisual.Icono"></i>@ausenciaVisual.Titulo
                                                </span>
                                            </div>
                                        </td>
                                        @if (_puedeReprocesar)
                                        {
                                            <td>
                                                <button class="asis-action-btn" @onclick="() => AbrirCorreccionDiaAsync(item)" title="Abrir wizard de corrección del día">
                                                    <i class="bi bi-pencil-square"></i>Revisar
                                                </button>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            </div>

            <AsistenciasCorreccionModal
                Visible="@(_puedeReprocesar && mostrarCorreccionDia && asistenciaSeleccionada != null)"
                Asistencia="asistenciaSeleccionada"
                Turnos="turnos"
                PuedeReprocesar="_puedeReprocesar"
                PuedeAprobarTiempoExtra="_puedeAprobarTiempoExtra"
                OnClose="CerrarCorreccionDia"
                OnUpdated="RecargarListadoAsync" />
        </div>
    }
</div>
