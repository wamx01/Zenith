@page "/rrhh/nominas/recibos/{NominaId:guid}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject INominaPdfService NominaPdfService
@inject INominaReciboBuilder NominaReciboBuilder
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<RecibosNomina> Logger
@rendermode InteractiveServer

<PageTitle>Recibos de Nómina</PageTitle>

<style>
    .recibos-print-wrap {
        max-width: 1200px;
        margin: 0 auto;
    }

    .recibos-print-stack {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    @@media print {
        .no-print {
            display: none !important;
        }

        .recibos-print-stack {
            gap: .75rem;
        }

        .recibos-print-page {
            page-break-after: always;
        }

        .recibos-print-page:last-child {
            page-break-after: auto;
        }
    }
</style>

<div class="container-fluid px-4 py-3 recibos-print-wrap">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning">No tienes permisos para ver recibos de nómina.</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (detalles.Count == 0)
    {
        <div class="text-center py-5 text-muted">No hay recibos para imprimir.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3 no-print">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-printer me-2"></i>Impresión masiva de recibos</h1>
                <div class="text-muted small">Nómina: @NumeroNominaDisplay · Periodo: @PeriodoNomina</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="/rrhh/nominas"><i class="bi bi-arrow-left me-1"></i>Volver</a>
                <a class="btn btn-primary" href="@($"/api/nomina/{NominaId}/recibos/pdf")" target="_blank"><i class="bi bi-file-earmark-pdf me-1"></i>PDF de todos</a>
            </div>
        </div>

        <div class="recibos-print-stack">
            @foreach (var item in detalles)
            {
                <div class="recibos-print-page">
                    <NominaReciboCard Detalle="item" Recibo="recibos[item.Id]" />
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid NominaId { get; set; }

    private List<NominaDetalle> detalles = [];
    private Dictionary<Guid, NominaReciboResult> recibos = [];
    private bool _puedeVer;
    private Guid _empresaId;
    private string? error;
    private string NumeroNominaDisplay => detalles.FirstOrDefault()?.Nomina.NumeroNomina ?? "—";
    private string PeriodoNomina => detalles.FirstOrDefault()?.Nomina.Periodo ?? "—";

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
        {
            await CargarDetalleAsync();
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "nominas.ver");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
        if (_empresaId == Guid.Empty)
            _puedeVer = false;
    }

    private async Task CargarDetalleAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            detalles = await db.NominaDetalles
                .AsNoTracking()
                .Include(d => d.Empleado)
                    .ThenInclude(e => e.Posicion)
                .Include(d => d.BonosEstructurados.Where(b => b.IsActive))
                    .ThenInclude(b => b.Detalles.Where(x => x.IsActive))
                        .ThenInclude(x => x.BonoRubroRrhh)
                .Include(d => d.PercepcionesManuales.Where(p => p.IsActive))
                    .ThenInclude(p => p.TipoPercepcion)
                .Include(d => d.DeduccionesEstructuradas.Where(x => x.IsActive))
                    .ThenInclude(x => x.TipoDeduccion)
                .Include(d => d.Nomina)
                    .ThenInclude(n => n.Empresa)
                .Where(d => d.NominaId == NominaId && d.Nomina.EmpresaId == _empresaId)
                .OrderBy(d => d.Empleado.Nombre)
                .ThenBy(d => d.Empleado.ApellidoPaterno)
                .ToListAsync();

            recibos = detalles.ToDictionary(d => d.Id, NominaReciboBuilder.Build);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando recibos masivos de nómina {NominaId}", NominaId);
            error = "Ocurrió un error al cargar los recibos. Intenta de nuevo o contacta al administrador.";
        }
    }
}
