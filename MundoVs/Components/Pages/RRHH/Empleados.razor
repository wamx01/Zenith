@page "/rrhh/empleados"
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Serigrafia
@rendermode InteractiveServer

<PageTitle>Empleados</PageTitle>

<div class="container-fluid px-3 px-md-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver empleados.</div>
    }
    else
    {
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="display-6 fw-bold"><i class="bi bi-person-vcard me-2"></i>Empleados</h1>
        @if (_puedeEditar)
        {
            <button class="btn btn-primary" @onclick="Nuevo"><i class="bi bi-plus-circle me-1"></i>Nuevo Empleado</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger">@error</div> }
    @if (!string.IsNullOrEmpty(ok)) { <div class="alert alert-success">@ok</div> }

    @if (mostrarForm)
    {
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">@(editando.Id == Guid.Empty ? "Nuevo Empleado" : "Editar Empleado")</h5></div>
            <div class="card-body">
                <EditForm Model="editando" OnValidSubmit="Guardar">
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <label class="form-label">Número de empleado</label>
                            <InputText class="form-control" @bind-Value="editando.NumeroEmpleado" />
                            <small class="text-muted">Captura el número administrativo del empleado.</small>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Código checador</label>
                            <InputText class="form-control" @bind-Value="editando.CodigoChecador" />
                            <small class="text-muted">Debe coincidir con el código que envía el reloj.</small>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Nombre</label>
                            <InputText class="form-control" @bind-Value="editando.Nombre" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Apellido Paterno</label>
                            <InputText class="form-control" @bind-Value="editando.ApellidoPaterno" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Apellido Materno</label>
                            <InputText class="form-control" @bind-Value="editando.ApellidoMaterno" />
                        </div>
                        <div class="col-6 col-md-1">
                            <div class="form-check mt-md-4">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.IsActive" />
                                <label class="form-check-label">Activo</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">CURP</label>
                            <InputText class="form-control" @bind-Value="editando.Curp" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">NSS</label>
                            <InputText class="form-control" @bind-Value="editando.Nss" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Teléfono</label>
                            <InputText class="form-control" @bind-Value="editando.Telefono" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="editando.Email" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">Dirección</label>
                            <InputText class="form-control" @bind-Value="editando.Direccion" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Fecha Nacimiento</label>
                            <InputDate class="form-control" @bind-Value="editando.FechaNacimiento" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Fecha Contratación</label>
                            <InputDate class="form-control" @bind-Value="editando.FechaContratacion" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Posición</label>
                            <InputSelect class="form-select" @bind-Value="editando.PosicionId">
                                <option value="">Seleccione...</option>
                                @foreach (var posicion in posiciones)
                                {
                                    <option value="@posicion.Id">@posicion.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Departamento</label>
                            <InputSelect class="form-select" @bind-Value="editando.Departamento">
                                <option value="">Seleccione...</option>
                                @foreach (var departamento in DepartamentosDisponibles)
                                {
                                    <option value="@departamento">@departamento</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12"><hr /><h6 class="text-muted">Turno</h6></div>
                        <div class="col-6 col-md-4">
                            <label class="form-label">Turno vigente</label>
                            <InputSelect class="form-select" @bind-Value="turnoSeleccionadoId">
                                <option value="">(sin turno)</option>
                                @foreach (var turno in turnosBase)
                                {
                                    <option value="@turno.Id">@ObtenerEtiquetaTurno(turno)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Vigente desde</label>
                            <InputDate class="form-control" @bind-Value="turnoVigenteDesde" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Vigente hasta</label>
                            <InputDate class="form-control" @bind-Value="turnoVigenteHasta" />
                            <small class="text-muted">Usa la misma fecha para cambio de un solo día.</small>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Observaciones de turno</label>
                            <InputText class="form-control" @bind-Value="turnoObservaciones" placeholder="Ej. cambio temporal o reasignación operativa" />
                        </div>

                        @if (historialTurnos.Count > 0)
                        {
                            <div class="col-12">
                                <details class="mt-2">
                                    <summary class="text-muted small">Historial de turnos (@historialTurnos.Count)</summary>
                                    <table class="table table-sm table-bordered mt-1 mb-0">
                                        <thead class="table-light"><tr><th>Turno</th><th>Desde</th><th>Hasta</th><th>Observaciones</th></tr></thead>
                                        <tbody>
                                            @foreach (var h in historialTurnos)
                                            {
                                                <tr>
                                                    <td>@h.NombreTurno</td>
                                                    <td>@h.Desde.ToString("dd/MM/yyyy")</td>
                                                    <td>@(h.Hasta?.ToString("dd/MM/yyyy") ?? "(vigente)")</td>
                                                    <td>@(string.IsNullOrWhiteSpace(h.Observaciones) ? "—" : h.Observaciones)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </details>
                            </div>
                        }

                        <div class="col-12">
                            <div class="row g-3">
                                <div class="col-6 col-md-3">
                                    <div class="card border-0 bg-light h-100">
                                        <div class="card-body py-2">
                                            <div class="small text-muted">Vacaciones disponibles</div>
                                            <div class="fw-bold">@ObtenerSaldoVacaciones(editando.Id).ToString("0.##") días</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="card border-0 bg-light h-100">
                                        <div class="card-body py-2">
                                            <div class="small text-muted">Banco de horas</div>
                                            <div class="fw-bold">@FormatearHorasBanco(ObtenerSaldoBancoHoras(editando.Id))</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <label class="form-label">Sueldo Base</label>
                            <InputNumber class="form-control" @bind-Value="editando.SueldoSemanal" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Periodicidad</label>
                            <InputSelect class="form-select" @bind-Value="editando.PeriodicidadPago">
                                <option value="@PeriodicidadPago.Semanal">Semanal</option>
                                <option value="@PeriodicidadPago.Quincenal">Quincenal</option>
                                <option value="@PeriodicidadPago.Mensual">Mensual</option>
                            </InputSelect>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check mt-md-4">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.AplicaImss" />
                                <label class="form-check-label">Aplica IMSS</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="form-check mt-md-4">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.AplicaIsr" />
                                <label class="form-check-label">Aplica ISR</label>
                            </div>
                        </div>
                        <div class="col-12"><hr /><h6 class="text-muted">Infonavit</h6></div>
                        <div class="col-6 col-md-3">
                            <div class="form-check mt-md-4">
                                <InputCheckbox class="form-check-input" @bind-Value="editando.AplicaInfonavit" />
                                <label class="form-check-label">Aplica Infonavit</label>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label">Número de crédito</label>
                            <InputText class="form-control" @bind-Value="editando.NumeroCreditoInfonavit" disabled="@(!editando.AplicaInfonavit)" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Factor descuento</label>
                            <InputNumber class="form-control" @bind-Value="editando.FactorDescuentoInfonavit" disabled="@(!editando.AplicaInfonavit)" />
                            <small class="text-muted">Usa porcentaje si es menor o igual a 1; si es mayor se toma como monto fijo.</small>
                        </div>
                        <div class="col-12"><hr /><h6 class="text-muted">Esquema de Pago</h6></div>
                        <div class="col-6 col-md-4">
                            <label class="form-label">Esquema</label>
                            <InputSelect class="form-select" @bind-Value="esquemaSeleccionadoId">
                                <option value="">(sin esquema)</option>
                                @foreach (var esq in esquemasPago)
                                {
                                    <option value="@esq.Id">@esq.Nombre — @TipoEsquemaLabel(esq.Tipo)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Vigente desde</label>
                            <InputDate class="form-control" @bind-Value="esquemaVigenteDesde" />
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label">Sueldo base override</label>
                            <InputNumber class="form-control" @bind-Value="esquemaSueldoOverride" />
                            <small class="text-muted">Dejar en 0 para usar el sugerido</small>
                        </div>

                        @if (historialEsquemas.Count > 0)
                        {
                            <div class="col-12">
                                <details class="mt-2">
                                    <summary class="text-muted small">Historial de esquemas (@historialEsquemas.Count)</summary>
                                    <table class="table table-sm table-bordered mt-1 mb-0">
                                        <thead class="table-light"><tr><th>Esquema</th><th>Desde</th><th>Hasta</th><th class="text-end">Override</th></tr></thead>
                                        <tbody>
                                            @foreach (var h in historialEsquemas)
                                            {
                                                <tr>
                                                    <td>@h.NombreEsquema</td>
                                                    <td>@h.Desde.ToString("dd/MM/yyyy")</td>
                                                    <td>@(h.Hasta?.ToString("dd/MM/yyyy") ?? "(vigente)")</td>
                                                    <td class="text-end">@(h.Override.HasValue ? h.Override.Value.ToString("C2") : "—")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </details>
                            </div>
                        }

                        <div class="col-12"><hr /><h6 class="text-muted">Conceptos recurrentes de nómina</h6></div>
                        <div class="col-12">
                            <div class="alert alert-light border small py-2 mb-3">
                                <strong>Uso rápido:</strong> para descuento fijo de IMSS usa <em>IMSS fijo obrero</em> o <em>IMSS fijo patronal</em>. Para ingresos recurrentes usa <em>Percepción recurrente</em>, <em>Premio puntualidad recurrente</em> o <em>Premio asistencia recurrente</em>.
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6 col-md-3">
                                    <label class="form-label">Concepto configurable</label>
                                    <InputSelect class="form-select form-select-sm" @bind-Value="conceptoEmpleadoTipoSeleccionadoId">
                                        <option value="">Seleccione...</option>
                                        @foreach (var concepto in conceptosNominaDisponibles)
                                        {
                                            <option value="@concepto.Id">@concepto.Nombre (@concepto.Naturaleza)</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-4 col-md-2">
                                    <label class="form-label">Monto</label>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Monto" />
                                </div>
                                <div class="col-4 col-md-2">
                                    <label class="form-label">Porcentaje</label>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Porcentaje" />
                                </div>
                                <div class="col-4 col-md-2">
                                    <label class="form-label">Cantidad</label>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Cantidad" />
                                </div>
                                <div class="col-4 col-md-2">
                                    <label class="form-label">Tarifa</label>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Tarifa" />
                                </div>
                                <div class="col-4 col-md-1">
                                    <label class="form-label">Límite</label>
                                    <InputNumber class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Limite" />
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label">Fecha inicio</label>
                                    <InputDate class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.FechaInicio" />
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label">Fecha fin</label>
                                    <InputDate class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.FechaFin" />
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="form-label">Observaciones</label>
                                    <InputText class="form-control form-control-sm" @bind-Value="conceptoEmpleadoEnCaptura.Observaciones" />
                                </div>
                                <div class="col-6 col-md-2 d-flex align-items-end">
                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="conceptoEmpleadoEnCaptura.EsRecurrente" />
                                        <label class="form-check-label">Recurrente</label>
                                    </div>
                                </div>
                                <div class="col-12 d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-primary" @onclick="AgregarOActualizarConceptoEmpleado">@(conceptoEmpleadoEnCaptura.Id == Guid.Empty ? "Agregar" : "Actualizar")</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PrepararNuevoConceptoEmpleado">Limpiar</button>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm table-bordered align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Concepto</th>
                                            <th class="text-end">Monto</th>
                                            <th class="text-end">%</th>
                                            <th class="text-end">Cant.</th>
                                            <th class="text-end">Tarifa</th>
                                            <th>Vigencia</th>
                                            <th class="text-center">Rec.</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (conceptosEmpleadoEditando.Count == 0)
                                        {
                                            <tr><td colspan="8" class="text-center text-muted py-3">No hay conceptos recurrentes asignados.</td></tr>
                                        }
                                        else
                                        {
                                            @foreach (var item in conceptosEmpleadoEditando.OrderBy(c => c.Orden).ThenBy(c => c.ConceptoNombre))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-semibold">@item.ConceptoNombre</div>
                                                        <div class="small text-muted">@item.Naturaleza · @item.Destino</div>
                                                    </td>
                                                    <td class="text-end">@item.Monto.ToString("C2")</td>
                                                    <td class="text-end">@item.Porcentaje.ToString("0.####")</td>
                                                    <td class="text-end">@item.Cantidad.ToString("0.####")</td>
                                                    <td class="text-end">@item.Tarifa.ToString("0.####")</td>
                                                    <td class="small">@(item.FechaInicio?.ToString("dd/MM/yyyy") ?? "—") - @(item.FechaFin?.ToString("dd/MM/yyyy") ?? "Vigente")</td>
                                                    <td class="text-center">@(item.EsRecurrente ? "Sí" : "No")</td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => EditarConceptoEmpleado(item)"><i class="bi bi-pencil"></i></button>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarConceptoEmpleado(item)"><i class="bi bi-trash"></i></button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="form-text">Aquí asignas descuentos fijos, IMSS/ISR fijo, provisiones y percepciones recurrentes específicas del empleado.</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <InputTextArea class="form-control" @bind-Value="editando.Notas" rows="2" />
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-success" type="submit" disabled="@guardando"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => mostrarForm = false">Cancelar</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body p-0">
            @if (_puedeEditar)
            {
                <div class="d-flex flex-wrap align-items-center gap-2 px-3 pt-3">
                    <div class="input-group" style="max-width:420px">
                        <span class="input-group-text d-none d-sm-inline">Turno lote</span>
                        <span class="input-group-text d-sm-none"><i class="bi bi-clock"></i></span>
                        <InputSelect class="form-select" @bind-Value="turnoBulkSeleccionadoId">
                            <option value="">(sin turno)</option>
                            @foreach (var turno in turnosBase)
                            {
                                <option value="@turno.Id">@ObtenerEtiquetaTurno(turno)</option>
                            }
                        </InputSelect>
                    </div>
                    <button class="btn btn-outline-primary" @onclick="AplicarTurnoBulk" disabled="@(guardando || empleadosSeleccionados.Count == 0)">
                        <i class="bi bi-people me-1"></i>Aplicar a selección
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="AlternarSeleccionTodos">
                        <i class="bi @(EstanTodosSeleccionados ? "bi-x-square" : "bi-check2-square") me-1"></i>@(EstanTodosSeleccionados ? "Quitar selección" : "Seleccionar todos")
                    </button>
                    <span class="badge text-bg-light">Seleccionados: @empleadosSeleccionados.Count</span>
                </div>
            }

            <div class="d-none d-md-block">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        @if (_puedeEditar)
                        {
                            <th class="text-center" style="width:52px">Sel.</th>
                        }
                        <th>No. Empleado</th><th>Cód. checador</th><th>Nombre</th><th>Posición</th><th>Depto</th>
                        <th class="text-end">Vacaciones</th><th class="text-end">Banco horas</th><th class="text-end">Sueldo Base</th><th>Periodicidad</th><th>IMSS</th><th>ISR</th><th>Infonavit</th><th>Esquema</th><th>Turno</th>
                        <th>F. Contratación</th><th class="text-center">Activo</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in lista)
                    {
                        <tr>
                            @if (_puedeEditar)
                            {
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input" checked="@empleadosSeleccionados.Contains(e.Id)" @onchange="args => AlternarSeleccionEmpleado(e.Id, args.Value)" />
                                </td>
                            }
                            <td class="fw-semibold">@e.NumeroEmpleado</td>
                            <td>@(string.IsNullOrWhiteSpace(e.CodigoChecador) ? "—" : e.CodigoChecador)</td>
                            <td>@e.Nombre @e.ApellidoPaterno @e.ApellidoMaterno</td>
                            <td>@ObtenerNombreActividad(e)</td>
                            <td>@(e.Departamento ?? "—")</td>
                            <td class="text-end">@ObtenerSaldoVacaciones(e.Id).ToString("0.##")</td>
                            <td class="text-end">@FormatearHorasBanco(ObtenerSaldoBancoHoras(e.Id))</td>
                            <td class="text-end">@e.SueldoSemanal.ToString("C2")</td>
                            <td><span class="badge bg-info text-dark">@e.PeriodicidadPago</span></td>
                            <td><span class="badge @(e.AplicaImss ? "bg-success" : "bg-secondary")">@(e.AplicaImss ? "Sí" : "No")</span></td>
                            <td><span class="badge @(e.AplicaIsr ? "bg-success" : "bg-secondary")">@(e.AplicaIsr ? "Sí" : "No")</span></td>
                            <td><span class="badge @(e.AplicaInfonavit ? "bg-warning text-dark" : "bg-secondary")">@(e.AplicaInfonavit ? "Sí" : "No")</span></td>
                            <td><span class="badge bg-secondary">@ObtenerEsquemaActivo(e.Id)</span></td>
                            <td><span class="badge bg-light text-dark">@(e.TurnoBase?.Nombre ?? "—")</span></td>
                            <td class="text-muted small">@(e.FechaContratacion?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="text-center"><span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Sí" : "No")</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-info me-1" href="@($"/rrhh/empleados/{e.Id}/perfil")" title="Perfil"><i class="bi bi-person-badge"></i></a>
                                @if (_puedeEditar)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(e)"><i class="bi bi-pencil"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            <div class="d-md-none">
                @foreach (var e in lista)
                {
                    <div class="ep-emp-card @(e.IsActive ? "" : "opacity-75")">
                        <div class="ep-emp-card__body">
                            @if (_puedeEditar)
                            {
                                <input type="checkbox" class="form-check-input ep-emp-card__check" checked="@empleadosSeleccionados.Contains(e.Id)" @onchange="args => AlternarSeleccionEmpleado(e.Id, args.Value)" />
                            }
                            <div class="ep-emp-card__name">@e.Nombre @e.ApellidoPaterno @e.ApellidoMaterno</div>
                            <div class="ep-emp-card__meta">
                                <span><i class="bi bi-hash me-1"></i>@e.NumeroEmpleado</span>
                                <span><i class="bi bi-person-workspace me-1"></i>@ObtenerNombreActividad(e)</span>
                                <span><i class="bi bi-building me-1"></i>@(e.Departamento ?? "—")</span>
                            </div>
                            <div class="ep-emp-card__tags">
                                <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">@(e.IsActive ? "Activo" : "Inactivo")</span>
                                <span class="badge bg-light text-dark">@(e.TurnoBase?.Nombre ?? "—")</span>
                                <span class="badge bg-secondary">@ObtenerEsquemaActivo(e.Id)</span>
                                @if (e.AplicaImss) { <span class="badge bg-info text-dark">IMSS</span> }
                                @if (e.AplicaIsr) { <span class="badge bg-warning text-dark">ISR</span> }
                                @if (e.AplicaInfonavit) { <span class="badge bg-danger">Infonavit</span> }
                            </div>
                            <div class="ep-emp-card__nums">
                                <span>@e.SueldoSemanal.ToString("C2") / @e.PeriodicidadPago</span>
                                <span>Vac: @ObtenerSaldoVacaciones(e.Id).ToString("0.##")d</span>
                                <span>Banco: @FormatearHorasBanco(ObtenerSaldoBancoHoras(e.Id))</span>
                            </div>
                        </div>
                        <div class="ep-emp-card__actions">
                            <a class="btn btn-sm btn-outline-info" href="@($"/rrhh/empleados/{e.Id}/perfil")" title="Perfil"><i class="bi bi-person-badge"></i></a>
                            @if (_puedeEditar)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(e)"><i class="bi bi-pencil"></i></button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    }
</div>
