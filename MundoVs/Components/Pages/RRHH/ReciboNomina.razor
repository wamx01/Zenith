@page "/rrhh/nominas/recibo/{DetalleId:guid}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject INominaPdfService NominaPdfService
@inject INominaReciboBuilder NominaReciboBuilder
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ReciboNomina> Logger
@rendermode InteractiveServer

<PageTitle>Recibo de Nómina</PageTitle>

<style>
    .recibo-wrap {
        max-width: 1100px;
        margin: 0 auto;
    }

    @@media print {
        .no-print {
            display: none !important;
        }

        body {
            background: #fff !important;
        }
    }
</style>

<div class="container-fluid px-4 py-3 recibo-wrap">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning">No tienes permisos para ver recibos de nómina.</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (detalle == null)
    {
        <div class="text-center py-5 text-muted">Cargando recibo...</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3 no-print">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-receipt me-2"></i>Recibo de Nómina</h1>
                <div class="text-muted small">Documento imprimible para firma del empleado.</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="/rrhh/nominas"><i class="bi bi-arrow-left me-1"></i>Volver</a>
                <a class="btn btn-primary" href="@($"/api/nomina/recibo/{DetalleId}/pdf")" target="_blank"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</a>
            </div>
        </div>

        <NominaReciboCard Detalle="detalle" Recibo="recibo" />
    }
</div>

@code {
    [Parameter] public Guid DetalleId { get; set; }

    private NominaDetalle? detalle;
    private NominaReciboResult recibo = new();
    private bool _puedeVer;
    private Guid _empresaId;
    private string? error;
    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
            await CargarDetalleAsync();
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "nominas.ver");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
        if (_empresaId == Guid.Empty)
            _puedeVer = false;
    }

    private async Task CargarDetalleAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            detalle = await db.NominaDetalles
                .AsNoTracking()
                .Include(d => d.Empleado)
                    .ThenInclude(e => e.Posicion)
                .Include(d => d.BonosEstructurados.Where(b => b.IsActive))
                    .ThenInclude(b => b.Detalles.Where(x => x.IsActive))
                        .ThenInclude(x => x.BonoRubroRrhh)
                .Include(d => d.PercepcionesManuales.Where(p => p.IsActive))
                    .ThenInclude(p => p.TipoPercepcion)
                .Include(d => d.DeduccionesEstructuradas.Where(x => x.IsActive))
                    .ThenInclude(x => x.TipoDeduccion)
                .Include(d => d.Nomina)
                    .ThenInclude(n => n.Empresa)
                .FirstOrDefaultAsync(d => d.Id == DetalleId && d.Nomina.EmpresaId == _empresaId);

            if (detalle == null)
            {
                error = "No se encontró el recibo de nómina.";
                return;
            }

            recibo = NominaReciboBuilder.Build(detalle);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error cargando recibo de nómina {DetalleId}", DetalleId);
            error = "Ocurrió un error al cargar el recibo. Intenta de nuevo o contacta al administrador.";
        }
    }
}
