@page "/rrhh/banco-horas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Entities
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Banco de Horas</PageTitle>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver banco de horas.</div>
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <h1 class="display-6 fw-bold"><i class="bi bi-hourglass-split me-2"></i>Banco de Horas</h1>
                <p class="text-muted mb-0">Consulta saldo por empleado y registra ajustes o consumos manuales.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Saldo total</div><div class="fs-4 fw-bold">@FormatearHoras(resumenes.Sum(r => r.SaldoActual))</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Con saldo</div><div class="fs-4 fw-bold">@resumenes.Count(r => r.SaldoActual > 0)</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Acumulado automático</div><div class="fs-4 fw-bold">@FormatearHoras(resumenes.Sum(r => r.AcumuladoAutomatico))</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Consumido</div><div class="fs-4 fw-bold">@FormatearHoras(resumenes.Sum(r => r.Consumido))</div></div></div></div>
        </div>

        @if (_puedeEditar)
        {
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center gap-2">
                    <strong>@(movimientoEditandoId.HasValue ? "Editar movimiento manual" : "Registrar movimiento manual")</strong>
                    @if (movimientoEditandoId.HasValue)
                    {
                        <button type="button" class="btn btn-sm btn-outline-light" @onclick="CancelarEdicion" disabled="@guardando">Cancelar edición</button>
                    }
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Empleado</label>
                            <InputSelect class="form-select" @bind-Value="empleadoCapturaId">
                                <option value="">Seleccione...</option>
                                @foreach (var empleado in empleados)
                                {
                                    <option value="@empleado.Id">@empleado.NombreCompleto</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Movimiento</label>
                            <InputSelect class="form-select" @bind-Value="tipoMovimientoCaptura">
                                <option value="@TipoMovimientoBancoHorasRrhh.AjusteManual">Ajuste</option>
                                <option value="@TipoMovimientoBancoHorasRrhh.Consumo">Consumo</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Fecha</label>
                            <InputDate class="form-control" @bind-Value="fechaCaptura" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Horas</label>
                            <InputNumber class="form-control" @bind-Value="horasCaptura" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-success w-100" @onclick="GuardarMovimientoManual" disabled="@guardando">
                                <i class="bi @(movimientoEditandoId.HasValue ? "bi-check2-square" : "bi-save") me-1"></i>@(movimientoEditandoId.HasValue ? "Actualizar" : "Guardar")
                            </button>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <InputText class="form-control" @bind-Value="observacionesCaptura" />
                            <div class="form-text">En ajustes puedes capturar horas positivas o negativas. En consumo, el sistema las registra como salida del saldo.</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Empleado</th>
                            <th class="text-end">Saldo</th>
                            <th class="text-end">Automático</th>
                            <th class="text-end">Manual</th>
                            <th class="text-end">Consumido</th>
                            <th class="text-center">Movs.</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (resumenes.Count == 0)
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No hay movimientos de banco de horas todavía.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in resumenes)
                            {
                                <tr class="@(empleadoHistorialId == item.EmpleadoId ? "table-active" : string.Empty)">
                                    <td class="fw-semibold">@item.NombreEmpleado</td>
                                    <td class="text-end fw-bold">@FormatearHoras(item.SaldoActual)</td>
                                    <td class="text-end">@FormatearHoras(item.AcumuladoAutomatico)</td>
                                    <td class="text-end">@FormatearHoras(item.AjustesManuales)</td>
                                    <td class="text-end">@FormatearHoras(item.Consumido)</td>
                                    <td class="text-center">@item.TotalMovimientos</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SeleccionarHistorial(item.EmpleadoId)"><i class="bi bi-clock-history"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (empleadoHistorialId.HasValue)
        {
            <div class="card shadow-sm border-0">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Historial de movimientos</strong>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => empleadoHistorialId = null">Cerrar</button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Fecha</th>
                                <th>Tipo</th>
                                <th class="text-end">Horas</th>
                                <th>Referencia</th>
                                <th>Notas</th>
                                @if (_puedeEditar)
                                {
                                    <th class="text-end pe-3">Acciones</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var movimiento in MovimientosHistorial)
                            {
                                <tr>
                                    <td class="ps-3 text-nowrap">@movimiento.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @ObtenerClaseTipoMovimiento(movimiento.TipoMovimiento)">@ObtenerEtiquetaTipoMovimiento(movimiento.TipoMovimiento)</span>
                                    </td>
                                    <td class="text-end fw-semibold @(movimiento.Horas < 0 ? "text-danger" : "text-success") text-nowrap">@FormatearHoras(movimiento.Horas)</td>
                                    <td>
                                        <div class="small text-truncate" style="max-width: 320px;" title="@movimiento.ReferenciaTipo">@ObtenerReferenciaCorta(movimiento.ReferenciaTipo)</div>
                                    </td>
                                    <td>
                                        <div class="small">@(string.IsNullOrWhiteSpace(movimiento.Observaciones) ? "—" : movimiento.Observaciones)</div>
                                    </td>
                                    @if (_puedeEditar)
                                    {
                                        <td class="text-end pe-3 text-nowrap">
                                            @if (PuedeModificarMovimiento(movimiento))
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-primary" @onclick="() => IniciarEdicionMovimiento(movimiento)" title="Editar movimiento">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger" @onclick="() => EliminarMovimientoAsync(movimiento.Id)" title="Eliminar movimiento">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-light border text-secondary">Automático</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Empleado> empleados = [];
    private List<RrhhBancoHorasMovimiento> movimientos = [];
    private List<BancoHorasResumenVm> resumenes = [];
    private Guid? empleadoCapturaId;
    private Guid? empleadoHistorialId;
    private Guid? movimientoEditandoId;
    private TipoMovimientoBancoHorasRrhh tipoMovimientoCaptura = TipoMovimientoBancoHorasRrhh.AjusteManual;
    private DateTime fechaCaptura = DateTime.Today;
    private decimal horasCaptura;
    private string? observacionesCaptura;
    private bool _puedeVer;
    private bool _puedeEditar;
    private bool guardando;
    private Guid _empresaId;
    private string? error;
    private string? ok;

    private IEnumerable<RrhhBancoHorasMovimiento> MovimientosHistorial => empleadoHistorialId.HasValue
        ? movimientos.Where(m => m.EmpleadoId == empleadoHistorialId.Value).OrderByDescending(m => m.Fecha).ThenByDescending(m => m.CreatedAt)
        : Enumerable.Empty<RrhhBancoHorasMovimiento>();

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
        {
            await CargarAsync();
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "nominas.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        empleados = await db.Empleados
            .AsNoTracking()
            .Where(e => e.IsActive)
            .OrderBy(e => e.Nombre)
            .ThenBy(e => e.ApellidoPaterno)
            .ToListAsync();

        movimientos = await db.RrhhBancoHorasMovimientos
            .AsNoTracking()
            .Include(m => m.Empleado)
            .Where(m => m.EmpresaId == _empresaId && m.IsActive)
            .OrderByDescending(m => m.Fecha)
            .ThenByDescending(m => m.CreatedAt)
            .ToListAsync();

        resumenes = movimientos
            .GroupBy(m => new { m.EmpleadoId, m.Empleado.NombreCompleto })
            .Select(g => new BancoHorasResumenVm
            {
                EmpleadoId = g.Key.EmpleadoId,
                NombreEmpleado = g.Key.NombreCompleto,
                SaldoActual = g.Sum(x => x.Horas),
                AcumuladoAutomatico = g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra).Sum(x => x.Horas),
                AjustesManuales = g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.AjusteManual).Sum(x => x.Horas),
                Consumido = Math.Abs(g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo).Sum(x => x.Horas)),
                TotalMovimientos = g.Count()
            })
            .OrderByDescending(r => r.SaldoActual)
            .ThenBy(r => r.NombreEmpleado)
            .ToList();
    }

    private async Task GuardarMovimientoManual()
    {
        error = ok = null;
        guardando = true;

        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para editar banco de horas.";
                return;
            }

            if (!empleadoCapturaId.HasValue || empleadoCapturaId == Guid.Empty)
            {
                error = "Selecciona un empleado.";
                return;
            }

            if (horasCaptura == 0)
            {
                error = "Captura un valor de horas distinto de cero.";
                return;
            }

            var horasMovimiento = tipoMovimientoCaptura == TipoMovimientoBancoHorasRrhh.Consumo
                ? -Math.Abs(horasCaptura)
                : horasCaptura;

            await using var db = await DbFactory.CreateDbContextAsync();
            var referenciaTipo = tipoMovimientoCaptura == TipoMovimientoBancoHorasRrhh.Consumo ? "Consumo manual" : "Ajuste manual";
            var observaciones = string.IsNullOrWhiteSpace(observacionesCaptura) ? null : observacionesCaptura.Trim();

            if (movimientoEditandoId.HasValue)
            {
                var movimiento = await db.RrhhBancoHorasMovimientos
                    .FirstOrDefaultAsync(m => m.Id == movimientoEditandoId.Value && m.EmpresaId == _empresaId && m.IsActive);

                if (movimiento is null)
                {
                    error = "No se encontró el movimiento a editar.";
                    return;
                }

                if (!PuedeModificarMovimiento(movimiento))
                {
                    error = "Solo se pueden editar movimientos manuales.";
                    return;
                }

                movimiento.EmpleadoId = empleadoCapturaId.Value;
                movimiento.Fecha = DateOnly.FromDateTime(fechaCaptura.Date);
                movimiento.TipoMovimiento = tipoMovimientoCaptura;
                movimiento.Horas = horasMovimiento;
                movimiento.ReferenciaTipo = referenciaTipo;
                movimiento.Observaciones = observaciones;
                movimiento.UpdatedAt = DateTime.UtcNow;
            }
            else
            {
                db.RrhhBancoHorasMovimientos.Add(new RrhhBancoHorasMovimiento
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    EmpleadoId = empleadoCapturaId.Value,
                    Fecha = DateOnly.FromDateTime(fechaCaptura.Date),
                    TipoMovimiento = tipoMovimientoCaptura,
                    Horas = horasMovimiento,
                    ReferenciaTipo = referenciaTipo,
                    Observaciones = observaciones,
                    EsAutomatico = false,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }

            await db.SaveChangesAsync();
            var empleadoHistorial = empleadoCapturaId;
            LimpiarCaptura();
            ok = movimientoEditandoId.HasValue ? "Movimiento de banco de horas actualizado." : "Movimiento de banco de horas guardado.";
            await CargarAsync();
            empleadoHistorialId = empleadoHistorial;
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void SeleccionarHistorial(Guid empleadoId)
    {
        empleadoHistorialId = empleadoId;
    }

    private void IniciarEdicionMovimiento(RrhhBancoHorasMovimiento movimiento)
    {
        if (!PuedeModificarMovimiento(movimiento))
        {
            error = "Solo se pueden editar movimientos manuales.";
            ok = null;
            return;
        }

        error = null;
        ok = null;
        movimientoEditandoId = movimiento.Id;
        empleadoCapturaId = movimiento.EmpleadoId;
        tipoMovimientoCaptura = movimiento.TipoMovimiento;
        fechaCaptura = movimiento.Fecha.ToDateTime(TimeOnly.MinValue);
        horasCaptura = movimiento.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
            ? Math.Abs(movimiento.Horas)
            : movimiento.Horas;
        observacionesCaptura = movimiento.Observaciones;
        empleadoHistorialId = movimiento.EmpleadoId;
    }

    private async Task EliminarMovimientoAsync(Guid movimientoId)
    {
        error = ok = null;

        if (!_puedeEditar)
        {
            error = "No tienes permisos para editar banco de horas.";
            return;
        }

        var confirmar = await JS.InvokeAsync<bool>("confirm", "¿Deseas eliminar este movimiento manual de banco de horas?");
        if (!confirmar)
        {
            return;
        }

        guardando = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var movimiento = await db.RrhhBancoHorasMovimientos
                .FirstOrDefaultAsync(m => m.Id == movimientoId && m.EmpresaId == _empresaId && m.IsActive);

            if (movimiento is null)
            {
                error = "No se encontró el movimiento a eliminar.";
                return;
            }

            if (!PuedeModificarMovimiento(movimiento))
            {
                error = "Solo se pueden eliminar movimientos manuales.";
                return;
            }

            movimiento.IsActive = false;
            movimiento.UpdatedAt = DateTime.UtcNow;

            await db.SaveChangesAsync();

            if (movimientoEditandoId == movimientoId)
            {
                LimpiarCaptura();
            }

            ok = "Movimiento de banco de horas eliminado.";
            await CargarAsync();
            empleadoHistorialId = movimiento.EmpleadoId;
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void CancelarEdicion()
    {
        error = null;
        ok = null;
        LimpiarCaptura();
    }

    private void LimpiarCaptura()
    {
        movimientoEditandoId = null;
        empleadoCapturaId = null;
        tipoMovimientoCaptura = TipoMovimientoBancoHorasRrhh.AjusteManual;
        fechaCaptura = DateTime.Today;
        horasCaptura = 0;
        observacionesCaptura = null;
    }

    private static bool PuedeModificarMovimiento(RrhhBancoHorasMovimiento movimiento)
        => !movimiento.EsAutomatico && movimiento.TipoMovimiento != TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra;

    private static string ObtenerEtiquetaTipoMovimiento(TipoMovimientoBancoHorasRrhh tipoMovimiento)
        => tipoMovimiento switch
        {
            TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra => "Generado por horas extra",
            TipoMovimientoBancoHorasRrhh.AjusteManual => "Ajuste manual",
            TipoMovimientoBancoHorasRrhh.Consumo => "Consumo",
            _ => tipoMovimiento.ToString()
        };

    private static string ObtenerClaseTipoMovimiento(TipoMovimientoBancoHorasRrhh tipoMovimiento)
        => tipoMovimiento switch
        {
            TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra => "text-bg-info",
            TipoMovimientoBancoHorasRrhh.AjusteManual => "text-bg-primary",
            TipoMovimientoBancoHorasRrhh.Consumo => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    private static string ObtenerReferenciaCorta(string? referencia)
    {
        if (string.IsNullOrWhiteSpace(referencia))
        {
            return "—";
        }

        const int maximo = 44;
        var valor = referencia.Trim();
        return valor.Length <= maximo ? valor : $"{valor[..maximo]}…";
    }

    private static string FormatearHoras(decimal horas)
        => $"{horas:0.##} h";

    private sealed class BancoHorasResumenVm
    {
        public Guid EmpleadoId { get; set; }
        public string NombreEmpleado { get; set; } = string.Empty;
        public decimal SaldoActual { get; set; }
        public decimal AcumuladoAutomatico { get; set; }
        public decimal AjustesManuales { get; set; }
        public decimal Consumido { get; set; }
        public int TotalMovimientos { get; set; }
    }
}
