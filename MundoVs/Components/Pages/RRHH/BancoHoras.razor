@page "/rrhh/banco-horas"
@using System.Text
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MundoVs.Core.Entities
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Banco de Horas</PageTitle>

<div class="container-fluid px-4 rrhh-rpt">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver banco de horas.</div>
    }
    else
    {
        <div class="rrhh-header">
            <div>
                <h1><i class="bi bi-hourglass-split"></i>Banco de Horas</h1>
                <p class="rrhh-subtitle">Consulta saldo por empleado y registra ajustes o consumos manuales.</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ExportarResumenCsvAsync" disabled="@(exportandoCsv || resumenes.Count == 0)">
                    @if (exportandoCsv)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <i class="bi bi-filetype-csv me-1"></i>
                    }
                    Exportar CSV
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (!string.IsNullOrWhiteSpace(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <div class="row g-3 rrhh-kpis">
            <div class="col-6 col-md"><div class="rrhh-kpi"><div class="card-body"><div class="kpi-etiqueta">Saldo total</div><div class="kpi-valor">@FormatearHoras(resumenes.Sum(r => r.SaldoActual))</div></div></div></div>
            <div class="col-6 col-md"><div class="rrhh-kpi"><div class="card-body"><div class="kpi-etiqueta">Con saldo</div><div class="kpi-valor">@resumenes.Count(r => r.SaldoActual > 0)</div></div></div></div>
            <div class="col-6 col-md"><div class="rrhh-kpi"><div class="card-body"><div class="kpi-etiqueta">Acumulado automático</div><div class="kpi-valor">@FormatearHoras(resumenes.Sum(r => r.AcumuladoAutomatico))</div></div></div></div>
            <div class="col-6 col-md"><div class="rrhh-kpi"><div class="card-body"><div class="kpi-etiqueta">Consumido</div><div class="kpi-valor">@FormatearHoras(resumenes.Sum(r => r.Consumido))</div></div></div></div>
            <div class="col-6 col-md"><div class="rrhh-kpi"><div class="card-body"><div class="kpi-etiqueta">Tope por empleado</div><div class="kpi-valor">@FormatearHoras(_bancoTopeHoras)</div><div class="kpi-sub">Configurado en nómina</div></div></div></div>
        </div>

        @if (_puedeEditar)
        {
            <div class="rrhh-filtros mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                        <span class="rrhh-presets-label">@(movimientoEditandoId.HasValue ? "Editar movimiento manual" : "Registrar movimiento manual")</span>
                        @if (movimientoEditandoId.HasValue)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelarEdicion" disabled="@guardando">Cancelar edición</button>
                        }
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Empleado</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="empleadoCapturaId">
                                <option value="">Seleccione...</option>
                                @foreach (var empleado in empleados)
                                {
                                    <option value="@empleado.Id">@empleado.NombreCompleto</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Movimiento</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="tipoMovimientoCaptura">
                                <option value="@TipoMovimientoBancoHorasRrhh.AjusteManual">Ajuste</option>
                                <option value="@TipoMovimientoBancoHorasRrhh.Consumo">Consumo</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Fecha</label>
                            <InputDate class="form-control form-control-sm" @bind-Value="fechaCaptura" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Horas</label>
                            <InputNumber class="form-control form-control-sm" @bind-Value="horasCaptura" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-accent btn-sm w-100" @onclick="GuardarMovimientoManual" disabled="@guardando">
                                <i class="bi @(movimientoEditandoId.HasValue ? "bi-check2-square" : "bi-save") me-1"></i>@(movimientoEditandoId.HasValue ? "Actualizar" : "Guardar")
                            </button>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <InputText class="form-control form-control-sm" @bind-Value="observacionesCaptura" />
                            <div class="form-text small text-muted">En ajustes puedes capturar horas positivas o negativas. En consumo, el sistema las registra como salida del saldo.</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="rrhh-filtros mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Buscar empleado</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Nombre del empleado..." @bind="filtroTexto" @bind:event="oninput" />
                            @if (!string.IsNullOrWhiteSpace(filtroTexto))
                            {
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => filtroTexto = string.Empty"><i class="bi bi-x"></i></button>
                            }
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <label class="form-label">Saldo</label>
                        <select class="form-select form-select-sm" value="@filtroSaldoSigno" @onchange="e => filtroSaldoSigno = (string?)e.Value">
                            <option value="">(todos)</option>
                            <option value="positivo">Con saldo positivo</option>
                            <option value="negativo">Con saldo negativo</option>
                            <option value="cero">Saldo cero</option>
                        </select>
                    </div>
                    @if (empleadoHistorialId.HasValue)
                    {
                        <div class="col-6 col-md-2">
                            <label class="form-label">Tipo mov.</label>
                            <select class="form-select form-select-sm" value="@filtroTipoHistorial" @onchange="e => filtroTipoHistorial = (string?)e.Value">
                                <option value="">(todos)</option>
                                <option value="auto">Automático</option>
                                <option value="manual">Manuales</option>
                            </select>
                        </div>
                        <div class="col-4 col-md-2">
                            <label class="form-label">Desde</label>
                            <InputDate class="form-control form-control-sm" @bind-Value="filtroFechaDesde" />
                        </div>
                        <div class="col-4 col-md-2">
                            <label class="form-label">Hasta</label>
                            <InputDate class="form-control form-control-sm" @bind-Value="filtroFechaHasta" />
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="rrhh-tabla-card mb-4">
            <div class="rrhh-tabla-wrap">
                <table class="table table-sm align-middle mb-0 rrhh-tabla">
                    <thead>
                        <tr>
                            <th style="cursor:pointer" @onclick="OrdenarResumenEmpleado">Empleado <i class="@IconoResumenEmpleado"></i></th>
                            <th style="cursor:pointer" class="text-end" @onclick="OrdenarResumenSaldo">Saldo <i class="@IconoResumenSaldo"></i></th>
                            <th class="text-end">% tope</th>
                            <th style="cursor:pointer" class="text-end" @onclick="OrdenarResumenAutomatico">Automático <i class="@IconoResumenAutomatico"></i></th>
                            <th style="cursor:pointer" class="text-end" @onclick="OrdenarResumenManual">Manual <i class="@IconoResumenManual"></i></th>
                            <th class="text-end">Cobertura</th>
                            <th class="text-end">Permiso</th>
                            <th class="text-end">Cons. manual</th>
                            <th style="cursor:pointer" class="text-center" @onclick="OrdenarResumenMovs">Movs. <i class="@IconoResumenMovs"></i></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!ResumenesFiltrados.Any())
                        {
                            <tr><td colspan="10" class="text-center text-muted py-4">@(!string.IsNullOrWhiteSpace(filtroTexto) ? "No se encontraron empleados con ese filtro." : "No hay movimientos de banco de horas todavía.")</td></tr>
                        }
                        else
                        {
                            @foreach (var item in ResumenesFiltrados)
                            {
                                <tr class="@(empleadoHistorialId == item.EmpleadoId ? "table-active" : string.Empty)">
                                    <td class="fw-semibold">@item.NombreEmpleado</td>
                                    <td class="text-end fw-bold">@FormatearHoras(item.SaldoActual)</td>
                                    <td class="text-end">
                                        @{
                                            var pct = CalcularPorcentajeTope(item.SaldoActual);
                                        }
                                        @if (pct.HasValue)
                                        {
                                            <span class="badge @ObtenerClasePorcentajeTope(pct.Value)">@pct.Value.ToString("0.#")%</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-end">@FormatearHoras(item.AcumuladoAutomatico)</td>
                                    <td class="text-end">@FormatearHoras(item.AjustesManuales)</td>
                                    <td class="text-end">@FormatearHoras(item.CoberturaBanco)</td>
                                    <td class="text-end">@FormatearHoras(item.PermisoBanco)</td>
                                    <td class="text-end">@FormatearHoras(item.ConsumoManual)</td>
                                    <td class="text-center">@item.TotalMovimientos</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SeleccionarHistorial(item.EmpleadoId)"><i class="bi bi-clock-history"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (empleadoHistorialId.HasValue)
        {
            <div class="rrhh-tabla-card">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 py-2 border-bottom">
                    <div>
                        <span class="rrhh-presets-label">Historial de movimientos</span>
                        <div class="small text-muted">
                            Saldo actual: @FormatearHoras(SaldoActualEmpleado) · Saldo en el periodo: @FormatearHoras(SaldoPeriodoEmpleado)
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportarHistorialCsvAsync" disabled="@(exportandoCsv || !HistorialOrdenado.Any())">
                            @if (exportandoCsv)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            else
                            {
                                <i class="bi bi-filetype-csv me-1"></i>
                            }
                            Exportar historial CSV
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => empleadoHistorialId = null">Cerrar</button>
                    </div>
                </div>
                <div class="rrhh-tabla-wrap">
                    <table class="table table-sm table-hover mb-0 align-middle rrhh-tabla">
                        <thead>
                            <tr>
                                <th class="ps-3" style="cursor:pointer" @onclick="OrdenarHistorialFecha">Fecha <i class="@IconoHistorialFecha"></i></th>
                                <th style="cursor:pointer" @onclick="OrdenarHistorialTipo">Tipo <i class="@IconoHistorialTipo"></i></th>
                                <th style="cursor:pointer" class="text-end" @onclick="OrdenarHistorialHoras">Horas <i class="@IconoHistorialHoras"></i></th>
                                <th style="cursor:pointer" @onclick="OrdenarHistorialReferencia">Referencia <i class="@IconoHistorialReferencia"></i></th>
                                <th>Notas</th>
                                @if (_puedeEditar)
                                {
                                    <th class="text-end pe-3">Acciones</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var movimiento in HistorialOrdenado)
                            {
                                <tr>
                                    <td class="ps-3 text-nowrap">@movimiento.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge @ObtenerClaseTipoMovimiento(movimiento.TipoMovimiento)">@ObtenerEtiquetaTipoMovimiento(movimiento.TipoMovimiento)</span>
                                    </td>
                                    <td class="text-end fw-semibold @(movimiento.Horas < 0 ? "text-danger" : "text-success") text-nowrap">@FormatearHoras(movimiento.Horas)</td>
                                    <td>
                                        <div class="small" title="@movimiento.ReferenciaTipo">@ObtenerEtiquetaReferencia(movimiento.ReferenciaTipo)</div>
                                    </td>
                                    <td>
                                        <div class="small">@(string.IsNullOrWhiteSpace(movimiento.Observaciones) ? "—" : movimiento.Observaciones)</div>
                                    </td>
                                    @if (_puedeEditar)
                                    {
                                        <td class="text-end pe-3 text-nowrap">
                                            @if (PuedeModificarMovimiento(movimiento) && !movimiento.EsAutomatico)
                                            {
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-primary" @onclick="() => IniciarEdicionMovimiento(movimiento)" title="Editar movimiento">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger" @onclick="() => EliminarMovimientoAsync(movimiento.Id)" title="Eliminar movimiento">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                            else if (PuedeModificarMovimiento(movimiento) && movimiento.EsAutomatico)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarMovimientoAsync(movimiento.Id)" title="Eliminar movimiento automático de resolución de periodo">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-light border text-secondary">Automático</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Empleado> empleados = [];
    private List<RrhhBancoHorasMovimiento> movimientos = [];
    private List<BancoHorasResumenVm> resumenes = [];
    private Guid? empleadoCapturaId;
    private Guid? empleadoHistorialId;
    private Guid? movimientoEditandoId;
    private TipoMovimientoBancoHorasRrhh tipoMovimientoCaptura = TipoMovimientoBancoHorasRrhh.AjusteManual;
    private DateTime fechaCaptura = DateTime.Today;
    private decimal horasCaptura;
    private string? observacionesCaptura;
    private bool _puedeVer;
    private bool _puedeEditar;
    private bool guardando;
    private bool exportandoCsv;
    private Guid _empresaId;
    private decimal _bancoTopeHoras;
    private string? error;
    private string? ok;
    private string filtroTexto = string.Empty;
    private string? filtroTipoHistorial;
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private string? filtroSaldoSigno;
    private string resumenOrdenColumna = "Saldo";
    private bool resumenOrdenAscendente = false;
    private string historialOrdenColumna = "Fecha";
    private bool historialOrdenAscendente = false;

    private IEnumerable<BancoHorasResumenVm> ResumenesFiltrados
    {
        get
        {
            var query = resumenes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(filtroTexto))
            {
                var termino = filtroTexto.Trim().ToLowerInvariant();
                query = query.Where(r => r.NombreEmpleado.ToLowerInvariant().Contains(termino));
            }

            if (!string.IsNullOrWhiteSpace(filtroSaldoSigno))
            {
                query = filtroSaldoSigno switch
                {
                    "positivo" => query.Where(r => r.SaldoActual > 0),
                    "negativo" => query.Where(r => r.SaldoActual < 0),
                    "cero" => query.Where(r => r.SaldoActual == 0),
                    _ => query
                };
            }

            query = resumenOrdenColumna switch
            {
                "Empleado" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.NombreEmpleado, StringComparer.OrdinalIgnoreCase)
                    : query.OrderByDescending(r => r.NombreEmpleado, StringComparer.OrdinalIgnoreCase),
                "Saldo" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.SaldoActual)
                    : query.OrderByDescending(r => r.SaldoActual),
                "Automatico" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.AcumuladoAutomatico)
                    : query.OrderByDescending(r => r.AcumuladoAutomatico),
                "Manual" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.AjustesManuales)
                    : query.OrderByDescending(r => r.AjustesManuales),
                "Consumido" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.Consumido)
                    : query.OrderByDescending(r => r.Consumido),
                "Movs" => resumenOrdenAscendente
                    ? query.OrderBy(r => r.TotalMovimientos)
                    : query.OrderByDescending(r => r.TotalMovimientos),
                _ => query.OrderByDescending(r => r.SaldoActual).ThenBy(r => r.NombreEmpleado)
            };

            return query;
        }
    }

    private IEnumerable<RrhhBancoHorasMovimiento> HistorialOrdenado
    {
        get
        {
            var query = MovimientosHistorial;

            if (!string.IsNullOrWhiteSpace(filtroTipoHistorial))
            {
                query = filtroTipoHistorial switch
                {
                    "auto" => query.Where(m => m.TipoMovimiento == TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra),
                    "manual" => query.Where(m => m.EsAutomatico == false && m.TipoMovimiento != TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra),
                    _ => query
                };
            }

            if (filtroFechaDesde.HasValue)
            {
                var desde = DateOnly.FromDateTime(filtroFechaDesde.Value.Date);
                query = query.Where(m => m.Fecha >= desde);
            }

            if (filtroFechaHasta.HasValue)
            {
                var hasta = DateOnly.FromDateTime(filtroFechaHasta.Value.Date);
                query = query.Where(m => m.Fecha <= hasta);
            }
            return historialOrdenColumna switch
            {
                "Fecha" => historialOrdenAscendente
                    ? query.OrderBy(m => m.Fecha).ThenBy(m => m.CreatedAt)
                    : query.OrderByDescending(m => m.Fecha).ThenByDescending(m => m.CreatedAt),
                "Tipo" => historialOrdenAscendente
                    ? query.OrderBy(m => m.TipoMovimiento.ToString())
                    : query.OrderByDescending(m => m.TipoMovimiento.ToString()),
                "Horas" => historialOrdenAscendente
                    ? query.OrderBy(m => m.Horas)
                    : query.OrderByDescending(m => m.Horas),
                "Referencia" => historialOrdenAscendente
                    ? query.OrderBy(m => m.ReferenciaTipo, StringComparer.OrdinalIgnoreCase)
                    : query.OrderByDescending(m => m.ReferenciaTipo, StringComparer.OrdinalIgnoreCase),
                _ => query
            };
        }
    }

    private void AlternarOrdenResumen(string columna)
    {
        if (resumenOrdenColumna == columna)
        {
            resumenOrdenAscendente = !resumenOrdenAscendente;
        }
        else
        {
            resumenOrdenColumna = columna;
            resumenOrdenAscendente = columna == "Empleado";
        }
    }

    private void AlternarOrdenHistorial(string columna)
    {
        if (historialOrdenColumna == columna)
        {
            historialOrdenAscendente = !historialOrdenAscendente;
        }
        else
        {
            historialOrdenColumna = columna;
            historialOrdenAscendente = false;
        }
    }

    private string ClaseOrdenResumen(string columna) => resumenOrdenColumna == columna
        ? (resumenOrdenAscendente ? "bi bi-sort-up" : "bi bi-sort-down")
        : "bi bi-sort-down opacity-25";

    private string ClaseOrdenHistorial(string columna) => historialOrdenColumna == columna
        ? (historialOrdenAscendente ? "bi bi-sort-up" : "bi bi-sort-down")
        : "bi bi-sort-down opacity-25";

    private void OrdenarResumenEmpleado() => AlternarOrdenResumen("Empleado");
    private void OrdenarResumenSaldo() => AlternarOrdenResumen("Saldo");
    private void OrdenarResumenAutomatico() => AlternarOrdenResumen("Automatico");
    private void OrdenarResumenManual() => AlternarOrdenResumen("Manual");
    private void OrdenarResumenConsumido() => AlternarOrdenResumen("Consumido");
    private void OrdenarResumenMovs() => AlternarOrdenResumen("Movs");

    private string IconoResumenEmpleado => ClaseOrdenResumen("Empleado");
    private string IconoResumenSaldo => ClaseOrdenResumen("Saldo");
    private string IconoResumenAutomatico => ClaseOrdenResumen("Automatico");
    private string IconoResumenManual => ClaseOrdenResumen("Manual");
    private string IconoResumenConsumido => ClaseOrdenResumen("Consumido");
    private string IconoResumenMovs => ClaseOrdenResumen("Movs");

    private void OrdenarHistorialFecha() => AlternarOrdenHistorial("Fecha");
    private void OrdenarHistorialTipo() => AlternarOrdenHistorial("Tipo");
    private void OrdenarHistorialHoras() => AlternarOrdenHistorial("Horas");
    private void OrdenarHistorialReferencia() => AlternarOrdenHistorial("Referencia");

    private string IconoHistorialFecha => ClaseOrdenHistorial("Fecha");
    private string IconoHistorialTipo => ClaseOrdenHistorial("Tipo");
    private string IconoHistorialHoras => ClaseOrdenHistorial("Horas");
    private string IconoHistorialReferencia => ClaseOrdenHistorial("Referencia");

    private IEnumerable<RrhhBancoHorasMovimiento> MovimientosHistorial => empleadoHistorialId.HasValue
        ? movimientos.Where(m => m.EmpleadoId == empleadoHistorialId.Value).OrderByDescending(m => m.Fecha).ThenByDescending(m => m.CreatedAt)
        : Enumerable.Empty<RrhhBancoHorasMovimiento>();

    protected override async Task OnInitializedAsync()
    {
        await CargarAccesoAsync();
        if (_puedeVer)
        {
            await CargarAsync();
        }
    }

    private async Task CargarAccesoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "rrhh.bancohoras.ver")
            || state.User.HasClaim("Capacidad", "empleados.ver")
            || state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "rrhh.bancohoras.editar")
            || state.User.HasClaim("Capacidad", "empleados.editar")
            || state.User.HasClaim("Capacidad", "nominas.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        empleados = await db.Empleados
            .AsNoTracking()
            .Where(e => e.IsActive)
            .OrderBy(e => e.Nombre)
            .ThenBy(e => e.ApellidoPaterno)
            .ToListAsync();

        // Tope del banco de horas (configuración de nómina) para la columna "% tope".
        var configuracion = await NominaConfiguracionLoader.LoadAsync(db, _empresaId);
        _bancoTopeHoras = configuracion.BancoHorasTopeHoras;

        movimientos = await db.RrhhBancoHorasMovimientos
            .AsNoTracking()
            .Include(m => m.Empleado)
            .Where(m => m.EmpresaId == _empresaId && m.IsActive)
            .OrderByDescending(m => m.Fecha)
            .ThenByDescending(m => m.CreatedAt)
            .ToListAsync();

        resumenes = movimientos
            .GroupBy(m => new { m.EmpleadoId, m.Empleado.NombreCompleto })
            .Select(g => new BancoHorasResumenVm
            {
                EmpleadoId = g.Key.EmpleadoId,
                NombreEmpleado = g.Key.NombreCompleto,
                SaldoActual = g.Sum(x => x.Horas),
                AcumuladoAutomatico = g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra).Sum(x => x.Horas),
                AjustesManuales = g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.AjusteManual).Sum(x => x.Horas),
                // Consumo se desglosa por ReferenciaTipo: cobertura de faltante, permiso pagado
                // con banco, o consumo manual. Todas son salidas (Horas negativas) → abs.
                CoberturaBanco = Math.Abs(g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
                    && (x.ReferenciaTipo ?? string.Empty).Contains("cobertura-banco", StringComparison.Ordinal)).Sum(x => x.Horas)),
                PermisoBanco = Math.Abs(g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
                    && (x.ReferenciaTipo ?? string.Empty).StartsWith("permiso-banco:", StringComparison.Ordinal)).Sum(x => x.Horas)),
                ConsumoManual = Math.Abs(g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
                    && (x.ReferenciaTipo ?? string.Empty) == "Consumo manual").Sum(x => x.Horas)),
                ConsumoOtro = Math.Abs(g.Where(x => x.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
                    && (x.ReferenciaTipo ?? string.Empty) != "Consumo manual"
                    && !(x.ReferenciaTipo ?? string.Empty).Contains("cobertura-banco", StringComparison.Ordinal)
                    && !(x.ReferenciaTipo ?? string.Empty).StartsWith("permiso-banco:", StringComparison.Ordinal)).Sum(x => x.Horas)),
                TotalMovimientos = g.Count()
            })
            .OrderByDescending(r => r.SaldoActual)
            .ThenBy(r => r.NombreEmpleado)
            .ToList();
    }

    private async Task GuardarMovimientoManual()
    {
        error = ok = null;
        guardando = true;

        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para editar banco de horas.";
                return;
            }

            if (!empleadoCapturaId.HasValue || empleadoCapturaId == Guid.Empty)
            {
                error = "Selecciona un empleado.";
                return;
            }

            if (horasCaptura == 0)
            {
                error = "Captura un valor de horas distinto de cero.";
                return;
            }

            var horasMovimiento = tipoMovimientoCaptura == TipoMovimientoBancoHorasRrhh.Consumo
                ? -Math.Abs(horasCaptura)
                : horasCaptura;

            await using var db = await DbFactory.CreateDbContextAsync();
            var referenciaTipo = tipoMovimientoCaptura == TipoMovimientoBancoHorasRrhh.Consumo ? "Consumo manual" : "Ajuste manual";
            var observaciones = string.IsNullOrWhiteSpace(observacionesCaptura) ? null : observacionesCaptura.Trim();

            if (movimientoEditandoId.HasValue)
            {
                var movimiento = await db.RrhhBancoHorasMovimientos
                    .FirstOrDefaultAsync(m => m.Id == movimientoEditandoId.Value && m.EmpresaId == _empresaId && m.IsActive);

                if (movimiento is null)
                {
                    error = "No se encontró el movimiento a editar.";
                    return;
                }

                if (!PuedeModificarMovimiento(movimiento))
                {
                    error = "Solo se pueden editar movimientos manuales.";
                    return;
                }

                movimiento.EmpleadoId = empleadoCapturaId.Value;
                movimiento.Fecha = DateOnly.FromDateTime(fechaCaptura.Date);
                movimiento.TipoMovimiento = tipoMovimientoCaptura;
                movimiento.Horas = horasMovimiento;
                movimiento.ReferenciaTipo = referenciaTipo;
                movimiento.Observaciones = observaciones;
                movimiento.UpdatedAt = DateTime.UtcNow;
            }
            else
            {
                db.RrhhBancoHorasMovimientos.Add(new RrhhBancoHorasMovimiento
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = _empresaId,
                    EmpleadoId = empleadoCapturaId.Value,
                    Fecha = DateOnly.FromDateTime(fechaCaptura.Date),
                    TipoMovimiento = tipoMovimientoCaptura,
                    Horas = horasMovimiento,
                    ReferenciaTipo = referenciaTipo,
                    Observaciones = observaciones,
                    EsAutomatico = false,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }

            await db.SaveChangesAsync();
            var empleadoHistorial = empleadoCapturaId;
            LimpiarCaptura();
            ok = movimientoEditandoId.HasValue ? "Movimiento de banco de horas actualizado." : "Movimiento de banco de horas guardado.";
            await CargarAsync();
            empleadoHistorialId = empleadoHistorial;
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void SeleccionarHistorial(Guid empleadoId)
    {
        empleadoHistorialId = empleadoId;
    }

    private void IniciarEdicionMovimiento(RrhhBancoHorasMovimiento movimiento)
    {
        if (!PuedeModificarMovimiento(movimiento))
        {
            error = "Solo se pueden editar movimientos manuales.";
            ok = null;
            return;
        }

        // Los automáticos de resolución de periodo solo se pueden eliminar, no editar.
        if (movimiento.EsAutomatico)
        {
            error = "Este movimiento es automático de resolución de periodo: solo se puede eliminar, no editar.";
            ok = null;
            return;
        }

        error = null;
        ok = null;
        movimientoEditandoId = movimiento.Id;
        empleadoCapturaId = movimiento.EmpleadoId;
        tipoMovimientoCaptura = movimiento.TipoMovimiento;
        fechaCaptura = movimiento.Fecha.ToDateTime(TimeOnly.MinValue);
        horasCaptura = movimiento.TipoMovimiento == TipoMovimientoBancoHorasRrhh.Consumo
            ? Math.Abs(movimiento.Horas)
            : movimiento.Horas;
        observacionesCaptura = movimiento.Observaciones;
        empleadoHistorialId = movimiento.EmpleadoId;
    }

    private async Task EliminarMovimientoAsync(Guid movimientoId)
    {
        error = ok = null;

        if (!_puedeEditar)
        {
            error = "No tienes permisos para editar banco de horas.";
            return;
        }

        var confirmar = await JS.InvokeAsync<bool>("confirm", "¿Deseas eliminar este movimiento de banco de horas? Si es automático de resolución de periodo, la resolución quedará inconsistente — reabre el periodo desde el Reporte de Tiempo Extra para revertirlo correctamente.");
        if (!confirmar)
        {
            return;
        }

        guardando = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var movimiento = await db.RrhhBancoHorasMovimientos
                .FirstOrDefaultAsync(m => m.Id == movimientoId && m.EmpresaId == _empresaId && m.IsActive);

            if (movimiento is null)
            {
                error = "No se encontró el movimiento a eliminar.";
                return;
            }

            if (!PuedeModificarMovimiento(movimiento))
            {
                error = "Solo se pueden eliminar movimientos manuales o automáticos de resolución de periodo.";
                return;
            }

            movimiento.IsActive = false;
            movimiento.UpdatedAt = DateTime.UtcNow;

            await db.SaveChangesAsync();

            if (movimientoEditandoId == movimientoId)
            {
                LimpiarCaptura();
            }

            ok = "Movimiento de banco de horas eliminado.";
            await CargarAsync();
            empleadoHistorialId = movimiento.EmpleadoId;
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void CancelarEdicion()
    {
        error = null;
        ok = null;
        LimpiarCaptura();
    }

    private void LimpiarCaptura()
    {
        movimientoEditandoId = null;
        empleadoCapturaId = null;
        tipoMovimientoCaptura = TipoMovimientoBancoHorasRrhh.AjusteManual;
        fechaCaptura = DateTime.Today;
        horasCaptura = 0;
        observacionesCaptura = null;
    }

    private static bool PuedeModificarMovimiento(RrhhBancoHorasMovimiento movimiento)
        => !movimiento.EsAutomatico
            || (movimiento.TipoMovimiento == TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra
                && !string.IsNullOrEmpty(movimiento.ReferenciaTipo)
                && movimiento.ReferenciaTipo.Contains("Periodo:", StringComparison.Ordinal));

    private static string ObtenerEtiquetaTipoMovimiento(TipoMovimientoBancoHorasRrhh tipoMovimiento)
        => tipoMovimiento switch
        {
            TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra => "Generado por horas extra",
            TipoMovimientoBancoHorasRrhh.AjusteManual => "Ajuste manual",
            TipoMovimientoBancoHorasRrhh.Consumo => "Consumo",
            _ => tipoMovimiento.ToString()
        };

    private static string ObtenerClaseTipoMovimiento(TipoMovimientoBancoHorasRrhh tipoMovimiento)
        => tipoMovimiento switch
        {
            TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra => "text-bg-info",
            TipoMovimientoBancoHorasRrhh.AjusteManual => "text-bg-primary",
            TipoMovimientoBancoHorasRrhh.Consumo => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    // Etiqueta legible del origen del movimiento. El ReferenciaTipo crudo queda en el tooltip
    // (title=) para trazabilidad. Orden: compensación antes que permiso-banco (aunque el sufijo
    // "permiso-compensacion-banco" no contiene "permiso-banco", revisamos primero por seguridad).
    private static string ObtenerEtiquetaReferencia(string? referencia)
    {
        if (string.IsNullOrWhiteSpace(referencia))
        {
            return "—";
        }

        var valor = referencia.Trim();
        if (valor.Contains("extra-banco", StringComparison.Ordinal)) return "Extra al banco";
        if (valor.Contains("restauracion-banco", StringComparison.Ordinal)) return "Restauración de banco";
        if (valor.Contains("cobertura-banco", StringComparison.Ordinal)) return "Cobertura de faltante";
        if (valor.StartsWith("permiso-compensacion-banco", StringComparison.Ordinal)) return "Compensación de permiso";
        if (valor.StartsWith("permiso-banco", StringComparison.Ordinal)) return "Permiso c/banco";
        if (valor == "Consumo manual") return "Consumo manual";
        if (valor == "Ajuste manual") return "Ajuste manual";

        const int maximo = 44;
        return valor.Length <= maximo ? valor : $"{valor[..maximo]}…";
    }

    // Clase de badge para el % de tope: verde <70%, amarillo <100%, rojo >=100%.
    private static string ObtenerClasePorcentajeTope(decimal pct)
        => pct < 70m ? "bg-success-subtle text-success-emphasis border border-success-subtle"
            : pct < 100m ? "bg-warning-subtle text-warning-emphasis border border-warning-subtle"
            : "bg-danger-subtle text-danger-emphasis border border-danger-subtle";

    // % del tope que ocupa el saldo del empleado. Null si no hay tope o el saldo no es positivo
    // (en ese caso la celda muestra "—").
    private decimal? CalcularPorcentajeTope(decimal saldo)
    {
        if (_bancoTopeHoras <= 0m || saldo <= 0m)
        {
            return null;
        }

        return saldo / _bancoTopeHoras * 100m;
    }

    // Saldo total (histórico) del empleado cuyo historial está abierto.
    private decimal SaldoActualEmpleado => empleadoHistorialId.HasValue
        ? resumenes.FirstOrDefault(r => r.EmpleadoId == empleadoHistorialId.Value)?.SaldoActual ?? 0m
        : 0m;

    // Saldo neto dentro del periodo filtrado (suma de Horas del historial ya filtrado por
    // fecha/tipo). Distinto del saldo total: aclara que la tabla resumen es histórica.
    private decimal SaldoPeriodoEmpleado => empleadoHistorialId.HasValue
        ? HistorialOrdenado.Sum(m => m.Horas)
        : 0m;

    private async Task ExportarResumenCsvAsync()
    {
        if (resumenes.Count == 0)
        {
            return;
        }

        exportandoCsv = true;
        try
        {
            var sb = new StringBuilder();
            sb.AppendLine("Empleado,Saldo,PorcentajeTope,Automatico,Manual,Cobertura,Permiso,ConsumoManual,Otro,TotalConsumido,Movimientos");
            foreach (var item in ResumenesFiltrados)
            {
                var pct = CalcularPorcentajeTope(item.SaldoActual);
                sb.Append(Csv(item.NombreEmpleado)).Append(',')
                  .Append(item.SaldoActual.ToString("0.##")).Append(',')
                  .Append(pct.HasValue ? pct.Value.ToString("0.#") : string.Empty).Append(',')
                  .Append(item.AcumuladoAutomatico.ToString("0.##")).Append(',')
                  .Append(item.AjustesManuales.ToString("0.##")).Append(',')
                  .Append(item.CoberturaBanco.ToString("0.##")).Append(',')
                  .Append(item.PermisoBanco.ToString("0.##")).Append(',')
                  .Append(item.ConsumoManual.ToString("0.##")).Append(',')
                  .Append(item.ConsumoOtro.ToString("0.##")).Append(',')
                  .Append(item.Consumido.ToString("0.##")).Append(',')
                  .Append(item.TotalMovimientos);
                sb.AppendLine();
            }

            var nombreArchivo = $"banco-horas-resumen-{DateTime.Today:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("mundoVsAuth.downloadCsv", nombreArchivo, sb.ToString());
            ok = "Resumen exportado correctamente.";
        }
        catch (Exception ex)
        {
            error = $"No se pudo exportar el CSV: {ex.Message}";
        }
        finally
        {
            exportandoCsv = false;
        }
    }

    private async Task ExportarHistorialCsvAsync()
    {
        if (!empleadoHistorialId.HasValue || !HistorialOrdenado.Any())
        {
            return;
        }

        exportandoCsv = true;
        try
        {
            var sb = new StringBuilder();
            sb.AppendLine("Fecha,Tipo,Horas,Referencia,ReferenciaCruda,Notas");
            foreach (var m in HistorialOrdenado)
            {
                sb.Append(m.Fecha.ToString("yyyy-MM-dd")).Append(',')
                  .Append(Csv(ObtenerEtiquetaTipoMovimiento(m.TipoMovimiento))).Append(',')
                  .Append(m.Horas.ToString("0.##")).Append(',')
                  .Append(Csv(ObtenerEtiquetaReferencia(m.ReferenciaTipo))).Append(',')
                  .Append(Csv(m.ReferenciaTipo)).Append(',')
                  .Append(Csv(m.Observaciones));
                sb.AppendLine();
            }

            var nombre = resumenes.FirstOrDefault(r => r.EmpleadoId == empleadoHistorialId.Value)?.NombreEmpleado ?? "empleado";
            var nombreArchivo = $"banco-horas-historial-{SanitizarNombre(nombre)}-{DateTime.Today:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("mundoVsAuth.downloadCsv", nombreArchivo, sb.ToString());
            ok = "Historial exportado correctamente.";
        }
        catch (Exception ex)
        {
            error = $"No se pudo exportar el CSV: {ex.Message}";
        }
        finally
        {
            exportandoCsv = false;
        }
    }

    private static string SanitizarNombre(string nombre)
    {
        var limpio = new StringBuilder();
        foreach (var c in nombre)
        {
            limpio.Append(char.IsLetterOrDigit(c) ? c : '_');
        }
        return limpio.Length == 0 ? "empleado" : limpio.ToString();
    }

    private static string Csv(string? valor)
    {
        if (string.IsNullOrEmpty(valor))
        {
            return string.Empty;
        }

        var necesitaComillas = valor.Contains(',') || valor.Contains('"') || valor.Contains('\n') || valor.Contains('\r');
        var escapado = valor.Replace("\"", "\"\"");
        return necesitaComillas ? $"\"{escapado}\"" : escapado;
    }

    private static string FormatearHoras(decimal horas)
        => $"{horas:0.##} h";

    private sealed class BancoHorasResumenVm
    {
        public Guid EmpleadoId { get; set; }
        public string NombreEmpleado { get; set; } = string.Empty;
        public decimal SaldoActual { get; set; }
        public decimal AcumuladoAutomatico { get; set; }
        public decimal AjustesManuales { get; set; }
        // Consumo desglosado por ReferenciaTipo (cobertura de faltante / permiso / manual / otro).
        public decimal CoberturaBanco { get; set; }
        public decimal PermisoBanco { get; set; }
        public decimal ConsumoManual { get; set; }
        public decimal ConsumoOtro { get; set; }
        // Total consumido = suma de los cuatro (para KPI y ordenamiento). Se mantiene para no
        // romper el ordenamiento existente por "Consumido" ni el KPI "Consumido".
        public decimal Consumido => CoberturaBanco + PermisoBanco + ConsumoManual + ConsumoOtro;
        public int TotalMovimientos { get; set; }
    }
}
