                                                        <div class="row g-2 mb-3">
                                                            <div class="col-md-6">
                                                                <select class="form-select form-select-sm" @bind="tipoPercepcionSeleccionadoId" disabled="@(!PuedeModificarNominaSeleccionada)">
                                                                    <option value="">Seleccionar tipo...</option>
                                                                    @foreach (var tipo in tiposPercepcion)
