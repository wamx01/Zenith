    private async Task CargarFestivosAplicadosAsync(DateTime inicio, DateTime fin, IEnumerable<Guid> empleadoIds)
    {
        var ids = empleadoIds.Distinct().Where(id => id != Guid.Empty).ToList();
        if (ids.Count == 0)
        {
            festivosAplicadosPorEmpleado = [];
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var festivosPorFecha = await db.FestivosRrhh
            .AsNoTracking()
            .Where(f => f.IsActive && f.Fecha >= inicio.Date && f.Fecha <= fin.Date && f.AplicaPrimaEspecial)
            .GroupBy(f => DateOnly.FromDateTime(f.Fecha.Date))
            .ToDictionaryAsync(
                g => g.Key,
                g => g.OrderByDescending(f => f.FactorPago).First());

        if (festivosPorFecha.Count == 0)
        {
            festivosAplicadosPorEmpleado = [];
            return;
        }

        var fechasFestivas = festivosPorFecha.Keys.ToHashSet();
        var asistencias = await db.RrhhAsistencias
            .AsNoTracking()
            .Where(a => ids.Contains(a.EmpleadoId)
                && a.Fecha >= DateOnly.FromDateTime(inicio)
                && a.Fecha <= DateOnly.FromDateTime(fin)
                && fechasFestivas.Contains(a.Fecha)
                && (a.Estatus == RrhhAsistenciaEstatus.AsistenciaNormal
                    || a.Estatus == RrhhAsistenciaEstatus.Retardo
                    || a.Estatus == RrhhAsistenciaEstatus.Incompleta
                    || a.Estatus == RrhhAsistenciaEstatus.DescansoTrabajado))
            .Select(a => new { a.EmpleadoId, a.Fecha })
            .ToListAsync();

        festivosAplicadosPorEmpleado = asistencias
            .GroupBy(a => a.EmpleadoId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderBy(a => a.Fecha)
                    .Select(a =>
                    {
                        var festivo = festivosPorFecha[a.Fecha];
                        var usaFallback = festivo.FactorPago <= 0m;
                        return new FestivoAplicadoVm
                        {
                            Fecha = a.Fecha,
                            Nombre = festivo.Nombre,
                            Factor = configuracionNomina.ObtenerFactorFestivoTrabajado(festivo.FactorPago),
                            UsaFallback = usaFallback
                        };
                    })
                    .ToList());
    }

