    private static Task<Prenomina?> ObtenerPrenominaCerradaAsync(CrmDbContext db, Guid empresaId, PeriodicidadPago periodicidadPago, int anioPeriodo, int numeroPeriodo)
        => db.Prenominas
            .OrderByDescending(p => p.CreatedAt)
            .FirstOrDefaultAsync(p => p.EmpresaId == empresaId
                && p.PeriodicidadPago == periodicidadPago
                && p.AnioPeriodo == anioPeriodo
                && p.NumeroPeriodo == numeroPeriodo
                && (p.Estatus == EstatusPrenomina.Cerrada || p.Estatus == EstatusPrenomina.Aplicada));

    private Task<Prenomina?> ObtenerPrenominaParaNominaAsync(CrmDbContext db, Guid empresaId, PeriodicidadPago periodicidadPago, int anioPeriodo, int numeroPeriodo)
        => reglasPrenomina.RequierePrenominaCerradaParaNomina
            ? ObtenerPrenominaCerradaAsync(db, empresaId, periodicidadPago, anioPeriodo, numeroPeriodo)
            : ObtenerPrenominaPeriodoAsync(db, empresaId, periodicidadPago, anioPeriodo, numeroPeriodo);

    private string ObtenerMensajePrenominaRequerida()
        => reglasPrenomina.RequierePrenominaCerradaParaNomina
            ? "Debes cerrar una prenómina del mismo periodo antes de guardar la nómina."
            : "Debes guardar una prenómina del mismo periodo antes de guardar la nómina.";

    private static Task<Prenomina?> ObtenerPrenominaPeriodoAsync(CrmDbContext db, Guid empresaId, PeriodicidadPago periodicidadPago, int anioPeriodo, int numeroPeriodo)
        => db.Prenominas
            .OrderByDescending(p => p.CreatedAt)
            .FirstOrDefaultAsync(p => p.EmpresaId == empresaId
                && p.PeriodicidadPago == periodicidadPago
                && p.AnioPeriodo == anioPeriodo
                && p.NumeroPeriodo == numeroPeriodo
                && p.Estatus != EstatusPrenomina.Cancelada);

    private async Task AplicarPeriodoNominaAsync(PeriodicidadPago periodicidad, DateTime? fechaReferencia = null)
    {
        var referencia = (fechaReferencia ?? fechaReferenciaNomina).Date;
        if (referencia == default)
            referencia = DateTime.Today;

        var periodo = NominaPeriodoHelper.ObtenerPeriodo(periodicidad, referencia, ObtenerCortePeriodo(periodicidad));
        fechaReferenciaNomina = referencia;
        editando.PeriodicidadPago = periodo.PeriodicidadPago;
        editando.AnioPeriodo = periodo.AnioPeriodo;
        editando.NumeroPeriodo = periodo.NumeroPeriodo;
        editando.NumeroNomina = periodo.NumeroNomina;
        editando.Periodo = periodo.Periodo;
        editando.FechaInicio = periodo.Inicio;
        editando.FechaFin = periodo.Fin;
        await CargarFestivosPeriodoAsync(periodo.Inicio, periodo.Fin);
    }

    private static string ObtenerAyudaFechaReferencia(PeriodicidadPago periodicidadPago)
        => periodicidadPago switch
        {
            PeriodicidadPago.Quincenal => "Elige cualquier fecha dentro de la quincena que quieres trabajar.",
            PeriodicidadPago.Mensual => "Elige cualquier fecha dentro del mes o período mensual deseado.",
            _ => "Elige cualquier fecha dentro de la semana que quieres trabajar."
        };

    private NominaCorteRrhh ObtenerCortePeriodo(PeriodicidadPago periodicidad)
        => periodicidad switch
        {
            PeriodicidadPago.Quincenal => corteQuincenal,
            PeriodicidadPago.Mensual => corteMensual,
            _ => corteSemanal
        };

    private async Task<NominaCorteRrhh> CargarCortePeriodoAsync(CrmDbContext db, PeriodicidadPago periodicidad, int diaCorteMesDefault)
        => await db.NominaCortesRrhh
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.EmpresaId == _empresaId && c.PeriodicidadPago == periodicidad && c.IsActive)
            ?? new NominaCorteRrhh
            {
                EmpresaId = _empresaId,
                PeriodicidadPago = periodicidad,
                DiaCorteSemana = DayOfWeek.Sunday,
                DiaCorteMes = diaCorteMesDefault,
                DiaPagoSugerido = DayOfWeek.Friday,
                IsActive = true
            };

    private Task<Nomina?> BuscarNominaExistenteAsync(CrmDbContext db, PeriodicidadPago periodicidadPago, int anioPeriodo, int numeroPeriodo)
        => db.Nominas
            .Include(n => n.Detalles)
            .Include(n => n.Prenomina)
            .AsNoTracking()
            .OrderByDescending(n => n.CreatedAt)
            .FirstOrDefaultAsync(n => n.EmpresaId == _empresaId
                && n.PeriodicidadPago == periodicidadPago
                && n.AnioPeriodo == anioPeriodo
                && n.NumeroPeriodo == numeroPeriodo
                && n.Estatus != EstatusNomina.Cancelada);

    private static string ObtenerClavePeriodo(PeriodicidadPago periodicidadPago, int anioPeriodo, int numeroPeriodo)
        => $"{ObtenerPrefijoPeriodicidad(periodicidadPago)} {anioPeriodo}-{numeroPeriodo:00}";

    private static string ObtenerPrefijoPeriodicidad(PeriodicidadPago periodicidadPago)
        => periodicidadPago switch
        {
            PeriodicidadPago.Quincenal => "QNA",
            PeriodicidadPago.Mensual => "MES",
            _ => "SEM"
        };

