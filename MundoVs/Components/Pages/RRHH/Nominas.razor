                                                                                <td><InputSelect class="form-select form-select-sm" @bind-Value="item.Origen" disabled="@(!PuedeModificarNominaSeleccionada)">@foreach (var origen in Enum.GetValues<OrigenPercepcionNomina>()) { <option value="@origen">@origen</option> }</InputSelect></td>
