@page "/rrhh/nominas"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject IAppConfigRepository AppConfig
@inject INominaCalculator NominaCalculator
@inject INominaLegalPolicyService NominaLegalPolicy
@inject INominaResumenBuilder NominaResumenBuilder
@inject CodigoNegocioService CodigoNegocio
@inject IAuditService AuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Nóminas</PageTitle>

<div class="container-fluid px-4">
    @if (!_puedeVer)
    {
        <div class="alert alert-warning mt-3">No tienes permisos para ver nóminas.</div>
    }
    else
    {
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="display-6 fw-bold"><i class="bi bi-wallet2 me-2"></i>Nóminas</h1>
        @if (_puedeEditar)
        {
            <button class="btn btn-primary" @onclick="NuevaNomina"><i class="bi bi-plus-circle me-1"></i>Nueva Nómina</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(error)) { <div class="alert alert-danger">@error</div> }
    @if (!string.IsNullOrEmpty(ok)) { <div class="alert alert-success">@ok</div> }

    @* ══ FORMULARIO NÓMINA ══ *@
    @if (mostrarForm)
    {
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">@(editando.Id == Guid.Empty ? "Nueva Nómina" : "Editar Nómina")</h5></div>
            <div class="card-body">
                <EditForm Model="editando" OnValidSubmit="GuardarNomina">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Periodicidad</label>
                            <InputSelect class="form-select" @bind-Value="editando.PeriodicidadPago" @bind-Value:after="OnPeriodicidadNominaChangedAsync" disabled="@(editando.Id != Guid.Empty || !PuedeModificarNominaEditando)">
                                @foreach (var periodicidad in PeriodicidadesDisponibles)
                                {
                                    <option value="@periodicidad">@periodicidad</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha de referencia</label>
                            <InputDate class="form-control" @bind-Value="fechaReferenciaNomina" @bind-Value:after="OnFechaReferenciaNominaChangedAsync" disabled="@(editando.Id != Guid.Empty || !PuedeModificarNominaEditando)" />
                            <div class="form-text">@ObtenerAyudaFechaReferencia(editando.PeriodicidadPago)</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Folio</label>
                            <InputText class="form-control" @bind-Value="editando.Folio" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Número nómina</label>
                            <InputText class="form-control" @bind-Value="editando.NumeroNomina" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Periodo</label>
                            <InputText class="form-control" @bind-Value="editando.Periodo" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Ciclo</label>
                            <input class="form-control" value="@ObtenerClavePeriodo(editando.PeriodicidadPago, editando.AnioPeriodo, editando.NumeroPeriodo)" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha Inicio</label>
                            <InputDate class="form-control" @bind-Value="editando.FechaInicio" disabled="true" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha Fin</label>
                            <InputDate class="form-control" @bind-Value="editando.FechaFin" disabled="true" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Estatus</label>
                            <InputSelect class="form-select" @bind-Value="editando.Estatus" disabled="@(!PuedeModificarNominaEditando)">
                                @foreach (var e in Enum.GetValues<EstatusNomina>()) { <option value="@e">@e</option> }
                            </InputSelect>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha Pago</label>
                            <InputDate class="form-control" @bind-Value="editando.FechaPago" disabled="@(!PuedeModificarNominaEditando)" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Notas</label>
                            <InputText class="form-control" @bind-Value="editando.Notas" disabled="@(!PuedeModificarNominaEditando)" />
                        </div>
                        @if (festivosPeriodo.Count > 0)
                        {
                            <div class="col-12">
                                <div class="alert alert-info py-2 small mb-0">
                                    <strong>Festivos en el período:</strong>
                                    @string.Join(", ", festivosPeriodo.OrderBy(f => f.Fecha).Select(f => $"{f.Fecha:dd/MM} {f.Nombre}"))
                                </div>
                            </div>
                        }
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-success" type="submit" disabled="@(guardando || !PuedeModificarNominaEditando)"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => mostrarForm = false">Cancelar</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* ══ DETALLE DE NÓMINA (empleados) ══ *@
    @if (nominaSeleccionada != null)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people-fill me-1"></i>Detalle — @(string.IsNullOrWhiteSpace(nominaSeleccionada.NumeroNomina) ? nominaSeleccionada.Periodo : $"{nominaSeleccionada.NumeroNomina} · {nominaSeleccionada.Periodo}")</h5>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-light text-primary">@detallesNomina.Count empleados</span>
                    <a class="btn btn-sm btn-outline-light" href="/configuracion/nomina"><i class="bi bi-sliders me-1"></i>Config nómina</a>
                    <a class="btn btn-sm btn-outline-light" href="/rrhh/bonos-distribuidos"><i class="bi bi-percent me-1"></i>Distribución</a>
                    <button class="btn btn-sm btn-outline-light" @onclick="ImprimirTodosRecibos" disabled="@(detallesNomina.Count == 0)"><i class="bi bi-printer me-1"></i>Imprimir todo</button>
                    @if (PuedeModificarNominaSeleccionada)
                    {
                        <button class="btn btn-sm btn-light" @onclick="RecalcularNominaSeleccionada" disabled="@(guardando || !PuedeModificarNominaSeleccionada)"><i class="bi bi-arrow-repeat me-1"></i>Recalcular</button>
                    }
                </div>
            </div>

            <div class="card-body border-bottom py-2">
                @if (festivosPeriodo.Count > 0)
                {
                    <div class="alert alert-info py-2 small mb-2">
                        <strong>Festivos del período:</strong>
                        @string.Join(", ", festivosPeriodo.OrderBy(f => f.Fecha).Select(f => $"{f.Fecha:dd/MM} {f.Nombre}"))
                    </div>
                }
                <div class="d-flex flex-wrap gap-2 small">
                    <span class="badge text-bg-light">Sueldo base: @resumenNomina.TotalSueldoBase.ToString("C2")</span>
                    <span class="badge text-bg-light">Destajo: @resumenNomina.TotalDestajo.ToString("C2")</span>
                    <span class="badge text-bg-light">Bono: @resumenNomina.TotalBono.ToString("C2")</span>
                    <span class="badge text-bg-light">Festivo trabajado: @resumenNomina.TotalFestivoTrabajado.ToString("C2")</span>
                     <span class="badge text-bg-light">Descanso trabajado: @resumenNomina.TotalDescansoTrabajado.ToString("C2")</span>
                    <span class="badge text-bg-light">Prima dominical: @resumenNomina.TotalPrimaDominical.ToString("C2")</span>
                    <span class="badge text-bg-light">Prima vacacional: @resumenNomina.TotalPrimaVacacional.ToString("C2")</span>
                    <span class="badge text-bg-light">Comp. salario mín.: @resumenNomina.TotalComplementoSalarioMinimo.ToString("C2")</span>
                    <span class="badge text-bg-light">Hrs dobles: @resumenNomina.TotalHorasExtraDobles.ToString("0.##")</span>
                    <span class="badge text-bg-light">Hrs triples: @resumenNomina.TotalHorasExtraTriples.ToString("0.##")</span>
                    <span class="badge text-bg-light">Hrs banco: @resumenNomina.TotalHorasExtraBanco.ToString("0.##")</span>
                    <span class="badge text-bg-light">Horas extra: @resumenNomina.TotalHorasExtra.ToString("C2")</span>
                    <span class="badge text-bg-light">Percep. manuales: @resumenNomina.TotalPercepcionesManuales.ToString("C2")</span>
                    <span class="badge text-bg-light">IMSS obrero: @resumenNomina.TotalImssObrero.ToString("C2")</span>
                    <span class="badge text-bg-light">ISR: @resumenNomina.TotalIsr.ToString("C2")</span>
                    <span class="badge text-bg-light">IMSS patronal: @resumenNomina.TotalImssPatronal.ToString("C2")</span>
                    <span class="badge text-bg-light">Terceros: @resumenNomina.TotalObligacionesTerceros.ToString("C2")</span>
                    <span class="badge text-bg-light">Provisiones: @resumenNomina.TotalProvisiones.ToString("C2")</span>
                    <span class="badge text-bg-light">Costo empresa: @resumenNomina.TotalCostoEmpresa.ToString("C2")</span>
                    <span class="badge text-bg-danger">Infonavit: @resumenNomina.TotalInfonavit.ToString("C2")</span>
                    <span class="badge text-bg-danger">Deducciones: @resumenNomina.TotalDeducciones.ToString("C2")</span>
                     <span class="badge text-bg-danger">Desc. minutos: @resumenNomina.TotalDescuentoMinutos.ToString("C2")</span>
                    <span class="badge text-bg-success">Total: @resumenNomina.TotalNeto.ToString("C2")</span>
                </div>
                <div class="row g-2 mt-2 small">
                    <div class="col-xl-3 col-md-6">
                        <div class="border rounded p-2 h-100 bg-white">
                            <div class="text-muted text-uppercase small fw-semibold">Neto empleado</div>
                            <div class="fw-bold text-success fs-6">@resumenNomina.TotalNeto.ToString("C2")</div>
                            <div>Sueldo, destajo, bonos y percepciones menos descuentos del trabajador.</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="border rounded p-2 h-100 bg-white">
                            <div class="text-muted text-uppercase small fw-semibold">Obligaciones a terceros</div>
                            <div class="fw-bold fs-6">@resumenNomina.TotalObligacionesTerceros.ToString("C2")</div>
                            <div>ISR @resumenNomina.TotalIsr.ToString("C2") · IMSS obrero @resumenNomina.TotalImssObrero.ToString("C2") · Infonavit @resumenNomina.TotalInfonavit.ToString("C2")</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="border rounded p-2 h-100 bg-white">
                            <div class="text-muted text-uppercase small fw-semibold">Aportaciones patronales</div>
                            <div class="fw-bold fs-6">@resumenNomina.TotalAportacionesPatronales.ToString("C2")</div>
                            <div>IMSS patronal @resumenNomina.TotalImssPatronal.ToString("C2")</div>
                        </div>
                    </div>
                    <div class="col-xl-3 col-md-6">
                        <div class="border rounded p-2 h-100 bg-white">
                            <div class="text-muted text-uppercase small fw-semibold">Provisiones y costo</div>
                            <div class="fw-bold fs-6">@resumenNomina.TotalCostoEmpresa.ToString("C2")</div>
                            <div>Prov. @resumenNomina.TotalProvisiones.ToString("C2") · Costo empresa total</div>
                        </div>
                    </div>
                </div>
                @if (NominaSeleccionadaRequiereActualizacionPrenomina)
                {
                    <div class="alert alert-warning py-2 small mt-2 mb-0">
                        <strong>Prenómina actualizada:</strong> la prenómina ligada cambió después de esta nómina. Recalcula para traer incidencias e importes actualizados.
                    </div>
                }
                <div class="small text-muted mt-2">Total neto = sueldo base + destajo + bono + festivo trabajado + descanso trabajado + prima dominical + prima vacacional + complemento salario mínimo + horas extra + percepciones manuales - descuentos por minutos - IMSS obrero - Infonavit - deducciones estructuradas.</div>
            </div>

            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Empleado</th>
                            <th>Incidencias</th>
                            <th>Ingresos</th>
                            <th>Legal</th>
                            <th class="text-end">Neto</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in detallesNomina)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@d.Empleado.Nombre @d.Empleado.ApellidoPaterno</div>
                                    <div class="small text-muted">@ObtenerNombreEsquema(d.EsquemaPagoId) · @d.Empleado.PeriodicidadPago</div>
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        @if (TieneFestivosAplicados(d.EmpleadoId))
                                        {
                                            <span class="badge text-bg-light" title="@ObtenerTextoFestivosAplicados(d.EmpleadoId)">
                                                <i class="bi bi-info-circle me-1"></i>Festivos
                                            </span>
                                        }
                                        @if (d.Bonos > 0)
                                        {
                                            <span class="badge text-bg-light">Percep. @d.Bonos.ToString("C0")</span>
                                        }
                                        @if (d.Deducciones > 0)
                                        {
                                            <span class="badge text-bg-light">Deduc. @d.Deducciones.ToString("C0")</span>
                                        }
                                        @if (d.MontoInfonavit > 0)
                                        {
                                            <span class="badge text-bg-light">Infonavit</span>
                                        }
                                        @if (TieneDiferenciaAsistenciaNomina(d))
                                        {
                                            <span class="badge text-bg-warning">Revisar asistencia</span>
                                        }
                                    </div>
                                </td>
                                <td class="small">
                                    <div>Trab @d.DiasTrabajados · Pag @d.DiasPagados · Vac @d.DiasVacaciones</div>
                                    <div>Desc @d.DiasDescansoTrabajado · Dom @d.DiasDomingoTrabajado · Fest @d.DiasFestivoTrabajado</div>
                                    <div>@ObtenerResumenHorasExtra(d) · Min @ObtenerMinutosDescuentoPreview(d)</div>
                                </td>
                                <td class="small">
                                    <div>Sueldo @d.SueldoBase.ToString("C2")</div>
                                    <div>Destajo @d.MontoDestajo.ToString("C2") · Bono @d.MontoBono.ToString("C2")</div>
                                    <div>Comp. mín. @d.ComplementoSalarioMinimo.ToString("C2")</div>
                                </td>
                                <td class="small">
                                    <div>Fest @d.MontoFestivoTrabajado.ToString("C2") · Desc @d.MontoDescansoTrabajado.ToString("C2")</div>
                                    <div>Dom @d.MontoPrimaDominical.ToString("C2") · Vac @d.MontoPrimaVacacional.ToString("C2")</div>
                                    <div>IMSS @ObtenerTextoImssObrero(d) · ISR @d.RetencionIsr.ToString("C2")</div>
                                    <div>Patronal @d.CuotaImssPatronal.ToString("C2") · Prov @d.TotalProvisiones.ToString("C2") · Costo @d.CostoEmpresa.ToString("C2")</div>
                                </td>
                                <td class="text-end fw-bold">@ObtenerTotalPagarPreview(d).ToString("C2")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => AbrirDetalleEmpleado(d)">
                                            <i class="bi bi-pencil-square me-1"></i>Detalle
                                        </button>
                                        <a class="btn btn-sm btn-outline-secondary" href="@($"/rrhh/nominas/recibo/{d.Id}")" target="_blank" title="Recibo de nómina"><i class="bi bi-printer"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark">
                            <td colspan="4" class="text-end fw-bold">TOTAL NÓMINA:</td>
                            <td class="text-end fw-bold">@resumenNomina.TotalNeto.ToString("C2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            @if (detalleModalSeleccionado != null)
            {
                var valesModal = ObtenerValesEmpleado(detalleModalSeleccionado.EmpleadoId);
                <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.45);" @onclick="CerrarDetalleEmpleado">
                    <div class="modal-dialog modal-xl modal-dialog-scrollable" @onclick:stopPropagation="true">
                        <div class="modal-content">
                            <div class="modal-header">
                                <div>
                                    <h5 class="modal-title mb-1">@detalleModalSeleccionado.Empleado.NombreCompleto</h5>
                                    <div class="small text-muted">@ObtenerNombreEsquema(detalleModalSeleccionado.EsquemaPagoId) · @detalleModalSeleccionado.Empleado.PeriodicidadPago</div>
                                </div>
                                <button type="button" class="btn-close" aria-label="Close" @onclick="CerrarDetalleEmpleado"></button>
                            </div>
                            <div class="modal-body">
                                <div class="d-flex flex-wrap gap-2 small mb-3">
                                    <span class="badge text-bg-light">Neto @ObtenerTotalPagarPreview(detalleModalSeleccionado).ToString("C2")</span>
                                    <span class="badge text-bg-light">Trab @detalleModalSeleccionado.DiasTrabajados</span>
                                    <span class="badge text-bg-light">Pag @detalleModalSeleccionado.DiasPagados</span>
                                    <span class="badge text-bg-light">Vac @detalleModalSeleccionado.DiasVacaciones</span>
                                    <span class="badge text-bg-light">Netas asistencia @ObtenerHorasTrabajadasNetasAsistencia(detalleModalSeleccionado.EmpleadoId).ToString("0.##") h</span>
                                    <span class="badge text-bg-light">Extra @detalleModalSeleccionado.HorasExtra.ToString("0.##") h</span>
                                    @if (TieneFestivosAplicados(detalleModalSeleccionado.EmpleadoId))
                                    {
                                        <span class="badge text-bg-light" title="@ObtenerTextoFestivosAplicados(detalleModalSeleccionado.EmpleadoId)">
                                            <i class="bi bi-info-circle me-1"></i>Festivos
                                        </span>
                                    }
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    @if (PuedeModificarNominaSeleccionada)
                                    {
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => EditarPercepcionesDetalleAsync(detalleModalSeleccionado)">
                                            <i class="bi bi-cash-coin me-1"></i>Percepciones
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => EditarDeduccionesDetalleAsync(detalleModalSeleccionado)">
                                            <i class="bi bi-dash-circle me-1"></i>Deducciones
                                        </button>
                                        <button class="btn btn-sm btn-outline-warning" @onclick="() => AbrirDistribucionBonos(detalleModalSeleccionado)">
                                            <i class="bi bi-percent me-1"></i>Distribución
                                        </button>
                                        <button class="btn btn-sm btn-primary" @onclick="() => GuardarCambiosDetalle(detalleModalSeleccionado)" disabled="@(guardando || !PuedeModificarNominaSeleccionada)">
                                            <i class="bi bi-save me-1"></i>Guardar detalle
                                        </button>
                                    }
                                    <a class="btn btn-sm btn-outline-secondary" href="@($"/rrhh/nominas/recibo/{detalleModalSeleccionado.Id}")" target="_blank">
                                        <i class="bi bi-printer me-1"></i>Recibo
                                    </a>
                                </div>

                                <div class="row g-3">
                                    <div class="col-lg-6">
                                        <div class="card h-100">
                                            <div class="card-header fw-semibold">Incidencias y tiempo</div>
                                            <div class="card-body">
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Trabajados</label>
                                                        <InputNumber class="form-control form-control-sm text-center" @bind-Value="detalleModalSeleccionado.DiasTrabajados" disabled="true" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Pagados</label>
                                                        <InputNumber class="form-control form-control-sm text-center" @bind-Value="detalleModalSeleccionado.DiasPagados" disabled="true" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Vacaciones</label>
                                                        <InputNumber class="form-control form-control-sm text-center" @bind-Value="detalleModalSeleccionado.DiasVacaciones" disabled="true" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Horas netas asistencia</label>
                                                        <input class="form-control form-control-sm text-end" value="@($"{ObtenerHorasTrabajadasNetasAsistencia(detalleModalSeleccionado.EmpleadoId):0.##}")" readonly />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Extra detectada</label>
                                                        <InputNumber class="form-control form-control-sm text-end" @bind-Value="detalleModalSeleccionado.HorasExtraBase" disabled="true" />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Extra aprobada banco</label>
                                                        <InputNumber class="form-control form-control-sm text-end" @bind-Value="detalleModalSeleccionado.HorasExtraBanco" disabled="true" />
                                                    </div>
                                                    <div class="col-12">
                                                        <div class="small text-muted">El tiempo neto trabajado viene de Asistencias. El tiempo extra solo se paga o manda a banco cuando existe resolución aprobada.</div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small mb-1">Extra aprobada pago</label>
                                                        <InputNumber class="form-control form-control-sm text-end" @bind-Value="detalleModalSeleccionado.HorasExtra" disabled="true" />
                                                    </div>
                                                    <div class="col-md-8">
                                                        @if (TieneDiferenciaAsistenciaNomina(detalleModalSeleccionado))
                                                        {
                                                            <div class="alert alert-warning py-2 small mb-0">@ObtenerMensajeDiferenciaAsistenciaNomina(detalleModalSeleccionado)</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="alert alert-success py-2 small mb-0">Tiempo aprobado sincronizado con Asistencias.</div>
                                                        }
                                                    </div>
                                                    @if (ObtenerDiasTiempoExtraPendiente(detalleModalSeleccionado.EmpleadoId) > 0)
                                                    {
                                                        <div class="col-12">
