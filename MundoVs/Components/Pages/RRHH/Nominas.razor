    private static void SincronizarBonosDistribuidos(CrmDbContext db, List<NominaBono> existentes, NominaDetalle detalle, BonoDistribucionEmpleadoRrhh distribucion, Guid empresaId)
    {
        var montoAsignado = distribucion.Detalles.Where(d => d.IsActive).Sum(d => d.MontoAsignado);
        var actual = existentes.FirstOrDefault(b => b.NominaDetalleId == detalle.Id);
        if (actual == null)
        {
            actual = new NominaBono
            {
                Id = Guid.NewGuid(),
                EmpresaId = empresaId,
                NominaDetalleId = detalle.Id,
                TipoCaptura = TipoCapturaBonoNomina.TotalDistribuido,
                MontoTotal = montoAsignado,
                CreatedAt = DateTime.UtcNow,
                IsActive = true,
                Detalles = []
            };
            db.NominasBonos.Add(actual);
            existentes.Add(actual);
        }

        actual.TipoCaptura = TipoCapturaBonoNomina.TotalDistribuido;
        actual.MontoTotal = montoAsignado;
        actual.IsActive = true;
        actual.UpdatedAt = DateTime.UtcNow;

        var detallesActuales = actual.Detalles.ToDictionary(d => d.BonoRubroRrhhId, d => d);
        var rubrosDistribuidos = distribucion.Detalles
            .Where(d => d.IsActive && d.BonoRubroRrhh.IsActive)
            .OrderBy(d => d.Orden)
            .ThenBy(d => d.BonoRubroRrhh.Nombre)
            .ToList();

        foreach (var eliminar in actual.Detalles.Where(d => rubrosDistribuidos.All(r => r.BonoRubroRrhhId != d.BonoRubroRrhhId)).ToList())
            db.NominasBonosDetalle.Remove(eliminar);

        var orden = 1;
        foreach (var rubro in rubrosDistribuidos)
        {
            if (!detallesActuales.TryGetValue(rubro.BonoRubroRrhhId, out var detalleBono))
            {
                detalleBono = new NominaBonoDetalle
                {
                    Id = Guid.NewGuid(),
                    NominaBono = actual,
                    BonoRubroRrhhId = rubro.BonoRubroRrhhId,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                };
                db.NominasBonosDetalle.Add(detalleBono);
                actual.Detalles.Add(detalleBono);
            }

            detalleBono.Porcentaje = rubro.Porcentaje;
            detalleBono.Importe = rubro.MontoAsignado;
            detalleBono.Orden = orden++;
            detalleBono.IsActive = true;
            detalleBono.UpdatedAt = DateTime.UtcNow;
        }

        detalle.MontoBono = montoAsignado;
    }

