    private async Task GuardarPercepcionesDetalleAsync()
    {
        if (detallePercepcionSeleccionado == null)
            return;

        error = ok = null;
        guardando = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var nominaActual = await db.NominaDetalles
                .Where(d => d.Id == detallePercepcionSeleccionado.Id)
                .Join(db.Nominas, d => d.NominaId, n => n.Id, (d, n) => n)
                .AsNoTracking()
                .FirstOrDefaultAsync();

            if (nominaActual == null)
            {
                error = "No se encontró la nómina del detalle.";
                return;
            }

            if (EstaBloqueadaNomina(nominaActual.Estatus))
            {
                error = ObtenerMensajeBloqueoNomina(nominaActual.Estatus);
                return;
            }

            var existentes = await db.NominasPercepciones
                .Where(p => p.NominaDetalleId == detallePercepcionSeleccionado.Id)
                .ToListAsync();

            var idsEditor = percepcionesEditando.Where(p => p.Id != Guid.Empty).Select(p => p.Id).ToHashSet();
            var eliminar = existentes.Where(p => !idsEditor.Contains(p.Id)).ToList();
            if (eliminar.Count > 0)
                db.NominasPercepciones.RemoveRange(eliminar);

            foreach (var item in percepcionesEditando)
            {
                if (item.Importe < 0)
                {
                    error = "Las percepciones manuales no pueden tener importe negativo.";
                    return;
                }

                var entity = item.Id == Guid.Empty ? null : existentes.FirstOrDefault(p => p.Id == item.Id);
                if (entity == null)
                {
                    entity = new NominaPercepcion
                    {
                        EmpresaId = _empresaId,
                        NominaDetalleId = detallePercepcionSeleccionado.Id,
                        TipoPercepcionId = item.TipoPercepcionId,
                        Descripcion = string.IsNullOrWhiteSpace(item.Descripcion) ? null : item.Descripcion.Trim(),
                        Referencia = string.IsNullOrWhiteSpace(item.Referencia) ? null : item.Referencia.Trim(),
                        Importe = item.Importe,
                        Origen = item.Origen,
                        Observaciones = string.IsNullOrWhiteSpace(item.Observaciones) ? null : item.Observaciones.Trim(),
                        CreatedAt = DateTime.UtcNow,
                        IsActive = true
                    };
                    db.NominasPercepciones.Add(entity);
                }
                else
                {
                    entity.TipoPercepcionId = item.TipoPercepcionId;
                    entity.Descripcion = string.IsNullOrWhiteSpace(item.Descripcion) ? null : item.Descripcion.Trim();
                    entity.Referencia = string.IsNullOrWhiteSpace(item.Referencia) ? null : item.Referencia.Trim();
                    entity.Importe = item.Importe;
                    entity.Origen = item.Origen;
                    entity.Observaciones = string.IsNullOrWhiteSpace(item.Observaciones) ? null : item.Observaciones.Trim();
                    entity.UpdatedAt = DateTime.UtcNow;
                }
            }

            var nominaDetalle = await db.NominaDetalles.FirstAsync(d => d.Id == detallePercepcionSeleccionado.Id);
            nominaDetalle.Bonos = TotalPercepcionesManualesEditando;

            await db.SaveChangesAsync();
            await Cargar();
            await CargarDetalles();
            await CargarDesgloseValesAsync();

            detallePercepcionSeleccionado = detallesNomina.FirstOrDefault(d => d.Id == detallePercepcionSeleccionado.Id);
            if (detallePercepcionSeleccionado != null)
                await EditarPercepcionesDetalleAsync(detallePercepcionSeleccionado);

            ok = "Percepciones manuales guardadas.";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

