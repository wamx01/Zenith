    @* ══ TABLA NÓMINAS ══ *@
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Folio</th><th>Nómina</th><th>Ciclo</th><th>Periodo</th><th>Inicio</th><th>Fin</th><th>Pago</th>
                        <th class="text-center">Estatus</th><th class="text-end">Total</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in nominas)
                    {
                        var total = n.Detalles.Sum(d => d.TotalPagar);
                        <tr class="@(nominaSeleccionada?.Id == n.Id ? "table-active" : "")">
                            <td class="fw-semibold">@(string.IsNullOrWhiteSpace(n.Folio) ? "—" : n.Folio)</td>
                            <td class="fw-semibold">@(string.IsNullOrWhiteSpace(n.NumeroNomina) ? "—" : n.NumeroNomina)</td>
                            <td><span class="badge text-bg-light">@ObtenerClavePeriodo(n.PeriodicidadPago, n.AnioPeriodo, n.NumeroPeriodo)</span></td>
                            <td class="fw-semibold">@n.Periodo</td>
                            <td>@n.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@n.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>@(n.FechaPago?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center gap-1">
                                    <span class="badge @EstatusBadge(n.Estatus)">@n.Estatus</span>
                                    @if (RequiereActualizacionDesdePrenomina(n))
                                    {
                                        <span class="badge text-bg-warning">Prenómina cambió</span>
                                    }
                                </div>
                            </td>
                            <td class="text-end fw-bold">@total.ToString("C2")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info me-1" @onclick="() => VerDetalle(n)" title="Ver detalle"><i class="bi bi-eye"></i></button>
                                @if (_puedeEditar && !EstaBloqueadaNomina(n.Estatus))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditarNomina(n)" title="Editar"><i class="bi bi-pencil"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    }
</div>

@code {
    private List<Nomina> nominas = [];
    private List<NominaDetalle> detallesNomina = [];
    private Dictionary<Guid, ResumenAsistenciaNominaVm> resumenAsistenciaPorEmpleado = [];
    private Dictionary<Guid, List<ValeResumenVm>> valesPorEmpleado = [];
    private Dictionary<Guid, string> esquemaNombrePorId = [];
    private List<Empleado> empleados = [];
    private List<NominaPercepcionTipo> tiposPercepcion = [];
    private List<DeduccionTipoRrhh> tiposDeduccion = [];
    private NominaConfiguracion configuracionNomina = new();
    private NominaCorteRrhh corteSemanal = new() { PeriodicidadPago = PeriodicidadPago.Semanal, DiaCorteSemana = DayOfWeek.Sunday, DiaPagoSugerido = DayOfWeek.Friday, IsActive = true };
    private NominaCorteRrhh corteQuincenal = new() { PeriodicidadPago = PeriodicidadPago.Quincenal, DiaCorteMes = 15, DiaPagoSugerido = DayOfWeek.Friday, IsActive = true };
    private NominaCorteRrhh corteMensual = new() { PeriodicidadPago = PeriodicidadPago.Mensual, DiaCorteMes = 31, DiaPagoSugerido = DayOfWeek.Friday, IsActive = true };
    private DateTime fechaReferenciaNomina = DateTime.Today;
    private List<FestivoRrhh> festivosPeriodo = [];
    private Dictionary<Guid, List<FestivoAplicadoVm>> festivosAplicadosPorEmpleado = [];
    private NominaDetalle? detalleModalSeleccionado;
    private Nomina editando = new();
    private NominaDetalle editandoDetalle = new();
    private NominaDetalle? detallePercepcionSeleccionado;
    private NominaDetalle? detalleDeduccionSeleccionado;
    private List<PercepcionManualEditor> percepcionesEditando = [];
    private string tipoPercepcionSeleccionadoId = string.Empty;
    private List<DeduccionEditor> deduccionesEditando = [];
    private string tipoDeduccionSeleccionadoId = string.Empty;
    private Nomina? nominaSeleccionada;
    private NominaResumenResult resumenNomina = new();
    private bool mostrarForm, mostrarFormDetalle, guardando;
    private string? error, ok;
    private bool _puedeVer;
    private bool _puedeEditar;
    private bool _nominaEditandoBloqueada;
    private Guid _empresaId;
    private ReglasPrenominaConfiguracion reglasPrenomina = new();
    private decimal TotalPercepcionesManualesEditando => percepcionesEditando.Sum(p => p.Importe);
    private decimal TotalDeduccionesEditando => deduccionesEditando.Sum(d => d.Importe);
    private bool PuedeModificarNominaEditando => _puedeEditar && !_nominaEditandoBloqueada;
    private bool PuedeModificarNominaSeleccionada => _puedeEditar && nominaSeleccionada is not null && !EstaBloqueadaNomina(nominaSeleccionada.Estatus);
    private bool NominaSeleccionadaRequiereActualizacionPrenomina => nominaSeleccionada is not null && RequiereActualizacionDesdePrenomina(nominaSeleccionada);
    private static IReadOnlyList<PeriodicidadPago> PeriodicidadesDisponibles { get; } = [PeriodicidadPago.Semanal, PeriodicidadPago.Quincenal, PeriodicidadPago.Mensual];

    protected override async Task OnInitializedAsync()
    {
        await CargarAcceso();
        if (_puedeVer)
        {
            await CargarConfiguracionNominaAsync();
            await Cargar();
        }
    }

    private async Task CargarConfiguracionNominaAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        configuracionNomina = await NominaConfiguracionLoader.LoadAsync(db);
        reglasPrenomina = configuracionNomina.ObtenerReglasPrenomina();

        corteSemanal = await CargarCortePeriodoAsync(db, PeriodicidadPago.Semanal, 31);
        corteQuincenal = await CargarCortePeriodoAsync(db, PeriodicidadPago.Quincenal, 15);
        corteMensual = await CargarCortePeriodoAsync(db, PeriodicidadPago.Mensual, 31);
    }

    private async Task CargarAcceso()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "nominas.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "nominas.editar");
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task Cargar()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        nominas = await db.Nominas.Include(n => n.Detalles).Include(n => n.Prenomina).OrderByDescending(n => n.FechaInicio).AsNoTracking().ToListAsync();
        empleados = await db.Empleados.Where(e => e.IsActive).OrderBy(e => e.Nombre).AsNoTracking().ToListAsync();
        esquemaNombrePorId = await db.EsquemasPago.AsNoTracking().ToDictionaryAsync(e => e.Id, e => e.Nombre);
        tiposPercepcion = await db.NominasPercepcionesTipos.Where(t => t.IsActive).OrderBy(t => t.Orden).ThenBy(t => t.Nombre).AsNoTracking().ToListAsync();
        tiposDeduccion = await db.DeduccionesTiposRrhh.Where(t => t.IsActive).OrderBy(t => t.Orden).ThenBy(t => t.Nombre).AsNoTracking().ToListAsync();
    }

    private async Task CargarDetalles()
    {
        if (nominaSeleccionada == null)
        {
            detallesNomina = [];
            resumenAsistenciaPorEmpleado = [];
            RecalcularResumenNomina();
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        detallesNomina = await db.NominaDetalles
            .Include(d => d.Empleado)
                .ThenInclude(e => e.Posicion)
                    .ThenInclude(p => p!.BonoEstructuraRrhh)
                        .ThenInclude(e => e!.Detalles)
                            .ThenInclude(d => d.BonoRubroRrhh)
            .Include(d => d.ProvisionesDetalle.Where(p => p.IsActive))
            .Where(d => d.NominaId == nominaSeleccionada.Id)
            .OrderBy(d => d.Empleado.Nombre)
            .AsNoTracking()
            .ToListAsync();
        await CargarResumenAsistenciaNominaAsync(nominaSeleccionada.FechaInicio, nominaSeleccionada.FechaFin, detallesNomina.Select(d => d.EmpleadoId));
        await CargarFestivosAplicadosAsync(nominaSeleccionada.FechaInicio, nominaSeleccionada.FechaFin, detallesNomina.Select(d => d.EmpleadoId));
        RecalcularResumenNomina();
    }

    private async Task CargarResumenAsistenciaNominaAsync(DateTime inicio, DateTime fin, IEnumerable<Guid> empleadoIds)
    {
        var ids = empleadoIds.Distinct().Where(id => id != Guid.Empty).ToList();
        if (ids.Count == 0)
        {
            resumenAsistenciaPorEmpleado = [];
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var asistencias = await db.RrhhAsistencias
            .AsNoTracking()
            .Where(a => ids.Contains(a.EmpleadoId)
                && a.Fecha >= DateOnly.FromDateTime(inicio)
                && a.Fecha <= DateOnly.FromDateTime(fin))
            .ToListAsync();

        resumenAsistenciaPorEmpleado = asistencias
            .GroupBy(a => a.EmpleadoId)
            .ToDictionary(
                g => g.Key,
                g => new ResumenAsistenciaNominaVm
                {
                    HorasTrabajadasNetas = Math.Round(g.Sum(a => Math.Max(0, a.MinutosTrabajadosNetos)) / 60m, 2),
                    HorasExtraDetectadas = Math.Round(g.Sum(a => Math.Max(0, a.MinutosExtra)) / 60m, 2),
                    HorasExtraAprobadasPago = Math.Round(g.Sum(a => Math.Max(0, a.MinutosExtraAutorizadosPago)) / 60m, 2),
                    HorasExtraAprobadasBanco = Math.Round(g.Sum(a => Math.Max(0, a.MinutosExtraAutorizadosBanco)) / 60m, 2),
                    DiasConTiempoExtraPendiente = g.Count(a => a.MinutosExtra > 0
                        && a.MinutosExtraAutorizadosPago == 0
                        && a.MinutosExtraAutorizadosBanco == 0
                        && string.IsNullOrWhiteSpace(a.ResolucionTiempoExtra))
                });
    }

    private async Task CargarDesgloseValesAsync()
    {
        valesPorEmpleado = [];

        if (nominaSeleccionada == null)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var inicio = nominaSeleccionada.FechaInicio.Date;
        var fin = nominaSeleccionada.FechaFin.Date;

        var vales = await db.ValesDestajo 
            .Include(v => v.Detalles).ThenInclude(d => d.TipoProceso)
            .Include(v => v.Detalles).ThenInclude(d => d.RegistrosOrigen)
            .Where(v => v.IsActive
                && (v.Estatus == EstatusValeDestajo.Aprobado
                    || v.Estatus == EstatusValeDestajo.EnNomina
                    || v.Estatus == EstatusValeDestajo.Pagado)
                && v.Fecha >= inicio && v.Fecha <= fin)
            .OrderBy(v => v.EmpleadoId)
            .ThenBy(v => v.Fecha)
            .AsNoTracking()
            .ToListAsync();

        valesPorEmpleado = vales
            .GroupBy(v => v.EmpleadoId)
            .ToDictionary(
                g => g.Key,
                g => g.Select(v => new ValeResumenVm
                {
                    Folio = v.Folio,
                    Fecha = v.Fecha,
                    TotalPiezas = v.Detalles.Sum(d => d.Cantidad),
                    TotalImporte = v.Detalles.Sum(d => d.Importe),
                    RegistrosOrigen = v.Detalles.Sum(d => d.RegistrosOrigen.Count),
                    Resumen = string.Join(" + ", v.Detalles.Select(d => $"{d.TipoProceso?.Nombre} {d.Cantidad}pz"))
                }).ToList());
    }

    private async Task NuevaNomina()
    {
        if (!_puedeEditar)
        {
            error = "No tienes permisos para crear nóminas.";
            return;
        }

        error = ok = null;
        editando = new()
        {
            Id = Guid.Empty,
            Folio = null,
            PeriodicidadPago = PeriodicidadPago.Semanal
        };
        fechaReferenciaNomina = DateTime.Today;
        _nominaEditandoBloqueada = false;
        await AplicarPeriodoNominaAsync(editando.PeriodicidadPago, fechaReferenciaNomina);

        await using var db = await DbFactory.CreateDbContextAsync();
        var existente = await BuscarNominaExistenteAsync(db, editando.PeriodicidadPago, editando.AnioPeriodo, editando.NumeroPeriodo);
        if (existente != null)
        {
            await EditarNomina(existente);
            ok = $"Ya existe una nómina activa para el ciclo {ObtenerClavePeriodo(existente.PeriodicidadPago, existente.AnioPeriodo, existente.NumeroPeriodo)}. Se abrió el registro actual.";
            return;
        }

        mostrarForm = true;
    }

    private async Task EditarNomina(Nomina n)
    {
        if (!_puedeEditar)
        {
            error = "No tienes permisos para editar nóminas.";
            return;
        }

        if (EstaBloqueadaNomina(n.Estatus))
        {
            error = ObtenerMensajeBloqueoNomina(n.Estatus);
            return;
        }

        error = ok = null;
        _nominaEditandoBloqueada = false;
        editando = new()
        {
            Id = n.Id, Folio = n.Folio, NumeroNomina = n.NumeroNomina, PeriodicidadPago = n.PeriodicidadPago, AnioPeriodo = n.AnioPeriodo, NumeroPeriodo = n.NumeroPeriodo, Periodo = n.Periodo, FechaInicio = n.FechaInicio,
            FechaFin = n.FechaFin, FechaPago = n.FechaPago,
            Estatus = n.Estatus, Notas = n.Notas
        };
        await CargarFestivosPeriodoAsync(n.FechaInicio, n.FechaFin);
        mostrarForm = true;
    }

