    private void AbrirDistribucionBonos(NominaDetalle detalle)
    {
        error = ok = null;
        if (nominaSeleccionada == null)
            return;

        var estructura = detalle.Empleado.Posicion?.BonoEstructuraRrhh;
        if (detalle.Empleado.PosicionId is not Guid posicionId || estructura?.TipoCaptura != TipoCapturaBonoNomina.TotalDistribuido)
        {
            error = "Este empleado no usa bono distribuido. La distribución solo aplica a posiciones con esquema total distribuido.";
            return;
        }

        var inicio = Uri.EscapeDataString(nominaSeleccionada.FechaInicio.ToString("yyyy-MM-dd"));
        var fin = Uri.EscapeDataString(nominaSeleccionada.FechaFin.ToString("yyyy-MM-dd"));
        var empleadoId = Uri.EscapeDataString(detalle.EmpleadoId.ToString());
        var posicion = Uri.EscapeDataString(posicionId.ToString());
        Navigation.NavigateTo($"/rrhh/bonos-distribuidos?inicio={inicio}&fin={fin}&posicionId={posicion}&empleadoId={empleadoId}&autocargar=true");
    }

