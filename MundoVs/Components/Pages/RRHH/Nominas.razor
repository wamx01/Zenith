    private static void AplicarConceptosConfigurablesEmpleado(CrmDbContext db, Nomina nomina, NominaDetalle detalle, IReadOnlyCollection<EmpleadoConceptoRrhh> conceptosEmpleado, decimal totalDeduccionesBase, string? conceptoDeduccionBase)
    {
        if (conceptosEmpleado.Count == 0)
        {
            detalle.Deducciones = totalDeduccionesBase;
            detalle.ConceptoDeducciones = conceptoDeduccionBase;
            return;
        }

        var baseCalculo = detalle.SueldoBase + detalle.MontoDestajo + detalle.MontoBono + detalle.MontoFestivoTrabajado
            + detalle.MontoDescansoTrabajado + detalle.MontoPrimaDominical + detalle.MontoPrimaVacacional + detalle.ComplementoSalarioMinimo
            + detalle.MontoHorasExtra + detalle.Bonos;

        var totalDeduccionesConfigurables = 0m;
        var etiquetasDeduccion = new List<string>();
        var ajusteImssObrero = 0m;
        var ajusteImssPatronal = 0m;
        var ajusteIsr = 0m;

        foreach (var conceptoEmpleado in conceptosEmpleado)
        {
            var concepto = conceptoEmpleado.ConceptoConfig;
            var importe = ResolverImporteConcepto(conceptoEmpleado, baseCalculo);
            if (importe <= 0)
                continue;

            if (concepto.Naturaleza == NaturalezaConceptoNominaRrhh.Provision || concepto.AfectaProvision)
            {
                db.NominasProvisionesDetalleRrhh.Add(new NominaProvisionDetalleRrhh
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = nomina.EmpresaId,
                    NominaDetalleId = detalle.Id,
                    EmpleadoId = detalle.EmpleadoId,
                    ConceptoConfigId = concepto.Id,
                    Importe = importe,
                    BaseCalculo = baseCalculo,
                    Cantidad = ObtenerCantidadConcepto(conceptoEmpleado),
                    Tarifa = ObtenerTarifaConcepto(conceptoEmpleado),
                    PeriodoInicio = nomina.FechaInicio.Date,
                    PeriodoFin = nomina.FechaFin.Date,
                    EsAjusteManual = false,
                    Observaciones = string.IsNullOrWhiteSpace(conceptoEmpleado.Observaciones) ? concepto.Observaciones : conceptoEmpleado.Observaciones,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
                continue;
            }

            if (concepto.AfectaPasivoImss)
            {
                if (concepto.AfectaNetoEmpleado)
                    ajusteImssObrero += importe;

                if (concepto.AfectaCostoEmpresa)
                    ajusteImssPatronal += importe;

                if (concepto.AfectaNetoEmpleado)
                    etiquetasDeduccion.Add(concepto.Nombre);

                continue;
            }

            if (concepto.AfectaPasivoSat)
            {
                if (concepto.AfectaNetoEmpleado)
                    ajusteIsr += importe;

                if (concepto.AfectaNetoEmpleado)
                    etiquetasDeduccion.Add(concepto.Nombre);

                continue;
            }

            if (EsPercepcionConfigurable(concepto))
            {
                continue;
            }

            if (concepto.AfectaNetoEmpleado)
            {
                totalDeduccionesConfigurables += importe;
                etiquetasDeduccion.Add(concepto.Nombre);
            }
        }

        detalle.CuotaImssObrera += ajusteImssObrero;
        detalle.CuotaImssPatronal += ajusteImssPatronal;
        detalle.RetencionIsr += ajusteIsr;
        detalle.Deducciones = totalDeduccionesBase + totalDeduccionesConfigurables;
        detalle.ConceptoDeducciones = ConstruirConceptoDeduccion(conceptoDeduccionBase, etiquetasDeduccion);
    }

    private static decimal ResolverImporteConcepto(EmpleadoConceptoRrhh conceptoEmpleado, decimal baseCalculo)
    {
        var concepto = conceptoEmpleado.ConceptoConfig;
        return concepto.TipoCalculo switch
        {
            TipoCalculoConceptoNominaRrhh.Porcentaje => Math.Round(baseCalculo * ObtenerPorcentajeConcepto(conceptoEmpleado), 2),
            TipoCalculoConceptoNominaRrhh.CantidadPorTarifa => Math.Round(ObtenerCantidadConcepto(conceptoEmpleado) * ObtenerTarifaConcepto(conceptoEmpleado), 2),
            _ => Math.Round(ObtenerMontoConcepto(conceptoEmpleado), 2)
        };
    }

    private static decimal ObtenerMontoConcepto(EmpleadoConceptoRrhh conceptoEmpleado)
        => conceptoEmpleado.Monto > 0 ? conceptoEmpleado.Monto : conceptoEmpleado.ConceptoConfig.MontoFijoDefault;

    private static decimal ObtenerPorcentajeConcepto(EmpleadoConceptoRrhh conceptoEmpleado)
    {
        var porcentaje = conceptoEmpleado.Porcentaje > 0 ? conceptoEmpleado.Porcentaje : conceptoEmpleado.ConceptoConfig.PorcentajeDefault;
        return porcentaje > 1m ? porcentaje / 100m : porcentaje;
    }

    private static decimal ObtenerCantidadConcepto(EmpleadoConceptoRrhh conceptoEmpleado)
        => conceptoEmpleado.Cantidad > 0 ? conceptoEmpleado.Cantidad : conceptoEmpleado.ConceptoConfig.CantidadDefault;

    private static decimal ObtenerTarifaConcepto(EmpleadoConceptoRrhh conceptoEmpleado)
        => conceptoEmpleado.Tarifa > 0 ? conceptoEmpleado.Tarifa : conceptoEmpleado.ConceptoConfig.TarifaDefault;

    private static List<PercepcionConfigurableAplicada> ConstruirPercepcionesConfigurablesEmpleado(IReadOnlyCollection<EmpleadoConceptoRrhh> conceptosEmpleado, decimal baseCalculo, Guid tipoPercepcionOtrosIngresosId, IReadOnlyDictionary<string, NominaPercepcionTipo> tiposPercepcionPorClave)
    {
        var percepciones = new List<PercepcionConfigurableAplicada>();
        if (conceptosEmpleado.Count == 0)
            return percepciones;

        foreach (var conceptoEmpleado in conceptosEmpleado)
        {
            if (!EsPercepcionConfigurable(conceptoEmpleado.ConceptoConfig))
                continue;

            var importe = ResolverImporteConcepto(conceptoEmpleado, baseCalculo);
            if (importe <= 0)
                continue;

            var claveSat = ResolverClavePercepcionConfigurable(conceptoEmpleado.ConceptoConfig.Clave, conceptoEmpleado.ConceptoConfig.Nombre);
            var tipoPercepcionId = tiposPercepcionPorClave.TryGetValue(claveSat, out var tipoPercepcion)
                ? tipoPercepcion.Id
                : tipoPercepcionOtrosIngresosId;
            var observaciones = string.IsNullOrWhiteSpace(conceptoEmpleado.Observaciones)
                ? conceptoEmpleado.ConceptoConfig.Observaciones
                : conceptoEmpleado.Observaciones;

            percepciones.Add(new PercepcionConfigurableAplicada
            {
                ConceptoConfigId = conceptoEmpleado.ConceptoConfigId,
                TipoPercepcionId = tipoPercepcionId,
                Importe = importe,
                Descripcion = conceptoEmpleado.ConceptoConfig.Nombre,
                Referencia = conceptoEmpleado.ConceptoConfig.Clave,
                Observaciones = observaciones,
                ClaveSat = claveSat
            });
        }

        return percepciones;
    }

    private static bool EsPercepcionConfigurable(NominaConceptoConfigRrhh concepto)
        => (concepto.Naturaleza == NaturalezaConceptoNominaRrhh.Percepcion || concepto.Naturaleza == NaturalezaConceptoNominaRrhh.Ajuste)
            && concepto.Destino == DestinoConceptoNominaRrhh.Empleado
            && concepto.AfectaNetoEmpleado
            && !concepto.AfectaPasivoImss
            && !concepto.AfectaPasivoSat
            && !concepto.AfectaProvision;

    private static string ResolverClavePercepcionConfigurable(string? claveConfigurada, string? nombre)
    {
        var texto = string.Join(" ", new[] { claveConfigurada, nombre }.Where(t => !string.IsNullOrWhiteSpace(t))).ToUpperInvariant();
        if (texto.Contains("PUNTUALIDAD"))
            return NominaSatCatalogos.Sistema.PercepcionPremioPuntualidad;
        if (texto.Contains("ASISTENCIA"))
            return NominaSatCatalogos.Sistema.PercepcionPremioAsistencia;
        if (texto.Contains("DESPENSA"))
            return NominaSatCatalogos.Sistema.PercepcionValesDespensa;
        if (texto.Contains("CAJA_AHORRO"))
            return NominaSatCatalogos.Sistema.PercepcionCajaAhorro;
        if (texto.Contains("FONDO_AHORRO"))
            return NominaSatCatalogos.Sistema.PercepcionFondoAhorro;
        if (texto.Contains("COMISION"))
            return NominaSatCatalogos.Sistema.PercepcionComisiones;

        return NominaSatCatalogos.Sistema.PercepcionOtrosIngresosSalarios;
    }

    private static void SincronizarPercepcionesConfigurables(CrmDbContext db, List<NominaPercepcion> existentes, NominaDetalle detalle, IReadOnlyCollection<PercepcionConfigurableAplicada> percepcionesConfigurables, Guid empresaId, string referenciaPrefijo)
    {
        var existentesDetalle = existentes
            .Where(p => p.NominaDetalleId == detalle.Id
                && p.Origen == OrigenPercepcionNomina.Ajuste
                && p.Referencia != null
                && p.Referencia.StartsWith(referenciaPrefijo))
            .ToDictionary(p => p.Referencia!, p => p);
        var referenciasActuales = percepcionesConfigurables
            .Select(p => $"{referenciaPrefijo}{p.ConceptoConfigId}")
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        foreach (var eliminar in existentesDetalle.Values.Where(p => !referenciasActuales.Contains(p.Referencia!)).ToList())
        {
            db.NominasPercepciones.Remove(eliminar);
            existentes.Remove(eliminar);
        }

        foreach (var percepcion in percepcionesConfigurables)
        {
            var referencia = $"{referenciaPrefijo}{percepcion.ConceptoConfigId}";
            if (!existentesDetalle.TryGetValue(referencia, out var actual))
            {
                actual = new NominaPercepcion
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = empresaId,
                    NominaDetalleId = detalle.Id,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                };
                db.NominasPercepciones.Add(actual);
                existentes.Add(actual);
            }

            actual.TipoPercepcionId = percepcion.TipoPercepcionId;
            actual.Descripcion = percepcion.Descripcion;
            actual.Importe = percepcion.Importe;
            actual.Origen = OrigenPercepcionNomina.Ajuste;
            actual.Referencia = referencia;
            actual.Observaciones = percepcion.Observaciones;
            actual.IsActive = true;
            actual.UpdatedAt = DateTime.UtcNow;
        }
    }

    private static async Task<NominaPercepcionTipo> ObtenerOCrearTipoPercepcionOtrosIngresosAsync(CrmDbContext db, IDictionary<string, NominaPercepcionTipo> tiposPercepcionPorClave)
    {
        if (tiposPercepcionPorClave.TryGetValue(NominaSatCatalogos.Sistema.PercepcionOtrosIngresosSalarios, out var tipo))
            return tipo;

        tipo = new NominaPercepcionTipo
        {
            Id = Guid.NewGuid(),
            Clave = NominaSatCatalogos.Sistema.PercepcionOtrosIngresosSalarios,
            Nombre = "Otros ingresos por salarios",
            Categoria = CategoriaPercepcionNomina.OtroIngreso,
            AfectaBaseImss = true,
            AfectaBaseIsr = true,
            Orden = 38,
            CreatedAt = DateTime.UtcNow,
            IsActive = true
        };
        await db.NominasPercepcionesTipos.AddAsync(tipo);
        tiposPercepcionPorClave[tipo.Clave] = tipo;
        return tipo;
    }

    private static string? ConstruirConceptoDeduccion(string? conceptoBase, IReadOnlyCollection<string> etiquetasConfigurables)
    {
        var conceptoNormalizado = string.IsNullOrWhiteSpace(conceptoBase) ? null : conceptoBase.Trim();

        if (etiquetasConfigurables.Count == 0)
            return conceptoNormalizado;

        if (string.IsNullOrWhiteSpace(conceptoNormalizado))
            return etiquetasConfigurables.Count == 1 ? etiquetasConfigurables.First() : "Deducciones configurables";

        if (conceptoNormalizado.Contains("configurables", StringComparison.OrdinalIgnoreCase))
            return conceptoNormalizado;

        return $"{conceptoNormalizado} + configurables";
    }

    private static void SincronizarBonosPrenomina(CrmDbContext db, List<NominaBono> existentes, NominaDetalle detalle, IReadOnlyCollection<PrenominaBono> bonosPrenomina, Guid empresaId)
    {
        var actual = existentes.FirstOrDefault(b => b.NominaDetalleId == detalle.Id);
        if (actual == null)
        {
            actual = new NominaBono
            {
                Id = Guid.NewGuid(),
                EmpresaId = empresaId,
                NominaDetalleId = detalle.Id,
                TipoCaptura = TipoCapturaBonoNomina.PorRubroImporte,
                CreatedAt = DateTime.UtcNow,
                IsActive = true,
                Detalles = []
            };
            db.NominasBonos.Add(actual);
            existentes.Add(actual);
        }

        actual.TipoCaptura = TipoCapturaBonoNomina.PorRubroImporte;
        actual.MontoTotal = bonosPrenomina.Sum(b => b.Importe);
        actual.Observaciones = "Generado desde prenómina";
        actual.IsActive = true;
        actual.UpdatedAt = DateTime.UtcNow;

        var existentesDetalle = actual.Detalles.ToDictionary(d => d.BonoRubroRrhhId, d => d);
        foreach (var eliminar in actual.Detalles.Where(d => bonosPrenomina.All(x => x.BonoRubroRrhhId != d.BonoRubroRrhhId)).ToList())
            db.NominasBonosDetalle.Remove(eliminar);

        var orden = 1;
        foreach (var bono in bonosPrenomina)
        {
            if (!existentesDetalle.TryGetValue(bono.BonoRubroRrhhId, out var detalleBono))
            {
                detalleBono = new NominaBonoDetalle
                {
                    Id = Guid.NewGuid(),
                    NominaBono = actual,
                    BonoRubroRrhhId = bono.BonoRubroRrhhId,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                };
                db.NominasBonosDetalle.Add(detalleBono);
                actual.Detalles.Add(detalleBono);
            }

            detalleBono.Importe = bono.Importe;
            detalleBono.Porcentaje = actual.MontoTotal <= 0 ? 0m : Math.Round((bono.Importe / actual.MontoTotal) * 100m, 2);
            detalleBono.Orden = orden++;
            detalleBono.IsActive = true;
            detalleBono.UpdatedAt = DateTime.UtcNow;
        }
    }

    private static void SincronizarPercepcionesPrenomina(CrmDbContext db, List<NominaPercepcion> existentes, NominaDetalle detalle, IReadOnlyCollection<PrenominaPercepcion> percepcionesPrenomina, Guid empresaId)
    {
        var existentesDetalle = existentes.Where(p => p.NominaDetalleId == detalle.Id).ToDictionary(p => p.TipoPercepcionId, p => p);
        foreach (var eliminar in existentes.Where(p => p.NominaDetalleId == detalle.Id && percepcionesPrenomina.All(x => x.TipoPercepcionId != p.TipoPercepcionId)).ToList())
            db.NominasPercepciones.Remove(eliminar);

        foreach (var percepcion in percepcionesPrenomina)
        {
            if (!existentesDetalle.TryGetValue(percepcion.TipoPercepcionId, out var actual))
            {
                actual = new NominaPercepcion
                {
                    Id = Guid.NewGuid(),
                    EmpresaId = empresaId,
                    NominaDetalleId = detalle.Id,
                    TipoPercepcionId = percepcion.TipoPercepcionId,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                };
                db.NominasPercepciones.Add(actual);
                existentes.Add(actual);
            }

            actual.Importe = percepcion.Importe;
            actual.Referencia = percepcion.Referencia;
            actual.Observaciones = string.IsNullOrWhiteSpace(percepcion.Observaciones) ? "Generado desde prenómina" : percepcion.Observaciones;
            actual.Origen = OrigenPercepcionNomina.Manual;
            actual.IsActive = true;
            actual.UpdatedAt = DateTime.UtcNow;
        }
    }

