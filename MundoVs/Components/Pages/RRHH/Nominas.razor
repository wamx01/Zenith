    private decimal ObtenerSueldoReferenciaDesdeDetalle(Empleado empleado, NominaDetalle detalle)
    {
        if (detalle.DiasPagados > 0 && detalle.SueldoBase > 0)
        {
            var diasBase = Math.Max(1, configuracionNomina.ObtenerDiasBase(empleado.PeriodicidadPago));
            return Math.Round((detalle.SueldoBase / detalle.DiasPagados) * diasBase, 2);
        }

        return empleado.SueldoSemanal;
    }
    private int CalcularAniosServicio(Empleado empleado, DateTime fechaReferencia)
    {
        if (!empleado.FechaContratacion.HasValue)
        {
            return 0;
        }

        return Math.Max(0, (int)Math.Floor((fechaReferencia.Date - empleado.FechaContratacion.Value.Date).TotalDays / 365.25));
    }

    private (decimal obrera, decimal patronal) CalcularCuotasImss(bool aplicaImss, decimal sueldoDiario, int diasPagados, int aniosServicio)
    {
        if (!aplicaImss || sueldoDiario <= 0 || diasPagados <= 0)
        {
            return (0m, 0m);
        }

        var diasVacacionesAnuales = configuracionNomina.ObtenerDiasVacacionesPorAntiguedad(aniosServicio);
        var factorAguinaldo = (configuracionNomina.DiasAguinaldoMinimo * sueldoDiario) / 365m;
        var factorVacaciones = (diasVacacionesAnuales * configuracionNomina.PrimaVacacionalMinima * sueldoDiario) / 365m;
        var sdi = sueldoDiario + factorAguinaldo + factorVacaciones;
        var tope = Math.Max(0m, configuracionNomina.TopeSbcEnUma) * Math.Max(0m, configuracionNomina.UmaDiaria);
        var minimo = Math.Max(0m, configuracionNomina.SalarioMinimoGeneral);
        var sbc = sdi;

        if (tope > 0)
        {
            sbc = Math.Min(sbc, tope);
        }

        if (minimo > 0)
        {
            sbc = Math.Max(sbc, minimo);
        }

        var basePeriodo = sbc * diasPagados;
        var obrera = Math.Round(basePeriodo * Math.Max(0m, configuracionNomina.TasaImssObrera), 2);
        var patronal = Math.Round(basePeriodo * (Math.Max(0m, configuracionNomina.TasaImssPatronal) + Math.Max(0m, configuracionNomina.PrimaRiesgoTrabajo)), 2);
        return (obrera, patronal);
    }

    private NominaCalculationResult CalcularResultadoPreview(NominaDetalle detalle)
        => detalle.Empleado == null
            ? new NominaCalculationResult { MontoHorasExtra = detalle.MontoHorasExtra, TotalPagar = detalle.TotalPagar }
            : CalcularResultadoPreview(detalle, detalle.Empleado);

    private NominaCalculationResult CalcularResultadoPreview(NominaDetalle detalle, Empleado empleado)
    {
        var sueldoReferencia = ObtenerSueldoReferenciaDesdeDetalle(empleado, detalle);
        var diasBase = Math.Max(1, configuracionNomina.ObtenerDiasBase(empleado.PeriodicidadPago));
        var sueldoDiario = sueldoReferencia <= 0 ? 0m : sueldoReferencia / diasBase;
        var factorFestivo = detalle.DiasFestivoTrabajado > 0 && sueldoDiario > 0
            ? Math.Max(0m, Math.Round(detalle.MontoFestivoTrabajado / (detalle.DiasFestivoTrabajado * sueldoDiario), 4))
            : configuracionNomina.ObtenerFactorFestivoTrabajado();

        return NominaCalculator.Calculate(new NominaCalculationInput
        {
            Empleado = empleado,
            Configuracion = configuracionNomina,
            SueldoReferencia = sueldoReferencia,
            SueldoBaseOverride = detalle.SueldoBase,
            DiasPagados = detalle.DiasPagados,
            DiasVacaciones = detalle.DiasVacaciones,
            DiasDescansoTrabajado = detalle.DiasDescansoTrabajado,
            DiasDomingoTrabajado = detalle.DiasDomingoTrabajado,
            DiasFestivoTrabajado = detalle.DiasFestivoTrabajado,
            MinutosDescuento = detalle.MinutosRetardo + detalle.MinutosSalidaAnticipada + detalle.MinutosDescuentoManual,
            AplicaImss = detalle.AplicaImss,
            AplicaIsr = empleado.AplicaIsr,
            HorasExtra = detalle.HorasExtra,
            MontoDestajo = detalle.MontoDestajo,
            MontoBono = detalle.MontoBono,
            MontoPercepcionesManuales = detalle.Bonos,
            MontoDeducciones = detalle.Deducciones,
            ComplementoSalarioMinimo = NominaLegalPolicy.CalcularComplementoSalarioMinimo(detalle.SueldoBase, detalle.MontoDestajo, detalle.DiasPagados, configuracionNomina),
            FactorFestivo = factorFestivo,
            AniosServicio = CalcularAniosServicio(empleado, nominaSeleccionada?.FechaFin ?? DateTime.Today)
        });
    }

