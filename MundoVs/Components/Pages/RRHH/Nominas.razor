    private void AgregarPercepcionManual()
    {
        if (!PuedeModificarNominaSeleccionada)
            return;

        if (!Guid.TryParse(tipoPercepcionSeleccionadoId, out var tipoId))
            return;

        var tipo = tiposPercepcion.FirstOrDefault(t => t.Id == tipoId);
        if (tipo == null)
            return;

        percepcionesEditando.Add(new PercepcionManualEditor
        {
            TipoPercepcionId = tipo.Id,
            TipoNombre = tipo.Nombre,
            Descripcion = tipo.Nombre,
            Origen = OrigenPercepcionNomina.Manual,
            Orden = percepcionesEditando.Count + 1
        });

        tipoPercepcionSeleccionadoId = string.Empty;
    }

    private void QuitarPercepcionManual(PercepcionManualEditor item)
    {
        if (!PuedeModificarNominaSeleccionada)
            return;

        percepcionesEditando.Remove(item);
        for (var i = 0; i < percepcionesEditando.Count; i++)
            percepcionesEditando[i].Orden = i + 1;
    }

