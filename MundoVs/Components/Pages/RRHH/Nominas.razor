    private async Task SincronizarNominaAsync(Guid nominaId, Guid? prenominaAnteriorId = null)
    {
        await CargarConfiguracionNominaAsync();
        await using var db = await DbFactory.CreateDbContextAsync();
        var nomina = await db.Nominas.FirstOrDefaultAsync(n => n.Id == nominaId);
        if (nomina == null)
        {
            return;
        }

        var inicio = nomina.FechaInicio.Date;
        var fin = nomina.FechaFin.Date;

        var prenomina = await ObtenerPrenominaParaNominaAsync(db, nomina.EmpresaId, nomina.PeriodicidadPago, nomina.AnioPeriodo, nomina.NumeroPeriodo);
        if (prenomina == null)
        {
            throw new InvalidOperationException(ObtenerMensajePrenominaRequerida());
        }

        prenomina = await db.Prenominas
            .Include(p => p.Detalles)
                .ThenInclude(d => d.BonosRapidos)
                    .ThenInclude(b => b.BonoRubroRrhh)
            .Include(p => p.Detalles)
                .ThenInclude(d => d.PercepcionesRapidas)
                    .ThenInclude(p => p.TipoPercepcion)
            .FirstOrDefaultAsync(p => p.Id == prenomina.Id);

        if (prenomina == null)
        {
            throw new InvalidOperationException("No se pudo cargar la prenómina vinculada para sincronizar la nómina.");
        }

        if (!string.IsNullOrWhiteSpace(prenomina.SnapshotConfiguracionJson))
        {
            try
            {
                var snapshotConfig = System.Text.Json.JsonSerializer.Deserialize<NominaConfiguracion>(prenomina.SnapshotConfiguracionJson);
                if (snapshotConfig != null)
                {
                    configuracionNomina = snapshotConfig;
                }
            }
            catch
            {
                // Si el snapshot no se puede deserializar, se mantiene la configuración viva cargada arriba.
            }
        }

        nomina.PrenominaId = prenomina.Id;
        await AplicarEstadoPrenominaDesdeNominaAsync(db, nomina, prenomina);
        if (prenominaAnteriorId.HasValue && prenominaAnteriorId.Value != prenomina.Id)
            await LiberarPrenominaAnteriorAsync(db, prenominaAnteriorId.Value, nomina.Id);

        var prenominaPorEmpleado = prenomina.Detalles.ToDictionary(d => d.EmpleadoId, d => d);

        var empleadosActivos = await db.Empleados
            .Where(e => e.IsActive && e.PeriodicidadPago == nomina.PeriodicidadPago)
            .OrderBy(e => e.Nombre)
            .ThenBy(e => e.ApellidoPaterno)
            .ToListAsync();

        var detallesExistentes = await db.NominaDetalles
            .Where(d => d.NominaId == nominaId)
            .ToListAsync();

        var detallesPorEmpleado = detallesExistentes
            .GroupBy(d => d.EmpleadoId)
            .ToDictionary(g => g.Key, g => g.First());

        var detalleIdsExistentes = detallesExistentes.Select(d => d.Id).ToList();
        var prenominaBonosPorEmpleado = prenomina.Detalles.ToDictionary(d => d.EmpleadoId, d => d.BonosRapidos.Where(b => b.IsActive && b.Importe > 0).OrderBy(b => b.BonoRubroRrhh.Orden).ThenBy(b => b.BonoRubroRrhh.Nombre).ToList());
        var prenominaPercepcionesPorEmpleado = prenomina.Detalles.ToDictionary(d => d.EmpleadoId, d => d.PercepcionesRapidas.Where(p => p.IsActive && p.Importe > 0).OrderBy(p => p.TipoPercepcion.Orden).ThenBy(p => p.TipoPercepcion.Nombre).ToList());
        var montoBonoPorDetalle = detalleIdsExistentes.Count == 0
            ? new Dictionary<Guid, decimal>()
            : await db.NominasBonos
                .Include(b => b.Detalles)
                .Where(b => b.IsActive && detalleIdsExistentes.Contains(b.NominaDetalleId))
                .ToDictionaryAsync(b => b.NominaDetalleId, b => b.Detalles.Where(d => d.IsActive).Sum(d => d.Importe));
        var percepcionesConfigurablesReferenciaPrefijo = "CONCEPTO_CONFIG:";
        var detalleConPercepcionesPersistidas = detalleIdsExistentes.Count == 0
            ? []
            : await db.NominasPercepciones
                .Where(p => p.IsActive && detalleIdsExistentes.Contains(p.NominaDetalleId))
                .Select(p => p.NominaDetalleId)
                .Distinct()
                .ToHashSetAsync();
        var montoPercepcionesPorDetalle = detalleIdsExistentes.Count == 0
            ? new Dictionary<Guid, decimal>()
            : await db.NominasPercepciones
                .Where(p => p.IsActive
                    && detalleIdsExistentes.Contains(p.NominaDetalleId)
                    && !(p.Origen == OrigenPercepcionNomina.Ajuste
                        && p.Referencia != null
                        && p.Referencia.StartsWith(percepcionesConfigurablesReferenciaPrefijo)))
                .GroupBy(p => p.NominaDetalleId)
                .ToDictionaryAsync(g => g.Key, g => g.Sum(p => p.Importe));
        var deduccionesPorDetalle = detalleIdsExistentes.Count == 0
            ? new Dictionary<Guid, decimal>()
            : await db.NominasDeducciones
                .Where(d => d.IsActive && detalleIdsExistentes.Contains(d.NominaDetalleId))
                .GroupBy(d => d.NominaDetalleId)
                .ToDictionaryAsync(g => g.Key, g => g.Sum(d => d.Importe));
        var conceptosDeduccionPorDetalle = detalleIdsExistentes.Count == 0
            ? new Dictionary<Guid, string?>()
            : await db.NominasDeducciones
                .Include(d => d.TipoDeduccion)
                .Where(d => d.IsActive && detalleIdsExistentes.Contains(d.NominaDetalleId))
                .GroupBy(d => d.NominaDetalleId)
                .ToDictionaryAsync(
                    g => g.Key,
                    g => g.Count() == 1
                        ? g.Select(d => d.TipoDeduccion.Nombre).FirstOrDefault()
                        : "Deducciones estructuradas");
        var bonosNominaExistentes = detalleIdsExistentes.Count == 0
            ? new List<NominaBono>()
            : await db.NominasBonos
                .Include(b => b.Detalles)
                .Where(b => detalleIdsExistentes.Contains(b.NominaDetalleId))
                .ToListAsync();
        var bonosDistribuidosPeriodo = await db.BonosDistribucionesPeriodoRrhh
            .AsNoTracking()
            .Include(b => b.BonoEstructuraRrhh)
                .ThenInclude(e => e.Detalles)
                    .ThenInclude(d => d.BonoRubroRrhh)
            .Include(b => b.Detalles)
                .ThenInclude(d => d.Detalles)
                    .ThenInclude(r => r.BonoRubroRrhh)
            .Where(b => b.IsActive && b.FechaInicio == inicio && b.FechaFin == fin)
            .ToListAsync();
        var bonosDistribuidosPorEmpleado = bonosDistribuidosPeriodo
            .SelectMany(b => b.Detalles.Where(d => d.IsActive), (b, d) => new { Captura = b, Detalle = d })
            .ToDictionary(x => x.Detalle.EmpleadoId, x => x);
        var conceptosEmpleadoActivos = await db.EmpleadosConceptosRrhh
            .Include(c => c.ConceptoConfig)
            .Where(c => c.EmpresaId == nomina.EmpresaId
                && c.IsActive
                && c.ConceptoConfig.IsActive
                && (!c.FechaInicio.HasValue || c.FechaInicio.Value <= fin)
                && (!c.FechaFin.HasValue || c.FechaFin.Value >= inicio))
            .ToListAsync();
        var conceptosActivosPorEmpleado = conceptosEmpleadoActivos
            .GroupBy(c => c.EmpleadoId)
            .ToDictionary(g => g.Key, g => g.OrderBy(c => c.ConceptoConfig.Orden).ThenBy(c => c.ConceptoConfig.Nombre).ToList());
        var percepcionesNominaExistentes = detalleIdsExistentes.Count == 0
            ? new List<NominaPercepcion>()
            : await db.NominasPercepciones
                .Where(p => detalleIdsExistentes.Contains(p.NominaDetalleId))
                .ToListAsync();
        var tiposPercepcionPorClave = await db.NominasPercepcionesTipos
            .Where(t => t.IsActive)
            .ToDictionaryAsync(t => t.Clave);
        var tipoPercepcionOtrosIngresos = await ObtenerOCrearTipoPercepcionOtrosIngresosAsync(db, tiposPercepcionPorClave);
        if (detalleIdsExistentes.Count > 0)
        {
            var provisionesExistentes = await db.NominasProvisionesDetalleRrhh
                .Where(p => detalleIdsExistentes.Contains(p.NominaDetalleId))
                .ToListAsync();

            if (provisionesExistentes.Count > 0)
            {
                db.NominasProvisionesDetalleRrhh.RemoveRange(provisionesExistentes);
            }
        }
        if (detalleIdsExistentes.Count > 0)
        {
            var movimientosBancoNomina = await db.RrhhBancoHorasMovimientos
                .Where(m => m.TipoMovimiento == TipoMovimientoBancoHorasRrhh.GeneradoPorHorasExtra
                    && m.NominaDetalleId.HasValue
                    && detalleIdsExistentes.Contains(m.NominaDetalleId.Value))
                .ToListAsync();

            if (movimientosBancoNomina.Count > 0)
            {
                db.RrhhBancoHorasMovimientos.RemoveRange(movimientosBancoNomina);
            }
        }

        if (detalleIdsExistentes.Count > 0)
        {
            var valesLigadosActuales = await db.ValesDestajo
                .Where(v => v.NominaDetalleId.HasValue
                    && detalleIdsExistentes.Contains(v.NominaDetalleId.Value)
                    && v.Estatus == EstatusValeDestajo.EnNomina)
                .ToListAsync();

            foreach (var vale in valesLigadosActuales)
            {
                vale.NominaDetalleId = null;
                vale.Estatus = EstatusValeDestajo.Aprobado;
                vale.UpdatedAt = DateTime.UtcNow;
            }
        }

        // Load approved vales for the period
        var valesAprobados = await db.ValesDestajo
            .Include(v => v.Detalles)
            .Where(v => v.IsActive
                && (v.Estatus == EstatusValeDestajo.Aprobado
                    || (v.Estatus == EstatusValeDestajo.EnNomina
                        && v.NominaDetalleId.HasValue
                        && detalleIdsExistentes.Contains(v.NominaDetalleId.Value)))
                && v.Fecha >= inicio && v.Fecha <= fin)
            .ToListAsync();

        var valesPorEmp = valesAprobados
            .GroupBy(v => v.EmpleadoId)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Load active scheme assignments
        var asignaciones = await db.EmpleadosEsquemaPago
            .Include(a => a.EsquemaPago)
            .Where(a => a.VigenteDesde <= fin && (a.VigenteHasta == null || a.VigenteHasta >= inicio))
            .ToListAsync();

        var esquemaPorEmp = asignaciones
            .GroupBy(a => a.EmpleadoId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.VigenteDesde).First());

        var festivosPeriodo = await db.FestivosRrhh
            .AsNoTracking()
            .Where(f => f.IsActive && f.Fecha >= inicio && f.Fecha <= fin && f.AplicaPrimaEspecial)
            .ToListAsync();

        var factoresFestivoPorFecha = festivosPeriodo
            .GroupBy(f => DateOnly.FromDateTime(f.Fecha.Date))
            .ToDictionary(
                g => g.Key,
                g => configuracionNomina.ObtenerFactorFestivoTrabajado(g.OrderByDescending(f => f.FactorPago).Select(f => (decimal?)f.FactorPago).FirstOrDefault()));

        var fechasFestivas = factoresFestivoPorFecha.Keys.ToList();
        var sumaFactorFestivoPorEmpleado = new Dictionary<Guid, decimal>();
        if (fechasFestivas.Count > 0)
        {
            var empleadoIds = empleadosActivos.Select(e => e.Id).ToList();
            var asistenciasFestivoTrabajado = await db.RrhhAsistencias
                .AsNoTracking()
                .Where(a => empleadoIds.Contains(a.EmpleadoId)
                    && a.Fecha >= DateOnly.FromDateTime(inicio)
                    && a.Fecha <= DateOnly.FromDateTime(fin)
                    && fechasFestivas.Contains(a.Fecha)
                    && (a.Estatus == RrhhAsistenciaEstatus.AsistenciaNormal
                        || a.Estatus == RrhhAsistenciaEstatus.Retardo
                        || a.Estatus == RrhhAsistenciaEstatus.Incompleta
                        || a.Estatus == RrhhAsistenciaEstatus.DescansoTrabajado))
                .Select(a => new { a.EmpleadoId, a.Fecha })
                .ToListAsync();

            sumaFactorFestivoPorEmpleado = asistenciasFestivoTrabajado
                .GroupBy(a => a.EmpleadoId)
                .ToDictionary(
                    g => g.Key,
                    g => g.Sum(a => factoresFestivoPorFecha.TryGetValue(a.Fecha, out var factor) ? factor : configuracionNomina.ObtenerFactorFestivoTrabajado()));
        }

        foreach (var empleado in empleadosActivos)
        {
            var esNuevo = false;
            if (!detallesPorEmpleado.TryGetValue(empleado.Id, out var detalle))
            {
                esNuevo = true;
                detalle = new NominaDetalle
                {
                    NominaId = nominaId,
                    EmpleadoId = empleado.Id
                };

                db.NominaDetalles.Add(detalle);
                detallesPorEmpleado[empleado.Id] = detalle;
            }

            var asignacion = esquemaPorEmp.GetValueOrDefault(empleado.Id);
            var esquema = asignacion?.EsquemaPago;
            var incidencia = prenominaPorEmpleado.GetValueOrDefault(empleado.Id);
            var diasPagados = incidencia?.DiasPagados ?? 0;
            var diasTrabajados = incidencia?.DiasTrabajados ?? 0;
            var diasVacaciones = incidencia?.DiasVacaciones ?? 0;
            var horasExtra = incidencia?.HorasExtra ?? detalle.HorasExtra;
            detalle.EsquemaPagoId = esquema?.Id;
            detalle.TipoPago = empleado.TipoNomina;
            detalle.DiasTrabajados = diasTrabajados;
            detalle.DiasPagados = diasPagados;
            detalle.DiasVacaciones = diasVacaciones;
            detalle.DiasFaltaJustificada = incidencia?.DiasFaltaJustificada ?? 0;
            detalle.DiasFaltaInjustificada = incidencia?.DiasFaltaInjustificada ?? 0;
            detalle.DiasIncapacidad = incidencia?.DiasIncapacidad ?? 0;
            detalle.DiasDescansoTrabajado = incidencia?.DiasDescansoTrabajado ?? 0;
            detalle.DiasConMarcacion = incidencia?.DiasConMarcacion ?? 0;
            detalle.DiasDomingoTrabajado = incidencia?.DiasDomingoTrabajado ?? 0;
            detalle.DiasFestivoTrabajado = incidencia?.DiasFestivoTrabajado ?? 0;
            detalle.HorasTrabajadasNetas = incidencia?.HorasTrabajadasNetas ?? detalle.HorasTrabajadasNetas;
            detalle.HorasExtraBase = incidencia?.HorasExtraBase ?? detalle.HorasExtraBase;
            detalle.HorasExtraBanco = incidencia?.HorasBancoAcumuladas ?? detalle.HorasExtraBanco;
            detalle.MinutosRetardo = incidencia?.MinutosRetardo ?? 0;
            detalle.MinutosSalidaAnticipada = incidencia?.MinutosSalidaAnticipada ?? 0;
            detalle.MinutosDescuentoManual = incidencia?.MinutosDescuentoManual ?? 0;
            detalle.AplicaImss = empleado.AplicaImss && (incidencia?.AplicaImss ?? true);
            detalle.HorasExtra = horasExtra;

            var sueldoReferencia = NominaLegalPolicy.ObtenerSueldoReferencia(empleado, asignacion);
            var incluyeSueldoBase = NominaLegalPolicy.IncluyeSueldoBase(asignacion);
            if (incluyeSueldoBase)
            {
                detalle.SueldoBase = NominaLegalPolicy.CalcularSueldoBasePeriodo(sueldoReferencia, empleado.PeriodicidadPago, diasPagados, configuracionNomina);
            }
            else
            {
                detalle.SueldoBase = 0;
            }

            if (valesPorEmp.TryGetValue(empleado.Id, out var valesEmp))
            {
                detalle.TotalPiezas = valesEmp.Sum(v => v.Detalles.Sum(d => d.Cantidad));
                detalle.MontoDestajo = valesEmp.Sum(v => v.Detalles.Sum(d => d.Importe));

                // Link vales to this detalle and set status
                foreach (var vale in valesEmp.Where(v => v.Estatus == EstatusValeDestajo.Aprobado))
                {
                    vale.NominaDetalleId = detalle.Id;
                    vale.Estatus = EstatusValeDestajo.EnNomina;
                }
            }
            else
            {
                detalle.TotalPiezas = 0;
                detalle.MontoDestajo = 0;
            }

            detalle.ComplementoSalarioMinimo = NominaLegalPolicy.CalcularComplementoSalarioMinimo(detalle.SueldoBase, detalle.MontoDestajo, diasPagados, configuracionNomina);

            var bonosPrenomina = prenominaBonosPorEmpleado.GetValueOrDefault(empleado.Id) ?? [];
            var bonoDistribuido = bonosDistribuidosPorEmpleado.GetValueOrDefault(empleado.Id);
            var percepcionesPrenomina = prenominaPercepcionesPorEmpleado.GetValueOrDefault(empleado.Id) ?? [];
            var montoBono = bonosPrenomina.Count > 0
                ? bonosPrenomina.Sum(b => b.Importe)
                : bonoDistribuido?.Detalle.MontoAsignado ?? montoBonoPorDetalle.GetValueOrDefault(detalle.Id);
            var conceptosEmpleado = conceptosActivosPorEmpleado.GetValueOrDefault(empleado.Id) ?? [];
            var baseCalculoConceptos = detalle.SueldoBase + detalle.MontoDestajo + montoBono + detalle.MontoFestivoTrabajado
                + detalle.MontoDescansoTrabajado + detalle.MontoPrimaDominical + detalle.MontoPrimaVacacional + detalle.ComplementoSalarioMinimo
                + detalle.MontoHorasExtra;
            var percepcionesConfigurables = ConstruirPercepcionesConfigurablesEmpleado(conceptosEmpleado, baseCalculoConceptos, tipoPercepcionOtrosIngresos.Id, tiposPercepcionPorClave);
            var totalPercepcionesConfigurables = percepcionesConfigurables.Sum(p => p.Importe);
            var percepcionesManual = percepcionesPrenomina.Count > 0
                ? percepcionesPrenomina.Sum(p => p.Importe)
                : montoPercepcionesPorDetalle.TryGetValue(detalle.Id, out var totalPercepcionesManual)
                    ? totalPercepcionesManual
                    : detalleConPercepcionesPersistidas.Contains(detalle.Id)
                        ? 0m
                        : detalle.Bonos;
            var totalDeducciones = deduccionesPorDetalle.TryGetValue(detalle.Id, out var deduccionesCalculadas) ? deduccionesCalculadas : 0m;
            var conceptoDeduccionBase = conceptosDeduccionPorDetalle.TryGetValue(detalle.Id, out var conceptoDeduccion) ? conceptoDeduccion : null;
            detalle.ConceptoDeducciones = conceptoDeduccionBase;
            var sumaFactorFestivo = sumaFactorFestivoPorEmpleado.GetValueOrDefault(empleado.Id);
            var factorFestivoAplicado = detalle.DiasFestivoTrabajado > 0 && sumaFactorFestivo > 0m
                ? Math.Round(sumaFactorFestivo / detalle.DiasFestivoTrabajado, 4)
                : configuracionNomina.ObtenerFactorFestivoTrabajado();

            var aniosServicio = CalcularAniosServicio(empleado, fin);
            var cicloVacacional = NominaLegalPolicy.ObtenerCicloVacacional(empleado, fin, configuracionNomina);
            var horasExtraBase = Math.Max(0m, detalle.HorasExtraBase > 0 ? detalle.HorasExtraBase : detalle.HorasExtra);
            var horasExtraPagables = Math.Max(0m, detalle.HorasExtra);
            detalle.HorasExtraDobles = Math.Min(9m, Math.Min(horasExtraBase, horasExtraPagables));
            detalle.HorasExtraTriples = Math.Max(0m, Math.Min(horasExtraBase, horasExtraPagables) - detalle.HorasExtraDobles);
            var resultado = NominaCalculator.Calculate(new NominaCalculationInput
            {
                Empleado = empleado,
                Configuracion = configuracionNomina,
                SueldoReferencia = incluyeSueldoBase ? sueldoReferencia : 0m,
                DiasPagados = diasPagados,
                DiasVacaciones = diasVacaciones,
                DiasDescansoTrabajado = detalle.DiasDescansoTrabajado,
                DiasDomingoTrabajado = detalle.DiasDomingoTrabajado,
                DiasFestivoTrabajado = detalle.DiasFestivoTrabajado,
                MinutosDescuento = detalle.MinutosRetardo + detalle.MinutosSalidaAnticipada + detalle.MinutosDescuentoManual,
                AplicaImss = detalle.AplicaImss,
                AplicaIsr = empleado.AplicaIsr,
                HorasExtraBase = detalle.HorasExtraBase,
                HorasExtraDobles = detalle.HorasExtraDobles,
                HorasExtraTriples = detalle.HorasExtraTriples,
                HorasExtraBanco = detalle.HorasExtraBanco,
                HorasExtra = detalle.HorasExtra,
                MontoDestajo = detalle.MontoDestajo,
                MontoBono = detalle.MontoBono,
                MontoPercepcionesManuales = percepcionesManual + totalPercepcionesConfigurables,
                MontoDeducciones = totalDeducciones,
                ComplementoSalarioMinimo = detalle.ComplementoSalarioMinimo,
                FactorFestivo = factorFestivoAplicado,
                AniosServicio = aniosServicio,
                DiasVacacionesAnualesOverride = cicloVacacional.DiasVacacionesEquivalentes
            });

            AplicarResultadoCalculo(detalle, resultado);
            AplicarConceptosConfigurablesEmpleado(db, nomina, detalle, conceptosEmpleado, totalDeducciones, conceptoDeduccionBase);

            if (bonosPrenomina.Count > 0)
                SincronizarBonosPrenomina(db, bonosNominaExistentes, detalle, bonosPrenomina, nomina.EmpresaId);
            else if (bonoDistribuido is not null)
                SincronizarBonosDistribuidos(db, bonosNominaExistentes, detalle, bonoDistribuido.Detalle, nomina.EmpresaId);

            if (percepcionesPrenomina.Count > 0)
                SincronizarPercepcionesPrenomina(db, percepcionesNominaExistentes, detalle, percepcionesPrenomina, nomina.EmpresaId);

            SincronizarPercepcionesConfigurables(db, percepcionesNominaExistentes, detalle, percepcionesConfigurables, nomina.EmpresaId, percepcionesConfigurablesReferenciaPrefijo);
        }

        nomina.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
    }

    private static Task AplicarEstadoPrenominaDesdeNominaAsync(CrmDbContext db, Nomina nomina, Prenomina prenomina)
    {
        if (nomina.Estatus != EstatusNomina.Cancelada)
        {
            prenomina.Estatus = EstatusPrenomina.Aplicada;
            prenomina.FechaCierre ??= DateTime.UtcNow;
            prenomina.UpdatedAt = DateTime.UtcNow;
            return Task.CompletedTask;
        }

        return LiberarPrenominaAnteriorAsync(db, prenomina.Id, nomina.Id);
    }

    private static async Task LiberarPrenominaAnteriorAsync(CrmDbContext db, Guid prenominaId, Guid nominaActualId)
    {
        var prenomina = await db.Prenominas.FirstOrDefaultAsync(p => p.Id == prenominaId);
        if (prenomina == null)
            return;

        var tieneOtraNominaActiva = await db.Nominas.AnyAsync(n => n.Id != nominaActualId && n.PrenominaId == prenominaId && n.Estatus != EstatusNomina.Cancelada);
        if (tieneOtraNominaActiva)
            return;

        if (prenomina.Estatus == EstatusPrenomina.Aplicada)
            prenomina.Estatus = EstatusPrenomina.Cerrada;

        prenomina.UpdatedAt = DateTime.UtcNow;
    }

    private async Task GuardarCambiosDetalle(NominaDetalle detalle)
    {
        error = ok = null;
        guardando = true;

        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para modificar nóminas.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var existente = await db.NominaDetalles.FirstOrDefaultAsync(x => x.Id == detalle.Id);
            if (existente == null)
            {
                error = "No se encontró el detalle de nómina.";
                return;
            }

            var nominaActual = await db.Nominas.AsNoTracking().FirstOrDefaultAsync(n => n.Id == existente.NominaId);
            if (nominaActual == null)
            {
                error = "No se encontró la nómina del detalle.";
                return;
            }

            if (EstaBloqueadaNomina(nominaActual.Estatus))
            {
                error = ObtenerMensajeBloqueoNomina(nominaActual.Estatus);
                return;
            }

            existente.MinutosRetardo = detalle.MinutosRetardo;
            existente.MinutosSalidaAnticipada = detalle.MinutosSalidaAnticipada;
            existente.MinutosDescuentoManual = detalle.MinutosDescuentoManual;
            existente.Bonos = detalle.Bonos;
            existente.Deducciones = detalle.Deducciones;

            var empleado = await db.Empleados.FirstOrDefaultAsync(x => x.Id == existente.EmpleadoId);

            if (empleado != null)
            {
                AplicarResultadoCalculo(existente, CalcularResultadoPreview(existente, empleado));
            }

            await db.SaveChangesAsync();
            await Cargar();
            await CargarDetalles();
            await CargarDesgloseValesAsync();
            ok = "Detalle de nómina actualizado.";
        }
        catch (Exception ex)
        {
            error = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task GuardarNomina()
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para guardar nóminas.";
                return;
            }

            if (string.IsNullOrWhiteSpace(editando.Periodo)) { error = "Periodo es requerido."; return; }

            var empresaId = _empresaId;
            if (empresaId == Guid.Empty) { error = "No hay empresa activa."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();
            var periodoActual = NominaPeriodoHelper.ObtenerPeriodo(editando.PeriodicidadPago, editando.FechaFin == default ? DateTime.Today : editando.FechaFin, ObtenerCortePeriodo(editando.PeriodicidadPago));
            editando.PeriodicidadPago = periodoActual.PeriodicidadPago;
            editando.AnioPeriodo = periodoActual.AnioPeriodo;
            editando.NumeroPeriodo = periodoActual.NumeroPeriodo;
            editando.Periodo = periodoActual.Periodo;
            editando.NumeroNomina = periodoActual.NumeroNomina;
            editando.FechaInicio = periodoActual.Inicio;
            editando.FechaFin = periodoActual.Fin;

            var periodo = editando.Periodo.Trim();
            var numeroNomina = string.IsNullOrWhiteSpace(editando.NumeroNomina) ? null : editando.NumeroNomina.Trim();
            var prenomina = await ObtenerPrenominaParaNominaAsync(db, empresaId, editando.PeriodicidadPago, editando.AnioPeriodo, editando.NumeroPeriodo);
            if (prenomina == null)
            {
                error = ObtenerMensajePrenominaRequerida();
                return;
            }

            if (await db.Nominas.AnyAsync(n => n.EmpresaId == empresaId
                && n.Id != editando.Id
                && n.PeriodicidadPago == editando.PeriodicidadPago
                && n.AnioPeriodo == editando.AnioPeriodo
                && n.NumeroPeriodo == editando.NumeroPeriodo))
            {
                error = "Ya existe una nómina para ese período calendario y periodicidad.";
                return;
            }

            if (editando.Id == Guid.Empty)
            {
                editando.Folio = string.IsNullOrWhiteSpace(editando.Folio)
                    ? await CodigoNegocio.GetNextPeriodFolioAsync(empresaId, "NOM", "Consecutivo:Nomina", editando.FechaInicio)
                    : editando.Folio.Trim();
                var nueva = new Nomina
                {
                    EmpresaId = empresaId, Folio = editando.Folio, NumeroNomina = numeroNomina, PeriodicidadPago = editando.PeriodicidadPago, AnioPeriodo = editando.AnioPeriodo, NumeroPeriodo = editando.NumeroPeriodo, Periodo = periodo,
                    FechaInicio = editando.FechaInicio, FechaFin = editando.FechaFin,
                    FechaPago = editando.FechaPago, Estatus = editando.Estatus, Notas = editando.Notas?.Trim(),
                    PrenominaId = prenomina.Id
                };
                db.Nominas.Add(nueva);
                await db.SaveChangesAsync();
                await SincronizarNominaAsync(nueva.Id);
                await AuditService.LogAsync("Crear nómina", nameof(Nomina), nueva.Id, $"Nómina {nueva.Periodo} creada.", empresaId);
                ok = "Nómina guardada."; mostrarForm = false; await Cargar();
                return;
            }
            else
            {
                var ex = await db.Nominas.FirstOrDefaultAsync(n => n.Id == editando.Id);
                if (ex == null) return;
                if (EstaBloqueadaNomina(ex.Estatus))
                {
                    error = ObtenerMensajeBloqueoNomina(ex.Estatus);
                    _nominaEditandoBloqueada = true;
                    return;
                }

                var prenominaAnteriorId = ex.PrenominaId;
                ex.Folio = string.IsNullOrWhiteSpace(editando.Folio) ? ex.Folio : editando.Folio.Trim();
                ex.NumeroNomina = numeroNomina;
                ex.PeriodicidadPago = editando.PeriodicidadPago;
                ex.AnioPeriodo = editando.AnioPeriodo;
                ex.NumeroPeriodo = editando.NumeroPeriodo;
                ex.Periodo = periodo; ex.FechaInicio = editando.FechaInicio;
                ex.FechaFin = editando.FechaFin; ex.FechaPago = editando.FechaPago;
                ex.Estatus = editando.Estatus; ex.Notas = editando.Notas?.Trim(); ex.PrenominaId = prenomina.Id; ex.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
                await SincronizarNominaAsync(ex.Id, prenominaAnteriorId);
                await AuditService.LogAsync("Editar nómina", nameof(Nomina), ex.Id, $"Nómina {ex.Periodo} actualizada.", empresaId);
                ok = "Nómina guardada."; mostrarForm = false; await Cargar();
                return;
            }
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private async Task GuardarDetalle()
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para modificar nóminas.";
                return;
            }

            if (nominaSeleccionada != null && EstaBloqueadaNomina(nominaSeleccionada.Estatus))
            {
                error = ObtenerMensajeBloqueoNomina(nominaSeleccionada.Estatus);
                return;
            }

            if (nominaSeleccionada == null || editandoDetalle.EmpleadoId == Guid.Empty)
            { error = "Seleccione un empleado."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();
            var empleado = await db.Empleados.AsNoTracking().FirstOrDefaultAsync(e => e.Id == editandoDetalle.EmpleadoId);
            if (empleado == null)
            {
                error = "No se encontró el empleado seleccionado.";
                return;
            }

            if (empleado.PeriodicidadPago != nominaSeleccionada.PeriodicidadPago)
            {
                error = "El empleado no coincide con la periodicidad de esta nómina.";
                return;
            }

            db.NominaDetalles.Add(new NominaDetalle
            {
                NominaId = nominaSeleccionada.Id, EmpleadoId = editandoDetalle.EmpleadoId,
                SueldoBase = editandoDetalle.SueldoBase,
                HorasExtra = editandoDetalle.HorasExtra, MontoHorasExtra = editandoDetalle.MontoHorasExtra,
                Bonos = editandoDetalle.Bonos, Deducciones = editandoDetalle.Deducciones,
                ConceptoDeducciones = editandoDetalle.ConceptoDeducciones, Notas = editandoDetalle.Notas
            });
            await db.SaveChangesAsync();
            ok = "Empleado agregado."; mostrarFormDetalle = false;
            await Cargar(); await CargarDetalles();
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private async Task EliminarDetalle(Guid id)
    {
        error = ok = null;
        try
        {
            if (!_puedeEditar)
            {
                error = "No tienes permisos para modificar nóminas.";
                return;
            }

            if (nominaSeleccionada != null && EstaBloqueadaNomina(nominaSeleccionada.Estatus))
            {
                error = ObtenerMensajeBloqueoNomina(nominaSeleccionada.Estatus);
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            var d = await db.NominaDetalles.FirstOrDefaultAsync(x => x.Id == id);
            if (d != null) { db.NominaDetalles.Remove(d); await db.SaveChangesAsync(); }
            await Cargar(); await CargarDetalles();
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
    }

    private static string EstatusBadge(EstatusNomina e) => e switch
    {
        EstatusNomina.Borrador => "bg-secondary",
        EstatusNomina.Aprobada => "bg-info",
        EstatusNomina.Pagada => "bg-success",
        EstatusNomina.Cancelada => "bg-danger",
        _ => "bg-light"
    };

    private static bool EstaBloqueadaNomina(EstatusNomina estatus)
        => estatus is EstatusNomina.Pagada or EstatusNomina.Cancelada;

    private static bool RequiereActualizacionDesdePrenomina(Nomina nomina)
        => nomina.Estatus == EstatusNomina.Borrador
            && nomina.Prenomina is not null
            && ObtenerFechaUltimaActualizacionPrenomina(nomina.Prenomina) > ObtenerFechaUltimaSincronizacionNomina(nomina);

    private static DateTime ObtenerFechaUltimaSincronizacionNomina(Nomina nomina)
        => nomina.UpdatedAt ?? nomina.CreatedAt;

    private static DateTime ObtenerFechaUltimaActualizacionPrenomina(Prenomina prenomina)
        => prenomina.UpdatedAt ?? prenomina.CreatedAt;

    private static string ObtenerMensajeBloqueoNomina(EstatusNomina estatus)
        => estatus switch
        {
            EstatusNomina.Pagada => "La nómina pagada no se puede modificar.",
            EstatusNomina.Cancelada => "La nómina cancelada no se puede modificar.",
            _ => "La nómina no se puede modificar."
        };

    private string ObtenerNombreEsquema(Guid? esquemaPagoId)
        => esquemaPagoId.HasValue && esquemaNombrePorId.TryGetValue(esquemaPagoId.Value, out var nombre) ? nombre : "—";

    private decimal ObtenerMontoHorasExtraPreview(NominaDetalle detalle)
        => resumenNomina.Detalles.TryGetValue(detalle.Id, out var resumenDetalle)
            ? resumenDetalle.MontoHorasExtraPreview
            : detalle.MontoHorasExtra;

    private string ObtenerResumenHorasExtra(NominaDetalle detalle)
    {
        var horasBase = detalle.HorasExtraBase > 0 ? detalle.HorasExtraBase : detalle.HorasExtra;
        var horasDobles = ObtenerHorasExtraDoblesPreview(detalle);
        var horasTriples = ObtenerHorasExtraTriplesPreview(detalle);

        if (horasDobles <= 0 && horasTriples <= 0)
        {
            return $"Extra base {horasBase:0.##} h";
        }

        var partes = new List<string>();
        if (horasBase > 0)
        {
            partes.Add($"Base {horasBase:0.##} h");
        }

        if (horasDobles > 0)
        {
            partes.Add($"Dobles {horasDobles:0.##} h");
        }

        if (horasTriples > 0)
        {
            partes.Add($"Triples {horasTriples:0.##} h");
        }

        return string.Join(" · ", partes);
    }

    private decimal ObtenerHorasExtraDoblesPreview(NominaDetalle detalle)
        => resumenNomina.Detalles.TryGetValue(detalle.Id, out var resumenDetalle)
            ? resumenDetalle.HorasExtraDoblesPreview
            : detalle.HorasExtraDobles;

    private decimal ObtenerHorasExtraTriplesPreview(NominaDetalle detalle)
        => resumenNomina.Detalles.TryGetValue(detalle.Id, out var resumenDetalle)
            ? resumenDetalle.HorasExtraTriplesPreview
            : detalle.HorasExtraTriples;

    private decimal ObtenerTotalPagarPreview(NominaDetalle detalle)
        => resumenNomina.Detalles.TryGetValue(detalle.Id, out var resumenDetalle)
            ? resumenDetalle.TotalPagarPreview
            : detalle.TotalPagar;

    private static string ObtenerTextoImssObrero(NominaDetalle detalle)
        => detalle.CuotaImssObrera > 0m || detalle.AplicaImss
            ? detalle.CuotaImssObrera.ToString("C2")
            : "—";

    private bool TieneFestivosAplicados(Guid empleadoId)
        => festivosAplicadosPorEmpleado.TryGetValue(empleadoId, out var festivos) && festivos.Count > 0;

    private string ObtenerTextoFestivosAplicados(Guid empleadoId)
        => !festivosAplicadosPorEmpleado.TryGetValue(empleadoId, out var festivos) || festivos.Count == 0
            ? "—"
            : string.Join(", ", festivos.Select(f => $"{f.Fecha:dd/MM} {f.Nombre} x{f.Factor:0.##}{(f.UsaFallback ? " (global)" : string.Empty)}"));

