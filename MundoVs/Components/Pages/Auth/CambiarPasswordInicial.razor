@page "/auth/cambiar-password-inicial"
@layout MundoVs.Components.Layout.LoginLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Cambiar contraseña</PageTitle>

<style>
    .onboarding-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,.3);
        width: 100%;
        max-width: 420px;
        overflow: hidden;
    }

    .onboarding-header {
        background: linear-gradient(135deg, #0d0d0d 0%, #1a1a2e 100%);
        padding: 2rem 2rem 1.5rem;
        text-align: center;
        color: white;
    }

    .onboarding-header h1 {
        font-size: 1.6rem;
        font-weight: 800;
        background: linear-gradient(90deg, #00e5a0, #29b6f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: .25rem;
    }

    .onboarding-header p {
        font-size: .78rem;
        opacity: .7;
        margin-bottom: 0;
    }

    .onboarding-body { padding: 2rem; }

    .onboarding-input-wrap { position: relative; margin-bottom: 1.25rem; }

    .onboarding-input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: .95rem;
    }

    .onboarding-input {
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        padding: .6rem 1rem .6rem 2.8rem;
        font-size: .88rem;
        width: 100%;
    }

    .onboarding-input:focus {
        border-color: #00e5a0;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0,229,160,.15);
    }

    .onboarding-btn {
        width: 100%;
        padding: .7rem;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #00e5a0, #00bcd4);
        color: #0d0d0d;
        font-weight: 700;
    }

    .onboarding-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 8px;
        padding: .5rem .75rem;
        font-size: .8rem;
        margin-bottom: 1rem;
    }

    .onboarding-logo-fallback {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #00e5a0, #00bcd4, #29b6f6);
        color: #0d0d0d;
        font-weight: 900;
        font-size: 1.4rem;
        border-radius: 14px;
        letter-spacing: -2px;
        margin-bottom: .75rem;
    }
</style>

<div class="onboarding-card">
    <div class="onboarding-header">
        <span class="onboarding-logo-fallback">VS</span>
        <h1>Cambia tu contraseña</h1>
        <p>Debes establecer una contraseña nueva para continuar</p>
    </div>

    <div class="onboarding-body">
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="onboarding-error">
                <i class="bi bi-exclamation-circle me-1"></i>@error
            </div>
        }

        @if (!string.IsNullOrEmpty(ok))
        {
            <div class="alert alert-success">@ok</div>
        }

        <EditForm Model="model" OnValidSubmit="Guardar">
            <div class="onboarding-input-wrap">
                <i class="bi bi-lock onboarding-input-icon"></i>
                <InputText class="onboarding-input" @bind-Value="model.Password" type="password" placeholder="Nueva contraseña" />
            </div>

            <div class="onboarding-input-wrap">
                <i class="bi bi-shield-lock onboarding-input-icon"></i>
                <InputText class="onboarding-input" @bind-Value="model.ConfirmPassword" type="password" placeholder="Confirmar contraseña" />
            </div>

            <button type="submit" class="onboarding-btn" disabled="@guardando">
                @if (guardando)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    <span>Guardando...</span>
                }
                else
                {
                    <i class="bi bi-check-lg me-1"></i>
                    <span>Guardar y continuar</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly ChangePasswordModel model = new();
    private string? error;
    private string? ok;
    private bool guardando;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var requiereCambioPassword = string.Equals(state.User.FindFirst("RequirePasswordChange")?.Value, "true", StringComparison.OrdinalIgnoreCase);
        if (!requiereCambioPassword)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
    }

    private async Task Guardar()
    {
        error = null;
        ok = null;
        guardando = true;

        try
        {
            if (string.IsNullOrWhiteSpace(model.Password) || string.IsNullOrWhiteSpace(model.ConfirmPassword))
            {
                error = "Captura y confirma la nueva contraseña.";
                return;
            }

            var passwordError = AuthService.ValidarPassword(model.Password);
            if (!string.IsNullOrWhiteSpace(passwordError))
            {
                error = passwordError;
                return;
            }

            if (!string.Equals(model.Password, model.ConfirmPassword, StringComparison.Ordinal))
            {
                error = "Las contraseñas no coinciden.";
                return;
            }

            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userIdValue = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!Guid.TryParse(userIdValue, out var userId))
            {
                error = "No se pudo identificar al usuario actual.";
                return;
            }

            var actualizado = await AuthService.CambiarPasswordInicialAsync(userId, model.Password);
            if (!actualizado)
            {
                error = "No fue posible actualizar la contraseña.";
                return;
            }

            var sessionUpdated = await AuthStateProvider.RefreshSessionAsync();
            if (!sessionUpdated)
            {
                error = "La contraseña se actualizó, pero no se pudo refrescar la sesión. Inicia sesión nuevamente.";
                return;
            }

            ok = "Contraseña actualizada correctamente.";
            Navigation.NavigateTo("/", forceLoad: true);
        }
        finally
        {
            guardando = false;
        }
    }

    private sealed class ChangePasswordModel
    {
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
