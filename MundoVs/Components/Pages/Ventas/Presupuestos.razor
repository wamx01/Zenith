    .cot-add-panel + .cot-add-panel {
        border-top: 1px solid #e2e8f0;
    }

    .cot-add-panel--info {
        font-size: .75rem;
        color: #64748b;
    }

    .cot-add-panel__title {
        font-size: .75rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: .4rem;
    }

    .cot-add-panel__row {
        display: flex;
        gap: .5rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .cot-add-panel__row .form-select {
        flex: 1 1 160px;
    }

    /* Resumen final */
    .cot-section--summary-final .cot-section__body {
        display: grid;
        gap: 1rem;
    }

    .cot-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
    }

    .cot-summary-card {
        border: 1px solid #dbe7f5;
        border-radius: 10px;
