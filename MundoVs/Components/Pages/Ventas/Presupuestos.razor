@page "/serigrafia/cotizaciones"
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IRepository<CotizacionSerigrafia> CotizacionRepository
@inject IClienteRepository ClienteRepository
@inject IProductoRepository ProductoRepository
@inject IRepository<CotizacionDetalle> DetalleRepository
@inject IRepository<MateriaPrima> MateriaPrimaRepository
@inject IRepository<Insumo> InsumoRepository
@inject IRepository<Posicion> PosicionRepository
@inject IRepository<GastoFijo> GastoFijoRepository
@inject IRepository<TipoProceso> TipoProcesoRepository
@inject IDbContextFactory<CrmDbContext> DbContextFactory
@rendermode InteractiveServer

<PageTitle>Cotizaciones</PageTitle>

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2><i class="bi bi-calculator"></i> Cotizaciones</h2>
        <button class="btn btn-success" @onclick="NuevaCotizacion">
            <i class="bi bi-plus-circle"></i> Nueva Cotización
        </button>
    </div>

    @if (mostrarFormulario && cotizacionEditando != null)
    {
        <div class="card mb-4 border-0 shadow">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <strong>@(cotizacionEditando.Id == Guid.Empty ? "Nueva Cotización" : "Editar Cotización")</strong>
                <button class="btn btn-sm btn-outline-light" @onclick="Cancelar">
                    <i class="bi bi-x-circle"></i> Cerrar
                </button>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Cliente</label>
                        <select class="form-select" @onchange="OnClienteChanged">
                            <option value="">Seleccione...</option>
                            @if (clientes != null)
                            {
                                @foreach (var cliente in clientes)
                                {
                                    <option value="@cliente.Id" selected="@(cotizacionEditando.ClienteId == cliente.Id)">@cliente.RazonSocial</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Producto</label>
                        <select class="form-select" @onchange="OnProductoChangedAsync">
                            <option value="">Seleccione...</option>
                            @if (productos != null)
                            {
                                @foreach (var p in productos)
                                {
                                    <option value="@p.Id" selected="@(cotizacionEditando.ProductoId == p.Id)">@p.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Pares por Lámina</label>
                        <input type="number" class="form-control" @bind="cotizacionEditando.ParesPorLamina" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Utilidad (%)</label>
                        <input type="number" class="form-control" step="0.01" @bind="cotizacionEditando.Utilidad" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label">Descripción</label>
                        <input type="text" class="form-control" @bind="cotizacionEditando.Descripcion" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Número de Personas</label>
                        <input type="number" class="form-control" min="1" @bind="cotizacionEditando.NumeroPersonas" />
                    </div>
                </div>

                <div class="d-flex gap-2 mb-4">
                    <button class="btn btn-primary" @onclick="GuardarCotizacion">
                        <i class="bi bi-save"></i> Guardar Encabezado
                    </button>
                    <button class="btn btn-secondary" @onclick="Cancelar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>

                @if (cotizacionEditando.Id != Guid.Empty)
                {
                    <div class="card mb-3 border-0">
                        <div class="card-header text-white fw-bold" style="background:#1e3a5f">
                            <i class="bi bi-diagram-3"></i> PROCESOS A USAR
                        </div>
                        <div class="card-body">
                            @if (catalogoProcesos.Any())
                            {
                                <div class="row g-2">
                                    @foreach (var proceso in catalogoProcesos)
                                    {
                                        var selected = procesosSeleccionados.Contains(proceso.Id);
                                        <div class="col-md-4">
                                            <label class="d-flex align-items-start gap-2 border rounded p-2 h-100" style="cursor:pointer;background:@(selected ? "#eef4ff" : "#fff")">
                                                <input type="checkbox"
                                                       class="form-check-input mt-1"
                                                       checked="@selected"
                                                       @onchange="async (e) => await ToggleProcesoCotizacion(proceso.Id, e.Value)" />
                                                <span>
                                                    <strong>@proceso.Nombre</strong><br />
                                                    <small class="text-muted">Posición: @(proceso.Posicion?.Nombre ?? "Sin posición") · Tarifa: @ObtenerTarifaPorMinuto(proceso).ToString("C4")/min</small>
                                                </span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-light mb-0">No hay procesos activos configurados.</div>
                            }
                        </div>
                    </div>
                }

                @if (cotizacionEditando.Id != Guid.Empty)
                {
                    <!-- ========== TINTAS ========== -->
                    <div class="card mb-3 border-0">
                        <div class="card-header text-white fw-bold" style="background:#8B008B">
                            <i class="bi bi-droplet-fill"></i> TINTAS
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:30%">Concepto</th>
                                        <th style="width:15%">Consumo</th>
                                        <th style="width:15%">Precio Unit.</th>
                                        <th style="width:15%">Costo</th>
                                        <th style="width:15%">Peso Ini/Fin</th>
                                        <th style="width:10%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ObtenerDetalles(CotizacionCategoria.Tinta))
                                    {
                                        <tr>
                                            <td>@d.Concepto</td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Consumo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PrecioUnitario" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td class="text-end fw-bold">$@d.Costo.ToString("N4")</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PesoInicial" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" />
                                                    <input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PesoFinal" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" />
                                                </div>
                                            </td>
                                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarDetalle(d)"><i class="bi bi-trash"></i></button></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="6">
                                            <div class="d-flex gap-2">
                                                <select class="form-select form-select-sm" @bind="selectedTintaId">
                                                    <option value="">Seleccionar tinta...</option>
                                                    @if (catalogoMP != null)
                                                    {
                                                        @foreach (var mp in catalogoMP)
                                                        {
                                                            <option value="@mp.Id">@mp.Nombre — $@mp.PrecioUnitario.ToString("N4")/@mp.UnidadMedida</option>
                                                        }
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-success" @onclick="AgregarTinta">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold" style="background:#f0e0f0">
                                        <td colspan="3" class="text-end">TOTAL TINTAS:</td>
                                        <td>$@cotizacionEditando.TotalTintas.ToString("N2")</td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- ========== INSUMOS BÁSICOS ========== -->
                    <div class="card mb-3 border-0">
                        <div class="card-header text-white fw-bold" style="background:#2E8B57">
                            <i class="bi bi-box-seam"></i> INSUMOS BÁSICOS
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40%">Concepto</th>
                                        <th style="width:20%">Consumo</th>
                                        <th style="width:20%">Precio Unit.</th>
                                        <th style="width:20%">Costo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ObtenerDetalles(CotizacionCategoria.InsumoBasico))
                                    {
                                        <tr>
                                            <td>@d.Concepto</td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Consumo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PrecioUnitario" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td class="text-end fw-bold">$@d.Costo.ToString("N4")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4">
                                            <div class="d-flex gap-2">
                                                <select class="form-select form-select-sm" @bind="selectedInsBasicoId">
                                                    <option value="">Seleccionar insumo básico...</option>
                                                    @if (catalogoInsBasicos != null)
                                                    {
                                                        @foreach (var ins in catalogoInsBasicos)
                                                        {
                                                            <option value="@ins.Id">@ins.Nombre — $@ins.PrecioUnitario.ToString("N2")/@ins.UnidadMedida</option>
                                                        }
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-success" @onclick="() => AgregarInsumo(TipoInsumoEnum.Basico)">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold" style="background:#e0f5e0">
                                        <td colspan="3" class="text-end">TOTAL INSUMOS BÁSICOS:</td>
                                        <td>$@cotizacionEditando.TotalInsumosBasicos.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- ========== INSUMOS DIVERSOS ========== -->
                    <div class="card mb-3 border-0">
                        <div class="card-header text-white fw-bold" style="background:#4169E1">
                            <i class="bi bi-tools"></i> INSUMOS DIVERSOS
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40%">Concepto</th>
                                        <th style="width:20%">Consumo</th>
                                        <th style="width:20%">Precio Unit.</th>
                                        <th style="width:20%">Costo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ObtenerDetalles(CotizacionCategoria.InsumoDiverso))
                                    {
                                        <tr>
                                            <td>@d.Concepto</td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Consumo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PrecioUnitario" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td class="text-end fw-bold">$@d.Costo.ToString("N4")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4">
                                            <div class="d-flex gap-2">
                                                <select class="form-select form-select-sm" @bind="selectedInsDiversoId">
                                                    <option value="">Seleccionar insumo diverso...</option>
                                                    @if (catalogoInsDiversos != null)
                                                    {
                                                        @foreach (var ins in catalogoInsDiversos)
                                                        {
                                                            <option value="@ins.Id">@ins.Nombre — $@ins.PrecioUnitario.ToString("N2")/@ins.UnidadMedida</option>
                                                        }
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-success" @onclick="() => AgregarInsumo(TipoInsumoEnum.Diverso)">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold" style="background:#e0e8f5">
                                        <td colspan="3" class="text-end">TOTAL INSUMOS DIVERSOS:</td>
                                        <td>$@cotizacionEditando.TotalInsumosDiversos.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- ========== MANO DE OBRA ========== -->
                    <div class="card mb-3 border-0">
                        <div class="card-header text-dark fw-bold" style="background:#FFD700">
                            <i class="bi bi-person-workspace"></i> MANO DE OBRA
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:22%">Proceso</th>
                                        <th style="width:22%">Posición</th>
                                        <th style="width:16%">Tiempo (min)</th>
                                        <th style="width:14%">Precio/Min</th>
                                        <th style="width:12%">Ganancia %</th>
                                        <th style="width:10%">Costo</th>
                                        <th style="width:4%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ObtenerDetalles(CotizacionCategoria.ManoObra))
                                    {
                                        <tr>
                                            <td>
                                                <strong>@ObtenerNombreProceso(d)</strong>
                                                @if (!string.Equals(d.Concepto, ObtenerNombreProceso(d), StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <div><small class="text-muted">@d.Concepto</small></div>
                                                }
                                            </td>
                                            <td>@ObtenerNombreActividad(d)</td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="d.Tiempo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Precio" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm" value="@ObtenerGananciaManoObra(d).ToString("N2")" readonly /></td>
                                            <td class="text-end fw-bold">$@d.Costo.ToString("N2")</td>
                                            <td class="text-center text-muted">Auto</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="7">
                                            <small class="text-muted">La mano de obra se genera automáticamente desde los procesos seleccionados. Puedes ajustar el <strong>precio/min</strong> solo para esta cotización; la ganancia se calcula contra la tarifa original.</small>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold" style="background:#fff3cd">
                                        <td colspan="5" class="text-end">TOTAL MANO DE OBRA:</td>
                                        <td>$@cotizacionEditando.TotalManoObra.ToString("N2")</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- ========== GASTOS FIJOS ========== -->
                    <div class="card mb-3 border-0">
                        <div class="card-header text-white fw-bold" style="background:#696969">
                            <i class="bi bi-building"></i> GASTOS FIJOS
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:40%">Concepto</th>
                                        <th style="width:20%">Tiempo (min)</th>
                                        <th style="width:20%">Precio/Min</th>
                                        <th style="width:15%">Costo</th>
                                        <th style="width:5%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in ObtenerDetalles(CotizacionCategoria.GastoFijo))
                                    {
                                        <tr>
                                            <td>@d.Concepto</td>
                                            <td><input type="number" step="0.01" class="form-control form-control-sm" value="@ObtenerTiempoManoObraTotal()" readonly /></td>
                                            <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Precio" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                            <td class="text-end fw-bold">$@d.Costo.ToString("N2")</td>
                                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarDetalle(d)"><i class="bi bi-trash"></i></button></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="5">
                                            <div class="d-flex gap-2">
                                                <select class="form-select form-select-sm" @bind="selectedGastoFijoId">
                                                    <option value="">Seleccionar gasto fijo...</option>
                                                    @if (catalogoGastosFijos != null)
                                                    {
                                                        @foreach (var gf in catalogoGastosFijos)
                                                        {
                                                            <option value="@gf.Id">@gf.Concepto — $@gf.CostoMensual.ToString("N2")/mes</option>
                                                        }
                                                    }
                                                </select>
                                                <button class="btn btn-sm btn-success" @onclick="AgregarGastoFijo">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold" style="background:#e0e0e0">
                                        <td colspan="4" class="text-end">TOTAL GASTOS FIJOS:</td>
                                        <td>$@cotizacionEditando.TotalGastosFijos.ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- ========== RESUMEN ========== -->
                    <div class="card border-0 shadow">
                        <div class="card-header bg-success text-white fw-bold">
                            <i class="bi bi-bar-chart-fill"></i> RESUMEN DE COSTOS
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#f0e0f0">
                                        <small class="text-muted">Tintas</small>
                                        <h5 class="mb-0">$@cotizacionEditando.TotalTintas.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#e0f5e0">
                                        <small class="text-muted">Insumos Básicos</small>
                                        <h5 class="mb-0">$@cotizacionEditando.TotalInsumosBasicos.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#e0e8f5">
                                        <small class="text-muted">Insumos Diversos</small>
                                        <h5 class="mb-0">$@cotizacionEditando.TotalInsumosDiversos.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#fff3cd">
                                        <small class="text-muted">Mano de Obra</small>
                                        <h5 class="mb-0">$@cotizacionEditando.TotalManoObra.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#e0e0e0">
                                        <small class="text-muted">Gastos Fijos</small>
                                        <h5 class="mb-0">$@cotizacionEditando.TotalGastosFijos.ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="card text-center p-2" style="background:#d6efe3">
                                        <small class="text-muted">Costo Base</small>
                                        <h5 class="mb-0">$@cotizacionEditando.CostoTotal.ToString("N2")</h5>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-3">
                                    <div class="card text-center p-2" style="background:#f1f5f9">
                                        <small class="text-muted">Costo por Par</small>
                                        <h5 class="mb-0">$@ObtenerCostoUnitarioBase().ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card text-center p-2" style="background:#eaf7ff">
                                        <small class="text-muted">Precio Sugerido</small>
                                        <h5 class="mb-0">$@ObtenerPrecioSugerido().ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card text-center p-2" style="background:#f1f5f9">
                                        <small class="text-muted">Utilidad (@cotizacionEditando.Utilidad.ToString("N2")%)</small>
                                        <h5 class="mb-0">$@ObtenerUtilidadMonto().ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card text-center p-2 bg-success text-white">
                                        <small>Precio Contado</small>
                                        <h4 class="mb-0">$@ObtenerPrecioContado().ToString("N2")</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <div class="card text-center p-2" style="background:#e8f2ff">
                                        <small class="text-muted">Precio Crédito</small>
                                        <h5 class="mb-0">$@ObtenerPrecioCredito().ToString("N2")</h5>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card text-center p-2 bg-success text-white">
                                        <small>Costo por Tarea</small>
                                        <h4 class="mb-0">$@ObtenerCostoTarea().ToString("N2")</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="card mt-3 border-0" style="background:#f8fafc">
                                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2" style="background:#eef2ff">
                                    <strong>Precios por variante</strong>
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="RegenerarPreciosVariantesAsync" disabled="@(cotizacionEditando.ClienteId == null || cotizacionEditando.ProductoId == Guid.Empty)">
                                        <i class="bi bi-magic me-1"></i>Aplicar sugerencias
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="small text-muted mb-2">La cotización define el precio final. Las reglas del cliente sólo proponen porcentajes sugeridos por dimensión y valor.</div>
                                    @if (!preciosVariantesEditando.Any())
                                    {
                                        <div class="text-muted small">No hay precios por variante generados todavía.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Variante</th>
                                                        <th class="text-end">% aplicado</th>
                                                        <th class="text-end">Contado</th>
                                                        <th class="text-end">Crédito</th>
                                                        <th class="text-center">Aceptada</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var precio in preciosVariantesEditando.OrderBy(p => p.Orden).ThenBy(p => p.Etiqueta))
                                                    {
                                                        <tr>
                                                            <td>
                                                                <div class="fw-semibold">@precio.Etiqueta</div>
                                                                @if (!string.IsNullOrWhiteSpace(precio.Sku))
                                                                {
                                                                    <div class="text-muted small">@precio.Sku</div>
                                                                }
                                                            </td>
                                                            <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PorcentajeVariacionAplicado" @bind-Value:after="() => OnPorcentajeVarianteChanged(precio)" /></td>
                                                            <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PrecioContado" @bind-Value:after="() => OnPrecioVarianteChanged(precio)" /></td>
                                                            <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PrecioCredito" @bind-Value:after="() => OnPrecioVarianteChanged(precio)" /></td>
                                                            <td class="text-center"><InputCheckbox class="form-check-input" @bind-Value="precio.Aceptada" /></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-3">
                                <button class="btn btn-primary" @onclick="GuardarCotizacion">
                                    <i class="bi bi-save"></i> Guardar Cotización
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Lista de cotizaciones existentes -->
    <div class="card border-0 shadow">
        <div class="card-body">
            @if (cotizaciones == null)
            {
                <div class="text-center py-3"><div class="spinner-border"></div></div>
            }
            else if (!cotizaciones.Any())
            {
                <div class="alert alert-info">No hay cotizaciones registradas.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Cliente</th>
                                <th>Producto</th>
                                <th>Descripción</th>
                                <th>Tintas</th>
                                <th>Insumos</th>
                                <th>Mano Obra</th>
                                <th>Gastos Fijos</th>
                                <th>Costo Total</th>
                                <th>Precio Contado</th>
                                <th>Utilidad</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in cotizaciones)
                            {
                                <tr>
                                    <td>@c.Cliente?.RazonSocial</td>
                                    <td>@c.Producto?.Nombre</td>
                                    <td>@c.Descripcion</td>
                                    <td>$@c.TotalTintas.ToString("N2")</td>
                                    <td>$@((c.TotalInsumosBasicos + c.TotalInsumosDiversos).ToString("N2"))</td>
                                    <td>$@c.TotalManoObra.ToString("N2")</td>
                                    <td>$@c.TotalGastosFijos.ToString("N2")</td>
                                    <td><span class="badge bg-success fs-6">$@c.CostoTotal.ToString("N2")</span></td>
                                    <td>$@c.PrecioFinalContado.ToString("N2")</td>
                                    <td>$@c.Ganancia.ToString("N2")</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" @onclick="() => EditarCotizacion(c)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DuplicarCotizacion(c)"><i class="bi bi-files"></i></button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarCotizacion(c)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<CotizacionSerigrafia>? cotizaciones;
    private IEnumerable<Cliente>? clientes;
    private IEnumerable<Producto>? productos;
    private CotizacionSerigrafia? cotizacionEditando;
    private bool mostrarFormulario;
    private List<ClienteReglaVariacionPrecio> reglasVariacionCliente = [];
    private List<CotizacionVariantePrecioEditor> preciosVariantesEditando = [];

    private IEnumerable<MateriaPrima>? catalogoMP;
    private IEnumerable<Insumo>? catalogoInsBasicos;
    private IEnumerable<Insumo>? catalogoInsDiversos;
    private IEnumerable<Posicion>? catalogoPosiciones;
    private IEnumerable<GastoFijo>? catalogoGastosFijos;
    private IEnumerable<TipoProceso> catalogoProcesos = [];

    private readonly SemaphoreSlim _dbLock = new(1, 1);

    private string selectedTintaId = "";
    private string selectedInsBasicoId = "";
    private string selectedInsDiversoId = "";
    private string selectedActividadId = "";
    private string selectedGastoFijoId = "";
    private HashSet<Guid> procesosSeleccionados = [];

    protected override async Task OnInitializedAsync()
    {
        await EjecutarConDbLock(async () =>
        {
            await CargarCatalogos();
            await CargarClientes();
            await CargarProductos();
            await CargarCotizaciones();
        });
    }

    private async Task<List<ClienteReglaVariacionPrecio>> CargarReglasVariacionClienteAsync(Guid clienteId)
    {
        return await EjecutarConNuevoContextoAsync(context =>
            context.ClientesReglasVariacionPrecio
                .AsNoTracking()
                .Where(r => r.ClienteId == clienteId && r.IsActive && r.Activa)
                .OrderBy(r => r.Orden)
                .ThenBy(r => r.Dimension)
                .ThenBy(r => r.Valor)
                .ToListAsync());
    }

    private async Task RegenerarPreciosVariantesAsync()
    {
        if (cotizacionEditando == null || cotizacionEditando.ProductoId == Guid.Empty)
        {
            preciosVariantesEditando = [];
            return;
        }

        cotizacionEditando.PrecioFinalContado = ObtenerPrecioContado();
        cotizacionEditando.PrecioCredito = ObtenerPrecioCredito();
        preciosVariantesEditando = await ConstruirPreciosVariantesSugeridosAsync();
    }

    private async Task<List<CotizacionVariantePrecioEditor>> ConstruirPreciosVariantesSugeridosAsync()
    {
        if (cotizacionEditando == null || cotizacionEditando.ProductoId == Guid.Empty)
        {
            return [];
        }

        var baseContado = ObtenerPrecioContado();
        var baseCredito = ObtenerPrecioCredito();

        return await EjecutarConNuevoContextoAsync(async context =>
        {
            var variantes = await context.ProductosVariantes
                .AsNoTracking()
                .Where(v => v.ProductoId == cotizacionEditando.ProductoId && v.IsActive && v.Activa)
                .OrderBy(v => v.Talla)
                .ThenBy(v => v.Color)
                .ThenBy(v => v.Sku)
                .ToListAsync();

            var precios = new List<CotizacionVariantePrecioEditor>
            {
                new()
                {
                    Etiqueta = "Precio base",
                    EsPrecioBase = true,
                    Orden = 0,
                    PorcentajeVariacionAplicado = 0m,
                    PrecioContado = baseContado,
                    PrecioCredito = baseCredito,
                    Aceptada = true
                }
            };

            foreach (var variante in variantes)
            {
                var porcentaje = ObtenerPorcentajeSugeridoVariante(variante);
                var factor = 1m + (porcentaje / 100m);
                precios.Add(new CotizacionVariantePrecioEditor
                {
                    ProductoVarianteId = variante.Id,
                    Sku = variante.Sku,
                    Etiqueta = ObtenerEtiquetaVariante(variante),
                    Talla = variante.Talla,
                    Color = variante.Color,
                    Orden = precios.Count,
                    PorcentajeVariacionAplicado = porcentaje,
                    PrecioContado = Math.Round(baseContado * factor, 2),
                    PrecioCredito = Math.Round(baseCredito * factor, 2),
                    Aceptada = true
                });
            }

            return precios;
        });
    }

    private decimal ObtenerPorcentajeSugeridoVariante(ProductoVariante variante)
    {
        decimal total = 0m;

        if (!string.IsNullOrWhiteSpace(variante.Talla))
        {
            total += reglasVariacionCliente
                .Where(r => r.PermiteVariacionPrecio
                    && string.Equals(r.Dimension, "Talla", StringComparison.OrdinalIgnoreCase)
                    && string.Equals(r.Valor, variante.Talla, StringComparison.OrdinalIgnoreCase))
                .Sum(r => r.PorcentajeVariacionSugerido);
        }

        if (!string.IsNullOrWhiteSpace(variante.Color))
        {
            total += reglasVariacionCliente
                .Where(r => r.PermiteVariacionPrecio
                    && string.Equals(r.Dimension, "Color", StringComparison.OrdinalIgnoreCase)
                    && string.Equals(r.Valor, variante.Color, StringComparison.OrdinalIgnoreCase))
                .Sum(r => r.PorcentajeVariacionSugerido);
        }

        return total;
    }

    private async Task GuardarPreciosVariantesCotizacionAsync()
    {
        if (cotizacionEditando == null || cotizacionEditando.Id == Guid.Empty)
        {
            return;
        }

        await EjecutarConNuevoContextoAsync(async context =>
        {
            var existentes = await context.CotizacionVariantePrecios
                .Where(p => p.CotizacionSerigrafiaId == cotizacionEditando.Id)
                .ToListAsync();

            if (existentes.Count > 0)
            {
                context.CotizacionVariantePrecios.RemoveRange(existentes);
                await context.SaveChangesAsync();
            }

            foreach (var precio in preciosVariantesEditando)
            {
                context.CotizacionVariantePrecios.Add(new CotizacionVariantePrecio
                {
                    Id = Guid.NewGuid(),
                    CotizacionSerigrafiaId = cotizacionEditando.Id,
                    ProductoVarianteId = precio.ProductoVarianteId,
                    Etiqueta = precio.Etiqueta,
                    Talla = precio.Talla,
                    Color = precio.Color,
                    EsPrecioBase = precio.EsPrecioBase,
                    PorcentajeVariacionAplicado = precio.PorcentajeVariacionAplicado,
                    PrecioContado = precio.PrecioContado,
                    PrecioCredito = precio.PrecioCredito,
                    Aceptada = precio.Aceptada,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }

            await context.SaveChangesAsync();
        });
    }

    private async Task CargarClientes()
    {
        clientes = await ClienteRepository.GetAllAsync();
    }

    private async Task CargarCatalogos()
    {
        await EjecutarConNuevoContextoAsync(async context =>
        {
            catalogoMP = await context.MateriasPrimas
                .AsNoTracking()
                .Where(m => m.IsActive)
                .OrderBy(m => m.Nombre)
                .ToListAsync();

            var insumos = await context.Insumos
                .AsNoTracking()
                .Where(i => i.IsActive)
                .OrderBy(i => i.Nombre)
                .ToListAsync();

            catalogoInsBasicos = insumos.Where(i => i.TipoInsumo == TipoInsumoEnum.Basico).ToList();
            catalogoInsDiversos = insumos.Where(i => i.TipoInsumo == TipoInsumoEnum.Diverso).ToList();

            var posiciones = await context.Posiciones
                .AsNoTracking()
                .Where(a => a.IsActive)
                .OrderBy(a => a.Orden)
                .ToListAsync();

            catalogoPosiciones = posiciones;

            catalogoGastosFijos = await context.GastosFijos
                .AsNoTracking()
                .Where(g => g.IsActive)
                .OrderBy(g => g.Orden)
                .ToListAsync();

            var procesos = await context.TiposProceso
                .AsNoTracking()
                .Where(p => p.IsActive && p.Activo)
                .OrderBy(p => p.Orden)
                .ToListAsync();

            foreach (var proceso in procesos)
            {
                proceso.Posicion = posiciones.FirstOrDefault(a => a.Id == proceso.PosicionId);
            }

            catalogoProcesos = procesos;
        });
    }

    private async Task CargarProductos()
    {
        await EjecutarConNuevoContextoAsync(async context =>
        {
            productos = await context.Productos
                .AsNoTracking()
                .Where(p => p.IsActive)
                .OrderBy(p => p.Nombre)
                .ToListAsync();
        });
    }

    private async Task CargarCotizaciones()
    {
        cotizaciones = await EjecutarConNuevoContextoAsync(context =>
            context.CotizacionesSerigrafia
                .AsNoTracking()
                .AsSplitQuery()
                .Include(c => c.Cliente)
                .Include(c => c.Producto)
                .Include(c => c.Detalles.Where(d => d.IsActive))
                .Include(c => c.PreciosVariantes.Where(p => p.IsActive))
                .Include(c => c.Procesos)
                    .ThenInclude(p => p.TipoProceso)
                .Where(c => c.IsActive)
                .OrderByDescending(c => c.CreatedAt)
                .ToListAsync());
    }

    private void NuevaCotizacion()
    {
        cotizacionEditando = new CotizacionSerigrafia { NumeroPersonas = 1 };
        procesosSeleccionados = [];
        reglasVariacionCliente = [];
        preciosVariantesEditando = [];
        mostrarFormulario = true;
    }

    private async Task EditarCotizacion(CotizacionSerigrafia cot)
    {
        cotizacionEditando = await CargarCotizacionPorIdAsync(cot.Id);
        procesosSeleccionados = cotizacionEditando?.Procesos.Select(p => p.TipoProcesoId).ToHashSet() ?? [];
        reglasVariacionCliente = cotizacionEditando?.ClienteId is Guid clienteId
            ? await CargarReglasVariacionClienteAsync(clienteId)
            : [];
        preciosVariantesEditando = cotizacionEditando?.PreciosVariantes
            .OrderBy(p => p.EsPrecioBase ? 0 : 1)
            .ThenBy(p => p.Talla)
            .ThenBy(p => p.Color)
            .Select((p, index) => new CotizacionVariantePrecioEditor
            {
                Id = p.Id,
                ProductoVarianteId = p.ProductoVarianteId,
                Sku = p.ProductoVariante?.Sku,
                Etiqueta = p.Etiqueta,
                Talla = p.Talla,
                Color = p.Color,
                EsPrecioBase = p.EsPrecioBase,
                Orden = index,
                PorcentajeVariacionAplicado = p.PorcentajeVariacionAplicado,
                PrecioContado = p.PrecioContado,
                PrecioCredito = p.PrecioCredito,
                Aceptada = p.Aceptada
            })
            .ToList() ?? [];
        mostrarFormulario = true;
    }

    private async Task OnClienteChanged(ChangeEventArgs e)
    {
        if (cotizacionEditando == null)
        {
            return;
        }

        cotizacionEditando.ClienteId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        reglasVariacionCliente = cotizacionEditando.ClienteId is Guid clienteId
            ? await CargarReglasVariacionClienteAsync(clienteId)
            : [];

        await RegenerarPreciosVariantesAsync();
    }

    private async Task OnProductoChangedAsync(ChangeEventArgs e)
    {
        if (cotizacionEditando == null)
        {
            return;
        }

        cotizacionEditando.ProductoId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : Guid.Empty;
        await RegenerarPreciosVariantesAsync();
    }

    private async Task GuardarCotizacion()
    {
        await EjecutarConDbLock(async () =>
        {
            if (cotizacionEditando == null || cotizacionEditando.ProductoId == Guid.Empty) return;

            cotizacionEditando.CostoTotalPorTarea = ObtenerCostoTarea();
            cotizacionEditando.CostoTotalPorPar = ObtenerCostoUnitarioBase();
            cotizacionEditando.PrecioSugerido = ObtenerPrecioSugerido();
            cotizacionEditando.PrecioFinalContado = ObtenerPrecioContado();
            cotizacionEditando.PrecioCredito = ObtenerPrecioCredito();
            cotizacionEditando.Ganancia = ObtenerUtilidadMonto();

            if (!preciosVariantesEditando.Any())
            {
                await RegenerarPreciosVariantesAsync();
            }

            var precioBase = preciosVariantesEditando.FirstOrDefault(p => p.EsPrecioBase);
            if (precioBase != null)
            {
                cotizacionEditando.PrecioFinalContado = precioBase.PrecioContado;
                cotizacionEditando.PrecioCredito = precioBase.PrecioCredito;
            }

            if (cotizacionEditando.Id == Guid.Empty)
            {
                PrepararNuevaEntidad(cotizacionEditando);
                await EjecutarConNuevoContextoAsync(async context =>
                {
                    context.CotizacionesSerigrafia.Add(cotizacionEditando);
                    await context.SaveChangesAsync();
                });

                cotizacionEditando = await CargarCotizacionPorIdAsync(cotizacionEditando.Id);
            }
            else
            {
                await EjecutarConNuevoContextoAsync(async context =>
                {
                    var cotizacionDb = await context.CotizacionesSerigrafia
                        .FirstOrDefaultAsync(c => c.Id == cotizacionEditando.Id);

                    if (cotizacionDb == null) return;

                    cotizacionDb.ProductoId = cotizacionEditando.ProductoId;
                    cotizacionDb.ClienteId = cotizacionEditando.ClienteId;
                    cotizacionDb.ParesPorLamina = cotizacionEditando.ParesPorLamina;
                    cotizacionDb.Utilidad = cotizacionEditando.Utilidad;
                    cotizacionDb.Descripcion = cotizacionEditando.Descripcion;
                    cotizacionDb.NumeroPersonas = cotizacionEditando.NumeroPersonas;
                    cotizacionDb.CostoTotalPorTarea = cotizacionEditando.CostoTotalPorTarea;
                    cotizacionDb.CostoTotalPorPar = cotizacionEditando.CostoTotalPorPar;
                    cotizacionDb.PrecioSugerido = cotizacionEditando.PrecioSugerido;
                    cotizacionDb.PrecioFinalContado = cotizacionEditando.PrecioFinalContado;
                    cotizacionDb.PrecioCredito = cotizacionEditando.PrecioCredito;
                    cotizacionDb.Ganancia = cotizacionEditando.Ganancia;
                    cotizacionDb.UpdatedAt = DateTime.UtcNow;

                    await context.SaveChangesAsync();
                });
            }

            await SincronizarProductoClienteCotizacionAsync();

            await GuardarPreciosVariantesCotizacionAsync();

            await SincronizarProcesosCotizacionAsync();
            await SincronizarManoObraDesdeProcesosAsync();

            await CargarCotizaciones();
        });
    }

    private async Task ToggleProcesoCotizacion(Guid tipoProcesoId, object? value)
    {
        if (value is bool b && b)
            procesosSeleccionados.Add(tipoProcesoId);
        else
            procesosSeleccionados.Remove(tipoProcesoId);

        if (cotizacionEditando?.Id != Guid.Empty)
        {
            await SincronizarProcesosCotizacionAsync();
            await SincronizarManoObraDesdeProcesosAsync();
            cotizacionEditando = await RecargarCotizacion();
            await CargarCotizaciones();
        }
    }

    private async Task SincronizarManoObraDesdeProcesosAsync()
    {
        if (cotizacionEditando == null || cotizacionEditando.Id == Guid.Empty) return;

        var procesosActivos = catalogoProcesos
            .Where(p => procesosSeleccionados.Contains(p.Id))
            .ToList();

        var procesoIdsValidos = procesosActivos
            .Where(p => p.PosicionId.HasValue)
            .Select(p => p.Id)
            .ToHashSet();

        await EjecutarConNuevoContextoAsync(async context =>
        {
            var detallesMo = await context.CotizacionDetalles
                .Where(d => d.CotizacionSerigrafiaId == cotizacionEditando.Id && d.Categoria == CotizacionCategoria.ManoObra && d.IsActive)
                .ToListAsync();

            var porDesactivar = detallesMo
                .Where(d => d.TipoProcesoId.HasValue && !procesoIdsValidos.Contains(d.TipoProcesoId.Value))
                .ToList();

            foreach (var detalle in porDesactivar)
            {
                detalle.IsActive = false;
                detalle.UpdatedAt = DateTime.UtcNow;
            }

            var siguienteOrden = detallesMo
                .Where(d => d.IsActive)
                .Select(d => d.Orden)
                .DefaultIfEmpty(0)
                .Max();

            foreach (var proceso in procesosActivos.Where(p => p.PosicionId.HasValue))
            {
                var detalleExistente = detallesMo.FirstOrDefault(d => d.TipoProcesoId == proceso.Id && d.IsActive);
                var precioMin = ObtenerTarifaPorMinuto(proceso);

                if (detalleExistente == null)
                {
                    detalleExistente = new CotizacionDetalle
                    {
                        CotizacionSerigrafiaId = cotizacionEditando.Id,
                        Categoria = CotizacionCategoria.ManoObra,
                        Concepto = proceso.Nombre,
                        Tiempo = 0,
                        Precio = precioMin,
                        GananciaPorcentaje = 0,
                        PosicionId = proceso.PosicionId,
                        TipoProcesoId = proceso.Id,
                        Orden = ++siguienteOrden,
                        IsActive = true
                    };

                    PrepararNuevaEntidad(detalleExistente);
                    detalleExistente.GananciaPorcentaje = CalcularGananciaManoObra(detalleExistente.Precio, precioMin);
                    detalleExistente.Costo = (detalleExistente.Tiempo ?? 0) * (detalleExistente.Precio ?? 0);
                    context.CotizacionDetalles.Add(detalleExistente);
                }
                else
                {
                    detalleExistente.Concepto = proceso.Nombre;
                    if (!detalleExistente.Precio.HasValue || detalleExistente.Precio <= 0)
                    {
                        detalleExistente.Precio = precioMin;
                    }

                    detalleExistente.GananciaPorcentaje = CalcularGananciaManoObra(detalleExistente.Precio, precioMin);
                    detalleExistente.PosicionId = proceso.PosicionId;
                    detalleExistente.TipoProcesoId = proceso.Id;
                    detalleExistente.Costo = (detalleExistente.Tiempo ?? 0) * (detalleExistente.Precio ?? 0);
                    detalleExistente.UpdatedAt = DateTime.UtcNow;
                }
            }

            await context.SaveChangesAsync();
        });

        await ActualizarGastosFijosTiempoAsync();
        cotizacionEditando = await RecargarCotizacion();
    }

    private async Task SincronizarProcesosCotizacionAsync()
    {
        if (cotizacionEditando == null || cotizacionEditando.Id == Guid.Empty) return;

        await EjecutarConNuevoContextoAsync(async context =>
        {
            var existentes = await context.CotizacionSerigrafiaProcesos
                .Where(p => p.CotizacionSerigrafiaId == cotizacionEditando.Id)
                .ToListAsync();

            var existentesIds = existentes.Select(p => p.TipoProcesoId).ToHashSet();
            var porEliminar = existentes.Where(p => !procesosSeleccionados.Contains(p.TipoProcesoId)).ToList();
            if (porEliminar.Any())
            {
                context.CotizacionSerigrafiaProcesos.RemoveRange(porEliminar);
            }

            var porAgregar = procesosSeleccionados
                .Where(id => !existentesIds.Contains(id))
                .Select(id =>
                {
                    var proceso = new CotizacionSerigrafiaProceso
                    {
                        CotizacionSerigrafiaId = cotizacionEditando.Id,
                        TipoProcesoId = id
                    };

                    PrepararNuevaEntidad(proceso);
                    return proceso;
                })
                .ToList();

            if (porAgregar.Any())
            {
                context.CotizacionSerigrafiaProcesos.AddRange(porAgregar);
            }

            if (porEliminar.Any() || porAgregar.Any())
            {
                await context.SaveChangesAsync();
            }
        });
    }

    private async Task AgregarTinta()
    {
        await EjecutarConDbLock(async () =>
        {
            if (cotizacionEditando == null || !Guid.TryParse(selectedTintaId, out var id)) return;
            var mp = catalogoMP?.FirstOrDefault(m => m.Id == id);
