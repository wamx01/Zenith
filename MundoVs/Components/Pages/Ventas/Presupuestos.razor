    }

    /* Layout detalle */
    .cot-detail-layout {
        display: block;
        padding: .75rem .9rem;
    }

    @@media (max-width: 1100px) {
        .cot-ficha { grid-template-columns: repeat(6, minmax(0, 1fr)); }
        .cot-ficha__field { grid-column: span 3; }
        .cot-ficha__field--sm { grid-column: span 2; }
        .cot-ficha__field--md { grid-column: span 6; }
        .cot-ficha__actions { grid-column: span 6; justify-content: flex-start; }
    }

    @@media (max-width: 768px) {
        .cot-ficha { grid-template-columns: repeat(1, minmax(0, 1fr)); }
