@page "/serigrafia/cotizaciones"
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Inventario
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IRepository<CotizacionSerigrafia> CotizacionRepository
@inject IClienteRepository ClienteRepository
@inject IProductoRepository ProductoRepository
@inject IRepository<CotizacionDetalle> DetalleRepository
@inject IRepository<Posicion> PosicionRepository
@inject IRepository<GastoFijo> GastoFijoRepository
@inject IRepository<TipoProceso> TipoProcesoRepository
@inject IDbContextFactory<CrmDbContext> DbContextFactory
@rendermode InteractiveServer

<PageTitle>Cotizaciones</PageTitle>

<div class="cot-page">

    @* Encabezado de pagina *@
    <div class="cot-topbar">
        <div class="cot-topbar__title">
            <i class="bi bi-calculator-fill"></i>
            <span>Cotizaciones</span>
        </div>
        <button class="btn btn-success btn-sm" @onclick="NuevaCotizacion">
            <i class="bi bi-plus-lg me-1"></i>Nueva cotización
        </button>
    </div>

    @* Formulario editor *@
    @if (mostrarFormulario && cotizacionEditando != null)
    {
        <div class="cot-editor">

            @* Encabezado del editor *@
            <div class="cot-editor__header">
                <div class="cot-editor__header-left">
                    <span class="cot-editor__badge">@(cotizacionEditando.Id == Guid.Empty ? "Nueva" : "Editando")</span>
                    <strong class="cot-editor__title">Cotización</strong>
                    @if (!string.IsNullOrWhiteSpace(cotizacionEditando.Descripcion))
                    {
                        <span class="cot-editor__subtitle">- @cotizacionEditando.Descripcion</span>
                    }
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="Cancelar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            @* Ficha de datos generales *@
            <div class="cot-ficha">
                <div class="cot-ficha__field">
                    <label><i class="bi bi-person-circle me-1"></i>Cliente</label>
                    <select class="form-select form-select-sm" @onchange="OnClienteChanged">
                        <option value="">Seleccionar cliente...</option>
                        @if (clientes != null)
                        {
                            @foreach (var cliente in clientes)
                            {
                                <option value="@cliente.Id" selected="@(cotizacionEditando.ClienteId == cliente.Id)">@cliente.RazonSocial</option>
                            }
                        }
                    </select>
                </div>
                <div class="cot-ficha__field">
                    <label><i class="bi bi-box-seam me-1"></i>Producto</label>
                    <select class="form-select form-select-sm" @onchange="OnProductoChangedAsync">
                        <option value="">Seleccionar producto...</option>
                        @if (productos != null)
                        {
                            @foreach (var p in productos)
                            {
                                <option value="@p.Id" selected="@(cotizacionEditando.ProductoId == p.Id)">@p.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="cot-ficha__field cot-ficha__field--sm">
                    <label><i class="bi bi-layers me-1"></i>Pares / lámina</label>
                    <input type="number" class="form-control form-control-sm" @bind="cotizacionEditando.ParesPorLamina" />
                </div>
                <div class="cot-ficha__field cot-ficha__field--sm">
                    <label><i class="bi bi-percent me-1"></i>Utilidad</label>
                    <input type="number" class="form-control form-control-sm" step="0.01" @bind="cotizacionEditando.Utilidad" />
                </div>
                <div class="cot-ficha__field cot-ficha__field--md">
                    <label><i class="bi bi-chat-left-text me-1"></i>Descripción</label>
                    <input type="text" class="form-control form-control-sm" @bind="cotizacionEditando.Descripcion" />
                </div>
                <div class="cot-ficha__field cot-ficha__field--sm">
                    <label><i class="bi bi-people me-1"></i>Personas</label>
                    <input type="number" class="form-control form-control-sm" min="1" @bind="cotizacionEditando.NumeroPersonas" />
                </div>
                <div class="cot-ficha__actions">
                    <button class="btn btn-primary btn-sm" @onclick="GuardarCotizacion">
                        <i class="bi bi-floppy me-1"></i>Guardar
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="Cancelar">
                        Cancelar
                    </button>
                </div>
            </div>

            @if (cotizacionEditando.Id != Guid.Empty)
            {
                @* Seccion procesos *@
                <div class="cot-section">
                    <div class="cot-section__header" style="--accent:#1e3a5f">
                        <span><i class="bi bi-diagram-3 me-1"></i>Procesos</span>
                        <span class="cot-badge-count">@procesosCotizacionAplicados.Count aplicado(s)</span>
                    </div>
                    <div class="cot-section__body">
                        @if (!catalogoProcesos.Any())
                        {
                            <p class="text-muted small mb-0">No hay procesos activos configurados.</p>
                        }
                        else
                        {
                            <p class="cot-hint"><i class="bi bi-info-circle me-1"></i>Activa los procesos que llevará esta cotización y ajusta cuántas veces corre cada uno.</p>
                            <div class="cot-procesos-grid">
                                @foreach (var proceso in catalogoProcesos)
                                {
                                    var sel = procesosSeleccionados.Contains(proceso.Id);
                                    <label class="cot-proceso-chip @(sel ? "cot-proceso-chip--on" : "")"
                                           @onchange="async (e) => await ToggleProcesoCotizacion(proceso.Id, e.Value)">
                                        <input type="checkbox" class="d-none" checked="@sel" />
                                        <span class="cot-proceso-chip__icon">
                                            <i class="bi @(sel ? "bi-check-circle-fill" : "bi-circle")"></i>
                                        </span>
                                        <span class="cot-proceso-chip__body">
                                            <strong>@proceso.Nombre</strong>
                                            <small>@(proceso.Posicion?.Nombre ?? "Sin posición") · @proceso.MinutosEstandar.ToString("N1") min · @ObtenerTarifaPorMinuto(proceso).ToString("C3")/min</small>
                                        </span>
                                        @if (sel)
                                        {
                                            var ap = procesosCotizacionAplicados.FirstOrDefault(x => x.TipoProcesoId == proceso.Id);
                                            @if (ap != null)
                                            {
                                                <span class="cot-proceso-chip__mult" @onclick:stopPropagation="true">
                                                    <span class="cot-proceso-chip__mult-label">×</span>
                                                    <InputNumber class="cot-proceso-chip__mult-input" @bind-Value="ap.Multiplicador" @bind-Value:after="() => ActualizarMultiplicadorProcesoAsync(ap)" />
                                                </span>
                                            }
                                        }
                                    </label>
                                }
                            </div>

                            @if (procesosCotizacionAplicados.Any())
                            {
                                <div class="cot-procesos-applied">
                                    @foreach (var ap in procesosCotizacionAplicados.OrderBy(p => p.Orden).ThenBy(p => p.TipoProceso?.Nombre))
                                    {
                                        var nombreProceso = ap.TipoProceso?.Nombre ?? ObtenerNombreProcesoAplicado(ap);
                                        var consumosLigados = ap.TipoProceso?.ConsumosEstandar.Count(c => c.IsActive && c.Activo) ?? 0;
                                        <div class="cot-proc-row">
                                            <div class="cot-proc-row__name">
                                                <i class="bi bi-gear-fill text-primary"></i>
                                                <strong>@nombreProceso</strong>
                                                <small class="text-muted">@(ap.TipoProceso?.Posicion?.Nombre ?? "Sin posición")</small>
                                            </div>
                                            <div class="cot-proc-row__stats">
                                                <span><label>Base</label><strong>@ap.MinutosEstandarAplicados.ToString("N2") min</strong></span>
                                                <span><label>Total</label><strong>@ap.TiempoTotal.ToString("N2") min</strong></span>
                                                <span><label>Consumos</label><strong>@consumosLigados</strong></span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

                @* Detalle principal *@
                <div class="cot-detail-layout">
                    <div class="cot-detail-layout__main">

                        @* MATERIALES *@
                        <div class="cot-section">
                            <div class="cot-section__header" style="--accent:#2c5f8a">
                                <span><i class="bi bi-box-seam me-1"></i>Materiales</span>
                                <span class="cot-total-badge">@ObtenerTotalMateriales().ToString("C2")</span>
                            </div>
                            <div class="cot-section__body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0 cot-table">
                                        <thead>
                                            <tr>
                                                <th style="width:5%"></th>
                                                <th style="width:18%">Grupo</th>
                                                <th>Concepto</th>
                                                <th style="width:13%">Consumo</th>
                                                <th style="width:13%">Precio</th>
                                                <th style="width:10%" class="text-end">Costo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ObtenerDetallesMateriales())
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button class="btn btn-xs btn-outline-danger" @onclick="() => EliminarDetalle(d)" title="Eliminar">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </td>
                                                    <td>
                                                        <div class="fw-semibold small">@ObtenerEtiquetaGrupoMaterial(d)</div>
                                                        <span class="badge @(d.OrigenDetalle == CotizacionDetalleOrigen.GeneradoPorProceso ? "bg-primary-subtle text-primary-emphasis" : "bg-light text-secondary border") badge-xs">
                                                            @(d.OrigenDetalle == CotizacionDetalleOrigen.GeneradoPorProceso ? "Auto" : "Manual")
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <div class="small fw-semibold">@d.Concepto</div>
                                                        <div class="text-muted" style="font-size:.7rem">@ObtenerOrigenProcesoMaterial(d)</div>
                                                    </td>
                                                    <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Consumo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                                    <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.PrecioUnitario" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                                    <td class="text-end fw-bold small">$@d.Costo.ToString("N4")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="cot-table-total">
                                                <td colspan="5" class="text-end fw-bold">Total materiales</td>
                                                <td class="text-end fw-bold">$@ObtenerTotalMateriales().ToString("N2")</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                @* Panel agregar material *@
                                <div class="cot-add-panel">
                                    <div class="cot-add-panel__title"><i class="bi bi-plus-circle me-1"></i>Agregar material</div>
                                    <div class="cot-add-panel__row">
                                        <select class="form-select form-select-sm" value="@tipoInventarioSeleccionadoId" @onchange="e => OnTipoInventarioCotizacionChanged(e.Value?.ToString())">
                                            <option value="">1. Tipo de inventario...</option>
                                            @foreach (var grupo in ObtenerGruposMaterialesCotizacion())
                                            {
                                                <option value="@grupo.Clave">@grupo.Titulo</option>
                                            }
                                        </select>
                                        <select class="form-select form-select-sm" value="@materialInventarioSeleccionadoId" @onchange="e => OnMaterialInventarioChanged(e.Value?.ToString())" disabled="@(string.IsNullOrWhiteSpace(tipoInventarioSeleccionadoId))">
                                            <option value="">2. Seleccionar material...</option>
                                            @foreach (var item in ObtenerMaterialesDisponiblesSeleccionados())
                                            {
                                                <option value="@item.Id">@item.Nombre - $@item.PrecioUnitario.ToString("N4")/@item.UnidadMedida</option>
                                            }
                                        </select>
                                        <button class="btn btn-success btn-sm" @onclick="AgregarMaterialSeleccionadoAsync" disabled="@(string.IsNullOrWhiteSpace(materialInventarioSeleccionadoId))">
                                            <i class="bi bi-plus-lg me-1"></i>Agregar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* MANO DE OBRA *@
                        <div class="cot-section">
                            <div class="cot-section__header" style="--accent:#b8860b">
                                <span><i class="bi bi-person-workspace me-1"></i>Mano de Obra</span>
                                <span class="cot-total-badge">$@cotizacionEditando.TotalManoObra.ToString("N2")</span>
                            </div>
                            <div class="cot-section__body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0 cot-table">
                                        <thead>
                                            <tr>
                                                <th style="width:22%">Proceso</th>
                                                <th style="width:20%">Posición</th>
                                                <th style="width:14%">Tiempo (min)</th>
                                                <th style="width:14%">$/min</th>
                                                <th style="width:12%">Ganancia %</th>
                                                <th style="width:12%" class="text-end">Costo</th>
                                                <th style="width:6%"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ObtenerDetalles(CotizacionCategoria.ManoObra))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-semibold small">@ObtenerNombreProceso(d)</div>
                                                        @if (!string.Equals(d.Concepto, ObtenerNombreProceso(d), StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <div style="font-size:.7rem" class="text-muted">@d.Concepto</div>
                                                        }
                                                    </td>
                                                    <td class="small">@ObtenerNombreActividad(d)</td>
                                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="d.Tiempo" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                                    <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Precio" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                                    <td><input type="number" step="0.01" class="form-control form-control-sm" value="@ObtenerGananciaManoObra(d).ToString("N2")" readonly /></td>
                                                    <td class="text-end fw-bold small">$@d.Costo.ToString("N2")</td>
                                                    <td class="text-center">
                                                        <span class="badge @(d.OrigenDetalle == CotizacionDetalleOrigen.GeneradoPorProceso ? "bg-primary-subtle text-primary-emphasis" : "bg-light text-secondary border") badge-xs">
                                                            @(d.OrigenDetalle == CotizacionDetalleOrigen.GeneradoPorProceso ? "Auto" : "Manual")
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="cot-table-total">
                                                <td colspan="5" class="text-end fw-bold">Total mano de obra</td>
                                                <td class="text-end fw-bold">$@cotizacionEditando.TotalManoObra.ToString("N2")</td>
                                                <td></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <div class="cot-add-panel cot-add-panel--info">
                                    <i class="bi bi-info-circle me-1"></i>La mano de obra se genera desde los procesos activos. Ajusta <strong>$/min</strong> para esta cotización si es necesario.
                                </div>
                            </div>
                        </div>

                        @* GASTOS FIJOS *@
                        <div class="cot-section">
                            <div class="cot-section__header" style="--accent:#555">
                                <span><i class="bi bi-building me-1"></i>Gastos Fijos</span>
                                <span class="cot-total-badge">$@cotizacionEditando.TotalGastosFijos.ToString("N2")</span>
                            </div>
                            <div class="cot-section__body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0 cot-table">
                                        <thead>
                                            <tr>
                                                <th style="width:5%"></th>
                                                <th>Concepto</th>
                                                <th style="width:20%">Tiempo (min)</th>
                                                <th style="width:20%">$/min</th>
                                                <th style="width:14%" class="text-end">Costo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in ObtenerDetalles(CotizacionCategoria.GastoFijo))
                                            {
                                                <tr>
                                                    <td class="text-center">
                                                        <button class="btn btn-xs btn-outline-danger" @onclick="() => EliminarDetalle(d)" title="Eliminar">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </td>
                                                    <td class="small fw-semibold">@d.Concepto</td>
                                                    <td><input type="number" step="0.01" class="form-control form-control-sm" value="@ObtenerTiempoManoObraTotal()" readonly /></td>
                                                    <td><input type="number" step="0.0001" class="form-control form-control-sm" @bind="d.Precio" @bind:event="onchange" @onblur="() => GuardarDetalle(d)" /></td>
                                                    <td class="text-end fw-bold small">$@d.Costo.ToString("N2")</td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr class="cot-table-total">
                                                <td colspan="4" class="text-end fw-bold">Total gastos fijos</td>
                                                <td class="text-end fw-bold">$@cotizacionEditando.TotalGastosFijos.ToString("N2")</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                                <div class="cot-add-panel">
                                    <div class="cot-add-panel__title"><i class="bi bi-plus-circle me-1"></i>Agregar gasto fijo</div>
                                    <div class="cot-add-panel__row">
                                        <select class="form-select form-select-sm" @bind="selectedGastoFijoId">
                                            <option value="">Seleccionar gasto fijo...</option>
                                            @if (catalogoGastosFijos != null)
                                            {
                                                @foreach (var gf in catalogoGastosFijos)
                                                {
                                                    <option value="@gf.Id">@gf.Concepto - $@gf.CostoMensual.ToString("N2")/mes</option>
                                                }
                                            }
                                        </select>
                                        <button class="btn btn-success btn-sm" @onclick="AgregarGastoFijo">
                                            <i class="bi bi-plus-lg me-1"></i>Agregar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* PRECIOS POR VARIANTE *@
                        <div class="cot-section">
                            <div class="cot-section__header" style="--accent:#3b4fa8">
                                <span><i class="bi bi-tags me-1"></i>Precios por variante</span>
                                <button type="button" class="btn btn-sm btn-outline-light" @onclick="RegenerarPreciosVariantesAsync" disabled="@(cotizacionEditando.ClienteId == null || cotizacionEditando.ProductoId == Guid.Empty)">
                                    <i class="bi bi-arrow-repeat me-1"></i>Recalcular
                                </button>
                            </div>
                            <div class="cot-section__body">
                                @if (!preciosVariantesEditando.Any())
                                {
                                    <p class="text-muted small mb-0">No hay precios por variante generados todavía. Usa el botón <em>Recalcular</em>.</p>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0 cot-table">
                                            <thead>
                                                <tr>
                                                    <th>Variante / SKU</th>
                                                    <th style="width:14%" class="text-end">% variación</th>
                                                    <th style="width:14%" class="text-end">Contado</th>
                                                    <th style="width:14%" class="text-end">Crédito</th>
                                                    <th style="width:8%" class="text-center">OK</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var precio in preciosVariantesEditando.OrderBy(p => p.Orden).ThenBy(p => p.Etiqueta))
                                                {
                                                    <tr class="@(precio.Aceptada ? "table-success" : "")">
                                                        <td>
                                                            <div class="fw-semibold small">@precio.Etiqueta</div>
                                                            @if (!string.IsNullOrWhiteSpace(precio.Sku))
                                                            {
                                                                <div class="text-muted" style="font-size:.7rem">@precio.Sku</div>
                                                            }
                                                        </td>
                                                        <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PorcentajeVariacionAplicado" @bind-Value:after="() => OnPorcentajeVarianteChanged(precio)" /></td>
                                                        <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PrecioContado" @bind-Value:after="() => OnPrecioVarianteChanged(precio)" /></td>
                                                        <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="precio.PrecioCredito" @bind-Value:after="() => OnPrecioVarianteChanged(precio)" /></td>
                                                        <td class="text-center"><InputCheckbox class="form-check-input" @bind-Value="precio.Aceptada" /></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>

                </div>

                <div class="cot-section cot-section--summary-final mt-3">
                    <div class="cot-section__header" style="--accent:#166534">
                        <span><i class="bi bi-bar-chart-fill me-1"></i>Resumen final</span>
                        <button class="btn btn-sm btn-outline-light" @onclick="GuardarCotizacion">
                            <i class="bi bi-floppy me-1"></i>Guardar cotización
                        </button>
                    </div>
                    <div class="cot-section__body">
                        <div class="cot-summary-grid">
                            <div class="cot-summary-card">
                                <div class="cot-summary-card__label">Materiales</div>
                                <div class="cot-summary-card__value">$@ObtenerTotalMateriales().ToString("N2")</div>
                            </div>
                            <div class="cot-summary-card">
                                <div class="cot-summary-card__label">Mano de obra</div>
                                <div class="cot-summary-card__value">$@cotizacionEditando.TotalManoObra.ToString("N2")</div>
                            </div>
                            <div class="cot-summary-card">
                                <div class="cot-summary-card__label">Gastos fijos</div>
                                <div class="cot-summary-card__value">$@cotizacionEditando.TotalGastosFijos.ToString("N2")</div>
                            </div>
                            <div class="cot-summary-card cot-summary-card--total">
                                <div class="cot-summary-card__label">Costo total</div>
                                <div class="cot-summary-card__value">$@cotizacionEditando.CostoTotal.ToString("N2")</div>
                            </div>
                        </div>

                        <div class="cot-summary-ledger">
                            <div class="cot-summary-ledger__row">
                                <span>Costo por par</span>
                                <strong>$@ObtenerCostoUnitarioBase().ToString("N2")</strong>
                            </div>
                            <div class="cot-summary-ledger__row">
                                <span>Precio sugerido</span>
                                <strong>$@ObtenerPrecioSugerido().ToString("N2")</strong>
                            </div>
                            <div class="cot-summary-ledger__row">
                                <span>Utilidad (@cotizacionEditando.Utilidad.ToString("N1")%)</span>
                                <strong class="text-success">$@ObtenerUtilidadMonto().ToString("N2")</strong>
                            </div>
                            <div class="cot-summary-ledger__row">
                                <span>Costo por tarea</span>
                                <strong>$@ObtenerCostoTarea().ToString("N2")</strong>
                            </div>
                        </div>

                        <div class="cot-summary-prices">
                            <div class="cot-summary-price cot-summary-price--contado">
                                <span>Precio contado</span>
                                <strong>$@ObtenerPrecioContado().ToString("N2")</strong>
                            </div>
                            <div class="cot-summary-price cot-summary-price--credito">
                                <span>Precio crédito</span>
                                <strong>$@ObtenerPrecioCredito().ToString("N2")</strong>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>@* /editor *@
    }

    @* Lista de cotizaciones *@
    <div class="cot-list-card">
        <div class="cot-list-card__header">
            <span><i class="bi bi-table me-1"></i>Cotizaciones registradas</span>
            @if (cotizaciones != null)
            {
                <span class="cot-badge-count">@cotizaciones.Count()</span>
            }
        </div>
        <div class="cot-list-card__body">
            @if (cotizaciones == null)
            {
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div><div class="small text-muted mt-2">Cargando...</div></div>
            }
            else if (!cotizaciones.Any())
            {
                <div class="alert alert-info mb-0">No hay cotizaciones registradas. Crea la primera con el botón <strong>Nueva cotización</strong>.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle cot-table mb-0">
                        <thead>
                            <tr>
                                <th style="width:7%">Acciones</th>
                                <th>Cliente</th>
                                <th>Producto</th>
                                <th>Descripción</th>
                                <th class="text-end">Materiales</th>
                                <th class="text-end">M. Obra</th>
                                <th class="text-end">G. Fijos</th>
                                <th class="text-end">Costo Total</th>
                                <th class="text-end">P. Contado</th>
                                <th class="text-end">Utilidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in cotizaciones)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-xs btn-primary" @onclick="() => EditarCotizacion(c)" title="Editar"><i class="bi bi-pencil"></i></button>
                                            <button class="btn btn-xs btn-outline-secondary" @onclick="() => DuplicarCotizacion(c)" title="Duplicar"><i class="bi bi-files"></i></button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => EliminarCotizacion(c)" title="Eliminar"><i class="bi bi-trash3"></i></button>
                                        </div>
                                    </td>
                                    <td class="fw-semibold small">@c.Cliente?.RazonSocial</td>
                                    <td class="small">@c.Producto?.Nombre</td>
                                    <td class="small text-muted">@c.Descripcion</td>
                                    <td class="text-end small">$@((c.TotalTintas + c.TotalInsumosBasicos + c.TotalInsumosDiversos).ToString("N2"))</td>
                                    <td class="text-end small">$@c.TotalManoObra.ToString("N2")</td>
                                    <td class="text-end small">$@c.TotalGastosFijos.ToString("N2")</td>
                                    <td class="text-end"><span class="badge bg-success">$@c.CostoTotal.ToString("N2")</span></td>
                                    <td class="text-end fw-semibold small">$@c.PrecioFinalContado.ToString("N2")</td>
                                    <td class="text-end small text-success fw-semibold">$@c.Ganancia.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>

<style>
