    private async Task CargarConfiguracionClienteAsync(Guid clienteId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var productosAsignados = await db.ProductosClientes
            .AsNoTracking()
            .Include(pc => pc.Producto)
            .Where(pc => pc.ClienteId == clienteId
                && pc.IsActive
                && pc.Producto.IsActive
                && (_empresaId == Guid.Empty || (pc.Cliente.EmpresaId == _empresaId && pc.Producto.EmpresaId == _empresaId)))
            .OrderBy(pc => pc.Producto.Nombre)
            .Select(pc => new ProductoClienteOption
            {
                ProductoId = pc.ProductoId,
                Nombre = pc.Producto.Nombre,
                PrecioBase = pc.Producto.PrecioBase,
                TallaBaseCalzado = pc.TallaBaseCalzado,
                TieneVariantes = pc.Producto.TieneVariantes,
                UsaVariantesTalla = pc.Producto.UsaVariantesTalla,
                UsaVariantesColor = pc.Producto.UsaVariantesColor,
                AplicaFraccionCalzado = pc.AplicaFraccionCalzado,
                ClienteFraccionCalzadoId = pc.ClienteFraccionCalzadoId
            })
            .ToListAsync();

        cotizacionesDisponiblesCliente = await db.CotizacionesSerigrafia
            .AsNoTracking()
            .Where(c => c.ClienteId == clienteId
                && c.IsActive
                && c.Producto.IsActive
                && (_empresaId == Guid.Empty || (c.Cliente.EmpresaId == _empresaId && c.Producto.EmpresaId == _empresaId)))
            .OrderByDescending(c => c.CreatedAt)
            .Select(c => new CotizacionClienteOption
            {
                Id = c.Id,
                ProductoId = c.ProductoId,
                ProductoNombre = c.Producto.Nombre,
                Descripcion = c.Descripcion,
                PrecioContado = c.PrecioFinalContado,
                PrecioCredito = c.PrecioCredito,
                CreatedAt = c.CreatedAt
            })
            .ToListAsync();

        var ultimaCotizacionPorProducto = cotizacionesDisponiblesCliente
            .GroupBy(c => c.ProductoId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(c => c.CreatedAt).First());

        foreach (var producto in productosAsignados)
        {
            if (ultimaCotizacionPorProducto.TryGetValue(producto.ProductoId, out var cotizacion))
            {
                producto.CotizacionSerigrafiaId = cotizacion.Id;
                producto.PrecioCotizacionContado = cotizacion.PrecioContado;
                producto.PrecioCotizacionCredito = cotizacion.PrecioCredito;
            }
        }

        productosDisponibles = productosAsignados
            .OrderBy(p => p.Nombre)
            .ToList();

        var catalogoTallasEmpresa = await db.CatalogoTallasCalzado
            .AsNoTracking()
            .Where(t => t.IsActive && t.Activa && (_empresaId == Guid.Empty || t.EmpresaId == _empresaId))
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new TallaClienteDisponible
            {
                CatalogoTallaCalzadoId = t.Id,
                Talla = t.Talla,
                Orden = t.Orden,
                EsTallaBaseDefault = false
            })
            .ToListAsync();

        var tallasOverrideCliente = await db.ClientesTallasCalzado
            .AsNoTracking()
            .Where(t => t.ClienteId == clienteId
                && t.IsActive
                && t.Activa
                && (_empresaId == Guid.Empty || t.EmpresaId == _empresaId))
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new TallaClienteDisponible
            {
                CatalogoTallaCalzadoId = t.CatalogoTallaCalzadoId,
                Talla = t.Talla,
                Orden = t.Orden,
                EsTallaBaseDefault = t.EsTallaBaseDefault
            })
            .ToListAsync();

        tallasDisponiblesCliente = tallasOverrideCliente.Any()
            ? tallasOverrideCliente
            : catalogoTallasEmpresa;

        var tallasPermitidas = tallasDisponiblesCliente
            .Select(t => t.Talla.Trim())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var productoIds = productosDisponibles.Select(p => p.ProductoId).ToList();
        variantesDisponiblesPorProducto = productoIds.Count == 0
            ? []
            : await db.ProductosVariantes
                .AsNoTracking()
                .Where(v => productoIds.Contains(v.ProductoId)
                    && v.IsActive
                    && v.Activa
                    && (_empresaId == Guid.Empty || v.Producto.EmpresaId == _empresaId))
                .Where(v => !v.Producto.UsaVariantesTalla || !string.IsNullOrWhiteSpace(v.Talla) && tallasPermitidas.Contains(v.Talla))
                .OrderBy(v => v.ProductoId)
                .ThenBy(v => v.Color)
                .ThenBy(v => v.Talla)
                .Select(v => new ProductoVarianteOption
                {
                    Id = v.Id,
                    ProductoId = v.ProductoId,
                    Sku = v.Sku,
                    Talla = v.Talla,
                    Color = v.Color,
                    Precio = v.PrecioOverride
                })
                .GroupBy(v => v.ProductoId)
                .ToDictionaryAsync(g => g.Key, g => g.ToList());

        fraccionesDisponiblesCliente = await db.ClientesFraccionesCalzado
            .AsNoTracking()
            .Include(f => f.Detalles)
            .Where(f => f.ClienteId == clienteId
                && f.IsActive
                && f.Activa
                && (_empresaId == Guid.Empty || f.EmpresaId == _empresaId))
            .OrderBy(f => f.Nombre)
            .ToListAsync();

        detallePedidoError = productosDisponibles.Any()
            ? null
            : cotizacionesDisponiblesCliente.Any()
                ? "Este cliente sí tiene cotizaciones activas, pero no tiene productos asignados. Así debe quedar hasta asignarlos en Productos por Cliente."
                : "Este cliente no tiene productos asignados o sus asignaciones no pertenecen a la empresa activa.";
    }

