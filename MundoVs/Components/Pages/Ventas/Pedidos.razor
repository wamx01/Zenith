@page "/pedidos"
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities.Calzado
@using MundoVs.Core.Entities
@using MundoVs.Core.Entities.Inventario
@using MundoVs.Core.Entities.Serigrafia
@using MundoVs.Core.Interfaces
@using MundoVs.Infrastructure.Data
@using Microsoft.AspNetCore.Components.Authorization
@inject IPedidoRepository PedidoRepository
@inject IClienteRepository ClienteRepository
@inject IProductoRepository ProductoRepository
@inject IRepository<PedidoDetalle> PedidoDetalleRepository
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Pedidos</PageTitle>

<div class="ps-page">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <div>
            <h1 class="ps-title mb-1"><i class="bi bi-cart-check me-2"></i>Pedidos</h1>
            <p class="text-muted mb-0" style="font-size:.82rem">Ubica el pedido rápido y entra directo a procesarlo.</p>
        </div>
        <button class="btn ps-btn-primary" @onclick="NuevoPedido">
            <i class="bi bi-plus-circle me-1"></i> Nuevo Pedido
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="ps-kpi-card">
                <div class="ps-kpi-label">Visibles</div>
                <div class="ps-kpi-value">@PedidosFiltrados.Count()</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ps-kpi-card ps-kpi-card--success">
                <div class="ps-kpi-label">Activos</div>
                <div class="ps-kpi-value">@(pedidos?.Count(p => p.IsActive) ?? 0)</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ps-kpi-card ps-kpi-card--muted">
                <div class="ps-kpi-label">Inactivos</div>
                <div class="ps-kpi-value">@(pedidos?.Count(p => !p.IsActive) ?? 0)</div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ps-kpi-card ps-kpi-card--info">
                <div class="ps-kpi-label">Pendientes</div>
                <div class="ps-kpi-value">@(pedidos?.Count(p => p.Estado is EstadoPedidoEnum.Nuevo or EstadoPedidoEnum.EnProceso or EstadoPedidoEnum.Producido) ?? 0)</div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="ps-card mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Estado</label>
                <select class="form-select ps-input" @bind="filtroEstadoPedido">
                    <option value="">Todos los estados</option>
                    @foreach (var estado in Enum.GetValues<EstadoPedidoEnum>())
                    {
                        <option value="@estado.ToString()">@estado</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Desde</label>
                <input type="date" class="form-control ps-input" @bind="fechaDesde" />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Hasta</label>
                <input type="date" class="form-control ps-input" @bind="fechaHasta" />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="ps-label">Registro</label>
                <select class="form-select ps-input" @bind="filtroActivoPedido">
                    <option value="activos">Activos</option>
                    <option value="inactivos">Inactivos</option>
                    <option value="todos">Todos</option>
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-4">
                <label class="ps-label">Buscar</label>
                <input type="text"
                       class="form-control ps-input"
                       @bind="busquedaTexto"
                       @bind:event="oninput"
                       placeholder="Pedido, cliente, observaciones..." />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <div class="d-grid gap-2">
                    <button class="btn ps-btn-secondary" @onclick="AplicarFiltrosPedidos">
                        <i class="bi bi-search me-1"></i> Buscar
                    </button>
                    <button class="btn ps-btn-ghost" @onclick="CargarPedidos">
                        <i class="bi bi-arrow-clockwise me-1"></i> Recargar
                    </button>
                    <button class="btn ps-btn-ghost" @onclick="LimpiarFiltrosPedidos">
                        <i class="bi bi-eraser me-1"></i> Limpiar
                    </button>
                </div>
            </div>
        </div>
        <div class="ps-filter-meta">
            <span class="ps-filter-pill">@PedidosFiltrados.Count() de @(pedidos?.Count() ?? 0) pedidos</span>
            <span class="ps-filter-hint">La acción principal es <strong>Procesar</strong> para abrir el seguimiento del pedido.</span>
        </div>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-0 shadow">
            <div class="card-header bg-dark text-white">
                <strong>@(pedidoEditando.Id == Guid.Empty ? "Nuevo Pedido" : "Editar Pedido")</strong>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Número de Pedido</label>
                        <input type="text" class="form-control" @bind="pedidoEditando.NumeroPedido" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <select class="form-select" value="@ObtenerClienteSeleccionadoValue()" @onchange="OnClienteChanged">
                            <option value="">Seleccione...</option>
                            @if (clientes != null)
                            {
                                @foreach (var c in clientes)
                                {
                                    <option value="@c.Id">@c.RazonSocial</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fecha Pedido</label>
                        <input type="date" class="form-control" @bind="pedidoEditando.FechaPedido" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fecha Entrega Estimada</label>
                        <input type="date" class="form-control" @bind="pedidoEditando.FechaEntregaEstimada" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Estado</label>
                        <select class="form-select" @bind="pedidoEditando.Estado">
                            @foreach (var estado in Enum.GetValues<EstadoPedidoEnum>())
                            {
                                <option value="@estado">@estado</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Subtotal</label>
                        <input type="number" step="0.01" class="form-control" @bind="pedidoEditando.Subtotal" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Impuestos</label>
                        <input type="number" step="0.01" class="form-control" @bind="pedidoEditando.Impuestos" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Total</label>
                        <input type="number" step="0.01" class="form-control" @bind="pedidoEditando.Total" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Observaciones</label>
                    <textarea class="form-control" rows="2" @bind="pedidoEditando.Observaciones"></textarea>
                </div>

                <div class="card border-0 bg-light mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                            <h6 class="mb-0">Detalle del pedido</h6>
                            <button class="btn btn-sm btn-outline-primary" type="button" @onclick="AgregarDetalle" disabled="@(pedidoEditando.ClienteId == Guid.Empty)">
                                <i class="bi bi-plus-circle me-1"></i>Agregar renglón
                            </button>
                        </div>

                        @if (pedidoEditando.ClienteId == Guid.Empty)
                        {
                            <div class="alert alert-info py-2 mb-0">Selecciona primero un cliente para cargar sus productos, tallas y fracciones configuradas.</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(detallePedidoError))
                        {
                            <div class="alert alert-warning py-2 mb-0">@detallePedidoError</div>
                        }
                        else if (!productosDisponibles.Any())
                        {
                            <div class="alert alert-warning py-2 mb-0">Este cliente no tiene productos asignados. La lista debe permanecer vacía hasta configurarlos.</div>
                        }
                        else if (!detallesPedido.Any())
                        {
                            <div class="alert alert-secondary py-2 mb-0">Agrega al menos un renglón de producto para el pedido.</div>
                        }
                        else
                        {
                            <div class="alert alert-info py-2 mb-3 ps-detail-guide">
                                <i class="bi bi-info-circle me-1"></i>Define primero <strong>producto</strong>, <strong>variación</strong>, <strong>talla base</strong> y <strong>fracción</strong>. Después ajusta la corrida por talla y al final captura precio y descuento.
                            </div>

                            <div class="ps-detail-stack">
                                @foreach (var detalle in detallesPedido)
                                {
                                    var indiceDetalle = detallesPedido.IndexOf(detalle) + 1;
                                    var cantidadDistribuida = ObtenerCantidadTallas(detalle);
                                    <div class="ps-detail-card">
                                        <div class="ps-detail-head">
                                            <div>
                                                <div class="ps-detail-title">Renglón @indiceDetalle</div>
                                                <div class="ps-detail-sub">Configura SKU, corrida y datos comerciales del producto.</div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <span class="ps-detail-pill @(cantidadDistribuida == detalle.Cantidad ? "is-ok" : string.Empty)">@cantidadDistribuida / @detalle.Cantidad pzas</span>
                                                <span class="ps-detail-total">@ObtenerTotalDetalle(detalle).ToString("C2")</span>
                                                <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => EliminarDetalle(detalle.LocalKey)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <div class="row g-3 mb-3">
                                            <div class="col-xl-4 col-lg-6">
                                                <label class="ps-label">Cotización</label>
                                                <select class="form-select form-select-sm" value="@ObtenerCotizacionSeleccionadaValue(detalle)" @onchange="e => OnCotizacionChanged(detalle, e)">
                                                    <option value="">Sin cotización</option>
                                                    @foreach (var cotizacion in cotizacionesDisponiblesCliente)
                                                    {
                                                        <option value="@cotizacion.Id">@cotizacion.Etiqueta</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-xl-4 col-lg-6">
                                                <label class="ps-label">Producto</label>
                                                <select class="form-select form-select-sm" value="@ObtenerProductoSeleccionadoValue(detalle)" @onchange="e => OnProductoDetalleChanged(detalle, e)">
                                                    <option value="">Seleccione...</option>
                                                    @foreach (var producto in productosDisponibles)
                                                    {
                                                        <option value="@producto.ProductoId">@producto.Nombre</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-xl-3 col-lg-6">
                                                <label class="ps-label">Variación</label>
                                                @if (detalle.UsaVariantesColor)
                                                {
                                                    <select class="form-select form-select-sm" value="@ObtenerVariacionSeleccionadaValue(detalle)" @onchange="e => OnVariacionChanged(detalle, e)">
                                                        <option value="">Seleccione...</option>
                                                        @foreach (var variacion in ObtenerVariacionesDisponibles(detalle.ProductoId))
                                                        {
                                                            <option value="@variacion">@variacion</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    <div class="ps-detail-static">Sin variación por color</div>
                                                }
                                            </div>
                                            <div class="col-xl-2 col-lg-4 col-md-6">
                                                <label class="ps-label">Talla base</label>
                                                <select class="form-select form-select-sm" value="@ObtenerTallaBaseValue(detalle)" @onchange="e => OnTallaBaseChanged(detalle, e)">
                                                    <option value="">Sin talla base</option>
                                                    @foreach (var talla in tallasDisponiblesCliente)
                                                    {
                                                        <option value="@talla.Talla">@talla.Talla</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-xl-1 col-lg-2 col-md-3">
                                                <label class="ps-label">Fracción</label>
                                                <div class="ps-detail-switch-wrap">
                                                    <InputCheckbox class="form-check-input" @bind-Value="detalle.AplicaFraccionCalzado" @bind-Value:after="(() => OnAplicaFraccionChanged(detalle))" />
                                                </div>
                                            </div>
                                            <div class="col-xl-2 col-lg-4 col-md-9">
                                                <label class="ps-label">Tipo fracción</label>
                                                <select class="form-select form-select-sm" value="@ObtenerFraccionSeleccionadaValue(detalle)" @onchange="e => OnFraccionChanged(detalle, e)" disabled="@(!detalle.AplicaFraccionCalzado)">
                                                    <option value="">Sin fracción</option>
                                                    @foreach (var fraccion in fraccionesDisponiblesCliente)
                                                    {
                                                        <option value="@fraccion.Id">@fraccion.Codigo - @fraccion.Nombre</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>

                                        <div class="ps-detail-distribution mb-3">
                                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                                                <div>
                                                    <div class="ps-detail-block-title">Corrida por talla</div>
                                                    <div class="ps-detail-block-sub">Tallas disponibles: @tallasDisponiblesCliente.Count · Distribución actual: <strong>@cantidadDistribuida / @detalle.Cantidad</strong></div>
                                                </div>
                                                <div class="d-flex gap-2">
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AgregarTallaDetalle(detalle)">
                                                        <i class="bi bi-plus-circle me-1"></i>Agregar talla
                                                    </button>
                                                    @if (detalle.AplicaFraccionCalzado && detalle.ClienteFraccionCalzadoId.HasValue)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => GenerarDistribucionDesdeFraccion(detalle)">
                                                            <i class="bi bi-magic me-1"></i>Regenerar corrida
                                                        </button>
                                                    }
                                                </div>
                                            </div>

                                            @if (!detalle.DetallesTalla.Any())
                                            {
                                                <div class="small text-muted">Sin corrida capturada. Puedes generarla desde la fracción o ajustar la distribución por talla.</div>
                                            }
                                            else
                                            {
                                                <div class="table-responsive">
                                                    <table class="table table-sm mb-0 align-middle ps-detail-table">
                                                        <thead>
                                                            <tr>
                                                                <th style="width:160px">Talla</th>
                                                                <th style="width:90px">Orden</th>
                                                                <th style="width:120px">Cantidad</th>
                                                                <th style="width:120px">% Var.</th>
                                                                <th style="width:120px">Origen</th>
                                                                <th style="width:50px"></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var tallaDetalle in detalle.DetallesTalla.OrderBy(t => t.Orden).ThenBy(t => t.Talla))
                                                            {
                                                                <tr>
                                                                    <td>
                                                                        <select class="form-select form-select-sm" value="@tallaDetalle.Talla" @onchange="e => OnDetalleTallaChanged(detalle, tallaDetalle, e)">
                                                                            <option value="">Seleccione...</option>
                                                                            @foreach (var talla in tallasDisponiblesCliente)
                                                                            {
                                                                                <option value="@talla.Talla">@talla.Talla</option>
                                                                            }
                                                                        </select>
                                                                    </td>
                                                                    <td><InputNumber class="form-control form-control-sm" @bind-Value="tallaDetalle.Orden" /></td>
                                                                    <td><InputNumber class="form-control form-control-sm" @bind-Value="tallaDetalle.Cantidad" @bind-Value:after="RecalcularTotales" /></td>
                                                                    <td><InputNumber class="form-control form-control-sm" @bind-Value="tallaDetalle.PorcentajeVariacion" /></td>
                                                                    <td>
                                                                        <span class="badge @(tallaDetalle.GeneradaDesdeFraccion ? "bg-primary" : "bg-secondary")">
                                                                            @(tallaDetalle.GeneradaDesdeFraccion ? "Fracción" : "Manual")
                                                                        </span>
                                                                    </td>
                                                                    <td class="text-end">
                                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarTallaDetalle(detalle, tallaDetalle.LocalKey)">
                                                                            <i class="bi bi-trash"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-xl-2 col-lg-4 col-md-6">
                                                <label class="ps-label">Cantidad</label>
                                                <InputNumber class="form-control form-control-sm" @bind-Value="detalle.Cantidad" @bind-Value:after="(() => OnCantidadChanged(detalle))" />
                                            </div>
                                            <div class="col-xl-2 col-lg-4 col-md-6">
                                                <label class="ps-label">Precio</label>
                                                <InputNumber class="form-control form-control-sm" @bind-Value="detalle.PrecioUnitario" @bind-Value:after="RecalcularTotales" />
                                            </div>
                                            <div class="col-xl-2 col-lg-4 col-md-6">
                                                <label class="ps-label">Descuento</label>
                                                <InputNumber class="form-control form-control-sm" @bind-Value="detalle.Descuento" @bind-Value:after="RecalcularTotales" />
                                            </div>
                                            <div class="col-xl-2 col-lg-4 col-md-6">
                                                <label class="ps-label">Total</label>
                                                <div class="ps-detail-static fw-semibold">@ObtenerTotalDetalle(detalle).ToString("C2")</div>
                                            </div>
                                            <div class="col-xl-4 col-lg-8 col-md-12">
                                                <label class="ps-label">Especificaciones</label>
                                                <InputText class="form-control form-control-sm" @bind-Value="detalle.Especificaciones" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="card border-0 bg-light mb-3">
                    <div class="card-body py-3">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                            <div>
                                <h6 class="mb-1">Consumos e inventario</h6>
                                <div class="text-muted small">Aquí puedes revisar cuánto se va a usar y cuánto hay en inventario antes de confirmar el pedido.</div>
                            </div>
                            @if (inventarioComprobadoEn.HasValue)
                            {
                                <span class="badge text-bg-light border">Comprobado @inventarioComprobadoEn.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            }
                        </div>

                        @if (revisandoComprobacionInventario)
                        {
                            <div class="d-flex align-items-center gap-2 text-muted small">
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                <span>Comprobando consumos e inventario...</span>
                            </div>
                        }
                        else
                        {
                            @if (HayFaltantesInventario)
                            {
                                <div class="alert alert-warning py-2 mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Hay materiales que no alcanzan en inventario. Puedes continuar con <strong>Confirmar y guardar</strong> si así lo decides.
                                </div>
                            }
                            else if (comprobacionInventarioItems.Any())
                            {
                                <div class="alert alert-success py-2 mb-3">
                                    <i class="bi bi-check-circle me-1"></i>La comprobación terminó. Revisa abajo cuánto se usará y cuánto hay disponible de cada item.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info py-2 mb-3">
                                    <i class="bi bi-info-circle me-1"></i>Presiona <strong>Comprobar consumos e inventario</strong> para revisar existencias antes de guardar.
                                </div>
                            }

                            @if (avisosComprobacionInventario.Any())
                            {
                                <div class="alert alert-secondary py-2 mb-3">
                                    <ul class="mb-0 ps-3">
                                        @foreach (var aviso in avisosComprobacionInventario)
                                        {
                                            <li>@aviso</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (comprobacionInventarioItems.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0 ps-inventory-table">
                                        <thead>
                                            <tr>
                                                <th>Tipo</th>
                                                <th>Concepto</th>
                                                <th class="text-end">Voy a usar</th>
                                                <th class="text-end">En inventario</th>
                                                <th class="text-end">Faltante</th>
                                                <th>Estado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in comprobacionInventarioItems)
                                            {
                                                <tr>
                                                    <td>@item.Tipo</td>
                                                    <td>
                                                        <div class="fw-semibold">@item.Nombre</div>
                                                        <div class="small text-muted">@item.ReferenciasTexto</div>
                                                    </td>
                                                    <td class="text-end">@item.CantidadRequerida.ToString("N4") @item.UnidadMedida</td>
                                                    <td class="text-end">@(item.ExistenciaInventario.HasValue ? $"{item.ExistenciaInventario.Value:N4} {item.UnidadMedida}" : "N/D")</td>
                                                    <td class="text-end">@(item.ExistenciaInventario.HasValue ? $"{item.Faltante:N4} {item.UnidadMedida}" : "N/D")</td>
                                                    <td>
                                                        <span class="ps-inventory-status @item.EstadoClase">@item.EstadoTexto</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn ps-btn-secondary" @onclick="ComprobarConsumosInventario" disabled="@revisandoComprobacionInventario">
                        <i class="bi bi-clipboard2-data"></i> Comprobar consumos e inventario
                    </button>
                    <button class="btn btn-success" @onclick="GuardarPedido" disabled="@(!inventarioComprobado || revisandoComprobacionInventario)">
                        <i class="bi bi-save"></i> Confirmar y guardar
                    </button>
                    <button class="btn btn-secondary" @onclick="Cancelar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
                @if (!inventarioComprobado)
                {
                    <div class="small text-muted mt-2">Primero ejecuta <strong>Comprobar consumos e inventario</strong> y luego confirma el guardado.</div>
                }
            </div>
        </div>
    }

    <!-- Lista -->
    <div class="ps-card ps-list-card">
        <div class="ps-list-head">
            <div>
                <div class="ps-list-title">Listado de pedidos</div>
                <div class="ps-list-sub">Vista compacta para localizar y entrar al pedido más rápido.</div>
            </div>
            <span class="ps-list-pill">@PedidosFiltrados.Count() visibles</span>
        </div>

        <div class="ps-list-body">
            @if (pedidos == null)
            {
                <div class="d-flex justify-content-center py-4"><div class="spinner-border text-primary"></div></div>
            }
            else if (!pedidos.Any())
            {
                <div class="ps-empty-state">No hay pedidos registrados.</div>
            }
            else if (!PedidosFiltrados.Any())
            {
                <div class="ps-empty-state">No hay pedidos que coincidan con los filtros o la búsqueda actual.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="ps-table">
                        <thead>
                            <tr>
                                <th>Acciones</th>
                                <th># Pedido</th>
                                <th>Cliente</th>
                                <th>Fecha</th>
                                <th>Entrega Est.</th>
                                <th>Estado</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in PedidosFiltrados)
                            {
                                var finalizado = p.Estado is EstadoPedidoEnum.Entregado or EstadoPedidoEnum.Facturado or EstadoPedidoEnum.Pagado;
                                var atrasado = p.FechaEntregaEstimada.HasValue && p.FechaEntregaEstimada.Value.Date < DateTime.Today && !finalizado;
                                <tr class="@($"{(atrasado ? "ps-row-late" : string.Empty)} {(!p.IsActive ? "ps-row-inactive" : string.Empty)}")">
                                    <td class="ps-td-actions">
                                        <div class="ps-row-actions">
                                            <a class="ps-btn-procesar" href="/pedidos/@p.Id/seguimiento" title="Abrir seguimiento del pedido">
                                                <i class="bi bi-play-circle-fill"></i>
                                                <span>Procesar</span>
                                            </a>
                                            <div class="ps-row-icons">
                                                <button class="btn ps-action-btn ps-action-edit" title="Editar" @onclick="() => EditarPedido(p)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn ps-action-btn ps-action-delete" title="Eliminar" @onclick="() => EliminarPedido(p)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="ps-order-cell">
                                            <strong>@p.NumeroPedido</strong>
                                            <span class="ps-order-sub">Alta: @p.FechaPedido.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>
                                    <td>@p.Cliente?.RazonSocial</td>
                                    <td>@p.FechaPedido.ToString("dd/MM/yy")</td>
                                    <td class="@(atrasado ? "text-danger fw-semibold" : string.Empty)">@(p.FechaEntregaEstimada?.ToString("dd/MM/yy") ?? "—")</td>
                                    <td>
                                        <div class="d-flex flex-column gap-1 align-items-start">
                                            <span class="ps-status-badge @ObtenerClaseEstadoPedido(p.Estado)">@p.Estado</span>
                                            <span class="badge @(p.IsActive ? "bg-success-subtle text-success-emphasis border border-success-subtle" : "bg-secondary")">@(p.IsActive ? "Activo" : "Inactivo")</span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold">@p.Total.ToString("C2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

