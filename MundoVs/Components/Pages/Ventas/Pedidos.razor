    private void AplicarProductoSeleccionado(PedidoDetalleEditor detalle, ProductoClienteOption? producto, bool conservarCotizacion = true, CotizacionClienteOption? cotizacion = null)
    {
        if (producto == null)
        {
            detalle.CotizacionSerigrafiaId = conservarCotizacion ? detalle.CotizacionSerigrafiaId : null;
            detalle.TieneVariantes = false;
            detalle.UsaVariantesTalla = false;
            detalle.UsaVariantesColor = false;
            detalle.VariacionValor = null;
            detalle.ProductoVarianteId = null;
            detalle.AplicaFraccionCalzado = false;
            detalle.ClienteFraccionCalzadoId = null;
            detalle.DetallesTalla.Clear();
            return;
        }

        cotizacion ??= detalle.CotizacionSerigrafiaId.HasValue
            ? cotizacionesDisponiblesCliente.FirstOrDefault(c => c.Id == detalle.CotizacionSerigrafiaId.Value)
            : null;

        detalle.CotizacionSerigrafiaId = conservarCotizacion
            ? cotizacion?.Id ?? producto.CotizacionSerigrafiaId
            : null;
        detalle.TieneVariantes = producto.TieneVariantes;
        detalle.UsaVariantesTalla = producto.UsaVariantesTalla;
        detalle.UsaVariantesColor = producto.UsaVariantesColor;
        detalle.PrecioUnitario = ObtenerPrecioProducto(producto, cotizacion);
        detalle.TallaBaseCalzado = producto.TallaBaseCalzado
            ?? tallasDisponiblesCliente.FirstOrDefault(t => t.EsTallaBaseDefault)?.Talla
            ?? tallasDisponiblesCliente.FirstOrDefault()?.Talla;
        detalle.VariacionValor = detalle.UsaVariantesColor
            ? ObtenerVariacionesDisponibles(detalle.ProductoId).FirstOrDefault()
            : null;
        detalle.AplicaFraccionCalzado = producto.AplicaFraccionCalzado;
        detalle.ClienteFraccionCalzadoId = producto.AplicaFraccionCalzado ? producto.ClienteFraccionCalzadoId : null;
        AplicarDistribucionInicial(detalle);
    }

    private decimal ObtenerPrecioProducto(ProductoClienteOption producto, CotizacionClienteOption? cotizacion = null)
    {
        if (pedidoEditando.TipoPrecio == TipoPrecioEnum.Credito)
        {
            if (cotizacion != null)
            {
                return cotizacion.PrecioCredito;
            }

            if (producto.PrecioCotizacionCredito.HasValue)
            {
                return producto.PrecioCotizacionCredito.Value;
            }
        }

        if (cotizacion != null)
        {
            return cotizacion.PrecioContado;
        }

        return producto.PrecioCotizacionContado ?? producto.PrecioBase;
    }

