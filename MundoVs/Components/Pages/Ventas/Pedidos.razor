    private void AplicarDistribucionInicial(PedidoDetalleEditor detalle)
    {
        if (detalle.AplicaFraccionCalzado && detalle.ClienteFraccionCalzadoId.HasValue)
        {
            GenerarDistribucionDesdeFraccion(detalle);
            return;
        }

        if (!detalle.DetallesTalla.Any() && !string.IsNullOrWhiteSpace(detalle.TallaBaseCalzado))
        {
            detalle.DetallesTalla.Add(CrearTallaManual(detalle.TallaBaseCalzado!, 1, detalle.Cantidad));
        }

        ActualizarVarianteDetalle(detalle);
        AsignarVariantesDetalle(detalle);
    }

    private void GenerarDistribucionDesdeFraccion(PedidoDetalleEditor detalle)
    {
        var fraccion = fraccionesDisponiblesCliente.FirstOrDefault(f => f.Id == detalle.ClienteFraccionCalzadoId);
        if (fraccion == null || !fraccion.Detalles.Any() || detalle.Cantidad <= 0)
        {
            return;
        }

        var plantilla = fraccion.Detalles
            .Where(d => d.Unidades > 0)
            .OrderBy(d => d.Orden)
            .ThenBy(d => d.Talla)
            .ToList();

        if (!plantilla.Any())
        {
            return;
        }

        var totalPeso = plantilla.Sum(d => d.Unidades);
        if (totalPeso <= 0)
        {
            return;
        }

        var calculados = plantilla
            .Select(d => new
            {
                d.Talla,
                d.Orden,
                d.PorcentajeVariacion,
                Exacto = (decimal)detalle.Cantidad * d.Unidades / totalPeso
            })
            .Select(d => new
            {
                d.Talla,
                d.Orden,
                d.PorcentajeVariacion,
                Base = (int)Math.Floor(d.Exacto),
                Resto = d.Exacto - Math.Floor(d.Exacto)
            })
            .ToList();

        var asignadas = calculados.Sum(x => x.Base);
        var faltantes = Math.Max(0, detalle.Cantidad - asignadas);
        var conResto = calculados
            .OrderByDescending(x => x.Resto)
            .ThenBy(x => x.Orden)
            .ToList();

        var extras = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        for (var i = 0; i < faltantes; i++)
        {
            var item = conResto[i % conResto.Count];
            extras[item.Talla] = extras.GetValueOrDefault(item.Talla) + 1;
        }

        detalle.DetallesTalla = calculados
            .Select(x => new PedidoDetalleTallaEditor
            {
                Talla = x.Talla,
                Orden = x.Orden,
                Cantidad = x.Base + extras.GetValueOrDefault(x.Talla),
                PorcentajeVariacion = x.PorcentajeVariacion,
                GeneradaDesdeFraccion = true
            })
            .Where(x => x.Cantidad > 0)
            .ToList();

        AsignarVariantesDetalle(detalle);
    }

    private void AgregarTallaDetalle(PedidoDetalleEditor detalle)
    {
        detallePedidoError = null;
        InvalidarComprobacionInventario();
        var siguienteOrden = detalle.DetallesTalla.Count == 0 ? 1 : detalle.DetallesTalla.Max(t => t.Orden) + 1;
        var talla = tallasDisponiblesCliente.FirstOrDefault(t => !detalle.DetallesTalla.Any(d => string.Equals(d.Talla, t.Talla, StringComparison.OrdinalIgnoreCase)));
        var detalleTalla = CrearTallaManual(talla?.Talla ?? string.Empty, siguienteOrden, 0);
        detalleTalla.ProductoVarianteId = ResolverProductoVarianteId(detalle, detalleTalla.Talla);
        detalle.DetallesTalla.Add(detalleTalla);
    }

