@code {
    private IEnumerable<Pedido>? pedidos;
    private IEnumerable<Cliente>? clientes;
    private Pedido pedidoEditando = new();
    private List<PedidoDetalleEditor> detallesPedido = [];
    private List<ProductoClienteOption> productosDisponibles = [];
    private List<CotizacionClienteOption> cotizacionesDisponiblesCliente = [];
    private Dictionary<Guid, List<ProductoVarianteOption>> variantesDisponiblesPorProducto = [];
    private List<TallaClienteDisponible> tallasDisponiblesCliente = [];
    private List<ClienteFraccionCalzado> fraccionesDisponiblesCliente = [];
    private readonly List<ComprobacionInventarioItem> comprobacionInventarioItems = [];
    private readonly List<string> avisosComprobacionInventario = [];
    private bool mostrarFormulario;
    private bool inventarioComprobado;
    private bool revisandoComprobacionInventario;
    private DateTime? inventarioComprobadoEn;
    private string? detallePedidoError;
    private string busquedaTexto = string.Empty;
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;
    private string filtroEstadoPedido = string.Empty;
    private string filtroActivoPedido = "activos";
    private Guid _empresaId;
    private IEnumerable<Pedido> PedidosFiltrados
        => pedidos == null
            ? []
            : pedidos.Where(p =>
                (filtroActivoPedido == "todos"
                    || (filtroActivoPedido == "inactivos" ? !p.IsActive : p.IsActive))
                && (string.IsNullOrWhiteSpace(filtroEstadoPedido)
                    || string.Equals(p.Estado.ToString(), filtroEstadoPedido, StringComparison.OrdinalIgnoreCase))
                && (!fechaDesde.HasValue || p.FechaPedido.Date >= fechaDesde.Value.Date)
                && (!fechaHasta.HasValue || p.FechaPedido.Date <= fechaHasta.Value.Date)
                && (string.IsNullOrWhiteSpace(busquedaTexto)
                    || p.NumeroPedido.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase)
                    || (p.Cliente?.RazonSocial?.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (!string.IsNullOrWhiteSpace(p.Observaciones) && p.Observaciones.Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase))
                    || p.Estado.ToString().Contains(busquedaTexto, StringComparison.OrdinalIgnoreCase)));

    private bool HayFaltantesInventario => comprobacionInventarioItems.Any(item => item.HayFaltante);

    protected override async Task OnInitializedAsync()
    {
        await CargarContextoAsync();
        clientes = await ClienteRepository.GetAllAsync();
        await CargarPedidos();
    }

    private async Task CargarContextoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarPedidos()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        pedidos = await db.Pedidos
            .AsNoTracking()
            .Include(p => p.Cliente)
            .Where(p => _empresaId == Guid.Empty || p.Cliente.EmpresaId == _empresaId)
            .OrderByDescending(p => p.FechaPedido)
            .ToListAsync();
    }

    private void NuevoPedido()
    {
        InvalidarComprobacionInventario();
        pedidoEditando = new Pedido
        {
            NumeroPedido = $"PED-{DateTime.UtcNow:yyyyMMddHHmmss}",
            FechaPedido = DateTime.Now
        };
        detallesPedido = [];
        productosDisponibles = [];
        cotizacionesDisponiblesCliente = [];
        variantesDisponiblesPorProducto = [];
        tallasDisponiblesCliente = [];
        fraccionesDisponiblesCliente = [];
        detallePedidoError = null;
        mostrarFormulario = true;
    }

    private async Task EditarPedido(Pedido p)
    {
        InvalidarComprobacionInventario();
        await using var db = await DbFactory.CreateDbContextAsync();
        var pedido = await db.Pedidos
            .AsNoTracking()
            .Include(x => x.Detalles)
                .ThenInclude(d => d.DetallesTalla)
            .FirstOrDefaultAsync(x => x.Id == p.Id);

        if (pedido == null)
        {
            return;
        }

        pedidoEditando = new Pedido
        {
            Id = pedido.Id,
            NumeroPedido = pedido.NumeroPedido,
            ClienteId = pedido.ClienteId,
            FechaPedido = pedido.FechaPedido,
            FechaEntregaEstimada = pedido.FechaEntregaEstimada,
            Estado = pedido.Estado,
            Subtotal = pedido.Subtotal,
            Impuestos = pedido.Impuestos,
            Total = pedido.Total,
            Observaciones = pedido.Observaciones,
            CreatedAt = pedido.CreatedAt,
            CreatedBy = pedido.CreatedBy,
            IsActive = pedido.IsActive
        };

        await CargarConfiguracionClienteAsync(pedido.ClienteId);
        detallesPedido = pedido.Detalles
            .OrderBy(d => d.CreatedAt)
            .Select(d => new PedidoDetalleEditor
            {
                Id = d.Id,
                ProductoId = d.ProductoId,
                ProductoVarianteId = d.ProductoVarianteId,
                CotizacionSerigrafiaId = d.CotizacionSerigrafiaId,
                Cantidad = d.Cantidad,
                PrecioUnitario = d.PrecioUnitario,
                Descuento = d.Descuento,
                TallaBaseCalzado = d.TallaBaseCalzado,
                VariacionValor = d.VariacionValor,
                AplicaFraccionCalzado = d.AplicaFraccionCalzado,
                ClienteFraccionCalzadoId = d.ClienteFraccionCalzadoId,
                Especificaciones = d.Especificaciones,
                DetallesTalla = d.DetallesTalla
                    .OrderBy(t => t.Orden)
                    .ThenBy(t => t.Talla)
                    .Select(t => new PedidoDetalleTallaEditor
                    {
                        Id = t.Id,
                        ProductoVarianteId = t.ProductoVarianteId,
                        Talla = t.Talla,
                        Orden = t.Orden,
                        Cantidad = t.Cantidad,
                        PorcentajeVariacion = t.PorcentajeVariacion,
                        GeneradaDesdeFraccion = t.GeneradaDesdeFraccion
                    })
                    .ToList()
            })
            .ToList();

        foreach (var detalle in detallesPedido)
        {
            var producto = productosDisponibles.FirstOrDefault(p => p.ProductoId == detalle.ProductoId);
            detalle.TieneVariantes = producto?.TieneVariantes == true;
            detalle.UsaVariantesTalla = producto?.UsaVariantesTalla == true;
            detalle.UsaVariantesColor = producto?.UsaVariantesColor == true;
            AsignarVariantesDetalle(detalle);
        }

        if (!detallesPedido.Any() && productosDisponibles.Any())
        {
            AgregarDetalle();
        }

        mostrarFormulario = true;
    }

    private async Task GuardarPedido()
    {
        if (string.IsNullOrWhiteSpace(pedidoEditando.NumeroPedido) || pedidoEditando.ClienteId == Guid.Empty)
            return;

        if (!inventarioComprobado)
        {
            detallePedidoError = "Primero comprueba consumos e inventario antes de confirmar el guardado.";
            return;
        }

        var detallesValidos = detallesPedido
            .Where(d => d.ProductoId != Guid.Empty && d.Cantidad > 0)
            .ToList();

        if (!detallesValidos.Any())
        {
            return;
        }

        if (!ValidarVariantesPedido(detallesValidos))
        {
            return;
        }

        RecalcularTotales();

        await using var db = await DbFactory.CreateDbContextAsync();
        if (pedidoEditando.Id == Guid.Empty)
        {
            pedidoEditando.Id = Guid.NewGuid();
            pedidoEditando.CreatedAt = DateTime.UtcNow;
            db.Pedidos.Add(pedidoEditando);
        }
        else
        {
            var existing = await db.Pedidos.Include(p => p.Detalles).FirstOrDefaultAsync(p => p.Id == pedidoEditando.Id);
            if (existing == null)
            {
                return;
            }

            existing.NumeroPedido = pedidoEditando.NumeroPedido;
            existing.ClienteId = pedidoEditando.ClienteId;
            existing.FechaPedido = pedidoEditando.FechaPedido;
            existing.FechaEntregaEstimada = pedidoEditando.FechaEntregaEstimada;
            existing.Estado = pedidoEditando.Estado;
            existing.Subtotal = pedidoEditando.Subtotal;
            existing.Impuestos = pedidoEditando.Impuestos;
            existing.Total = pedidoEditando.Total;
            existing.Observaciones = pedidoEditando.Observaciones;
            existing.UpdatedAt = DateTime.UtcNow;

            if (existing.Detalles.Any())
            {
                db.PedidoDetalles.RemoveRange(existing.Detalles);
            }
        }

        foreach (var detalle in detallesValidos)
        {
            var detalleId = detalle.Id == Guid.Empty ? Guid.NewGuid() : detalle.Id;
            db.PedidoDetalles.Add(new PedidoDetalle
            {
                Id = detalleId,
                PedidoId = pedidoEditando.Id,
                ProductoId = detalle.ProductoId,
                ProductoVarianteId = detalle.ProductoVarianteId,
                CotizacionSerigrafiaId = detalle.CotizacionSerigrafiaId,
                Cantidad = detalle.Cantidad,
                PrecioUnitario = detalle.PrecioUnitario,
                Descuento = detalle.Descuento,
                Total = ObtenerTotalDetalle(detalle),
                TallaBaseCalzado = LimpiarTexto(detalle.TallaBaseCalzado),
                VariacionValor = LimpiarTexto(detalle.VariacionValor),
                AplicaFraccionCalzado = detalle.AplicaFraccionCalzado,
                ClienteFraccionCalzadoId = detalle.AplicaFraccionCalzado ? detalle.ClienteFraccionCalzadoId : null,
                Especificaciones = LimpiarTexto(detalle.Especificaciones),
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });

            foreach (var tallaDetalle in detalle.DetallesTalla.Where(t => !string.IsNullOrWhiteSpace(t.Talla) && t.Cantidad > 0))
            {
                db.PedidosDetalleTalla.Add(new PedidoDetalleTalla
                {
                    Id = tallaDetalle.Id == Guid.Empty ? Guid.NewGuid() : tallaDetalle.Id,
                    PedidoDetalleId = detalleId,
                    ProductoVarianteId = tallaDetalle.ProductoVarianteId,
                    Talla = tallaDetalle.Talla.Trim(),
                    Orden = tallaDetalle.Orden,
                    Cantidad = tallaDetalle.Cantidad,
                    PorcentajeVariacion = tallaDetalle.PorcentajeVariacion,
                    GeneradaDesdeFraccion = tallaDetalle.GeneradaDesdeFraccion,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }
        }

        await db.SaveChangesAsync();

        await CargarPedidos();
        Cancelar();
    }

    private async Task ComprobarConsumosInventario()
    {
        InvalidarComprobacionInventario();

        if (string.IsNullOrWhiteSpace(pedidoEditando.NumeroPedido) || pedidoEditando.ClienteId == Guid.Empty)
        {
            detallePedidoError = "Completa los datos generales del pedido antes de revisar consumos e inventario.";
            return;
        }

        var detallesValidos = detallesPedido
            .Where(d => d.ProductoId != Guid.Empty && d.Cantidad > 0)
            .ToList();

        if (!detallesValidos.Any())
        {
            detallePedidoError = "Agrega al menos un renglón válido para revisar consumos e inventario.";
            return;
        }

        if (!ValidarVariantesPedido(detallesValidos))
        {
            return;
        }

        detallePedidoError = null;
        revisandoComprobacionInventario = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var cotizacionIds = detallesValidos
                .Where(d => d.CotizacionSerigrafiaId.HasValue)
                .Select(d => d.CotizacionSerigrafiaId!.Value)
                .Distinct()
                .ToList();

            var detallesCotizacion = cotizacionIds.Count == 0
                ? []
                : await db.CotizacionDetalles
                    .AsNoTracking()
                    .Where(d => cotizacionIds.Contains(d.CotizacionSerigrafiaId))
                    .Where(d => d.Categoria == CotizacionCategoria.Tinta || d.Categoria == CotizacionCategoria.InsumoBasico || d.Categoria == CotizacionCategoria.InsumoDiverso)
                    .Select(d => new ComprobacionInventarioFuente
                    {
                        CotizacionSerigrafiaId = d.CotizacionSerigrafiaId,
                        Categoria = d.Categoria,
                        Concepto = d.Concepto,
                        Consumo = d.Consumo,
                        InventarioItemId = d.InventarioItemId,
                        Nombre = d.InventarioItem != null ? d.InventarioItem.Nombre : d.Concepto,
                        UnidadMedida = d.InventarioItem != null ? d.InventarioItem.UnidadMedida : string.Empty,
                        ExistenciaInventario = d.InventarioItem != null ? d.InventarioItem.Cantidad : null
                    })
                    .ToListAsync();

            var acumulado = new Dictionary<string, ComprobacionInventarioItem>(StringComparer.OrdinalIgnoreCase);

            foreach (var detalle in detallesValidos)
            {
                var indice = detallesPedido.IndexOf(detalle) + 1;
                var productoNombre = productosDisponibles.FirstOrDefault(p => p.ProductoId == detalle.ProductoId)?.Nombre ?? $"Renglón {indice}";
                var referencia = $"Renglón {indice} - {productoNombre}";

                if (!detalle.CotizacionSerigrafiaId.HasValue)
                {
                    avisosComprobacionInventario.Add($"{referencia}: no tiene cotización ligada, por lo que no se pudo estimar consumo.");
                    continue;
                }

                var consumosDetalle = detallesCotizacion
                    .Where(d => d.CotizacionSerigrafiaId == detalle.CotizacionSerigrafiaId.Value && d.Consumo > 0)
                    .ToList();

                if (!consumosDetalle.Any())
                {
                    avisosComprobacionInventario.Add($"{referencia}: la cotización seleccionada no tiene materias primas o insumos con consumo capturado.");
                    continue;
                }

                foreach (var consumo in consumosDetalle)
                {
                    var cantidadRequerida = consumo.Consumo * detalle.Cantidad;
                    if (cantidadRequerida <= 0)
                    {
                        continue;
                    }

                    var tipo = consumo.Categoria == CotizacionCategoria.Tinta ? "Material tipo tinta" : "Material de apoyo";
                    var itemId = consumo.InventarioItemId;
                    var nombre = consumo.Nombre;
                    var unidadMedida = consumo.UnidadMedida;
                    var existencia = consumo.ExistenciaInventario;
                    var sinVinculoInventario = !itemId.HasValue;
                    var clave = itemId.HasValue
                        ? $"{tipo}:{itemId.Value}"
                        : $"{tipo}:sin-mapeo:{(nombre ?? consumo.Concepto).Trim().ToUpperInvariant()}";

                    if (!acumulado.TryGetValue(clave, out var item))
                    {
                        item = new ComprobacionInventarioItem
                        {
                            Tipo = tipo,
                            Nombre = string.IsNullOrWhiteSpace(nombre) ? consumo.Concepto : nombre!,
                            UnidadMedida = string.IsNullOrWhiteSpace(unidadMedida) ? string.Empty : unidadMedida!,
                            ExistenciaInventario = existencia,
                            SinVinculoInventario = sinVinculoInventario
                        };
                        acumulado[clave] = item;
                    }

                    item.CantidadRequerida += cantidadRequerida;
                    item.Referencias.Add(referencia);
                }
            }

            comprobacionInventarioItems.AddRange(acumulado.Values
                .OrderByDescending(item => item.HayFaltante)
                .ThenByDescending(item => item.SinVinculoInventario)
                .ThenBy(item => item.Tipo)
                .ThenBy(item => item.Nombre));

            inventarioComprobado = true;
            inventarioComprobadoEn = DateTime.Now;
        }
        finally
        {
            revisandoComprobacionInventario = false;
        }
    }

