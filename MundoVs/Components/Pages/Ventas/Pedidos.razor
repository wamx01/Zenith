    private sealed class ComprobacionInventarioItem
    {
        public string Tipo { get; set; } = string.Empty;
        public string Nombre { get; set; } = string.Empty;
        public string UnidadMedida { get; set; } = string.Empty;
        public decimal CantidadRequerida { get; set; }
        public decimal? ExistenciaInventario { get; set; }
        public bool SinVinculoInventario { get; set; }
        public HashSet<string> Referencias { get; } = new(StringComparer.OrdinalIgnoreCase);
        public decimal Faltante => ExistenciaInventario.HasValue ? Math.Max(0, CantidadRequerida - ExistenciaInventario.Value) : 0;
        public bool HayFaltante => ExistenciaInventario.HasValue && CantidadRequerida > ExistenciaInventario.Value;
        public string ReferenciasTexto => Referencias.Count == 0 ? string.Empty : string.Join(" • ", Referencias.OrderBy(x => x));
        public string EstadoTexto => SinVinculoInventario
            ? "Sin vínculo inventario"
            : HayFaltante
                ? "No alcanza"
                : "Disponible";
        public string EstadoClase => SinVinculoInventario
            ? "ps-inventory-status--info"
            : HayFaltante
                ? "ps-inventory-status--warning"
                : "ps-inventory-status--ok";
    }
