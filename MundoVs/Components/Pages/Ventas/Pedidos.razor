        if (!detalle.CotizacionSerigrafiaId.HasValue)
        {
            AplicarProductoSeleccionado(detalle, productosDisponibles.FirstOrDefault(p => p.ProductoId == detalle.ProductoId), false);
            RecalcularTotales();
            return;
        }

        var cotizacion = cotizacionesDisponiblesCliente.FirstOrDefault(c => c.Id == detalle.CotizacionSerigrafiaId.Value);
        if (cotizacion == null)
        {
            RecalcularTotales();
            return;
        }

        detalle.ProductoId = cotizacion.ProductoId;
        AplicarProductoSeleccionado(detalle, productosDisponibles.FirstOrDefault(p => p.ProductoId == cotizacion.ProductoId), true, cotizacion);
        RecalcularTotales();
