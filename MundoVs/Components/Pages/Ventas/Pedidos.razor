    private decimal ObtenerCantidadTallas(PedidoDetalleEditor detalle)
        => detalle.DetallesTalla.Sum(t => t.Cantidad);

    private static PedidoDetalleTallaEditor CrearTallaManual(string talla, int orden, decimal cantidad)
        => new()
        {
            Talla = talla,
            Orden = orden,
            Cantidad = cantidad,
            GeneradaDesdeFraccion = false
        };

    private IEnumerable<string> ObtenerVariacionesDisponibles(Guid productoId)
        => variantesDisponiblesPorProducto.TryGetValue(productoId, out var variantes)
            ? variantes
                .Select(v => v.Color)
                .Where(color => !string.IsNullOrWhiteSpace(color))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(color => color)
                .Cast<string>()
            : [];

    private void ActualizarVarianteDetalle(PedidoDetalleEditor detalle)
    {
        if (!detalle.TieneVariantes)
        {
            detalle.ProductoVarianteId = null;
            return;
        }

        if (detalle.UsaVariantesTalla)
        {
            detalle.ProductoVarianteId = null;
            return;
        }

        detalle.ProductoVarianteId = ResolverProductoVarianteId(detalle, null);
    }

    private void AsignarVariantesDetalle(PedidoDetalleEditor detalle)
    {
        ActualizarVarianteDetalle(detalle);

        foreach (var tallaDetalle in detalle.DetallesTalla)
        {
            tallaDetalle.ProductoVarianteId = ResolverProductoVarianteId(detalle, tallaDetalle.Talla);
        }
    }

    private Guid? ResolverProductoVarianteId(PedidoDetalleEditor detalle, string? talla)
    {
        if (!detalle.TieneVariantes || !variantesDisponiblesPorProducto.TryGetValue(detalle.ProductoId, out var variantes))
        {
            return null;
        }

        var query = variantes.AsEnumerable();
        if (detalle.UsaVariantesColor)
        {
            if (string.IsNullOrWhiteSpace(detalle.VariacionValor))
            {
                return null;
            }

            query = query.Where(v => string.Equals(v.Color, detalle.VariacionValor, StringComparison.OrdinalIgnoreCase));
        }

        if (detalle.UsaVariantesTalla)
        {
            if (string.IsNullOrWhiteSpace(talla))
            {
                return null;
            }

            query = query.Where(v => string.Equals(v.Talla, talla, StringComparison.OrdinalIgnoreCase));
        }

        return query.Select(v => (Guid?)v.Id).FirstOrDefault();
    }

    private bool ValidarVariantesPedido(IEnumerable<PedidoDetalleEditor> detalles)
    {
        detallePedidoError = null;

        foreach (var detalle in detalles)
        {
            if (detalle.UsaVariantesColor && string.IsNullOrWhiteSpace(detalle.VariacionValor))
            {
                detallePedidoError = "Selecciona la variación del producto antes de guardar el pedido.";
                return false;
            }

            AsignarVariantesDetalle(detalle);

            if (detalle.TieneVariantes && !detalle.UsaVariantesTalla && detalle.ProductoVarianteId == null)
            {
                detallePedidoError = "No se encontró un SKU válido para la variación seleccionada.";
                return false;
            }

            if (detalle.UsaVariantesTalla)
            {
                var tallasSinSku = detalle.DetallesTalla
                    .Where(t => !string.IsNullOrWhiteSpace(t.Talla) && t.Cantidad > 0 && t.ProductoVarianteId == null)
                    .ToList();

                if (tallasSinSku.Any())
                {
                    detallePedidoError = $"Falta resolver SKU para las tallas: {string.Join(", ", tallasSinSku.Select(t => t.Talla).Distinct(StringComparer.OrdinalIgnoreCase))}.";
                    return false;
                }
            }
        }

        return true;
    }

    private decimal ObtenerTotalDetalle(PedidoDetalleEditor detalle)
        => Math.Max(0, (detalle.Cantidad * detalle.PrecioUnitario) - detalle.Descuento);

    private void InvalidarComprobacionInventario()
    {
        inventarioComprobado = false;
        inventarioComprobadoEn = null;
        comprobacionInventarioItems.Clear();
        avisosComprobacionInventario.Clear();
    }

    private void RecalcularTotales()
    {
        pedidoEditando.Subtotal = detallesPedido.Sum(ObtenerTotalDetalle);
        pedidoEditando.Total = pedidoEditando.Subtotal + pedidoEditando.Impuestos;
    }

    private static string? LimpiarTexto(string? valor)
        => string.IsNullOrWhiteSpace(valor) ? null : valor.Trim();

    private string ObtenerColorEstado(EstadoPedidoEnum estado) => estado switch
    {
        EstadoPedidoEnum.Nuevo => "secondary",
        EstadoPedidoEnum.EnProceso => "warning",
        EstadoPedidoEnum.Producido => "primary",
        EstadoPedidoEnum.Entregado => "success",
        EstadoPedidoEnum.Facturado => "success",
        EstadoPedidoEnum.Cancelado => "danger",
        _ => "secondary"
    };

    private static string ObtenerClaseEstadoPedido(EstadoPedidoEnum estado) => estado switch
    {
        EstadoPedidoEnum.Nuevo => "ps-status-nuevo",
        EstadoPedidoEnum.EnProceso => "ps-status-proceso",
        EstadoPedidoEnum.Producido => "ps-status-producido",
        EstadoPedidoEnum.Entregado => "ps-status-entregado",
        EstadoPedidoEnum.Facturado => "ps-status-facturado",
        EstadoPedidoEnum.Cancelado => "ps-status-cancelado",
        _ => "ps-status-default"
    };

