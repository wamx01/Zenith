@page "/clientes"
@using Microsoft.EntityFrameworkCore
@using MundoVs.Core.Entities.Calzado
@using MundoVs.Core.Entities
@using MundoVs.Core.Interfaces
@using MundoVs.Core.Services
@using MundoVs.Infrastructure.Data
@inject IClienteRepository ClienteRepository
@inject CodigoNegocioService CodigoNegocio
@inject IDbContextFactory<CrmDbContext> DbFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Clientes</PageTitle>

<div class="container-fluid cat-page">
    <div class="d-flex align-items-start justify-content-between mb-2">
        <div>
            <div class="cat-title"><i class="bi bi-people-fill me-1"></i>Clientes</div>
            <div class="cat-subtitle">Gestión de clientes, datos fiscales y configuración comercial</div>
        </div>
        <button class="btn btn-sm btn-primary" @onclick="NuevoCliente">
            <i class="bi bi-plus-circle me-1"></i>Nuevo
        </button>
    </div>

    <div class="cat-kpi mb-2">
        <span class="cat-kpi-chip">Total: @clientes.Count</span>
        <span class="cat-kpi-chip active">Activos: @clientes.Count(c => c.IsActive)</span>
        <span class="cat-kpi-chip inactive">Inactivos: @clientes.Count(c => !c.IsActive)</span>
        @if (textoBusquedaClientes.Length > 0 || filtroIndustriaClientes.Length > 0 || filtroEstadoClientes != "activos")
        {
            <span class="cat-kpi-chip filtered">Filtrados: @clientesFiltrados.Count()</span>
        }
    </div>

    <div class="cat-filter-bar mb-3">
        <div>
            <label>Buscar</label>
            <div class="input-group" style="width:260px">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input class="form-control" @bind="textoBusquedaClientes" @bind:after="AplicarFiltrosClientes" placeholder="Código, razón social, RFC..." />
            </div>
        </div>
        <div>
            <label>Industria</label>
            <select class="form-select" style="width:140px" @bind="filtroIndustriaClientes" @bind:after="AplicarFiltrosClientes">
                <option value="">Todas</option>
                <option value="@IndustriaEnum.Calzado.ToString()">Calzado</option>
                <option value="@IndustriaEnum.Serigrafia.ToString()">Serigrafía</option>
                <option value="@IndustriaEnum.Ambas.ToString()">Ambas</option>
            </select>
        </div>
        <div>
            <label>Estado</label>
            <select class="form-select" style="width:120px" @bind="filtroEstadoClientes" @bind:after="AplicarFiltrosClientes">
                <option value="activos">Activos</option>
                <option value="inactivos">Inactivos</option>
                <option value="todos">Todos</option>
            </select>
        </div>
        <div class="d-flex align-items-end">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LimpiarFiltrosClientes">
                <i class="bi bi-x-circle me-1"></i>Limpiar
            </button>
        </div>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>@(clienteEditando.Id == Guid.Empty ? "Nuevo Cliente" : "Editar Cliente")</h5>
            </div>
            <div class="card-body">
                <EditForm Model="clienteEditando" OnValidSubmit="GuardarCliente">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                        <label class="form-label">Código</label>
                        <InputText class="form-control" @bind-Value="clienteEditando.Codigo" readonly />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">RFC/CIF</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.RfcCif" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Razón Social</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.RazonSocial" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre Comercial</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.NombreComercial" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="clienteEditando.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.Telefono" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email Facturación</label>
                            <InputText type="email" class="form-control" @bind-Value="clienteEditando.EmailFacturacion" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email Cobranza</label>
                            <InputText type="email" class="form-control" @bind-Value="clienteEditando.EmailCobranza" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Dirección</label>
                        <InputText class="form-control" @bind-Value="clienteEditando.Direccion" />
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Ciudad</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.Ciudad" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Estado</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.Estado" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Código Postal</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.CodigoPostal" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">País</label>
                            <InputText class="form-control" @bind-Value="clienteEditando.Pais" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Industria</label>
                            <InputSelect class="form-select" @bind-Value="clienteEditando.Industria">
                                <option value="@IndustriaEnum.Calzado">Calzado</option>
                                <option value="@IndustriaEnum.Serigrafia">Serigrafía</option>
                                <option value="@IndustriaEnum.Ambas">Ambas</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <h6 class="mb-0">Reglas sugeridas de variación comercial</h6>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AgregarReglaVariacionPrecio">
                                    <i class="bi bi-plus-circle me-1"></i>Regla
                                </button>
                            </div>

                            <div class="small text-muted mb-3">
                                Estas reglas son sugerencias por cliente para cotización. No guardan precio final; solo indican si una dimensión o valor propone un ajuste porcentual sobre el precio base cotizado.
                            </div>

                            @if (reglasVariacionCliente.Any())
                            {
                                <div class="table-responsive mb-3">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Dimensión</th>
                                                <th>Valor</th>
                                                <th>Orden</th>
                                                <th class="text-center">Permite variación</th>
                                                <th class="text-end">% sugerido</th>
                                                <th class="text-center">Activa</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var regla in reglasVariacionCliente.OrderBy(r => r.Orden).ThenBy(r => r.Dimension).ThenBy(r => r.Valor))
                                            {
                                                <tr>
                                                    <td><InputText class="form-control form-control-sm" @bind-Value="regla.Dimension" placeholder="Talla, Color, etc." /></td>
                                                    <td><InputText class="form-control form-control-sm" @bind-Value="regla.Valor" placeholder="22, Rojo, etc." /></td>
                                                    <td><InputNumber class="form-control form-control-sm" @bind-Value="regla.Orden" /></td>
                                                    <td class="text-center"><InputCheckbox class="form-check-input" @bind-Value="regla.PermiteVariacionPrecio" /></td>
                                                    <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="regla.PorcentajeVariacionSugerido" /></td>
                                                    <td class="text-center"><InputCheckbox class="form-check-input" @bind-Value="regla.Activa" /></td>
                                                    <td class="text-end">
                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarReglaVariacionPrecio(regla.LocalKey)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small mb-3">No hay reglas sugeridas configuradas para este cliente.</div>
                            }

                            <h6 class="mb-3">Datos fiscales y crédito</h6>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Régimen Fiscal</label>
                                    <InputText class="form-control" @bind-Value="clienteEditando.RegimenFiscalReceptor" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Uso CFDI</label>
                                    <InputText class="form-control" @bind-Value="clienteEditando.UsoCfdi" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">CP Fiscal</label>
                                    <InputText class="form-control" @bind-Value="clienteEditando.DomicilioFiscalCp" />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Días de Crédito</label>
                                    <InputNumber class="form-control" @bind-Value="clienteEditando.DiasCredito" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Límite de Crédito</label>
                                    <InputNumber class="form-control" @bind-Value="clienteEditando.LimiteCredito" />
                                </div>
                                <div class="col-md-4 mb-3 d-flex align-items-end">
                                    <div class="form-check mb-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="clienteEditando.RfcValidado" />
                                        <label class="form-check-label">RFC validado</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                                <h6 class="mb-0">Configuración de tallas y fracciones</h6>
                                <span class="text-muted small">Catálogo base por empresa · override opcional por cliente</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(configuracionCalzadoError))
                            {
                                <div class="alert alert-warning py-2">@configuracionCalzadoError</div>
                            }

                            <div class="small text-muted mb-3">
                                <strong>Ajuste %</strong> es la variación relativa de una talla respecto a la talla base. Hoy se guarda como referencia de la corrida/fracción.
                            </div>

                            <div class="row g-4">
                                    <div class="col-12 col-xl-5">
                                        <div class="border rounded p-3 bg-white h-100">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <strong>Tallas base de la empresa</strong>
                                                <a class="btn btn-sm btn-outline-primary" href="/configuracion/tallas-calzado">
                                                    <i class="bi bi-sliders me-1"></i>Catálogo base
                                                </a>
                                            </div>

                                            @if (!tallasCliente.Any())
                                            {
                                                <div class="alert alert-warning py-2 mb-0">No hay tallas base configuradas para la empresa.</div>
                                            }
                                            else
                                            {
                                                <div class="form-check form-switch mb-3">
                                                    <InputCheckbox class="form-check-input" @bind-Value="usarCatalogoBaseCliente" />
                                                    <label class="form-check-label">Usar catálogo base completo para este cliente</label>
                                                </div>

                                                @if (usarCatalogoBaseCliente)
                                                {
                                                    <div class="small text-muted mb-2">Este cliente heredará automáticamente todas las tallas activas de la empresa.</div>
                                                    <div class="d-flex flex-wrap gap-2">
                                                        @foreach (var talla in tallasCliente.Where(t => t.ActivaCatalogo).OrderBy(t => t.OrdenCatalogo).ThenBy(t => t.Talla))
                                                        {
                                                            <span class="badge rounded-pill bg-light text-dark border">@talla.Talla <span class="text-muted">@talla.SistemaNumeracion</span></span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="small text-muted mb-2">Selecciona sólo las tallas que este cliente utiliza y define una talla base.</div>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm align-middle mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th>Talla</th>
                                                                    <th>Sistema</th>
                                                                    <th>Orden base</th>
                                                                    <th>Usar</th>
                                                                    <th>Orden cliente</th>
                                                                    <th>Base</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var talla in tallasCliente.OrderBy(t => t.OrdenCatalogo).ThenBy(t => t.Talla))
                                                                {
                                                                    <tr>
                                                                        <td class="fw-semibold">@talla.Talla</td>
                                                                        <td>@talla.SistemaNumeracion</td>
                                                                        <td>@talla.OrdenCatalogo</td>
                                                                        <td class="text-center"><InputCheckbox class="form-check-input" @bind-Value="talla.Seleccionada" /></td>
                                                                        <td><InputNumber class="form-control form-control-sm" @bind-Value="talla.OrdenCliente" disabled="@(!talla.Seleccionada)" /></td>
                                                                        <td class="text-center">
                                                                            <InputRadioGroup @bind-Value="tallaBaseSeleccionada">
                                                                                <InputRadio class="form-check-input" Value="@talla.CatalogoTallaCalzadoId" disabled="@(!talla.Seleccionada)" />
                                                                            </InputRadioGroup>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>

                                    <div class="col-12 col-xl-7">
                                        <div class="border rounded p-3 bg-white h-100">
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <strong>Fracciones del cliente</strong>
                                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AgregarFraccionCliente">
                                                    <i class="bi bi-plus-circle me-1"></i>Fracción
                                                </button>
                                            </div>

                                            @if (!fraccionesCliente.Any())
                                            {
                                                <div class="text-muted small">Define las fracciones reutilizables con sus unidades por talla y ajuste porcentual opcional.</div>
                                            }
                                            else
                                            {
                                                @foreach (var fraccion in fraccionesCliente)
                                                {
                                                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                                                        <div class="row g-2 align-items-end mb-2">
                                                            <div class="col-md-3">
                                                                <label class="form-label small mb-1">Código</label>
                                                                <InputText class="form-control form-control-sm" @bind-Value="fraccion.Codigo" />
                                                            </div>
                                                            <div class="col-md-4">
                                                                <label class="form-label small mb-1">Nombre</label>
                                                                <InputText class="form-control form-control-sm" @bind-Value="fraccion.Nombre" />
                                                            </div>
                                                            <div class="col-md-3">
                                                                <label class="form-label small mb-1">Unidades por fracción</label>
                                                                <InputNumber class="form-control form-control-sm" @bind-Value="fraccion.UnidadesPorFraccion" />
                                                            </div>
                                                            <div class="col-md-1 text-center">
                                                                <label class="form-label small mb-1">Activa</label>
                                                                <div><InputCheckbox class="form-check-input" @bind-Value="fraccion.Activa" /></div>
                                                            </div>
                                                            <div class="col-md-1 text-end">
                                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarFraccionCliente(fraccion.LocalKey)"><i class="bi bi-trash"></i></button>
                                                            </div>
                                                        </div>

                                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                                            <span class="small fw-semibold text-muted">Detalle por talla</span>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => AgregarDetalleFraccion(fraccion.LocalKey)">
                                                                <i class="bi bi-plus-circle me-1"></i>Detalle
                                                            </button>
                                                        </div>

                                                        @if (!fraccion.Detalles.Any())
                                                        {
                                                            <div class="text-muted small">Agrega las tallas y unidades de la fracción.</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="table-responsive">
                                                                <table class="table table-sm align-middle mb-0">
                                                                    <thead class="table-light">
                                                                        <tr>
                                                                            <th>Talla</th>
                                                                            <th>Orden</th>
                                                                            <th>Unidades</th>
                                                                            <th>Ajuste %</th>
                                                                            <th></th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var detalle in fraccion.Detalles.OrderBy(d => d.Orden).ThenBy(d => d.Talla))
                                                                        {
                                                                            <tr>
                                                                                <td>
                                                                                    <InputSelect class="form-select form-select-sm" @bind-Value="detalle.Talla">
                                                                                        <option value="">Seleccione...</option>
                                                                                        @foreach (var tallaDisponible in ObtenerTallasDisponiblesParaDetalle(fraccion, detalle))
                                                                                        {
                                                                                            <option value="@tallaDisponible">@tallaDisponible</option>
                                                                                        }
                                                                                    </InputSelect>
                                                                                </td>
                                                                                <td><InputNumber class="form-control form-control-sm" @bind-Value="detalle.Orden" /></td>
                                                                                <td><InputNumber class="form-control form-control-sm" @bind-Value="detalle.Unidades" /></td>
                                                                                <td><InputNumber class="form-control form-control-sm" @bind-Value="detalle.PorcentajeVariacion" /></td>
                                                                                <td class="text-end">
                                                                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => EliminarDetalleFraccion(fraccion.LocalKey, detalle.LocalKey)"><i class="bi bi-trash"></i></button>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            }

                                        </div>
                                    </div>
                                </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="CancelarEdicion">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (clientes == null)
            {
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <div class="text-muted small mt-1">Cargando clientes...</div>
                </div>
            }
            else if (!clientesFiltrados.Any())
            {
                <div class="text-center py-4 text-muted small"><i class="bi bi-inbox me-1"></i>Sin registros con los filtros actuales.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0 cat-table">
                        <thead>
                            <tr>
                                <th style="width:110px">Acciones</th>
                                <th style="width:72px">Estado</th>
                                <th>Código</th>
                                <th>Razón Social</th>
                                <th>RFC/CIF</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th>Industria</th>
                                <th>Ciudad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in clientesFiltrados)
                            {
                                <tr class="@(!cliente.IsActive ? "cat-row-inactive" : string.Empty)">
                                    <td class="cat-actions">
                                        <button class="cat-btn-edit me-1" @onclick="async () => await EditarCliente(cliente)" title="Editar"><i class="bi bi-pencil"></i></button>
                                        @if (cliente.IsActive)
                                        {
                                            <button class="cat-btn-delete" @onclick="() => CambiarEstadoCliente(cliente, false)" title="Desactivar"><i class="bi bi-pause-circle"></i></button>
                                        }
                                        else
                                        {
                                            <button class="cat-btn-activate" @onclick="() => CambiarEstadoCliente(cliente, true)" title="Activar"><i class="bi bi-play-circle"></i></button>
                                        }
                                    </td>
                                    <td><span class="@(cliente.IsActive ? "cat-badge-active" : "cat-badge-inactive")">@(cliente.IsActive ? "Activo" : "Inactivo")</span></td>
                                    <td class="fw-semibold text-primary-emphasis">@cliente.Codigo</td>
                                    <td>
                                        <div>@cliente.RazonSocial</div>
                                        @if (!string.IsNullOrWhiteSpace(cliente.NombreComercial))
                                        {
                                            <div class="small text-muted">@cliente.NombreComercial</div>
                                        }
                                    </td>
                                    <td class="text-muted">@cliente.RfcCif</td>
                                    <td>@cliente.Email</td>
                                    <td>@cliente.Telefono</td>
                                    <td>
                                        <span class="badge bg-@ObtenerColorIndustria(cliente.Industria)" style="font-size:0.68rem">@cliente.Industria</span>
                                    </td>
                                    <td>@cliente.Ciudad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .cat-page { padding: 0.65rem 0.9rem; }
    .cat-title { font-size: 1rem; font-weight: 700; color: #1e3a5f; }
    .cat-subtitle { font-size: 0.74rem; color: #6c757d; }
    .cat-kpi { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .cat-kpi-chip { font-size: 0.73rem; padding: 0.18rem 0.6rem; border-radius: 999px; border: 1px solid #dee2e6; background: #f8f9fa; color: #495057; font-weight: 600; }
    .cat-kpi-chip.active { background: #d1e7dd; border-color: #a3cfbb; color: #146c43; }
    .cat-kpi-chip.inactive { background: #e9ecef; border-color: #ced4da; color: #6c757d; }
    .cat-kpi-chip.filtered { background: #cfe2ff; border-color: #9ec5fe; color: #084298; }
