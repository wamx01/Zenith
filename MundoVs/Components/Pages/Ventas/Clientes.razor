@code {
    private List<Cliente> clientes = [];
    private IEnumerable<Cliente> clientesFiltrados = [];
    private Cliente clienteEditando = new();
    private bool mostrarFormulario = false;
    private List<ReglaVariacionClienteEditor> reglasVariacionCliente = [];
    private List<TallaClienteEditor> tallasCliente = [];
    private List<FraccionClienteEditor> fraccionesCliente = [];
    private Guid? tallaBaseSeleccionada;
    private Guid _empresaId;
    private bool usarCatalogoBaseCliente = true;
    private string? configuracionCalzadoError;
    private string textoBusquedaClientes = string.Empty;
    private string filtroIndustriaClientes = string.Empty;
    private string filtroEstadoClientes = "activos";

    protected override async Task OnInitializedAsync()
    {
        await CargarContextoAsync();
        await CargarClientes();
    }

    private async Task CargarContextoAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out _empresaId);
    }

    private async Task CargarClientes()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        clientes = await db.Clientes
            .AsNoTracking()
            .IgnoreQueryFilters()
            .Where(c => c.EmpresaId == _empresaId)
            .OrderBy(c => c.RazonSocial)
            .ToListAsync();
        AplicarFiltrosClientes();
    }

    private void AplicarFiltrosClientes()
    {
        IEnumerable<Cliente> consulta = clientes;

        if (!string.IsNullOrWhiteSpace(textoBusquedaClientes))
        {
            var texto = textoBusquedaClientes.Trim();
            consulta = consulta.Where(c =>
                c.Codigo.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || c.RazonSocial.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || (c.NombreComercial?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false)
                || c.RfcCif.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || c.Email.Contains(texto, StringComparison.OrdinalIgnoreCase)
                || (c.Ciudad?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        if (!string.IsNullOrWhiteSpace(filtroIndustriaClientes)
            && Enum.TryParse<IndustriaEnum>(filtroIndustriaClientes, out var industria))
        {
            consulta = consulta.Where(c => c.Industria == industria);
        }

        consulta = filtroEstadoClientes switch
        {
            "inactivos" => consulta.Where(c => !c.IsActive),
            "todos" => consulta,
            _ => consulta.Where(c => c.IsActive)
        };

        clientesFiltrados = consulta.ToList();
    }

    private void LimpiarFiltrosClientes()
    {
        textoBusquedaClientes = string.Empty;
        filtroIndustriaClientes = string.Empty;
        filtroEstadoClientes = "activos";
        AplicarFiltrosClientes();
    }

    private async Task NuevoCliente()
    {
        clienteEditando = new Cliente
        {
            Pais = "México",
            Codigo = _empresaId == Guid.Empty ? string.Empty : await CodigoNegocio.GetNextEntityCodeAsync(_empresaId, "CLI", "Consecutivo:Cliente")
        };
        reglasVariacionCliente = [];
        tallasCliente = [];
        fraccionesCliente = [];
        tallaBaseSeleccionada = null;
        configuracionCalzadoError = null;
        mostrarFormulario = true;
    }

    private async Task EditarCliente(Cliente cliente)
    {
        clienteEditando = ClonarCliente(cliente);
        await CargarReglasVariacionPrecioAsync(cliente.Id);
        await CargarConfiguracionCalzadoAsync(cliente.Id);
        configuracionCalzadoError = null;
        mostrarFormulario = true;
    }

    private async Task GuardarCliente()
    {
        if (clienteEditando.Id == Guid.Empty && string.IsNullOrWhiteSpace(clienteEditando.Codigo))
        {
            clienteEditando.Codigo = await CodigoNegocio.GetNextEntityCodeAsync(_empresaId, "CLI", "Consecutivo:Cliente");
        }

        PrepararClienteParaGuardar();

        if (!ValidarReglasVariacionPrecio())
        {
            return;
        }

        if (clienteEditando.RfcValidado)
        {
            clienteEditando.FechaValidacionRfc ??= DateTime.UtcNow;
        }
        else
        {
            clienteEditando.FechaValidacionRfc = null;
        }

        if (clienteEditando.Id == Guid.Empty)
        {
            await ClienteRepository.AddAsync(clienteEditando);
        }
        else
        {
            clienteEditando.UpdatedAt = DateTime.UtcNow;
            await ClienteRepository.UpdateAsync(clienteEditando);
        }

        await GuardarReglasVariacionPrecioAsync(clienteEditando.Id);

        if (EsClienteCalzado())
        {
            if (!ValidarConfiguracionCalzado())
            {
                return;
            }

            await GuardarConfiguracionCalzadoAsync(clienteEditando.Id);
        }

        await CargarClientes();
        CancelarEdicion();
    }

    private async Task CambiarEstadoCliente(Cliente cliente, bool activar)
    {
        if (!activar)
        {
            var confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Deseas desactivar al cliente '{cliente.RazonSocial}'?");
            if (!confirmado)
            {
                return;
            }
        }

        cliente.IsActive = activar;
        cliente.UpdatedAt = DateTime.UtcNow;
        await ClienteRepository.UpdateAsync(cliente);
        await CargarClientes();
    }

    private void CancelarEdicion()
    {
        clienteEditando = new();
        reglasVariacionCliente = [];
        tallasCliente = [];
        fraccionesCliente = [];
        tallaBaseSeleccionada = null;
        usarCatalogoBaseCliente = true;
        configuracionCalzadoError = null;
        mostrarFormulario = false;
    }

    private bool EsClienteCalzado()
        => clienteEditando.Industria is IndustriaEnum.Calzado or IndustriaEnum.Ambas;

    private void AgregarReglaVariacionPrecio()
    {
        var siguienteOrden = reglasVariacionCliente.Count == 0 ? 1 : reglasVariacionCliente.Max(r => r.Orden) + 1;
        reglasVariacionCliente.Add(new ReglaVariacionClienteEditor
        {
            Orden = siguienteOrden,
            Dimension = "Talla",
            PermiteVariacionPrecio = true,
            Activa = true
        });
    }

    private void EliminarReglaVariacionPrecio(string localKey)
        => reglasVariacionCliente.RemoveAll(r => r.LocalKey == localKey);

    private void AgregarFraccionCliente()
    {
        var fraccion = new FraccionClienteEditor
        {
            Activa = true,
            UnidadesPorFraccion = 12
        };

        fraccion.Codigo = GenerarCodigoFraccion(fraccion.LocalKey);
        fraccionesCliente.Add(fraccion);

        configuracionCalzadoError = null;
    }

    private void EliminarFraccionCliente(string localKey)
    {
        fraccionesCliente.RemoveAll(f => f.LocalKey == localKey);
        configuracionCalzadoError = null;
    }

    private void AgregarDetalleFraccion(string fraccionKey)
    {
        var fraccion = fraccionesCliente.FirstOrDefault(f => f.LocalKey == fraccionKey);
        if (fraccion == null)
        {
            return;
        }

        var tallaDisponible = ObtenerTallasDisponiblesCliente()
            .Where(t => !fraccion.Detalles.Any(d => string.Equals(d.Talla, t.Talla, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(t => t.OrdenCliente)
            .ThenBy(t => t.Talla)
            .Select(t => t.Talla.Trim())
            .FirstOrDefault();

        if (string.IsNullOrWhiteSpace(tallaDisponible))
        {
            configuracionCalzadoError = "Ya no hay tallas disponibles para agregar en esta fracción.";
            return;
        }

        var siguienteOrden = fraccion.Detalles.Count == 0 ? 1 : fraccion.Detalles.Max(d => d.Orden) + 1;
        fraccion.Detalles.Add(new FraccionDetalleClienteEditor { Orden = siguienteOrden, Unidades = 1, Talla = tallaDisponible });
        configuracionCalzadoError = null;
    }

    private void EliminarDetalleFraccion(string fraccionKey, string detalleKey)
    {
        var fraccion = fraccionesCliente.FirstOrDefault(f => f.LocalKey == fraccionKey);
        fraccion?.Detalles.RemoveAll(d => d.LocalKey == detalleKey);
        configuracionCalzadoError = null;
    }

    private IEnumerable<string> ObtenerTallasDisponiblesParaDetalle(FraccionClienteEditor fraccion, FraccionDetalleClienteEditor detalle)
    {
        var ocupadas = fraccion.Detalles
            .Where(d => d.LocalKey != detalle.LocalKey && !string.IsNullOrWhiteSpace(d.Talla))
            .Select(d => d.Talla.Trim())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return ObtenerTallasDisponiblesCliente()
            .Where(t => !string.IsNullOrWhiteSpace(t.Talla) && (!ocupadas.Contains(t.Talla.Trim()) || string.Equals(t.Talla, detalle.Talla, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(t => t.OrdenCliente)
            .ThenBy(t => t.Talla)
            .Select(t => t.Talla.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private bool ValidarConfiguracionCalzado()
    {
        configuracionCalzadoError = null;

        var tallasValidas = ObtenerTallasDisponiblesCliente()
            .Select(t => t.Talla.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!usarCatalogoBaseCliente)
        {
            var tallasSeleccionadas = ObtenerTallasDisponiblesCliente().ToList();
            if (!tallasSeleccionadas.Any())
            {
                configuracionCalzadoError = "Selecciona al menos una talla para el cliente o usa el catálogo base completo.";
                return false;
            }

            if (!tallaBaseSeleccionada.HasValue || !tallasSeleccionadas.Any(t => t.CatalogoTallaCalzadoId == tallaBaseSeleccionada.Value))
            {
                configuracionCalzadoError = "Selecciona una talla base válida para el cliente.";
                return false;
            }
        }

        foreach (var fraccion in fraccionesCliente.Where(f => !string.IsNullOrWhiteSpace(f.Codigo) || !string.IsNullOrWhiteSpace(f.Nombre)))
        {
            var etiquetaFraccion = ObtenerEtiquetaFraccion(fraccion);
            var detallesValidos = fraccion.Detalles
                .Where(d => !string.IsNullOrWhiteSpace(d.Talla))
                .ToList();

            var tallasRepetidas = detallesValidos
                .GroupBy(d => d.Talla.Trim(), StringComparer.OrdinalIgnoreCase)
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToList();

            if (tallasRepetidas.Any())
            {
                configuracionCalzadoError = $"La fracción '{etiquetaFraccion}' tiene tallas repetidas: {string.Join(", ", tallasRepetidas)}.";
                return false;
            }

            var tallaInvalida = detallesValidos.FirstOrDefault(d => !tallasValidas.Contains(d.Talla.Trim()));
            if (tallaInvalida != null)
            {
                configuracionCalzadoError = $"La talla '{tallaInvalida.Talla}' de la fracción '{etiquetaFraccion}' no existe en las tallas disponibles del cliente.";
                return false;
            }

            var totalUnidades = detallesValidos.Sum(d => Math.Max(0, d.Unidades));
            if (totalUnidades > fraccion.UnidadesPorFraccion)
            {
                configuracionCalzadoError = $"La fracción '{etiquetaFraccion}' suma {totalUnidades} unidades y no puede exceder {fraccion.UnidadesPorFraccion}.";
                return false;
            }

            if (fraccion.UnidadesPorFraccion > 0 && detallesValidos.Any() && totalUnidades != fraccion.UnidadesPorFraccion)
            {
                configuracionCalzadoError = $"La fracción '{etiquetaFraccion}' suma {totalUnidades} unidades y debe cuadrar con {fraccion.UnidadesPorFraccion}.";
                return false;
            }
        }

        var codigosDuplicados = fraccionesCliente
            .Where(f => !string.IsNullOrWhiteSpace(f.Codigo) || !string.IsNullOrWhiteSpace(f.Nombre))
            .Select(f => NormalizarCodigoFraccion(f))
            .GroupBy(c => c, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() > 1)
            .Select(g => g.Key)
            .ToList();

        if (codigosDuplicados.Any())
        {
            configuracionCalzadoError = $"Hay códigos de fracción duplicados: {string.Join(", ", codigosDuplicados)}.";
            return false;
        }

        return true;
    }

    private bool ValidarReglasVariacionPrecio()
    {
        var duplicadas = reglasVariacionCliente
            .Where(r => !string.IsNullOrWhiteSpace(r.Dimension) && !string.IsNullOrWhiteSpace(r.Valor))
            .GroupBy(r => $"{r.Dimension.Trim().ToUpperInvariant()}|{r.Valor.Trim().ToUpperInvariant()}")
            .Where(g => g.Count() > 1)
            .Select(g => g.Key.Replace("|", " = "))
            .ToList();

        if (duplicadas.Any())
        {
            configuracionCalzadoError = $"Hay reglas de variación duplicadas: {string.Join(", ", duplicadas)}.";
            return false;
        }

        return true;
    }

    private async Task CargarReglasVariacionPrecioAsync(Guid clienteId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        reglasVariacionCliente = await db.ClientesReglasVariacionPrecio
            .AsNoTracking()
            .Where(r => r.ClienteId == clienteId && r.IsActive)
            .OrderBy(r => r.Orden)
            .ThenBy(r => r.Dimension)
            .ThenBy(r => r.Valor)
            .Select(r => new ReglaVariacionClienteEditor
            {
                Id = r.Id,
                Dimension = r.Dimension,
                Valor = r.Valor,
                Orden = r.Orden,
                PermiteVariacionPrecio = r.PermiteVariacionPrecio,
                PorcentajeVariacionSugerido = r.PorcentajeVariacionSugerido,
                Activa = r.Activa
            })
            .ToListAsync();
    }

    private async Task GuardarReglasVariacionPrecioAsync(Guid clienteId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var existentes = await db.ClientesReglasVariacionPrecio
            .Where(r => r.ClienteId == clienteId)
            .ToListAsync();

        if (existentes.Count > 0)
        {
            db.ClientesReglasVariacionPrecio.RemoveRange(existentes);
            await db.SaveChangesAsync();
        }

        foreach (var regla in reglasVariacionCliente.Where(r => !string.IsNullOrWhiteSpace(r.Dimension) && !string.IsNullOrWhiteSpace(r.Valor)))
        {
            db.ClientesReglasVariacionPrecio.Add(new ClienteReglaVariacionPrecio
            {
                Id = Guid.NewGuid(),
                ClienteId = clienteId,
                Dimension = regla.Dimension.Trim(),
                Valor = regla.Valor.Trim(),
                Orden = regla.Orden,
                PermiteVariacionPrecio = regla.PermiteVariacionPrecio,
                PorcentajeVariacionSugerido = regla.PorcentajeVariacionSugerido,
                Activa = regla.Activa,
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            });
        }

        await db.SaveChangesAsync();
    }

    private async Task CargarConfiguracionCalzadoAsync(Guid clienteId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        tallasCliente = await db.CatalogoTallasCalzado
            .AsNoTracking()
            .Where(t => t.IsActive)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new TallaClienteEditor
            {
                CatalogoTallaCalzadoId = t.Id,
                Talla = t.Talla,
                SistemaNumeracion = t.SistemaNumeracion,
                OrdenCatalogo = t.Orden,
                OrdenCliente = t.Orden,
                ActivaCatalogo = t.Activa,
                Seleccionada = t.Activa
            })
            .ToListAsync();

        var overrides = await db.ClientesTallasCalzado
            .AsNoTracking()
            .Where(t => t.ClienteId == clienteId && t.IsActive)
            .ToListAsync();

        usarCatalogoBaseCliente = !overrides.Any();
        tallaBaseSeleccionada = overrides.FirstOrDefault(t => t.EsTallaBaseDefault)?.CatalogoTallaCalzadoId;

        if (overrides.Any())
        {
            var overridesPorCatalogo = overrides.ToDictionary(t => t.CatalogoTallaCalzadoId);
            foreach (var talla in tallasCliente)
            {
                if (overridesPorCatalogo.TryGetValue(talla.CatalogoTallaCalzadoId, out var overrideTalla))
                {
                    talla.Seleccionada = overrideTalla.Activa;
                    talla.OrdenCliente = overrideTalla.Orden;
                }
                else
                {
                    talla.Seleccionada = false;
                }
            }
        }

        fraccionesCliente = await db.ClientesFraccionesCalzado
            .AsNoTracking()
            .Include(f => f.Detalles)
            .Where(f => f.ClienteId == clienteId)
            .OrderBy(f => f.Nombre)
            .Select(f => new FraccionClienteEditor
            {
                Codigo = f.Codigo,
                Nombre = f.Nombre,
                UnidadesPorFraccion = f.UnidadesPorFraccion,
                Activa = f.Activa,
                Detalles = f.Detalles
                    .OrderBy(d => d.Orden)
                    .ThenBy(d => d.Talla)
                    .Select(d => new FraccionDetalleClienteEditor
                    {
                        Talla = d.Talla,
                        Orden = d.Orden,
                        Unidades = d.Unidades,
                        PorcentajeVariacion = d.PorcentajeVariacion
                    })
                    .ToList()
            })
            .ToListAsync();
    }

    private async Task GuardarConfiguracionCalzadoAsync(Guid clienteId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var detallesExistentes = await db.ClientesFraccionesCalzadoDetalle.Where(d => d.ClienteFraccionCalzado.ClienteId == clienteId).ToListAsync();
        var fraccionesExistentes = await db.ClientesFraccionesCalzado.Where(f => f.ClienteId == clienteId).ToListAsync();
        var tallasExistentes = await db.ClientesTallasCalzado.Where(t => t.ClienteId == clienteId).ToListAsync();

        if (detallesExistentes.Count > 0)
            db.ClientesFraccionesCalzadoDetalle.RemoveRange(detallesExistentes);
        if (fraccionesExistentes.Count > 0)
            db.ClientesFraccionesCalzado.RemoveRange(fraccionesExistentes);
        if (tallasExistentes.Count > 0)
            db.ClientesTallasCalzado.RemoveRange(tallasExistentes);

        await db.SaveChangesAsync();

        var tallasValidas = ObtenerTallasDisponiblesCliente().ToList();

        var tallaMap = new Dictionary<string, Guid>(StringComparer.OrdinalIgnoreCase);
        foreach (var talla in tallasValidas)
        {
            tallaMap[talla.Talla] = talla.CatalogoTallaCalzadoId;
        }

        if (!usarCatalogoBaseCliente)
        {
            foreach (var talla in tallasValidas)
            {
                db.ClientesTallasCalzado.Add(new ClienteTallaCalzado
                {
                    Id = Guid.NewGuid(),
                    ClienteId = clienteId,
                    CatalogoTallaCalzadoId = talla.CatalogoTallaCalzadoId,
                    Talla = talla.Talla.Trim(),
                    Orden = talla.OrdenCliente,
                    PorcentajeVariacionDefault = 0m,
                    Activa = true,
                    EsTallaBaseDefault = talla.CatalogoTallaCalzadoId == tallaBaseSeleccionada,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }
        }

        foreach (var fraccion in fraccionesCliente.Where(f => !string.IsNullOrWhiteSpace(f.Codigo) && !string.IsNullOrWhiteSpace(f.Nombre)))
        {
            var codigoFraccion = NormalizarCodigoFraccion(fraccion);
            var fraccionEntity = new ClienteFraccionCalzado
            {
                Id = Guid.NewGuid(),
                ClienteId = clienteId,
                Codigo = codigoFraccion,
                Nombre = fraccion.Nombre.Trim(),
                UnidadesPorFraccion = fraccion.UnidadesPorFraccion,
                Activa = fraccion.Activa,
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            };

            db.ClientesFraccionesCalzado.Add(fraccionEntity);

            foreach (var detalle in fraccion.Detalles.Where(d => !string.IsNullOrWhiteSpace(d.Talla)))
            {
                db.ClientesFraccionesCalzadoDetalle.Add(new ClienteFraccionCalzadoDetalle
                {
                    Id = Guid.NewGuid(),
                    ClienteFraccionCalzadoId = fraccionEntity.Id,
                    CatalogoTallaCalzadoId = tallaMap.TryGetValue(detalle.Talla.Trim(), out var tallaId) ? tallaId : null,
                    Talla = detalle.Talla.Trim(),
                    Orden = detalle.Orden,
                    Unidades = detalle.Unidades,
                    PorcentajeVariacion = detalle.PorcentajeVariacion,
                    CreatedAt = DateTime.UtcNow,
                    IsActive = true
                });
            }
        }

        await db.SaveChangesAsync();
    }

    private void PrepararClienteParaGuardar()
    {
        clienteEditando.Codigo = clienteEditando.Codigo.Trim();
        clienteEditando.RfcCif = clienteEditando.RfcCif.Trim();
        clienteEditando.RazonSocial = clienteEditando.RazonSocial.Trim();
        clienteEditando.NombreComercial = LimpiarTexto(clienteEditando.NombreComercial);
        clienteEditando.Email = clienteEditando.Email.Trim();
        clienteEditando.EmailFacturacion = LimpiarTexto(clienteEditando.EmailFacturacion) ?? clienteEditando.Email;
        clienteEditando.EmailCobranza = LimpiarTexto(clienteEditando.EmailCobranza) ?? clienteEditando.EmailFacturacion;
        clienteEditando.Telefono = LimpiarTexto(clienteEditando.Telefono);
        clienteEditando.Direccion = LimpiarTexto(clienteEditando.Direccion);
        clienteEditando.Ciudad = LimpiarTexto(clienteEditando.Ciudad);
        clienteEditando.Estado = LimpiarTexto(clienteEditando.Estado);
        clienteEditando.CodigoPostal = LimpiarTexto(clienteEditando.CodigoPostal);
        clienteEditando.Pais = LimpiarTexto(clienteEditando.Pais) ?? "México";
        clienteEditando.RegimenFiscalReceptor = LimpiarTexto(clienteEditando.RegimenFiscalReceptor);
        clienteEditando.UsoCfdi = LimpiarTexto(clienteEditando.UsoCfdi);
        clienteEditando.DomicilioFiscalCp = LimpiarTexto(clienteEditando.DomicilioFiscalCp) ?? clienteEditando.CodigoPostal;
    }

