    private static string? LimpiarTexto(string? valor)
        => string.IsNullOrWhiteSpace(valor) ? null : valor.Trim();

    private static string ObtenerEtiquetaFraccion(FraccionClienteEditor fraccion)
        => !string.IsNullOrWhiteSpace(fraccion.Nombre)
            ? fraccion.Nombre.Trim()
            : !string.IsNullOrWhiteSpace(fraccion.Codigo)
                ? fraccion.Codigo.Trim()
                : "sin nombre";

    private string NormalizarCodigoFraccion(FraccionClienteEditor fraccion)
    {
        var codigo = LimpiarTexto(fraccion.Codigo);
        if (!string.IsNullOrWhiteSpace(codigo))
        {
            fraccion.Codigo = codigo.ToUpperInvariant();
            return fraccion.Codigo;
        }

        fraccion.Codigo = GenerarCodigoFraccion(fraccion.LocalKey);
        return fraccion.Codigo;
    }

    private string GenerarCodigoFraccion(string localKey)
    {
        var baseCliente = ObtenerPrefijoFraccionCliente();
        var sufijo = localKey.Length >= 6
            ? localKey[..6].ToUpperInvariant()
            : localKey.ToUpperInvariant();

        var codigo = $"FRAC-{baseCliente}-{sufijo}";
        var codigosExistentes = fraccionesCliente
            .Where(f => !string.Equals(f.LocalKey, localKey, StringComparison.OrdinalIgnoreCase))
            .Select(f => f.Codigo?.Trim())
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!codigosExistentes.Contains(codigo))
        {
            return codigo;
        }

        var codigoAlterno = $"FRAC-{baseCliente}-{Guid.NewGuid():N[..6].ToUpperInvariant()}";
        return codigoAlterno;
    }

    private string ObtenerPrefijoFraccionCliente()
    {
        var origen = LimpiarTexto(clienteEditando.Codigo)
            ?? LimpiarTexto(clienteEditando.NombreComercial)
            ?? LimpiarTexto(clienteEditando.RazonSocial)
            ?? "CLIENTE";

        var caracteres = origen
            .Where(char.IsLetterOrDigit)
            .Select(char.ToUpperInvariant)
            .Take(10)
            .ToArray();

        return caracteres.Length == 0 ? "CLIENTE" : new string(caracteres);
    }

    private async Task CargarCatalogoTallasEmpresaAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        tallasCliente = await db.CatalogoTallasCalzado
            .AsNoTracking()
            .Where(t => t.IsActive)
            .OrderBy(t => t.Orden)
            .ThenBy(t => t.Talla)
            .Select(t => new TallaClienteEditor
            {
                CatalogoTallaCalzadoId = t.Id,
                Talla = t.Talla,
                SistemaNumeracion = t.SistemaNumeracion,
                OrdenCatalogo = t.Orden,
                OrdenCliente = t.Orden,
                ActivaCatalogo = t.Activa,
                Seleccionada = t.Activa
            })
            .ToListAsync();
    }

    private IEnumerable<TallaClienteEditor> ObtenerTallasDisponiblesCliente()
        => usarCatalogoBaseCliente
            ? tallasCliente.Where(t => t.ActivaCatalogo)
            : tallasCliente.Where(t => t.ActivaCatalogo && t.Seleccionada);

    private string ObtenerColorIndustria(IndustriaEnum industria)
    {
        return industria switch
        {
            IndustriaEnum.Calzado => "primary",
            IndustriaEnum.Serigrafia => "success",
            IndustriaEnum.Ambas => "info",
            _ => "secondary"
        };
    }

