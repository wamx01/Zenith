@code {
    private List<Proveedor> proveedores = [];
    private List<ProveedorAgrupado>? proveedoresAgrupados;
    private List<ProveedorAgrupado> todosProveedores = [];
    private CuentaPorPagar editando = new();
    private bool mostrarForm, mostrarFormPago, guardando;
    private string? error, ok;

    private CuentaPorPagar? cuentaParaPago;
    private PagoCxP nuevoPago = new();
    private decimal saldoPendiente;
    private bool _puedeVer;
    private bool _puedeEditar;

    private string textoBusqueda = "";
    private string filtroEstatus = "pendientes";
    private string ordenarPor = "mayor_adeudo";
    private Guid? expandedProveedor;
    private Guid? expandedCuenta;

    private decimal totalPendiente;
    private decimal totalPagado;
    private int proveedoresConAdeudo;
    private decimal montoVencido;

    protected override async Task OnInitializedAsync()
    {
        await CargarAcceso();
        if (_puedeVer)
            await Cargar();
    }

    private async Task CargarAcceso()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _puedeVer = state.User.HasClaim("Capacidad", "cxp.ver");
        _puedeEditar = state.User.HasClaim("Capacidad", "cxp.editar");
    }

    private async Task Cargar()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var lista = await db.CuentasPorPagar
            .Include(c => c.Proveedor)
            .Include(c => c.Pagos)
            .OrderByDescending(c => c.FechaEmision)
            .AsNoTracking()
            .ToListAsync();
        proveedores = await db.Proveedores.Where(p => p.IsActive).OrderBy(p => p.Nombre).AsNoTracking().ToListAsync();

        var cuentasView = lista.Select(c =>
        {
            var pagadoC = c.Pagos.Sum(p => p.Monto);
            var saldoC = c.Total - pagadoC;
            var diasAtraso = 0;
            if (saldoC > 0 && c.FechaVencimiento.HasValue && c.FechaVencimiento.Value.Date < DateTime.Today)
            {
                diasAtraso = (DateTime.Today - c.FechaVencimiento.Value.Date).Days;
            }

            return new CuentaViewModel
            {
                Id = c.Id,
                ProveedorId = c.ProveedorId,
                ProveedorNombre = c.Proveedor.Nombre,
                TipoDocumento = c.TipoDocumento,
                NumeroDocumento = c.NumeroDocumento,
                Concepto = c.Concepto,
                FechaEmision = c.FechaEmision,
                FechaVencimiento = c.FechaVencimiento,
                DiasAtraso = diasAtraso,
                Total = c.Total,
                PagadoTotal = pagadoC,
                Pagos = c.Pagos.ToList(),
                CuentaOriginal = c
            };
        }).ToList();

        var sumTotal = cuentasView.Sum(c => c.Total);
        totalPagado = cuentasView.Sum(c => c.PagadoTotal);
        totalPendiente = Math.Max(0, sumTotal - totalPagado);
        montoVencido = cuentasView.Where(c => c.DiasAtraso > 0).Sum(c => c.Total - c.PagadoTotal);
        montoVencido = Math.Max(0, montoVencido);

        todosProveedores = cuentasView
            .GroupBy(c => new { c.ProveedorId, c.ProveedorNombre })
            .Select(g =>
            {
                var total = g.Sum(c => c.Total);
                var pagado = g.Sum(c => c.PagadoTotal);
                var mayorAtraso = g.Where(c => c.Total - c.PagadoTotal > 0).Select(c => c.DiasAtraso).DefaultIfEmpty(0).Max();

                return new ProveedorAgrupado
                {
                    ProveedorId = g.Key.ProveedorId,
                    ProveedorNombre = g.Key.ProveedorNombre,
                    Total = total,
                    TotalPagado = pagado,
                    Saldo = Math.Max(0, total - pagado),
                    MayorDiasAtraso = mayorAtraso,
                    Cuentas = g.OrderByDescending(c => c.FechaEmision).ToList()
                };
            })
            .ToList();

        proveedoresConAdeudo = todosProveedores.Count(p => p.Saldo > 0);
        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        var lista = todosProveedores.AsEnumerable();

        lista = filtroEstatus switch
        {
            "pendientes" => lista.Where(p => p.Saldo > 0),
            "pagadas" => lista.Where(p => p.Saldo <= 0),
            _ => lista
        };

        if (!string.IsNullOrWhiteSpace(textoBusqueda))
        {
            var busq = textoBusqueda.Trim();
            lista = lista.Where(p => p.ProveedorNombre.Contains(busq, StringComparison.OrdinalIgnoreCase));
        }

        lista = ordenarPor switch
        {
            "mayor_adeudo" => lista.OrderByDescending(p => p.Saldo),
            "mayor_atraso" => lista.OrderByDescending(p => p.MayorDiasAtraso).ThenByDescending(p => p.Saldo),
            "nombre" => lista.OrderBy(p => p.ProveedorNombre),
            _ => lista.OrderByDescending(p => p.Saldo)
        };

        proveedoresAgrupados = lista.ToList();
    }

    private void ToggleProveedor(Guid id)
    {
        if (expandedProveedor == id) { expandedProveedor = null; expandedCuenta = null; }
        else { expandedProveedor = id; expandedCuenta = null; }
    }

    private void ToggleCuenta(Guid id) => expandedCuenta = expandedCuenta == id ? null : id;

    private void NuevaCuenta()
    {
        if (!_puedeEditar) { error = "No tienes permisos para crear cuentas por pagar."; return; }
        error = ok = null;
        editando = new() { Id = Guid.Empty, FechaEmision = DateTime.Today };
        mostrarForm = true; mostrarFormPago = false;
    }

    private void EditarCuenta(CuentaPorPagar c)
    {
        if (!_puedeEditar) { error = "No tienes permisos para editar cuentas por pagar."; return; }
        error = ok = null;
        editando = new()
        {
            Id = c.Id, ProveedorId = c.ProveedorId, TipoDocumento = c.TipoDocumento,
            NumeroDocumento = c.NumeroDocumento, Concepto = c.Concepto,
            FechaEmision = c.FechaEmision, FechaVencimiento = c.FechaVencimiento,
            Subtotal = c.Subtotal, Impuestos = c.Impuestos, Total = c.Total,
            Estatus = c.Estatus, Notas = c.Notas
        };
        mostrarForm = true; mostrarFormPago = false;
    }

    private void AbrirPago(CuentaPorPagar c)
    {
        if (!_puedeEditar) { error = "No tienes permisos para registrar pagos."; return; }
        error = ok = null;
        cuentaParaPago = c;
        saldoPendiente = c.Total - c.Pagos.Sum(p => p.Monto);
        nuevoPago = new() { FechaPago = DateTime.Today, Monto = saldoPendiente };
        mostrarFormPago = true; mostrarForm = false;
    }

    private async Task Guardar()
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar) { error = "No tienes permisos para guardar cuentas por pagar."; return; }
            if (editando.ProveedorId == Guid.Empty || string.IsNullOrWhiteSpace(editando.NumeroDocumento))
            { error = "Proveedor y número de documento son requeridos."; return; }

            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            _ = Guid.TryParse(state.User.FindFirst("EmpresaId")?.Value, out var empresaId);
            if (empresaId == Guid.Empty) { error = "No hay empresa activa."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();
            if (editando.Id == Guid.Empty)
            {
                var nueva = new CuentaPorPagar
                {
                    EmpresaId = empresaId, ProveedorId = editando.ProveedorId,
                    TipoDocumento = editando.TipoDocumento, NumeroDocumento = editando.NumeroDocumento.Trim(),
                    Concepto = editando.Concepto?.Trim(), FechaEmision = editando.FechaEmision,
                    FechaVencimiento = editando.FechaVencimiento, Subtotal = editando.Subtotal,
                    Impuestos = editando.Impuestos, Total = editando.Total,
                    Estatus = editando.Estatus, Notas = editando.Notas?.Trim()
                };
                db.CuentasPorPagar.Add(nueva);
                await db.SaveChangesAsync();
                await AuditService.LogAsync("Crear cuenta por pagar", nameof(CuentaPorPagar), nueva.Id, $"Cuenta {nueva.NumeroDocumento} creada.", empresaId);
                ok = "Guardado."; mostrarForm = false; await Cargar();
            }
            else
            {
                var ex = await db.CuentasPorPagar.FirstOrDefaultAsync(c => c.Id == editando.Id);
                if (ex == null) return;
                ex.ProveedorId = editando.ProveedorId; ex.TipoDocumento = editando.TipoDocumento;
                ex.NumeroDocumento = editando.NumeroDocumento.Trim(); ex.Concepto = editando.Concepto?.Trim();
                ex.FechaEmision = editando.FechaEmision; ex.FechaVencimiento = editando.FechaVencimiento;
                ex.Subtotal = editando.Subtotal; ex.Impuestos = editando.Impuestos; ex.Total = editando.Total;
                ex.Estatus = editando.Estatus; ex.Notas = editando.Notas?.Trim(); ex.UpdatedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
                await AuditService.LogAsync("Editar cuenta por pagar", nameof(CuentaPorPagar), ex.Id, $"Cuenta {ex.NumeroDocumento} actualizada.", empresaId);
                ok = "Guardado."; mostrarForm = false; await Cargar();
            }
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private async Task GuardarPago()
    {
        error = ok = null; guardando = true;
        try
        {
            if (!_puedeEditar) { error = "No tienes permisos para registrar pagos."; return; }
            if (cuentaParaPago == null || nuevoPago.Monto <= 0) { error = "El importe debe ser mayor a cero."; return; }
            if (nuevoPago.Monto > saldoPendiente) { error = "El importe no puede exceder el saldo pendiente."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();
            db.PagosCxP.Add(new PagoCxP
            {
                CuentaPorPagarId = cuentaParaPago.Id, Monto = nuevoPago.Monto,
                FechaPago = nuevoPago.FechaPago, MetodoPago = nuevoPago.MetodoPago,
                Referencia = nuevoPago.Referencia?.Trim(), Notas = nuevoPago.Notas?.Trim()
            });

            var cuenta = await db.CuentasPorPagar.Include(c => c.Pagos).FirstAsync(c => c.Id == cuentaParaPago.Id);
            var totalPag = cuenta.Pagos.Sum(p => p.Monto) + nuevoPago.Monto;
            cuenta.Estatus = totalPag >= cuenta.Total ? EstatusCxP.Pagada : EstatusCxP.ParcialmentePagada;
            cuenta.UpdatedAt = DateTime.UtcNow;

            await db.SaveChangesAsync();
            await AuditService.LogAsync("Registrar pago CxP", nameof(PagoCxP), null, $"Pago {nuevoPago.Monto:C2} registrado para cuenta {cuenta.NumeroDocumento}.", cuenta.EmpresaId);
            ok = "Pago registrado."; mostrarFormPago = false;
            var keepProv = expandedProveedor;
            await Cargar();
            expandedProveedor = keepProv;
        }
        catch (Exception ex) { error = ex.InnerException?.Message ?? ex.Message; }
        finally { guardando = false; }
    }

    private static string GetAtrasoColor(int dias) => dias switch
    {
        <= 0 => "#10b981",
        <= 30 => "#f59e0b",
        _ => "#ef4444"
    };

    private class CuentaViewModel
    {
        public Guid Id { get; set; }
        public Guid ProveedorId { get; set; }
        public string ProveedorNombre { get; set; } = "";
        public TipoDocumentoCxP TipoDocumento { get; set; }
        public string NumeroDocumento { get; set; } = "";
        public string? Concepto { get; set; }
        public DateTime FechaEmision { get; set; }
        public DateTime? FechaVencimiento { get; set; }
        public int DiasAtraso { get; set; }
        public decimal Total { get; set; }
        public decimal PagadoTotal { get; set; }
        public List<PagoCxP> Pagos { get; set; } = [];
        public CuentaPorPagar CuentaOriginal { get; set; } = null!;
    }

    private class ProveedorAgrupado
    {
        public Guid ProveedorId { get; set; }
        public string ProveedorNombre { get; set; } = "";
        public decimal Total { get; set; }
        public decimal TotalPagado { get; set; }
        public decimal Saldo { get; set; }
        public int MayorDiasAtraso { get; set; }
        public List<CuentaViewModel> Cuentas { get; set; } = [];
    }
}
